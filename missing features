private setupPopupBridge(): void {
  if (!this.view?.popup) return;

  const popup = this.view.popup;

  this.eventHandles.add(
    reactiveUtils.watch(
      () => popup.features,
      (features) => {
        const popupFeatures = ((features ?? []) as Graphic[]);
        this.popupFeatures = Array.from(popupFeatures);

        const detail: PopupEvent = {
          features: this.popupFeatures,
          selectedIndex: popup.selectedFeatureIndex ?? 0
        };

        this.dispatchEvent(
          new CustomEvent<PopupEvent>('popup-features-set', {
            detail,
            bubbles: true,
            composed: true
          })
        );

        this.dispatchEvent(
          new CustomEvent<PopupEvent>('popupFeaturesSet', {
            detail,
            bubbles: true,
            composed: true
          })
        );

        // No features found
        if (!this.popupFeatures.length) {
          const noFeaturesHtml =
            `${this.popupCloseButton}` +
            `<div class="popup-scrollable-content">` +
            `<p>No features in this area</p>` +
            `</div>`;

          this.setPopupContent(noFeaturesHtml, true);
          return;
        }

        this.rebuildPopupContent();
      }
    )
  );

  this.eventHandles.add(
    reactiveUtils.watch(
      () => popup.selectedFeatureIndex,
      (selectedIndex) => {
        const detail: PopupEvent = {
          features: this.popupFeatures ?? [],
          selectedIndex: selectedIndex ?? 0
        };

        this.dispatchEvent(
          new CustomEvent<PopupEvent>('popup-features-set', {
            detail,
            bubbles: true,
            composed: true
          })
        );

        this.dispatchEvent(
          new CustomEvent<PopupEvent>('popupFeaturesSet', {
            detail,
            bubbles: true,
            composed: true
          })
        );

        if (!this.popupFeatures?.length) {
          const noFeaturesHtml =
            `${this.popupCloseButton}` +
            `<div class="popup-scrollable-content">` +
            `<p>No features in this area</p>` +
            `</div>`;

          this.setPopupContent(noFeaturesHtml, true);
          return;
        }

        this.rebuildPopupContent();
      }
    )
  );
}


private registerLayerEvents(): void {
  if (!this.view) return;

  console.log('NEW CHANGE: registerLayerEvents called');

  this.handles.remove('view-click');
  this.handles.remove('native-dblclick');

  // single click
  this.handles.add(
    this.view.on('click', async (event: __esri.ViewClickEvent) => {
      console.log('NEW CHANGE: single click fired', {
        enableUserEdit: this.enableUserEdit,
        inDrawingMode: this.inDrawingMode,
        editorActive: this.editorActive,
        suppress: this.shouldSuppressMapInteraction()
      });

      if (!this.view || this.inDrawingMode || this.editorActive) return;
      if (this.shouldSuppressMapInteraction()) return;

      const hit = await this.view.hitTest(event);

      const result = (hit.results ?? []).find((r: any) => {
        return r?.type === 'graphic' && this.resultBelongsToManagedLayerResult(r);
      }) as any;

      if (!result?.graphic) {
        this.closeMapPopup();
        return;
      }

      const graphic = result.graphic as Graphic;
      const uniqueId = graphic.attributes?.[this.uniqueIdPropertyName];
      const nativeEvent = (event as any).native ?? (event as any);

      if (
        this.enableUserEdit &&
        this.enableUserEditRemove &&
        (nativeEvent?.ctrlKey || nativeEvent?.metaKey)
      ) {
        this.closeMapPopup();

        if (uniqueId !== undefined && uniqueId !== null) {
          await this.removeById(uniqueId);
        }
        return;
      }

      // In edit mode, single click should do nothing
      if (this.enableUserEdit) {
        this.closeMapPopup();
        return;
      }

      const location = event.mapPoint ?? this.getPopupLocation(graphic.geometry);
      if (location) {
        this.openMapPopup(graphic, location);
      }

      this.dispatchEvent(
        new CustomEvent('layerClick', {
          detail: {
            graphic,
            uniqueId,
            attributes: graphic.attributes ?? {}
          },
          bubbles: true,
          composed: true
        })
      );
    }),
    'view-click'
  );

  // native double click
  const container = this.view.container as HTMLElement | null;
  if (!container) return;

  const nativeDblClickHandler = async (evt: MouseEvent) => {
    console.log('NEW CHANGE: native dblclick fired', {
      enableUserEdit: this.enableUserEdit,
      inDrawingMode: this.inDrawingMode,
      editorActive: this.editorActive,
      suppress: this.shouldSuppressMapInteraction(),
      editActivationInProgress: this.editActivationInProgress
    });

    if (!this.view || this.inDrawingMode || !this.enableUserEdit || this.editorActive) return;
    if (this.shouldSuppressMapInteraction()) return;

    evt.preventDefault();
    evt.stopPropagation();

    this.closeMapPopup();

    const rect = container.getBoundingClientRect();
    const screenPoint = {
      x: evt.clientX - rect.left,
      y: evt.clientY - rect.top
    };

    const hit = await this.view.hitTest(screenPoint as any);

    console.log('NEW CHANGE: native dblclick hit results', hit.results);

    const result = (hit.results ?? []).find((r: any) => {
      return r?.type === 'graphic' && this.resultBelongsToManagedLayerResult(r);
    }) as any;

    if (!result?.graphic) {
      console.log('NEW CHANGE: no graphic hit on dblclick');
      return;
    }

    // IMPORTANT:
    // set this only after hitTest succeeds, not before
    if (this.editActivationInProgress) return;
    this.editActivationInProgress = true;

    try {
      const graphic = result.graphic as Graphic;
      const uniqueId = graphic.attributes?.[this.uniqueIdPropertyName];

      await this.activateGraphicsEditor(graphic);

      this.dispatchEvent(
        new CustomEvent('doubleClick', {
          detail: {
            graphic,
            uniqueId,
            attributes: graphic.attributes ?? {}
          },
          bubbles: true,
          composed: true
        })
      );
    } finally {
      setTimeout(() => {
        this.editActivationInProgress = false;
      }, 100);
    }
  };

  container.addEventListener('dblclick', nativeDblClickHandler);

  this.handles.add(
    {
      remove: () => container.removeEventListener('dblclick', nativeDblClickHandler)
    } as __esri.Handle,
    'native-dblclick'
  );
}


