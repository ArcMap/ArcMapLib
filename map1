import { LitElement, css, html, PropertyValues } from 'lit';
import { customElement, property, query, state } from 'lit/decorators.js';

import ArcGISMap from '@arcgis/core/Map';
import MapView from '@arcgis/core/views/MapView';
import Basemap from '@arcgis/core/Basemap';
import Extent from '@arcgis/core/geometry/Extent';
import Point from '@arcgis/core/geometry/Point';
import Graphic from '@arcgis/core/Graphic';
import Layer from '@arcgis/core/layers/Layer';
import GraphicsLayer from '@arcgis/core/layers/GraphicsLayer';
import ScaleBar from '@arcgis/core/widgets/ScaleBar';
import SketchViewModel from '@arcgis/core/widgets/Sketch/SketchViewModel';
import * as webMercatorUtils from '@arcgis/core/geometry/support/webMercatorUtils';

import type {
  LatLongPoint,
  UpMapExtent,
  PopupEvent,
  MapTransientShapeCoordinates,
} from '../external-api';
import type {
  LayerElement,
  GraphicsLayerElement,
  NonGraphicsLayerElement,
} from '../common/shared-types';

import MapUtils from '../common/map-utils';
import DrawEditUtils from '../common/draw-edit-utils';
import ValidationService from '../common/validation-service';
import JsonUtils from '../common/json-utils';

type DrawGeometryType = string;

@customElement('up-map')
export class UpMapComponent extends LitElement {
  static styles = css`
    :host {
      display: block;
      position: relative;
      width: 100%;
      height: 100%;
      min-height: 240px;
    }

    #internal-map-root {
      position: relative;
      width: 100%;
      height: 100%;
      min-height: inherit;
    }

    #viewDiv {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
    }
  `;

  private static readonly DEFAULT_BASEMAP = 'gray-vector';
  private static readonly DEFAULT_ZOOM = 5;
  private static readonly DEFAULT_CENTER_LATITUDE = 38.3;
  private static readonly DEFAULT_CENTER_LONGITUDE = -98.4;

  @query('#viewDiv')
  private internalDivElement!: HTMLDivElement;

  @state()
  private internalPopupVersion = 0;

  @property({ type: String, reflect: true })
  basemap = UpMapComponent.DEFAULT_BASEMAP;

  @property({ attribute: false })
  center: LatLongPoint | string = {
    latitude: UpMapComponent.DEFAULT_CENTER_LATITUDE,
    longitude: UpMapComponent.DEFAULT_CENTER_LONGITUDE,
  };

  @property({ type: Boolean })
  disableMapScrollWheelZoom = false;

  @property({ type: Boolean })
  enableDoubleClickToZoom = true;

  @property({ type: Boolean })
  enableKeyboardNavigation = true;

  @property({ attribute: false })
  extent: UpMapExtent | string | null = null;

  @property({ type: Boolean })
  isPopupVisible = true;

  @property({ type: Number })
  maxZoom = 23;

  @property({ type: Number })
  minZoom = 0;

  @property({ type: Boolean, reflect: true })
  usePopupContentOnly = false;

  @property({ type: Boolean })
  showScaleBar = false;

  @property({ type: Number, reflect: true })
  zoom = UpMapComponent.DEFAULT_ZOOM;

  private map!: ArcGISMap;
  private view!: MapView;
  private mapReady!: Promise<void>;
  private resolveMapReady!: () => void;

  private scaleBar?: ScaleBar;
  private drawLayer!: GraphicsLayer;
  private drawTransientShapeTool?: SketchViewModel;

  private popupFeatures: Graphic[] = [];
  private localPopupContent: string | null = null;
  private customPopupContent: string | null = null;

  private reflectOnlyCenter?: LatLongPoint;
  private reflectOnlyExtent?: UpMapExtent;
  private reflectOnlyZoom?: number;

  private layerAddQueue: Promise<void> = Promise.resolve();
  private pendingExtentChanges: Promise<void> = Promise.resolve();

  private previousExtentStack: Extent[] = [];
  private nextExtentStack: Extent[] = [];
  private suspendExtentTracking = false;

  private popupCloseButton =
    `<button type="button" data-action="closePopup" ` +
    `style="position:absolute;top:8px;right:8px;z-index:1;border:none;background:transparent;cursor:pointer;font-size:20px;">×</button>`;

  private popupContentClickHandler = (event: Event) => {
    const target = event.target as HTMLElement | null;
    const actionElement = target?.closest('[data-action]') as HTMLElement | null;
    if (!actionElement) return;

    const action = actionElement.dataset.action;
    if (action === 'closePopup') {
      this.closePopup();
      return;
    }

    if (action === 'popupDetails') {
      const index = Number(actionElement.dataset.index ?? 0);
      const feature = this.popupFeatures[index];
      if (!feature) return;

      this.setPopupFeatures([feature]);
      const detailsHtml = UpMapComponent.buildSingleFeaturePopupHtml(feature, this.popupCloseButton);
      this.setPopupContent(detailsHtml, true);
    }
  };

  connectedCallback(): void {
    super.connectedCallback();

    this.mapReady = new Promise((resolve) => {
      this.resolveMapReady = resolve;
    });
  }

  disconnectedCallback(): void {
    super.disconnectedCallback();
    this.destroyMap();
  }

  render() {
    return html`
      <div id="internal-map-root">
        <div id="viewDiv"></div>
      </div>
    `;
  }

  async firstUpdated(): Promise<void> {
    await this.initializeMap();
  }

  protected async updated(changedProperties: PropertyValues<this>): Promise<void> {
    if (!this.view) return;

    if (changedProperties.has('basemap')) {
      await this.updateBasemap(
        this.basemap,
        String(changedProperties.get('basemap') ?? UpMapComponent.DEFAULT_BASEMAP),
      );
    }

    if (changedProperties.has('center')) {
      await this.updateCenter(this.center);
    }

    if (changedProperties.has('extent')) {
      await this.updateExtent(this.extent);
    }

    if (changedProperties.has('zoom')) {
      this.updateZoom(this.zoom, Number(changedProperties.get('zoom') ?? UpMapComponent.DEFAULT_ZOOM));
    }

    if (changedProperties.has('isPopupVisible')) {
      this.updatePopupVisible(this.isPopupVisible);
    }

    if (changedProperties.has('usePopupContentOnly')) {
      this.updateOnlyUsePopupContent(this.usePopupContentOnly);
    }

    if (changedProperties.has('disableMapScrollWheelZoom')) {
      this.view.navigation.mouseWheelZoomEnabled = !this.disableMapScrollWheelZoom;
    }

    if (changedProperties.has('enableDoubleClickToZoom')) {
      this.syncDoubleClickZoom();
    }

    if (changedProperties.has('enableKeyboardNavigation')) {
      this.syncKeyboardNavigation();
    }

    if (changedProperties.has('showScaleBar')) {
      if (this.showScaleBar) {
        await this.showScaleBarMethod();
      } else {
        await this.hideScaleBar();
      }
    }
  }

  private async initializeMap(): Promise<void> {
    this.drawLayer = new GraphicsLayer({
      id: '__up_map_draw_layer__',
      listMode: 'hide',
    });

    this.map = new ArcGISMap({
      basemap: this.basemap || UpMapComponent.DEFAULT_BASEMAP,
      layers: [this.drawLayer],
    });

    const validCenter = UpMapComponent.parseValidateAndConvertLatLongPoint(this.center);
    const parsedExtent = await UpMapComponent.parseValidateAndConvertExtent(this.extent).catch(() => null);

    this.view = new MapView({
      container: this.internalDivElement,
      map: this.map,
      center: validCenter
        ? [validCenter.longitude, validCenter.latitude]
        : [UpMapComponent.DEFAULT_CENTER_LONGITUDE, UpMapComponent.DEFAULT_CENTER_LATITUDE],
      zoom: Math.round(this.zoom),
      extent: parsedExtent ?? undefined,
      constraints: {
        minZoom: this.minZoom,
        maxZoom: this.maxZoom,
      },
      popup: {
        dockEnabled: false,
        visibleElements: {
          closeButton: this.isPopupVisible,
        },
      },
    });

    this.view.navigation.mouseWheelZoomEnabled = !this.disableMapScrollWheelZoom;
    this.syncDoubleClickZoom();
    this.syncKeyboardNavigation();

    this.setupPopupBridge();
    this.setupDrawTool();
    this.attachMapEvents();

    if (this.showScaleBar) {
      this.scaleBar = new ScaleBar({
        view: this.view,
        unit: 'dual',
      });
      this.view.ui.add(this.scaleBar, 'bottom-left');
    }

    await this.view.when();
    this.resolveMapReady();
  }