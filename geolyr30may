private async initializeMap(): Promise<void> {
  this.upMapInstance =
    this.upMapElement().nativeElement as UpMap;

  // Capture the deep-link extent before waiting for MapView.
  const deepLinkExtent = this.mapFacade.state().extent;

  try {
    const mapView = await this.upMapInstance.getMapView();
    this.mapFacade.setMapView(mapView);
  } catch (error) {
    console.error('Failed to get MapView from up-map', error);
    this.mapFacade.setMapView(null);
  }

  const defaultBasemap = MAP_CONFIG.basemap;
  const defaultExtent: UpMapExtent = MAP_CONFIG.initialExtent;

  this.setBasemap(defaultBasemap);

  // URL extent has priority over the default extent.
  if (deepLinkExtent && this.isValidExtent(deepLinkExtent)) {
    this.setExtent(deepLinkExtent);
  } else {
    this.setExtent(defaultExtent);
    this.mapFacade.setExtent(defaultExtent);
  }

  this.setZoom(this.upMapInstance.zoom);
  this.upMapInstance.showZoom = false;
}