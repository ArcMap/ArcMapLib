private initializeRenderedUpMapChildren(): void {
  if (!this.upMapInstance) {
    return;
  }

  requestAnimationFrame(() => {
    requestAnimationFrame(() => {
      const upMapWithDeferredInitialization =
        this.upMapInstance as unknown as {
          initializeDeferredChildren?: () => Promise<void>;
        };

      if (
        typeof upMapWithDeferredInitialization
          .initializeDeferredChildren !== 'function'
      ) {
        console.error(
          '[MapViewComponent.initializeRenderedUpMapChildren] ' +
            'UPMap initializeDeferredChildren() is unavailable.',
        );
        return;
      }

      void upMapWithDeferredInitialization
        .initializeDeferredChildren();
    });
  });
}



constructor() {
  afterNextRender(() => {
    void this.initializeMap();
  });

  effect(() => {
    const layers = this.mapVisibleLayers();

    if (
      !this.upMapInstance ||
      layers.length === 0
    ) {
      return;
    }

    this.initializeRenderedUpMapChildren();
  });
}