// in LayersFacade
serializeDisplayedLayers(): string {
  const displayedLayers = this.selectedMapLayers().map((layer) => ({
    uniqueLayerId: layer.id,            // numeric id → 13040, 13050, ...
    isChecked: layer.visible === true,  // on/off, matches legacy
  }));
  return JSON.stringify({ displayedLayers });
}



