public async startDrawing(drawGeometryType: string): Promise<void> {
  await this.componentOnReady();

  this.featureLayer?.graphics?.removeAll();
  this.sketchLayer?.graphics?.removeAll();
  this.blockGeoJsonUpdate = true;
  this.geojson = { type: "FeatureCollection", features: [] };
  this.blockGeoJsonUpdate = false;

  const normalizedType = String(
    drawGeometryType ?? ""
  ).toLowerCase();

  await this.createEditor();

  if (!this.graphicsEditor) {
    console.error(
      "[arc-geojson-layer] startDrawing: no graphicsEditor"
    );
    return;
  }

  this._currentDrawGeometryType = normalizedType;
  this.inDrawingMode = true;
  this._isStartingDraw = true;
  this._editorOpen = false;
  this._lastCreatedByDrawing = true;
  this._suppressPopupUntil = Date.now() + 1500;
  this._activeVisibleType = normalizedType;
  this.filterGraphicsByActiveType(normalizedType);
  this.enableInfoPopupWindow(false);
  this.closePopup();

  try { this.graphicsEditor.cancel(); } catch { }

  const sketchTool = this.normalizeSketchTool(normalizedType);

  // Use native setTimeout to escape Angular zone
  const win = window as any;
  const nativeSetTimeout =
    win.__zone_symbol__setTimeout ?? setTimeout;

  await new Promise<void>((resolve) => {
    nativeSetTimeout(() => {
      try {
        this.graphicsEditor!.create(sketchTool as any);
        console.log(
          "[arc-geojson-layer] startDrawing: create called for tool:", sketchTool
        );
      } catch (err) {
        console.error(
          "[arc-geojson-layer] startDrawing: create failed", err
        );
      }
      resolve();
    }, 0);
  });
}




private async createEditor(): Promise<void> {
  if (!this.view || !this.sketchLayer) return;
  if (this.graphicsEditor) return;

  // Run outside Angular zone to prevent change detection
  // overhead on every SVM event
  const createSVM = () => {
    try {
      this.graphicsEditor = new SketchViewModel({
        view: this.view,
        layer: this.sketchLayer,
        defaultUpdateOptions: {
          tool: "reshape",
          multipleSelectionEnabled: false,
          toggleToolOnClick: false,
        } as any,
        // Disable features that trigger Angular CD
        updateOnGraphicClick: false,
      } as any);

      console.log(
        "[arc-geojson-layer] createEditor: SVM created"
      );
    } catch (err) {
      console.error(
        "[arc-geojson-layer] createEditor: failed", err
      );
      this.graphicsEditor = undefined;
      return;
    }

    this.bindEditorEvents();
  };

  // Use Promise to escape zone.js microtask queue
  await new Promise<void>((resolve) => {
    // setTimeout 0 runs outside Angular's current
    // change detection cycle
    const win = window as any;
    const nativeSetTimeout =
      win.__zone_symbol__setTimeout ?? setTimeout;
    nativeSetTimeout(() => {
      createSVM();
      resolve();
    }, 0);
  });
}

private async activateGraphicsEditor(
  graphic: Graphic
): Promise<void> {
  if (!this.isUserEditEnabled() || !graphic?.geometry) return;

  console.log(
    "[arc-geojson-layer] activateGraphicsEditor: starting"
  );

  this.closePopup();
  this._suppressPopupUntil = Date.now() + 2000;

  if (!this.graphicsEditor) {
    await this.createEditor();
  }
  if (!this.graphicsEditor) {
    console.error(
      "[arc-geojson-layer] activateGraphicsEditor: no graphicsEditor"
    );
    return;
  }

  // Cancel if busy
  try {
    const state = (this.graphicsEditor as any).state;
    console.log(
      "[arc-geojson-layer] activateGraphicsEditor: SVM state:", state
    );
    if (state === "active") {
      this.graphicsEditor.cancel();
      // Use native setTimeout to avoid zone.js delay
      const win = window as any;
      const nativeSetTimeout =
        win.__zone_symbol__setTimeout ?? setTimeout;
      await new Promise<void>((r) =>
        nativeSetTimeout(r, 50)
      );
    }
  } catch { }

  this._editorOpen = true;
  this.inDrawingMode = false;
  this._isStartingDraw = false;
  this.enableInfoPopupWindow(false);

  // Find source graphic in featureLayer
  const id =
    graphic.attributes?.OBJECTID ??
    graphic.attributes?._featureIndex ??
    graphic.attributes?.[this.uniqueIdPropertyName] ??
    0;

  const sourceGraphic =
    this.featureLayer?.graphics?.find((g: Graphic) => {
      const gid =
        g.attributes?.OBJECTID ??
        g.attributes?._featureIndex ??
        0;
      return String(gid) === String(id);
    }) ?? graphic;

  console.log(
    "[arc-geojson-layer] activateGraphicsEditor: sourceGraphic found:", !!sourceGraphic
  );

  try {
    this.featureLayer?.graphics?.remove(sourceGraphic);
  } catch { }

  const editGraphic = sourceGraphic.clone();
  if (!editGraphic.attributes) editGraphic.attributes = {};

  const isCircle = this.isCircleGraphic(editGraphic);

  if (isCircle) {
    editGraphic.attributes.isCircle = true;
    editGraphic.attributes.drawGeometryType = "circle";
    editGraphic.attributes.shapeType = "circle";
    editGraphic.attributes.shape = "circle";
  }

  // Assign symbol
  if (isCircle || editGraphic.geometry?.type === "polygon") {
    editGraphic.symbol = {
      type: "simple-fill",
      style: "solid",
      color: [0, 120, 255, 0.2],
      outline: {
        type: "simple-line",
        color: [0, 120, 255, 1],
        width: 2,
        style: "solid",
      },
    } as any;
  } else if (editGraphic.geometry?.type === "polyline") {
    editGraphic.symbol = {
      type: "simple-line",
      color: [0, 120, 255, 1],
      width: 3,
      style: "solid",
    } as any;
  } else {
    editGraphic.symbol = {
      type: "simple-marker",
      style: "circle",
      size: 18,
      color: [0, 120, 255, 1],
      outline: {
        type: "simple-line",
        color: [255, 255, 255, 1],
        width: 2,
      },
    } as any;
  }

  editGraphic.popupTemplate = null as any;
  this.sketchLayer?.graphics?.removeAll();
  this.sketchLayer?.graphics?.add(editGraphic);

  const updateOptions: any = isCircle
    ? {
        tool: "transform",
        enableRotation: false,
        enableScaling: true,
        preserveAspectRatio: true,
        multipleSelectionEnabled: false,
        toggleToolOnClick: false,
      }
    : {
        tool: this.resolveUpdateTool(editGraphic),
        enableRotation: this.enableUserEditRotating,
        enableScaling: this.enableUserEditScaling,
        preserveAspectRatio: this.enableUserEditUniformScaling,
        multipleSelectionEnabled: false,
        toggleToolOnClick: false,
      };

  console.log(
    "[arc-geojson-layer] activateGraphicsEditor: calling SVM.update with options:", updateOptions
  );

  // Run SVM update outside Angular zone using native Promise
  // and native setTimeout to avoid zone.js wrapping
  const win = window as any;
  const nativeSetTimeout =
    win.__zone_symbol__setTimeout ?? setTimeout;
  const nativePromise =
    win.__zone_symbol__Promise ?? Promise;

  await new nativePromise<void>(
    (resolve: () => void, reject: (err: any) => void) => {
      nativeSetTimeout(async () => {
        try {
          await this.graphicsEditor!.update(
            [editGraphic],
            updateOptions
          );
          console.log(
            "[arc-geojson-layer] activateGraphicsEditor: SVM.update started successfully"
          );
          resolve();
        } catch (err: any) {
          console.error(
            "[arc-geojson-layer] activateGraphicsEditor: SVM.update failed", err
          );
          reject(err);
        }
      }, 0);
    }
  ).catch((err: any) => {
    console.error(
      "[arc-geojson-layer] activateGraphicsEditor: failed", err
    );
    try {
      this.sketchLayer?.graphics?.remove(editGraphic);
    } catch { }
    this.featureLayer?.graphics?.add(sourceGraphic);
    this._editorOpen = false;
    this.enableInfoPopupWindow(true);
  });
}
