/* ✅ Target calcite button scale via CSS custom properties */
::ng-deep arcgis-zoom calcite-button {
  --calcite-button-padding-y: 4px !important;
  --calcite-button-padding-x: 4px !important;
}

/* ✅ Target the zoom buttons directly */
::ng-deep arcgis-zoom .zoom-in,
::ng-deep arcgis-zoom .zoom-out {
  width: 24px !important;
  height: 24px !important;
}
