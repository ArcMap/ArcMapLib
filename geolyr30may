.toolbar {
  .sort-button {
    min-width: 86px;
    align-self: stretch;
  }

  .sort-button:focus,
  .sort-button:focus-visible,
  .sort-button::part(button),
  .sort-button::part(button):focus,
  .sort-button::part(button):focus-visible {
    outline: none !important;
    box-shadow: none !important;
  }
}