if (subsequentLayerIndexes.length > 0) {
  const firstLayerIndexAfter = Math.min(...subsequentLayerIndexes);
  this.map.add(newLayer, firstLayerIndexAfter);
} else {
  this.map.add(newLayer);
}

console.log("[arc-map] layer order after add", this.map.layers.toArray().map((layer: any, index: number) => ({
  index,
  id: layer.id,
  type: layer.type,
  title: layer.title,
})));

queueMicrotask(() => {
  this.reorderGeoJsonLayersToTop();

  console.log("[arc-map] layer order after reorder", this.map.layers.toArray().map((layer: any, index: number) => ({
    index,
    id: layer.id,
    type: layer.type,
