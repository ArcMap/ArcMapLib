function resolvePath(filePath) {
  // 1. Exact path
  if (isFile(filePath)) return filePath;

  // 2. Add .js extension
  if (isFile(filePath + '.js')) return filePath + '.js';

  // 3. index.js inside directory
  const indexPath = join(filePath, 'index.js');
  if (isFile(indexPath)) return indexPath;

  // 4. dist/index.js
  const distIndexPath = join(filePath, 'dist', 'index.js');
  if (isFile(distIndexPath)) return distIndexPath;

  // ✅ 5. For arcgis-map-components folders
  // Each component folder contains [name]/[name].js
  const name = filePath.split(/[/\\]/).pop();

  // Try [folder]/[name].js
  const sameName = join(filePath, name + '.js');
  if (isFile(sameName)) return sameName;

  // Try [folder]/[name]/[name].js
  const nestedSame = join(filePath, name, name + '.js');
  if (isFile(nestedSame)) return nestedSame;

  return null;
}
