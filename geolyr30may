return `
  <div
    class="autocomplete-item"
    style="${this.getAutocompleteItemStyle()}"
  >
    <span
      class="autocomplete-text-wrapper"
      data-item-key="${item}"
      style="${this.getAutocompleteTextWrapperStyle()}"
    >
      <span
        class="autocomplete-ellipsis-text"
        style="${this.getAutocompleteTextStyle()}"
      >
        ${displayText}
      </span>

      ${
        shouldShowTooltip
          ? `
            <up-tooltip
              class="autocomplete-name-tooltip"
              placement="top"
              show-arrow
              style="position:absolute;"
            >
              ${displayText}
            </up-tooltip>
          `
          : ''
      }
    </span>

    <span style="${this.getAutocompleteChipStyle()}">
      ${chipLabel}
    </span>
  </div>
`;