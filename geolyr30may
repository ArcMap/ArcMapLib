} else if (
    !this._editorOpen &&
    !this.inDrawingMode &&
    !this._isStartingDraw &&
    !this.shouldSuppressPopup()
) {
    // Only ONE layer opens popup per click — ArcGIS fetchFeatures
    // finds topmost layer automatically
    if (evt.timestamp !== _lastPopupTimestamp) {
        _lastPopupTimestamp = evt.timestamp;
        (this.view as any).openPopup({
            location: evt.mapPoint,
            fetchFeatures: true,
        });
    }
    return;
}
