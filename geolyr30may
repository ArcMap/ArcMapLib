async function initialize(): Promise<void> {
  const arcgisBaseUrl = "https://js.arcgis.com/5.0.19";

  esriConfig.assetsPath = arcgisBaseUrl;
  setMapAssetPath(arcgisBaseUrl);

  await Promise.all([
    addStylesheetOnce(
      "upmap-arcgis-core-css",
      `${arcgisBaseUrl}/esri/themes/light/main.css`
    ),
    addStylesheetOnce(
      "upmap-map-components-css",
      `${arcgisBaseUrl}/map-components/main.css`
    )
  ]);
}