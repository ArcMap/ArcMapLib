private registerAutocompleteTooltipHover(): void {
  document.addEventListener('mouseover', this.handleAutocompleteTooltipHover);
}

private handleAutocompleteTooltipHover = (event: MouseEvent): void => {
  const target = event.target as HTMLElement | null;

  if (!target) {
    return;
  }

  const textElement = target.closest(
    '.autocomplete-ellipsis-text'
  ) as HTMLElement | null;

  if (!textElement) {
    return;
  }

  const wrapperElement = textElement.closest(
    '.autocomplete-text-wrapper'
  ) as HTMLElement | null;

  if (!wrapperElement) {
    return;
  }

  const tooltipElement = wrapperElement.querySelector(
    'up-tooltip.autocomplete-name-tooltip'
  ) as HTMLElement | null;

  if (!tooltipElement) {
    return;
  }

  const hasEllipsis =
    textElement.scrollWidth > textElement.clientWidth;

  if (hasEllipsis) {
    tooltipElement.style.display = '';
  } else {
    tooltipElement.style.display = 'none';
  }
};


ngOnDestroy(): void {
  // keep your existing ngOnDestroy code

  document.removeEventListener('mouseover', this.handleAutocompleteTooltipHover);
}