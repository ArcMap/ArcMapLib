import { signal } from '@angular/core';

// Fix the navState mock — activePanel must be a signal/function
const navStateMock = {
    activePanel: signal<string | null>(null),   // ← must be a signal
    openPanel: jasmine.createSpy('openPanel').and.callFake((panel: string) => {
        navStateMock.activePanel.set(panel);
    }),
    closePanel: jasmine.createSpy('closePanel').and.callFake(() => {
        navStateMock.activePanel.set(null);
    }),
};



// Test 1
it('should default activeMode to none', () => {
    const fixture = TestBed.createComponent(AppShellComponent);
    expect(fixture.componentInstance.activeMode()).toBe('none');  // ← add ()
});

// Test 2
it('should update activeMode on onModeChange', () => {
    const fixture = TestBed.createComponent(AppShellComponent);
    fixture.componentInstance.onModeChange('maps-layers');
    expect(fixture.componentInstance.activeMode()).toBe('maps-layers');  // ← add ()
});

// Test 3
it('should block restricted modes for limited users', () => {
    const fixture = TestBed.createComponent(AppShellComponent);
    fixture.componentInstance.onModeChange('maps-layers');
    expect(fixture.componentInstance.activeMode()).toBe('maps-layers');  // ← add ()
});




beforeEach(() => {
    navStateMock.activePanel.set(null);  // reset signal before each test
    navStateMock.openPanel.calls.reset();
    navStateMock.closePanel.calls.reset();
});
