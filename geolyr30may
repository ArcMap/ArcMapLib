<div class="measure-panel" [class.has-drawing]="hasDrawing()">
  <div class="measure-instructions">
    <calcite-icon icon="cursor-click" scale="s"></calcite-icon>
    <span>Click on the map to add points. Double-click to finish.</span>
  </div>

  <div class="measurement-host">
    @if (mode() === 'distance') {
      <measurement
        #
        map-id="upMap"
        tools="distance"
        default-tool="distance"
        display-mode="panel"
      ></measurement>
    } @else {
      <measurement
        #
        map-id="upMap"
        tools="area"
        default-tool="area"
        display-mode="panel"
      ></umeasurement>
    }

    @if (hasDrawing()) {
      <div class="measure-actions">
        <calcite-button
          appearance="outline"
          width="full"
          icon-start="reset"
          (click)="onClear()"
        >
          Clear
        </calcite-button>
      </div>
    }
  </div>
</d





.measure-panel {
  display: flex;
  flex-direction: column;
  padding: 0;
}

.measurement-host {
  position: relative;
  width: 100%;
  min-height: 170px;
}

up-measurement {
  display: block;
  width: 100%;
  position: relative;
  z-index: 1;
}

.measure-actions {
  position: absolute;
  left: 12px;
  right: 12px;
  top: 118px;
  z-index: 20;
  background: var(--calcite-color-foreground-1);
}

.measure-actions calcite-button {
  width: 100%;
}