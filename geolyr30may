private notifyDeferredChildrenReady(): void {
  if (!this.upMapInstance) {
    return;
  }

  const mapElement =
    this.upMapElement().nativeElement as HTMLElement;

  const view = this.mapFacade.mapView();
  const map = view?.map;

  if (!view || !map) {
    console.warn(
      '[MapViewComponent.notifyDeferredChildrenReady] ' +
        'Map or MapView is unavailable.',
    );
    return;
  }

  mapElement
    .querySelectorAll<HTMLElement>('*')
    .forEach((element) => {
      const tagName = element.tagName.toLowerCase();

      if (
        !tagName.startsWith('up-') ||
        tagName === 'up-map'
      ) {
        return;
      }

      element.dispatchEvent(
        new CustomEvent('upMapDeferredReady', {
          detail: {
            map,
            view,
          },
          bubbles: false,
          composed: true,
        }),
      );
    });
}