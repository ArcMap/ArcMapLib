private async createEditor(): Promise<void> {
  if (!this.featureLayer) return;

  // Guard — prevent duplicate registration
  if (this._editorCreated) return;
  this._editorCreated = true;

  // Cleanup old handles first
  this.editorHandles?.forEach((h: any) => { try { h?.remove?.(); } catch { } });
  this.editorHandles = [];

  const view = await this._getView();
  if (!view) return;

  // ✅ _handleClick is registered HERE on the view click event
  const clickHandle = (view as any).on("click", async (evt: any) => {
    await this._handleClick(evt);
  });

  this.editorHandles.push(clickHandle);
}

// ✅ _handleClick is a separate private method called from above
private async _handleClick(event: any): Promise<void> {
  if (!this.view) return;
  if (this.inDrawingMode) return;
  if (this._isStartingDraw) return;
  if (Date.now() < this._suppressPopupUntil) return;

  // ✅ Only test our two layers — biggest performance win
  const hitResult = await this.view.hitTest(event, {
    include: [this.featureLayer, this.sketchLayer].filter(Boolean)
  });

  const allResults = hitResult.results ?? [];
  console.log("[up-geojson-layer] click: hitTest results:", allResults.length);

  // Deduplicate by feature ID
  const seen = new Set<string>();
  const uniqueResults = allResults.filter((r: any) => {
    const attrs = r.graphic?.attributes ?? {};
    const id = String(
      attrs.OBJECTID ?? attrs._featureIndex ??
      attrs[this.uniqueIdPropertyName] ?? Math.random()
    );
    if (seen.has(id)) return false;
    seen.add(id);
    return true;
  });

  console.log("[up-geojson-layer] click: thisLayerResults:", uniqueResults.length);

  if (uniqueResults.length === 0) {
    this.closePopup();
    return;
  }

  const graphic = uniqueResults[0].graphic;

  // Edit mode — activate editor
  if (this.enableUserEdit) {
    if ((event.native?.ctrlKey || event.native?.metaKey) && this.enableUserEditRemove) {
      await this.removeFromGeoJson(graphic);
      return;
    }
    await this.activateGraphicsEditor(graphic);
    return;
  }

  // Popup mode
  await this.showGraphicPopup(graphic, event.mapPoint);
}
