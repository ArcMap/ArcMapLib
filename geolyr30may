private showGraphicPopup(
  graphic: Graphic,
  mapPoint: Point,
  graphics: Graphic[],
): void {
  if (
    this._editorOpen ||
    this.inDrawingMode ||
    this._isStartingDraw ||
    this.shouldSuppressPopup()
  ) return;

  if (!this.infoTemplate) {
    console.warn('[popup-debug] showGraphicPopup: infoTemplate is not set, skipping popup');
    return;
  }

  const popupGraphics = graphics.length > 1 ? graphics : [graphic];
  const popupGraphic = popupGraphics[0];
  if (!popupGraphic || !this.view?.popup) return;

  // Build template BEFORE opening — assign to all graphics
  const templates: PopupTemplate[] = [];
  popupGraphics.forEach((g) => {
    const tpl = this.buildPopupTemplateFromCurrent(g);
    if (tpl) {
      g.popupTemplate = tpl;
      templates.push(tpl);
    } else {
      console.warn('[popup-debug] No template built for graphic', g.attributes);
    }
  });

  if (templates.length === 0) {
    console.warn('[popup-debug] No popup templates built — aborting popup open');
    return;
  }

  this.view.popupEnabled = true;

  // Clear any previous popup state first
  try { this.view.popup.features = []; } catch { }
  try { this.view.popup.visible = false; } catch { }

  const location =
    mapPoint ??
    ArcGeojsonLayer.getPopupPoint(popupGraphic.geometry) ??
    undefined;

  if (this.view.stationary === false) {
    const handle = this.view.watch("stationary", (isStationary: boolean) => {
      if (isStationary) {
        handle.remove();
        this._doOpenPopupMultiple(popupGraphics, location);
      }
    });
  } else {
    // Open synchronously — no setTimeout needed
    this._doOpenPopupMultiple(popupGraphics, location);
  }
}

private _doOpenPopupMultiple(graphics: Graphic[], location: any): void {
  try {
    this.view.popupEnabled = true;

    const popup: any = this.view?.popup;
    if (!popup) return;

    // Set everything before opening
    try { popup.location = location ?? undefined; } catch { }
    try { popup.features = graphics; } catch { }
    try { (popup as any).updateLocationEnabled = false; } catch { }

    // Open the popup
    if (typeof popup.open === "function") {
      try { popup.open({ features: graphics, location: location ?? undefined }); } catch { }
    } else if (typeof popup.open === "boolean") {
      try { popup.open = true; } catch { }
    }

    try { popup.visible = true; } catch { }

    // Reposition after DOM updates
    requestAnimationFrame(() => {
      try { popup.reposition?.(); } catch { }
    });

    // Force DOM visibility as last resort
    setTimeout(() => {
      try {
        const dom = document.querySelector(".esri-popup-main-container") as HTMLElement;
        if (dom) {
          dom.style.display = "block";
          dom.style.visibility = "visible";
        }
      } catch { }
    }, 150);

  } catch (error) {
    console.warn('[popup-debug] _doOpenPopupMultiple FAILED', error);
  }
}



private buildPopupTemplateFromCurrent(graphic: Graphic): PopupTemplate | null {
  if (!graphic) return null;

  const attributes = graphic.attributes ?? {};

  const replaceTokens = (value: string): string =>
    value.replace(/\$\{([^}]+)\}/g, (_, key: string) => {
      const v = attributes[key.trim()];
      return v === undefined || v === null ? "" : String(v);
    });

  try {
    let title: any =
      this.infoTemplate?.title ??
      this.infoTemplate?.listTitle ??
      "Details";

    if (typeof title === "function") {
      title = title.call(this.infoTemplate, graphic);
    }
    if (typeof title === "string") {
      title = replaceTokens(title);
    }

    let content: any =
      this.infoTemplate?.content ??
      this.infoTemplate?.details ??
      (typeof this.infoTemplate === "string" ? this.infoTemplate : null);

    if (typeof content === "function") {
      content = content.call(this.infoTemplate, graphic);
    }
    if (typeof content === "string") {
      content = replaceTokens(content);
    }

    // If still no content, render all attributes as a table
    if (!content || typeof content !== "string") {
      const rows = Object.entries(attributes)
        .filter(([k]) => !k.startsWith("_") && k !== "OBJECTID")
        .map(([k, v]) => `<tr><td><b>${k}</b></td><td>${v ?? ""}</td></tr>`)
        .join("");
      content = `<table style="width:100%;border-collapse:collapse">${rows}</table>`;
    }

    return new PopupTemplate({ title, content });
  } catch (error) {
    console.error("[arc-geojson-layer] buildPopupTemplateFromCurrent failed", error);
    return null;
  }
}
