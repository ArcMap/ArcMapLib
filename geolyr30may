private async initializeMapView(): Promise<void> {
  await this.view.when();

  this.dispatchEvent(
    new CustomEvent("arcgisViewReadyChange", {
      detail: {
        ready: true,
        map: this.map,
        view: this.view,
      },
      bubbles: true,
      composed: true,
    }),
  );

  await this.initializeDeferredChildren();
}


private async initializeDeferredChildren(): Promise<void> {
  await new Promise<void>((resolve) => {
    requestAnimationFrame(() => resolve());
  });

  await new Promise<void>((resolve) => {
    requestAnimationFrame(() => resolve());
  });

  const detail = {
    map: this.map,
    view: this.view,
  };

  const children = Array.from(this.children);

  children.forEach((child: Element) => {
    child.dispatchEvent(
      new CustomEvent("upMapDeferredReady", {
        detail,
        bubbles: false,
        composed: true,
      }),
    );
  });

  this.resolveDeferredChildrenReady?.();
}