public ownsGraphic(graphic: Graphic | undefined | null): boolean {
  if (!graphic) {
    return false;
  }

  return (
    graphic.layer === this.featureLayer ||
    graphic.layer === this.sketchLayer
  );
}

public async handleParentMapClick(evt: any, topGraphic: Graphic): Promise<void> {
  if (!topGraphic) {
    return;
  }

  this.emitLayerEvent(
    "layerClick",
    this.graphicToGeoJsonFeature(topGraphic),
    topGraphic,
    {
      event: {
        coordinates: {
          latitude: evt.mapPoint?.latitude ?? 0,
          longitude: evt.mapPoint?.longitude ?? 0,
        },
        attributes: topGraphic.attributes ?? {},
      },
    }
  );

  if (this.isUserEditEnabled()) {
    this.closePopup();

    if (evt.native?.ctrlKey || evt.native?.metaKey || evt.native?.altKey) {
      this.removeFromGeoJSON(topGraphic);
      this.graphicsEditor?.cancel();
      return;
    }

    await this.activateGraphicsEditor(topGraphic, "transform");
    return;
  }

  if (
    !this._editorOpen &&
    !this.inDrawingMode &&
    !this.__isStartingDraw &&
    !this.shouldSuppressPopup()
  ) {
    this.showGraphicPopup(topGraphic, evt.mapPoint, [topGraphic]);
  }
}