if (!parsed.map || parsed.map.trim().toLowerCase() === 'all at layers') {
  if (!parsed.layers?.length) return;
  const layerIds = parsed.layers.map((id) => Number(id)).filter((id) => !Number.isNaN(id));
  this.layersFacade.applyFullCatalogLayerIds(layerIds);
  this.navState.openPanel('maps-layers');
  return;
}
