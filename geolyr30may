// src/arcgis-assets.ts

import esriConfig from "@arcgis/core/config";
import { setAssetPath as setMapComponentsAssetPath } from "@arcgis/map-components";
import { setAssetPath as setCommonComponentsAssetPath } from "@arcgis/common-components";

let arcgisAssetsConfigured = false;

export function configureArcgisAssets(): void {
  if (arcgisAssetsConfigured) {
    return;
  }

  /*
   * IMPORTANT:
   * Do NOT use:
   * https://js.arcgis.com/5.0/@arcgis/map-components/dist/cdn/assets
   *
   * That path does not exist and causes 404.
   *
   * For ArcGIS component packages, use the package CDN base path.
   */
  const arcgisVersion = "5.0";

  esriConfig.assetsPath = `https://js.arcgis.com/${arcgisVersion}/assets`;

  setMapComponentsAssetPath(`https://js.arcgis.com/${arcgisVersion}/map-components/`);
  setCommonComponentsAssetPath(`https://js.arcgis.com/${arcgisVersion}/common-components/`);

  addStylesheetOnce(
    "upmap-arcgis-core-css",
    `https://js.arcgis.com/${arcgisVersion}/esri/themes/light/main.css`
  );

  addStylesheetOnce(
    "upmap-arcgis-map-components-css",
    `https://js.arcgis.com/${arcgisVersion}/map-components/main.css`
  );

  addStylesheetOnce(
    "upmap-arcgis-common-components-css",
    `https://js.arcgis.com/${arcgisVersion}/common-components/main.css`
  );

  arcgisAssetsConfigured = true;
}

function addStylesheetOnce(id: string, href: string): void {
  if (typeof document === "undefined") {
    return;
  }

  if (document.getElementById(id)) {
    return;
  }

  const link = document.createElement("link");
  link.id = id;
  link.rel = "stylesheet";
  link.href = href;
  document.head.appendChild(link);
}