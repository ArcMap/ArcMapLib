private openMeasurementWithoutIcon(): void {

  setTimeout(async () => {

    const upMeasurement = this.upMeasurement.nativeElement as any;

    await customElements.whenDefined('up-measurement');

    await upMeasurement.updateComplete;

    const shadowRoot = upMeasurement.shadowRoot;

    if (!shadowRoot) {

      return;

    }

    const areaExpand = shadowRoot.querySelector('#area-expand') as any;

    const distExpand = shadowRoot.querySelector('#dist-expand') as any;

    const coordExpand = shadowRoot.querySelector('#coord-expand') as any;

    this.hideExpandIcon(areaExpand);

    this.hideExpandIcon(distExpand);

    this.hideExpandIcon(coordExpand);

    if (distExpand) {

      distExpand.expanded = false;

    }

    if (coordExpand) {

      coordExpand.expanded = false;

    }

    if (areaExpand) {

      areaExpand.expanded = true;

    }

  }, 1000);

}

private hideExpandIcon(expandElement: any): void {

  if (!expandElement) {

    return;

  }

  expandElement.style.position = 'static';

  const applyHide = () => {

    const shadowRoot = expandElement.shadowRoot;

    if (!shadowRoot) {

      return;

    }

    const style = document.createElement('style');

    style.textContent = `

      calcite-action,

      button,

      [slot="action"],

      .toggle,

      .action,

      .expand-toggle {

        display: none !important;

        width: 0 !important;

        height: 0 !important;

        min-width: 0 !important;

        padding: 0 !important;

        margin: 0 !important;

        opacity: 0 !important;

        pointer-events: none !important;

      }

    `;

    shadowRoot.appendChild(style);

  };

  applyHide();

  setTimeout(applyHide, 300);

  setTimeout(applyHide, 800);

}