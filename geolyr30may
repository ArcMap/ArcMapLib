private showGraphicPopup(
  graphic: Graphic,
  mapPoint: Point,
  graphics: Graphic[],
): void {
  if (
    this._editorOpen ||
    this.inDrawingMode ||
    this._isStartingDraw ||
    this.shouldSuppressPopup()
  ) return;

  if (!this.infoTemplate) {
    console.warn('[popup-debug] showGraphicPopup: no infoTemplate set, skipping');
    return;
  }

  const popupGraphics = graphics.length > 1 ? graphics : [graphic];
  const popupGraphic = popupGraphics[0];
  if (!popupGraphic) return;

  // Build and assign templates synchronously
  let builtCount = 0;
  popupGraphics.forEach((g) => {
    const tpl = this.buildPopupTemplateFromCurrent(g);
    if (tpl) {
      g.popupTemplate = tpl;
      builtCount++;
    }
  });

  if (builtCount === 0) {
    console.warn('[popup-debug] no templates built, skipping popup');
    return;
  }

  const location =
    mapPoint ??
    ArcGeojsonLayer.getPopupPoint(popupGraphic.geometry) ??
    undefined;

  this._popupOpen = true;
  this._doOpenPopupMultiple(popupGraphics, location);
}

private _doOpenPopupMultiple(graphics: Graphic[], location: any): void {
  try {
    // Enable popupEnabled so the popup can render
    this.view.popupEnabled = true;

    const popup: any = this.view?.popup;
    if (!popup) return;

    // Keep auto-open off — we control when it opens
    popup.autoOpenEnabled = false;
    popup.highlightEnabled = false;

    // Remove "Zoom to" action every time
    try {
      if (popup.actions) {
        const zoomAction = popup.actions.find?.(
          (a: any) => a.id === "zoom-to" || a.title === "Zoom to"
        );
        if (zoomAction) popup.actions.remove(zoomAction);
      }
    } catch { }

    // Set features and location
    popup.location = location ?? undefined;
    popup.features = graphics;

    // Open using the correct ArcGIS 5.x API
    if (typeof popup.open === "function") {
      popup.open({
        features: graphics,
        location: location ?? undefined,
        updateLocationEnabled: false,
      });
    } else {
      popup.open = true;
    }

    popup.visible = true;

    // Reposition after render
    requestAnimationFrame(() => {
      try { popup.reposition?.(); } catch { }
    });

    // After popup is open, disable popupEnabled again
    // so ArcGIS can't fire its own popup on next click
    setTimeout(() => {
      try { this.view.popupEnabled = false; } catch { }
    }, 500);

  } catch (error) {
    console.warn('[popup-debug] _doOpenPopupMultiple FAILED', error);
    this._popupOpen = false;
  }
}




