async function initialize(): Promise<void> {
  const arcgisBaseUrl = "https://js.arcgis.com/5.0.19";

  await Promise.all([
    addPreconnectOnce("u-preconnect-js-arcgis", "https://js.arcgis.com"),
    addPreconnectOnce("u-preconnect-static-arcgis", "https://static.arcgis.com"),
    addPreconnectOnce("u-preconnect-basemaps", "https://basemaps.arcgis.com"),

    addPreloadOnce(
      "upmap-calcite-action-messages",
      "https://js.arcgis.com/calcite-components/5.0.2/assets/action/t9n/messages_en.json"
    ),
    addPreloadOnce(
      "u-calcite-panel-messages",
      "https://js.arcgis.com/calcite-components/5.0.2/assets/panel/t9n/messages_en.json"
    ),
    addPreloadOnce(
      "u-arcgis-zoom-messages",
      `${arcgisBaseUrl}/esri/widgets/Zoom/t9n/Zoom_en.json`
    ),

    addStylesheetOnce(
      "u-arcgis-core-css",
      `${arcgisBaseUrl}/esri/themes/light/main.css`
    ),
    addStylesheetOnce(
      "ui-map-components-css",
      `${arcgisBaseUrl}/map-components/main.css`
    )
  ]);
}



function addPreloadOnce(id: string, href: string): Promise<void> {
  return new Promise((resolve) => {
    if (typeof document === "undefined" || document.getElementById(id)) {
      resolve();
      return;
    }

    const link = document.createElement("link");
    link.id = id;
    link.rel = "preload";
    link.as = "fetch";
    link.href = href;
    link.crossOrigin = "anonymous";

    document.head.appendChild(link);
    resolve();
  });
}