import esriConfig from "@arcgis/core/config";
import { setAssetPath as setMapAssetPath } from "@arcgis/map-components";
import { setAssetPath as setCommonAssetPath } from "@arcgis/common-components";

import "@arcgis/core/assets/esri/themes/light/main.css";
import "@arcgis/map-components/dist/cdn/main.css";
import "@arcgis/common-components/dist/cdn/main.css";

let initializedPromise: Promise<void> | null = null;

let baseArcgisComponentsPromise: Promise<void> | null = null;
let basemapGalleryComponentPromise: Promise<void> | null = null;
let legendComponentPromise: Promise<void> | null = null;
let layerListComponentPromise: Promise<void> | null = null;
let measurementComponentsPromise: Promise<void> | null = null;

export function configureArcgisAssets(): Promise<void> {
  if (initializedPromise) {
    return initializedPromise;
  }

  initializedPromise = initialize();
  return initializedPromise;
}

async function initialize(): Promise<void> {
  esriConfig.assetsPath = "assets";
  setMapAssetPath("assets");
  setCommonAssetPath("assets");

  addStyleTextOnce(
    "upmap-production-css-fix",
    `
    .esri-popup,
    .esri-popup__main-container,
    .esri-feature,
    .esri-feature__content-node {
      background: var(--calcite-color-foreground-1, #ffffff) !important;
      color: var(--calcite-color-text-1, #151515) !important;
    }

    arcgis-zoom {
      --calcite-color-border-input: transparent;
      --calcite-color-border-1: transparent;
      --calcite-color-border-2: transparent;
      --calcite-color-border-3: transparent;
    }

    arcgis-zoom calcite-button,
    arcgis-zoom calcite-action {
      box-shadow: none !important;
      outline: none !important;
    }
    `
  );
}

export function loadBaseArcgisComponents(): Promise<void> {
  if (baseArcgisComponentsPromise) {
    return baseArcgisComponentsPromise;
  }

  baseArcgisComponentsPromise = Promise.all([
    import("@arcgis/map-components/dist/components/arcgis-map"),
    import("@arcgis/map-components/dist/components/arcgis-zoom"),
    import("@arcgis/map-components/dist/components/arcgis-home"),
    import("@arcgis/map-components/dist/components/arcgis-locate"),
    import("@arcgis/map-components/dist/components/arcgis-scale-bar")
  ]).then(() => undefined);

  return baseArcgisComponentsPromise;
}

export function loadBasemapGalleryComponent(): Promise<void> {
  if (basemapGalleryComponentPromise) {
    return basemapGalleryComponentPromise;
  }

  basemapGalleryComponentPromise = import(
    "@arcgis/map-components/dist/components/arcgis-basemap-gallery"
  ).then(() => undefined);

  return basemapGalleryComponentPromise;
}

export function loadLegendComponent(): Promise<void> {
  if (legendComponentPromise) {
    return legendComponentPromise;
  }

  legendComponentPromise = import(
    "@arcgis/map-components/dist/components/arcgis-legend"
  ).then(() => undefined);

  return legendComponentPromise;
}

export function loadLayerListComponent(): Promise<void> {
  if (layerListComponentPromise) {
    return layerListComponentPromise;
  }

  layerListComponentPromise = import(
    "@arcgis/map-components/dist/components/arcgis-layer-list"
  ).then(() => undefined);

  return layerListComponentPromise;
}

export function loadMeasurementComponents(): Promise<void> {
  if (measurementComponentsPromise) {
    return measurementComponentsPromise;
  }

  measurementComponentsPromise = Promise.all([
    import("@arcgis/map-components/dist/components/arcgis-distance-measurement-2d"),
    import("@arcgis/map-components/dist/components/arcgis-area-measurement-2d")
  ]).then(() => undefined);

  return measurementComponentsPromise;
}

function addStyleTextOnce(id: string, cssText: string): void {
  if (typeof document === "undefined" || document.getElementById(id)) {
    return;
  }

  const style = document.createElement("style");
  style.id = id;
  style.textContent = cssText;
  document.head.appendChild(style);
}