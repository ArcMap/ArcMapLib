import { LitElement, html, css } from "lit";
import { property } from "lit/decorators.js";

export class UpMeasurement extends LitElement {
  @property({ type: Object })
  view: any;

  @property({ type: String })
  tools = "distance,area,location";

  @property({ type: String, attribute: "default-tool" })
  defaultTool: "distance" | "area" | "location" = "distance";

  /**
   * icon  = normal multiple icon behavior
   * panel = stable panel, no icon
   */
  @property({ type: String, attribute: "display-mode" })
  displayMode: "icon" | "panel" = "icon";

  /**
   * Only for icon mode.
   * Opens selected popup automatically on load.
   */
  @property({ type: Boolean, attribute: "open-by-default" })
  openByDefault = false;

  async firstUpdated(): Promise<void> {
    await this.updateComplete;
    await this.bindMeasurementView();

    if (this.displayMode === "panel") {
      await this.activatePanelTool();
      return;
    }

    if (this.openByDefault) {
      await this.openDefaultPopup();
    }
  }

  private async bindMeasurementView(): Promise<void> {
    const distanceEl = this.shadowRoot?.querySelector(
      "arcgis-distance-measurement-2d"
    ) as any;

    const areaEl = this.shadowRoot?.querySelector(
      "arcgis-area-measurement-2d"
    ) as any;

    const coordEl = this.shadowRoot?.querySelector(
      "arcgis-coordinate-conversion"
    ) as any;

    if (distanceEl) {
      distanceEl.view = this.view;
      await distanceEl.componentOnReady?.();
    }

    if (areaEl) {
      areaEl.view = this.view;
      await areaEl.componentOnReady?.();
    }

    if (coordEl) {
      coordEl.view = this.view;
      await coordEl.componentOnReady?.();
    }
  }

  private async openDefaultPopup(): Promise<void> {
    const distanceExpand = this.shadowRoot?.querySelector("#dist-expand") as any;
    const areaExpand = this.shadowRoot?.querySelector("#area-expand") as any;
    const coordExpand = this.shadowRoot?.querySelector("#coord-expand") as any;

    if (distanceExpand) {
      distanceExpand.expanded = false;
    }

    if (areaExpand) {
      areaExpand.expanded = false;
    }

    if (coordExpand) {
      coordExpand.expanded = false;
    }

    if (this.defaultTool === "area" && areaExpand) {
      await areaExpand.componentOnReady?.();
      areaExpand.expanded = true;
      return;
    }

    if (this.defaultTool === "location" && coordExpand) {
      await coordExpand.componentOnReady?.();
      coordExpand.expanded = true;
      return;
    }

    if (distanceExpand) {
      await distanceExpand.componentOnReady?.();
      distanceExpand.expanded = true;
    }
  }

  private async activatePanelTool(): Promise<void> {
    const distanceEl = this.shadowRoot?.querySelector(
      "arcgis-distance-measurement-2d"
    ) as any;

    const areaEl = this.shadowRoot?.querySelector(
      "arcgis-area-measurement-2d"
    ) as any;

    if (this.defaultTool === "area" && areaEl) {
      await areaEl.componentOnReady?.();
      return;
    }

    if (distanceEl) {
      await distanceEl.componentOnReady?.();
    }
  }

  private shouldShow(tool: "distance" | "area" | "location"): boolean {
    if (!this.tools) {
      return false;
    }

    return this.tools
      .split(",")
      .map((item) => item.trim().toLowerCase())
      .includes(tool);
  }

  render() {
    if (this.displayMode === "panel") {
      return html`
        <div class="measurement-panel-mode">
          ${this.defaultTool === "area" && this.shouldShow("area")
            ? html`
                <arcgis-area-measurement-2d id="area-measurement-panel">
                </arcgis-area-measurement-2d>
              `
            : null}

          ${this.defaultTool !== "area" && this.shouldShow("distance")
            ? html`
                <arcgis-distance-measurement-2d id="distance-measurement-panel">
                </arcgis-distance-measurement-2d>
              `
            : null}
        </div>
      `;
    }

    return html`
      <div class="widget-stack" slot="bottom-left">
        ${this.shouldShow("distance")
          ? html`
              <arcgis-expand
                id="dist-expand"
                expand-icon="measure-line"
                expanded-icon="measure-line"
                expand-tooltip="Distance Measurement">
                <arcgis-distance-measurement-2d>
                </arcgis-distance-measurement-2d>
              </arcgis-expand>
            `
          : null}

        ${this.shouldShow("area")
          ? html`
              <arcgis-expand
                id="area-expand"
                expand-icon="measure-area"
                expanded-icon="measure-area"
                expand-tooltip="Area Measurement">
                <arcgis-area-measurement-2d>
                </arcgis-area-measurement-2d>
              </arcgis-expand>
            `
          : null}

        ${this.shouldShow("location")
          ? html`
              <arcgis-expand
                id="coord-expand"
                expand-icon="pin-plus"
                expanded-icon="pin-plus"
                expand-tooltip="Capture Location">
                <arcgis-coordinate-conversion>
                </arcgis-coordinate-conversion>
              </arcgis-expand>
            `
          : null}
      </div>
    `;
  }

  static styles = css`
    :host {
      display: block;
    }

    .widget-stack {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    .measurement-panel-mode {
      width: 100%;
      display: block;
    }

    arcgis-distance-measurement-2d,
    arcgis-area-measurement-2d {
      width: 100%;
      display: block;
    }
  `;
}

customElements.define("up-measurement", UpMeasurement);