private showGraphicPopup(
  graphic: Graphic,
  mapPoint: Point,
  graphics: Graphic[]
): void {
  console.log("[arc-geojson-layer] showGraphicPopup called", {
    graphic,
    mapPoint,
    graphicsCount: graphics.length,
    infoTemplate: this.infoTemplate,
    editorOpen: this._editorOpen,
    inDrawingMode: this.inDrawingMode,
    suppressedUntil: this._suppressPopupUntil,
    now: Date.now(),
  });

  if (this._editorOpen) {
    console.warn("[arc-geojson-layer] showGraphicPopup: editor is open, skipping");
    return;
  }
  if (this.inDrawingMode) {
    console.warn("[arc-geojson-layer] showGraphicPopup: in drawing mode, skipping");
    return;
  }
  if (this._isStartingDraw) {
    console.warn("[arc-geojson-layer] showGraphicPopup: isStartingDraw, skipping");
    return;
  }
  if (this.shouldSuppressPopup()) {
    console.warn("[arc-geojson-layer] showGraphicPopup: suppressed, skipping");
    return;
  }
  if (!this.infoTemplate) {
    console.warn("[arc-geojson-layer] showGraphicPopup: no infoTemplate, skipping");
    return;
  }

  const popupGraphics = graphics.filter((g) => g?.geometry);
  console.log("[arc-geojson-layer] showGraphicPopup: popupGraphics count:", popupGraphics.length);

  if (popupGraphics.length === 0) {
    console.warn("[arc-geojson-layer] showGraphicPopup: no valid graphics");
    return;
  }

  // Build and assign popup template to each graphic
  let builtAny = false;
  popupGraphics.forEach((g, i) => {
    const tpl = this.buildPopupTemplate(g);
    console.log(`[arc-geojson-layer] showGraphicPopup: template for graphic[${i}]:`, tpl);
    if (tpl) {
      g.popupTemplate = tpl;
      builtAny = true;
    }
  });

  if (!builtAny) {
    console.warn("[arc-geojson-layer] showGraphicPopup: no templates built, skipping");
    return;
  }

  const location =
    mapPoint ??
    ArcGeojsonLayer.getPopupPoint(graphic.geometry) ??
    undefined;

  console.log("[arc-geojson-layer] showGraphicPopup: location:", location);

  try {
    const popup = this.view?.popup;
    console.log("[arc-geojson-layer] showGraphicPopup: popup object:", popup);
    console.log("[arc-geojson-layer] showGraphicPopup: typeof popup.open:", typeof (popup as any)?.open);

    if (!popup) {
      console.error("[arc-geojson-layer] showGraphicPopup: no popup on view");
      return;
    }

    // Always disable auto-open and remove zoom action
    popup.autoOpenEnabled = false;
    popup.highlightEnabled = false;
    try { popup.actions?.removeAll?.(); } catch { }

    this._popupOpen = true;

    // Set features and location FIRST
    popup.features = popupGraphics;
    popup.location = location;

    // ArcGIS 5.0 — use view.openPopup() which is the correct API
    // popup.open is a boolean property NOT a function in 5.0
    if (typeof (this.view as any).openPopup === "function") {
      console.log("[arc-geojson-layer] showGraphicPopup: using view.openPopup()");
      (this.view as any).openPopup({
        features: popupGraphics,
        location,
        updateLocationEnabled: false,
      });
    } else {
      console.log("[arc-geojson-layer] showGraphicPopup: using popup.open = true");
      // Fallback — set open as boolean property
      (popup as any).open = true;
      popup.visible = true;
    }

    // Remove zoom action after popup renders
    setTimeout(() => {
      try {
        popup.actions?.removeAll?.();
        console.log("[arc-geojson-layer] showGraphicPopup: actions cleared after open");
      } catch { }
    }, 50);

    console.log("[arc-geojson-layer] showGraphicPopup: popup opened successfully");

  } catch (err) {
    console.error("[arc-geojson-layer] showGraphicPopup failed:", err);
    this._popupOpen = false;
  }
}

public closePopup(): void {
  console.log("[arc-geojson-layer] closePopup called", {
    popupOpen: this._popupOpen,
  });

  this._popupOpen = false;

  try {
    const popup: any = this.view?.popup;
    if (popup) {
      // ArcGIS 5.0 — close popup using close() method or
      // setting open = false as boolean
      try {
        if (typeof popup.close === "function") {
          popup.close();
          console.log("[arc-geojson-layer] closePopup: called popup.close()");
        } else {
          popup.open = false;
          console.log("[arc-geojson-layer] closePopup: set popup.open = false");
        }
      } catch { }
      try { popup.visible = false; } catch { }
      try { popup.features = []; } catch { }
    }
  } catch { }

  try { this._popupHighlightHandle?.remove?.(); } catch { }
  this._popupHighlightHandle = null;

  console.log("[arc-geojson-layer] closePopup: done");
}



const clickHandle = this.view.on("click", async (evt: any) => {
  if (this.isPopupDomTarget(evt?.native?.target)) {
    console.log("[arc-geojson-layer] click: target is popup DOM, ignoring");
    return;
  }

  // Clear existing timer
  if (clickTimer) {
    clearTimeout(clickTimer);
    clickTimer = null;
  }

  clickTimer = setTimeout(async () => {
    clickTimer = null;

    console.log("[arc-geojson-layer] click: hitTest running");
    const hit = await this.view.hitTest(evt);
    const allResults = hit?.results ?? [];

    console.log("[arc-geojson-layer] click: hitTest results:", allResults.length);

    const thisLayerGraphics = allResults
      .map((r: any) => r.graphic)
      .filter(
        (g: Graphic) =>
          g?.geometry && g?.layer === this.featureLayer
      );

    console.log("[arc-geojson-layer] click: thisLayerGraphics:", thisLayerGraphics.length);

    if (thisLayerGraphics.length === 0) {
      // Only close if popup is already open
      // Do NOT close immediately — let popup stay open
      // unless user clicks truly empty space
      const hitAnyGraphic = allResults.length > 0;
      if (!hitAnyGraphic && this._popupOpen) {
        console.log("[arc-geojson-layer] click: empty space, closing popup");
        this.closePopup();
      }
      return;
    }

    const topGraphic = thisLayerGraphics[0];
    console.log("[arc-geojson-layer] click: topGraphic:", topGraphic?.attributes);

    this.emitLayerEvent(
      "layerClick",
      this.graphicToGeoJsonFeature(topGraphic),
      topGraphic,
      {
        event: {
          coordinates: {
            latitude: evt.mapPoint?.latitude ?? 0,
            longitude: evt.mapPoint?.longitude ?? 0,
          },
          attributes: topGraphic.attributes ?? {},
        },
      }
    );

    if (
      !this._editorOpen &&
      !this.inDrawingMode &&
      !this._isStartingDraw &&
      !this.shouldSuppressPopup()
    ) {
      this.showGraphicPopup(
        topGraphic,
        evt.mapPoint,
        thisLayerGraphics
      );
    }

    if (
      this.enableUserEdit &&
      !this._editorOpen &&
      !this.inDrawingMode
    ) {
      if (evt.native?.ctrlKey && this.enableUserEditRemove) {
        this.removeFromGeoJSON(topGraphic);
        this.graphicsEditor?.cancel();
        return;
      }
      await this.activateGraphicsEditor(topGraphic);
    }
  }, 180);
});



private setupPopupCloseWatcher(): void {
  try { this._popupVisibleWatchHandle?.remove?.(); } catch { }
  this._popupVisibleWatchHandle = null;

  const popup: any = this.view?.popup;
  if (!popup) return;

  // Use reactiveUtils instead of deprecated popup.watch
  try {
    this._popupVisibleWatchHandle = reactiveUtils.watch(
      () => this.view?.popup?.visible,
      (visible: boolean) => {
        console.log("[arc-geojson-layer] popup visible changed:", visible);
        if (!visible) {
          // Popup closed externally — reset state only, do NOT call closePopup()
          // to avoid infinite loop
          this._popupOpen = false;
          this.setViewCursor("default");
          console.log("[arc-geojson-layer] popup closed externally, reset state");
        }
      }
    );
  } catch (err) {
    console.warn("[arc-geojson-layer] setupPopupCloseWatcher failed:", err);
  }
}
