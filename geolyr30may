private openDefaultArcGISMeasurementScreen(): void {
  setTimeout(async () => {
    const upMeasurementElement = this.upMeasurement?.nativeElement as any;

    await customElements.whenDefined('up-measurement');
    await upMeasurementElement.updateComplete;

    const shadowRoot = upMeasurementElement.shadowRoot;
    const distanceExpand = shadowRoot.querySelector('#dist-expand') as any;

    if (distanceExpand) {
      distanceExpand.expanded = true;
    }
  }, 500);
}