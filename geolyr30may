private readonly extentChangedHandler = (event: Event): void => {
  if (this.ignoreExtentChange) {
    return;
  }

  const extent =
    (event as CustomEvent<UpMapExtent>).detail;

  if (!extent || !this.isValidExtent(extent)) {
    return;
  }

  const current = this.mapFacade.state().extent;

  if (this.extentsEqual(current, extent)) {
    return;
  }

  this.mapFacade.setExtent(extent);
};




setTimeout(() => {
  this.ignoreExtentChange = false;
}, 500);