// Pass 1: unrestricted — see ALL layers for topmost check
const allLayersHit = await this.view.hitTest(evt);
const allLayersResults = allLayersHit?.results ?? [];

const validResults = allLayersResults.filter((r: any) =>
    r?.graphic?.geometry &&
    r?.graphic?.layer !== this.sketchLayer &&
    r?.graphic?.layer !== this.labelLayer
);

const thisLayerFirstIndex = allLayersResults.findIndex(
    (r: any) => r?.graphic?.layer === this.featureLayer
);
const otherLayerFirstIndex = allLayersResults.findIndex(
    (r: any) => r?.graphic?.layer !== this.featureLayer &&
                r?.graphic?.layer !== this.sketchLayer &&
                r?.graphic?.layer !== this.labelLayer
);
