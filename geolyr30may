loadUserMaps(): void {
  this.mapsApi.readUserMaps().subscribe({
    next: (dtos) => {
      const maps = this.applyFavoriteMapFlags(
        dtos
          .filter((dto) => dto.userID !== 'predefined')
          .map((dto) => this.mapDtoToSavedMap(dto)),
      );

      this.savedMaps.set(maps);

      // NEW: auto-load the default map at startup
      const defaultMap = maps.find((map) => map.isDefault);
      if (defaultMap) {
        this.loadSavedMap(defaultMap.id);
      }
    },
    error: (err) => console.error('[SavedMapFacade] loadUserMaps failed', err),
  });
}
