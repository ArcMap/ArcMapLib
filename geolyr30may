private updateEllipsisTooltips(): void {
  requestAnimationFrame(() => {
    requestAnimationFrame(() => {
      const textWrappers = document.querySelectorAll(
        '.autocomplete-text-wrapper'
      );

      textWrappers.forEach((wrapperElement) => {
        const textElement = wrapperElement.querySelector(
          '.autocomplete-ellipsis-text'
        ) as HTMLElement | null;

        const tooltipElement = wrapperElement.querySelector(
          'up-tooltip.autocomplete-name-tooltip'
        ) as HTMLElement | null;

        if (!textElement || !tooltipElement) {
          return;
        }

        const isEllipsisVisible =
          textElement.scrollWidth > textElement.clientWidth;

        if (isEllipsisVisible) {
          tooltipElement.removeAttribute('disabled');
          (tooltipElement as any).disabled = false;
        } else {
          tooltipElement.setAttribute('disabled', '');
          (tooltipElement as any).disabled = true;
        }
      });
    });
  });
}