private async initializeMap(): Promise<void> {
  this.upMapInstance =
    this.upMapElement().nativeElement as UpMap;

  try {
    const mapView = await this.upMapInstance.getMapView();
    this.mapFacade.setMapView(mapView);

    setTimeout(() => {
      const upMapElement =
        this.upMapElement().nativeElement as HTMLElement;

      upMapElement
        .querySelectorAll<HTMLElement>('[class], up-esri-feature-layer, up-image-service-layer')
        .forEach((element) => {
          if (!element.tagName.toLowerCase().startsWith('up-')) {
            return;
          }

          element.dispatchEvent(
            new CustomEvent('upMapDeferredReady', {
              detail: {
                map: mapView.map,
                view: mapView,
              },
              bubbles: false,
              composed: true,
            }),
          );
        });
    });
  } catch (error) {
    console.error(
      '[MapViewComponent.initializeMap] Failed to initialize map',
      error,
    );

    this.mapFacade.setMapView(null);
  }

  // Keep the remaining existing initializeMap() logic here.
}