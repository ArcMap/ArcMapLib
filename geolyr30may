export async function runWithMapLoader(
  layerElement: HTMLElement,
  callback: () => Promise<void>
): Promise<void> {
  const ancestorMap =
    (layerElement.closest('map') as any) ||
    (layerElement.closest('u') as any);

  const loaderManager = ancestorMap?.getLoaderManager?.();

  if (!loaderManager) {
    console.warn('[layer-loader-utils] Loader manager not found');
    await callback();
    return;
  }

  loaderManager.start();

  try {
    await waitForBrowserPaint();
    await callback();
  } finally {
    loaderManager.stop();
  }
}

function waitForBrowserPaint(): Promise<void> {
  return new Promise((resolve) => {
    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        resolve();
      });
    });
  });
}