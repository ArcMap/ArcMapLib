private getLayerIndexFromDomOrder(element: HTMLElement): number {
  const layerElements = Array.from(
    this.querySelectorAll(
      "up-esri-feature-layer, up-geojson-layer, up-image-service-layer, up-tiled-map-service-layer, up-wms-layer"
    )
  ) as HTMLElement[];

  const domIndex = layerElements.indexOf(element);

  if (domIndex === -1) {
    return this.map?.layers?.length ?? 0;
  }

  // Reverse DOM order:
  // first element -> bottom
  // last element -> top
  return layerElements.length - domIndex - 1;
}


public addLayerByDomOrder(layer: Layer, element: HTMLElement): void {
  const layerIndex = this.getLayerIndexFromDomOrder(element);
  this.map.add(layer, layerIndex);
}




