private async activatePanelDefaultTool(): Promise<void> {
  const distEl = this.shadowRoot?.querySelector(
    "arcgis-distance-measurement-2d"
  ) as any;

  const areaEl = this.shadowRoot?.querySelector(
    "arcgis-area-measurement-2d"
  ) as any;

  if (this.defaultTool === "area" && areaEl) {
    await areaEl.componentOnReady?.();

    if (this.autoStart) {
      setTimeout(() => {
        areaEl.clear?.();
        areaEl.start?.();
      }, 300);
    }

    return;
  }

  if (distEl) {
    await distEl.componentOnReady?.();

    if (this.autoStart) {
      setTimeout(() => {
        distEl.clear?.();
        distEl.start?.();
      }, 300);
    }
  }
}




