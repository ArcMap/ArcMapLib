.measure-content {
  display: flex;
  flex-direction: column;
  width: 100%;
  box-sizing: border-box;
}

.measurement-host {
  position: relative;
  width: 100%;
  min-height: 210px;
}

up-measurement {
  display: block;
  width: 100%;
}

.measure-actions {
  position: relative;
  z-index: 20;
  width: 100%;
  box-sizing: border-box;
  padding: 8px 12px 12px;
  background: var(--calcite-color-foreground-1);
}

.measure-actions calcite-button {
  width: 100%;
}