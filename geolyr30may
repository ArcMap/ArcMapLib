<div slot="content" class="rename-row">
  <calcite-input-text
    class="rename-input"
    [value]="renameMapName()"
    (calciteInputTextInput)="onRenameMapNameInput($event)"
  ></calcite-input-text>

  <calcite-action
    class="rename-cancel"
    icon="x"
    text="Cancel"
    (click)="cancelRenameInstance()"
  ></calcite-action>

  <calcite-action
    class="rename-save"
    icon="check"
    text="Save"
    (click)="confirmRenameInstance(map.id)"
  ></calcite-action>
</div>



.rename-row {
  display: flex;
  width: 100%;
  align-items: stretch;
}

.rename-input {
  flex: 1;
}

.rename-cancel,
.rename-save {
  width: 38px;
  min-width: 38px;
  height: 32px;
  border: 1px solid var(--calcite-input-text-border-color);
  border-left: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.rename-cancel {
  background: white;
  color: var(--calcite-color-text-2);
}

.rename-save {
  background: var(--calcite-color-brand);
  border-color: var(--calcite-color-brand);
  color: white;
  --calcite-icon-color: white;
  --calcite-color-text-1: white;
}

.rename-save::part(icon) {
  color: white;
  fill: white;
}