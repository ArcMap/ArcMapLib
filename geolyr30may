private buildPopupTemplate(graphic: Graphic): PopupTemplate | null {
  console.log("[arc-geojson-layer] buildPopupTemplate called", {
    hasInfoTemplate: !!this.infoTemplate,
    infoTemplate: this.infoTemplate,
    infoTemplateKeys: this.infoTemplate
      ? Object.keys(this.infoTemplate)
      : [],
    attributes: graphic?.attributes,
  });

  if (!this.infoTemplate) {
    console.warn(
      "[arc-geojson-layer] buildPopupTemplate: no infoTemplate set"
    );
    return null;
  }

  if (!graphic) {
    console.warn(
      "[arc-geojson-layer] buildPopupTemplate: no graphic"
    );
    return null;
  }

  const attributes = graphic.attributes ?? {};
  const tmpl = this.infoTemplate;

  console.log("[arc-geojson-layer] buildPopupTemplate: tmpl is:", tmpl);
  console.log("[arc-geojson-layer] buildPopupTemplate: tmpl keys:", Object.keys(tmpl));

  // Token replacer — supports ${field} and {field}
  const resolveTokens = (str: string): string => {
    if (!str || typeof str !== "string") return str;
    return str
      .replace(/\$\{([^}]+)\}/g, (_, k) => {
        const v = attributes[k.trim()];
        console.log(`[arc-geojson-layer] token \${${k.trim()}} =>`, v);
        return v == null ? "" : String(v);
      })
      .replace(/\{([^}]+)\}/g, (_, k) => {
        if (k.includes("/") || k.includes("expression")) {
          return `{${k}}`;
        }
        const v = attributes[k.trim()];
        console.log(`[arc-geojson-layer] token {${k.trim()}} =>`, v);
        return v == null ? "" : String(v);
      });
  };

  try {
    // ── Title ─────────────────────────────────────────────────
    // Accept ALL common title keys users might pass
    const rawTitle =
      tmpl?.title ??
      tmpl?.Title ??
      tmpl?.listItem ??      // ← user is passing listItem
      tmpl?.listTitle ??
      tmpl?.heading ??
      tmpl?.header ??
      tmpl?.name ??
      null;

    console.log(
      "[arc-geojson-layer] buildPopupTemplate: rawTitle:", rawTitle
    );

    let title: string;

    if (rawTitle === null || rawTitle === undefined) {
      title = "";
      console.warn(
        "[arc-geojson-layer] buildPopupTemplate: no title key found in infoTemplate"
      );
    } else if (typeof rawTitle === "function") {
      title = String(rawTitle.call(tmpl, graphic) ?? "");
      console.log(
        "[arc-geojson-layer] buildPopupTemplate: title from function:", title
      );
    } else {
      title = resolveTokens(String(rawTitle));
      console.log(
        "[arc-geojson-layer] buildPopupTemplate: title resolved:", title
      );
    }

    // ── Content ───────────────────────────────────────────────
    // Accept ALL common content keys users might pass
    const rawContent =
      tmpl?.content ??
      tmpl?.Content ??
      tmpl?.details ??        // ← user is passing details
      tmpl?.body ??
      tmpl?.description ??
      tmpl?.template ??
      null;

    console.log(
      "[arc-geojson-layer] buildPopupTemplate: rawContent:", rawContent
    );
    console.log(
      "[arc-geojson-layer] buildPopupTemplate: typeof rawContent:", typeof rawContent
    );

    let content: any = null;

    if (typeof rawContent === "function") {
      // Call the function with the graphic — user returns HTML string or element
      const result = rawContent.call(tmpl, graphic);
      console.log(
        "[arc-geojson-layer] buildPopupTemplate: content from function result:", result
      );

      if (typeof result === "string" && result.trim()) {
        content = resolveTokens(result);
      } else if (result !== null && result !== undefined) {
        content = result;
      }

      console.log(
        "[arc-geojson-layer] buildPopupTemplate: content after function call:", content
      );
    } else if (typeof rawContent === "string" && rawContent.trim()) {
      content = resolveTokens(rawContent);
      console.log(
        "[arc-geojson-layer] buildPopupTemplate: content resolved from string:", content
      );
    } else if (rawContent !== null && typeof rawContent === "object") {
      content = rawContent;
      console.log(
        "[arc-geojson-layer] buildPopupTemplate: content is object:", content
      );
    }

    // ── Validate — skip popup if no data at all ────────────────
    const SKIP = new Set([
      "OBJECTID",
      "_featureIndex",
      "__isTemporaryDrawing",
      "__labelFor",
      "_parentFeatureCollection",
    ]);

    const hasValidAttributes = Object.entries(attributes).some(
      ([k, v]) =>
        !k.startsWith("_") &&
        !SKIP.has(k) &&
        v !== null &&
        v !== undefined &&
        String(v).trim() !== ""
    );

    console.log(
      "[arc-geojson-layer] buildPopupTemplate: hasValidAttributes:", hasValidAttributes,
      "hasContent:", !!content
    );

    if (!content && !hasValidAttributes) {
      console.warn(
        "[arc-geojson-layer] buildPopupTemplate: no content and no valid attributes — skipping"
      );
      return null;
    }

    // ── Build PopupTemplate ───────────────────────────────────
    let popupTemplate: PopupTemplate;

    if (content && typeof content === "string") {
      console.log(
        "[arc-geojson-layer] buildPopupTemplate: building with string content"
      );
      popupTemplate = new PopupTemplate({
        title,
        content,
        actions: [] as any,
      });
    } else if (
      content &&
      typeof content === "object" &&
      !Array.isArray(content)
    ) {
      console.log(
        "[arc-geojson-layer] buildPopupTemplate: building with object content"
      );
      popupTemplate = new PopupTemplate({
        title,
        content,
        actions: [] as any,
      });
    } else if (Array.isArray(content) && content.length > 0) {
      console.log(
        "[arc-geojson-layer] buildPopupTemplate: building with array content"
      );
      popupTemplate = new PopupTemplate({
        title,
        content,
        actions: [] as any,
      });
    } else {
      // No content — use native ArcGIS fields block
      const fieldInfos = Object.keys(attributes)
        .filter((k) => !k.startsWith("_") && !SKIP.has(k))
        .map((k) => ({
          fieldName: k,
          label: k,
          visible: true,
        }));

      console.log(
        "[arc-geojson-layer] buildPopupTemplate: building with fieldInfos:", fieldInfos
      );

      popupTemplate = new PopupTemplate({
        title,
        content: [
          {
            type: "fields",
            fieldInfos,
          },
        ] as any,
        actions: [] as any,
      });
    }

    console.log(
      "[arc-geojson-layer] buildPopupTemplate: final template:", popupTemplate
    );

    return popupTemplate;

  } catch (error) {
    console.error(
      "[arc-geojson-layer] buildPopupTemplate failed:", error
    );
    return null;
  }
}
