if (setAsDefault) {
  this.addFavoriteMapId(saved.mapID);

  // Also save as a predefined map
  this.savePredefinedMap({
    id: saved.mapID,
    name: trimmedName,
    layers: this.parseMapLayerInfo(mapLayerInfo),
  }).subscribe({
    error: (err) =>
      console.error('[SavedMapFacade] savePredefinedMap failed', err),
  });

  // Persist as user preference
  this.userContextFacade.setPreference('userDefaultSavedMap', saved.mapID);
}
