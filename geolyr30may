private _killArcGISDefaultPopup(): void {
  try {
    if (!this.view) return;

    // Do NOT disable popupEnabled globally — it blocks our own popup too
    // Only kill auto-open and the "Zoom to" default action
    const popup: any = this.view?.popup;
    if (!popup) return;

    popup.autoOpenEnabled = false;
    popup.highlightEnabled = false;

    // Remove the "Zoom to" default action only
    try {
      if (popup.actions?.length > 0) {
        const zoomAction = popup.actions.find(
          (a: any) => a.id === "zoom-to" || a.title === "Zoom to"
        );
        if (zoomAction) {
          popup.actions.remove(zoomAction);
        }
      }
    } catch { }

  } catch { }
}



private bindViewEvents(): void {
  if (!this.view || !this.featureLayer) return;

  this.cleanupViewEvents();
  this.setupPopupCloseWatcher();

  // Kill ArcGIS default popup auto-open — but do NOT disable popupEnabled
  try {
    if (this.view.popup) {
      this.view.popup.autoOpenEnabled = false;
      this.view.popup.highlightEnabled = false;
      // Watch using reactiveUtils (not deprecated view.watch)
      reactiveUtils.watch(
        () => this.view?.popup?.visible,
        (visible: boolean) => {
          if (visible) {
            // If ArcGIS opened it on its own (blank/zoom-to), close it
            const popup: any = this.view?.popup;
            const hasOurTemplate = popup?.features?.length > 0 &&
              popup?.features?.[0]?.popupTemplate != null;
            if (!hasOurTemplate && !this._popupOpen) {
              try { popup?.close?.(); } catch { }
              try { popup.visible = false; } catch { }
            }
          }
        }
      );
    }
  } catch { }

  let clickTimer: any = null;

  const clickHandle = this.view.on("click", async (evt: any) => {
    if (this.isPopupDomTarget(evt?.native?.target)) return;

    // Immediately close any ArcGIS-opened popup (the blank "Zoom to" one)
    try {
      const popup: any = this.view?.popup;
      if (popup?.visible && !this._popupOpen) {
        popup.close?.();
        popup.visible = false;
      }
    } catch { }

    if (clickTimer) {
      clearTimeout(clickTimer);
      clickTimer = null;
      return;
    }

    clickTimer = setTimeout(async () => {
      clickTimer = null;

      const hit = await this.view.hitTest(evt);
      const allResults = hit?.results ?? [];
      const topResult = allResults[0];
      const graphic = topResult?.graphic;

      if (!graphic) return;
      if (graphic.layer !== this.featureLayer) return;

      const thisLayerGraphics = allResults
        .map((r: any) => r.graphic)
        .filter((g: Graphic) => g?.layer === this.featureLayer);

      this.emitLayerEvent(
        "layerClick",
        this.graphicToGeoJsonFeature(graphic),
        graphic,
        {
          event: {
            coordinates: {
              latitude: evt.mapPoint?.latitude ?? 0,
              longitude: evt.mapPoint?.longitude ?? 0,
            },
            attributes: graphic.attributes ?? {},
          },
        },
      );

      if (
        !this._editorOpen &&
        !this.inDrawingMode &&
        !this._isStartingDraw &&
        !this.shouldSuppressPopup()
      ) {
        this.showGraphicPopup(
          graphic,
          evt.mapPoint,
          thisLayerGraphics.length > 0 ? thisLayerGraphics : [graphic],
        );
      }

      if (
        this.enableUserEdit &&
        !this._editorOpen &&
        !this.inDrawingMode &&
        this.infoTemplate
      ) {
        if (evt.native?.ctrlKey && this.enableUserEditRemove) {
          this.removeFromGeoJSON(graphic);
          this.graphicsEditor?.cancel();
          return;
        }
        this.activateGraphicsEditor(graphic);
      }
    }, 180);
  });

