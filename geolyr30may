protected override async updated(changedProperties: Map<string, unknown>): Promise<void> {
  super.updated(changedProperties);

  if (changedProperties.has('showZoom') && this.showZoom) {
    await loadZoomComponent();
  }

  if (changedProperties.has('showHome') && this.showHome) {
    await loadHomeComponent();
  }

  if (changedProperties.has('showLocate') && this.showLocate) {
    await loadLocateComponent();
  }

  if (changedProperties.has('showScaleBar') && this.showScaleBar) {
    await loadScaleBarComponent();
  }
}