export type MapLoaderListener = (isLoading: boolean) => void;

export class MapLoaderManager {
  private loadingCount = 0;
  private listeners: MapLoaderListener[] = [];

  public start(): void {
    this.loadingCount++;
    this.notify();
  }

  public stop(): void {
    this.loadingCount = Math.max(0, this.loadingCount - 1);
    this.notify();
  }

  public async run<T>(task: () => Promise<T>): Promise<T> {
    this.start();

    try {
      return await task();
    } finally {
      this.stop();
    }
  }

  public isLoading(): boolean {
    return this.loadingCount > 0;
  }

  public subscribe(listener: MapLoaderListener): () => void {
    this.listeners.push(listener);
    listener(this.isLoading());

    return () => {
      this.listeners = this.listeners.filter(
        (existingListener) => existingListener !== listener
      );
    };
  }

  private notify(): void {
    const isLoading = this.isLoading();

    this.listeners.forEach((listener) => {
      listener(isLoading);
    });
  }
}





import { html, LitElement, nothing, css } from 'lit';
import { customElement, state } from 'lit/decorators.js';
import { MapLoaderManager } from './MapLoaderManager';



private mapLoaderManager = new MapLoaderManager();
private unsubscribeMapLoader?: () => void;

@state()
private isMapLoading = fals




public getLoaderManager(): MapLoaderManager {
  return this.mapLoaderManager;
}




public connectedCallback(): void {
  super.connectedCallback();

  this.unsubscribeMapLoader = this.mapLoaderManager.subscribe(
    (isLoading: boolean) => {
      this.isMapLoading = isLoading;
      this.requestUpdate();
    }
  );
}



public disconnectedCallback(): void {
  if (this.unsubscribeMapLoader) {
    this.unsubscribeMapLoader();
    this.unsubscribeMapLoader = undefined;
  }

  super.disconnectedCallback();
}




private renderMapLoader() {
  if (!this.isMapLoading) {
    return nothing;
  }

  return html`
    <div class="map-loader-overlay">
      <div class="map-loader-box">
        <div class="map-loader-spinner"></div>
        <div class="map-loader-text">Loading map data...</div>
      </div>
    </div>
  `;
}



protected render() {
  return html`
    <div class="arc-map-root">
      <div id="mapViewDiv" class="arc-map-view"></div>

      <slot></slot>

      ${this.renderMapLoader()}
    </div>
  `;
}






