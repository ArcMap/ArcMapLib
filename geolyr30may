private reorderGraphicsLayersToTop(): void {
  if (!this.map?.layers) {
    return;
  }

  const layers = this.map.layers.toArray();

  const graphicsLayers = layers.filter((layer: any) =>
    layer?.id?.includes("geojson") ||
    layer?.id?.includes("graphics") ||
    layer?.id?.includes("label") ||
    layer?.id?.includes("sketch")
  );

  graphicsLayers.forEach((layer: any) => {
    this.map.reorder(layer, this.map.layers.length - 1);
  });
}



