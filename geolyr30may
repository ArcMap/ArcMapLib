private static popupLayerInstances = new Set<UpGeojsonLayer>();
private static prioritizedHitTests = new Map<string, Promise<any>>();

private getClickSignature(evt: any): string {
  const nativeTime = evt?.native?.timeStamp ?? 0;
  const x = Math.round(evt?.x ?? evt?.screenPoint?.x ?? evt?.native?.offsetX ?? 0);
  const y = Math.round(evt?.y ?? evt?.screenPoint?.y ?? evt?.native?.offsetY ?? 0);

  return `${nativeTime}_${x}_${y}`;
}

private getGraphicPriority(graphic: Graphic): number {
  const type = graphic?.geometry?.type;

  if (type === "point" || type === "multipoint") {
    return 3;
  }

  if (type === "polyline") {
    return 2;
  }

  if (type === "polygon") {
    return 1;
  }

  return 0;
}

private getWinningGraphicFromResults(graphicResults: any[]): Graphic | undefined {
  const sortedResults = [...graphicResults].sort((a: any, b: any) => {
    const aPriority = this.getGraphicPriority(a.graphic);
    const bPriority = this.getGraphicPriority(b.graphic);

    if (aPriority !== bPriority) {
      return bPriority - aPriority;
    }

    return 0;
  });

  return sortedResults[0]?.graphic as Graphic | undefined;
}

private getRegisteredLayers(): any[] {
  const layers: any[] = [];

  UpGeojsonLayer.popupLayerInstances.forEach((instance: UpGeojsonLayer) => {
    [instance.featureLayer, instance.sketchLayer].forEach((layer: any) => {
      if (layer && !layers.includes(layer)) {
        layers.push(layer);
      }
    });
  });

  return layers;
}

private getPrioritizedSharedHitTest(evt: any): Promise<any> {
  const signature = this.getClickSignature(evt);

  const existing = UpGeojsonLayer.prioritizedHitTests.get(signature);
  if (existing) {
    return existing;
  }

  const promise = (async () => {
    const start = performance.now();

    const hit = await this.view.hitTest(evt, {
      include: this.getRegisteredLayers(),
    });

    const graphicResults = (hit?.results ?? []).filter((result: any) => {
      return (
        result?.type === "graphic" &&
        result?.graphic &&
        result.graphic.layer &&
        result.graphic.geometry
      );
    });

    const winningGraphic = this.getWinningGraphicFromResults(graphicResults);

    const ms = Math.round(performance.now() - start);

    if (ms > 300) {
      console.warn("[popup-perf] prioritized hitTest slow", {
        ms,
        totalResults: graphicResults.length,
        winningLayer: winningGraphic?.layer?.title,
        winningGeometry: winningGraphic?.geometry?.type,
      });
    }

    return {
      winningGraphic,
      graphicResults,
    };
  })().finally(() => {
    UpGeojsonLayer.prioritizedHitTests.delete(signature);
  });

  UpGeojsonLayer.prioritizedHitTests.set(signature, promise);

  return promise;
}