/* ✅ Reduce zoom widget button size */
::ng-deep arcgis-zoom .esri-widget--button {
  width: 24px !important;
  height: 24px !important;
  min-width: 24px !important;
  min-height: 24px !important;
}

/* ✅ Reduce icon size inside buttons */
::ng-deep arcgis-zoom .esri-icon {
  font-size: 12px !important;
}

/* ✅ Reduce gap between zoom in and zoom out */
::ng-deep arcgis-zoom .esri-zoom {
  gap: 2px !important;
}

/* ✅ Reduce overall widget padding */
::ng-deep arcgis-zoom .esri-component {
  padding: 0 !important;
}
