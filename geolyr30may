private updateMapQueryParams(map: MapSelectionItem): void {
  const checkedLayerIds = (map.layers ?? [])
    .filter((layer) => layer.isChecked === true)
    .map((layer) => layer.uniqueLayerId)
    .filter(
      (layerId): layerId is number =>
        layerId !== null && layerId !== undefined,
    );

  this.suppressNextDeepLinkApply = true;

  void this.router.navigate(['/'], {
    queryParams: {
      layers:
        checkedLayerIds.length > 0
          ? checkedLayerIds.join(',')
          : null,
      userMap: map.name,
      bookmarkId: null,
    },
    queryParamsHandling: 'merge',
    replaceUrl: true,
  });
}