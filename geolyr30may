private defaultMapLoaded = false;

loadUserMaps(): void {
  this.mapApi.readUserMaps().subscribe({
    next: (dtos) => {
      const maps = dtos
        .filter((dto) => dto.userID !== 'predefined')
        .map((dto) => this.mapDtoToSavedMap(dto));

      this.savedMaps.set(
        this.applyFavoriteMapFlag(maps)
      );

      if (!this.defaultMapLoaded) {
        const defaultMapId =
          this.userFacade.getPreference('userDefaultSearchLayer');

        if (
          defaultMapId &&
          maps.some(
            (map) => String(map.id) === String(defaultMapId)
          )
        ) {
          this.defaultMapLoaded = true;
          this.loadSavedMap(String(defaultMapId));
        }
      }
    },

    error: (err) =>
      console.error('[SavedMapFacade] loadUserMaps failed', err),
  });
}