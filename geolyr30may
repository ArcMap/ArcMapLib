// Filter to only operational layers present in map.layers
const validResults = allResults.filter((r: any) => {
    const layer = r?.graphic?.layer;
    if (!layer || !r?.graphic?.geometry) return false;
    return this.view.map.layers.indexOf(layer) !== -1;
});

const topmostGraphic = validResults[0]?.graphic;
const topmostLayer = topmostGraphic?.layer;
const topmostIsThisLayer =
    topmostLayer === this.featureLayer ||
    topmostLayer === this.sketchLayer;

if (topmostGraphic && !topmostIsThisLayer) {
    try {
        const topmostIndex = this.view.map.layers.indexOf(topmostLayer);
        const thisIndex = this.view.map.layers.indexOf(this.featureLayer);
        if (topmostIndex > thisIndex) return;
    } catch {}
}
