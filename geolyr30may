serializeDisplayedLayers(): string {
  console.log('[serialize] layers() =', this.layers().map(l => ({id: l.id, visible: l.visible, mapVisible: l.mapVisible})));
  console.log('[serialize] selectedMapLayers() =', this.selectedMapLayers().map(l => ({id: l.id, visible: l.visible})));
  console.log('[serialize] visibleLayers() =', this.visibleLayers().map(l => l.id));
  console.log('[serialize] selectedMap() =', this.selectedMap());

  const displayedLayers = this.selectedMapLayers().map((layer) => ({
    uniqueLayerId: layer.id,
    isChecked: layer.visible === true,
  }));
  return JSON.stringify({ displayedLayers });
}
