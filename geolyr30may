selectMap(map: PredefinedMap): void {
  const item = this.getDistinctMapSelectionItems().find(
    (candidate) => candidate.type === 'predefined' && candidate.mapId === map.mapID,
  );
  if (item) {
    this.applyMapSelection(item, { updateQueryParams: true });
  } else {
    // fallback: at least clear stale URL params even if list lookup fails
    this.layersFacade.setSelectedMap(map);
  }
}
