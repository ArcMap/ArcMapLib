private logPopupPerf(label: string, startTime: number, extra?: any): void {
  const duration = Math.round(performance.now() - startTime);

  if (duration > 100) {
    console.warn(`[up-geojson-layer][popup-perf] ${label}: ${duration}ms`, extra ?? "");
  } else {
    console.log(`[up-geojson-layer][popup-perf] ${label}: ${duration}ms`, extra ?? "");
  }
}




