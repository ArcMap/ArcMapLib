<div class="rename-row">
  <calcite-input-text
    class="rename-input"
    [value]="renameMapName()"
    (calciteInputTextInput)="onRenameMapNameInput($event)">
  </calcite-input-text>

  <calcite-button
    appearance="solid"
    (click)="confirmRenameInstance(map.id)">
    Save
  </calcite-button>

  <calcite-button
    appearance="outline"
    kind="neutral"
    (click)="cancelRenameInstance()">
    Cancel
  </calcite-button>
</div>