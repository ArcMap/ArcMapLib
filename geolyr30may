    ]).then(() => undefined)
  );

  return measurementComponentsPromise;
}

async function initialize(): Promise<void> {
  if (initializedPromise) {
    return initializedPromise;
  }

  initializedPromise = Promise.all([
    addPreconnectOnce('u-preconnect-js-arcgis', 'https://js.arcgis.com'),
    addPreconnectOnce('u-preconnect-static-arcgis', 'https://static.arcgis.com'),
    addStylesheetOnce('u-arcgis-core-css', `${ARCGIS_BASE_URL}/esri/themes/light/main.css`),
    addStylesheetOnce('u-map-components-css', `${ARCGIS_BASE_URL}/map-components/main.css`)
  ]).then(() => {
    esriConfig.assetsPath = `${ARCGIS_BASE_URL}/assets`;
    setMapAssetPath(`${ARCGIS_BASE_URL}/map-components/assets`);
  });

  return initializedPromise;
}

function addPreconnectOnce(id: string, href: string): Promise<void> {
  return new Promise((resolve) => {
    if (typeof document === 'undefined' || document.getElementById(id)) {
      resolve();
      return;
    }

    const link = document.createElement('link');
    link.id = id;
    link.rel = 'preconnect';
    link.href = href;
    link.crossOrigin = 'anonymous';

    document.head.appendChild(link);
    resolve();
  });
}

function addStylesheetOnce(id: string, href: string): Promise<void> {
  return new Promise((resolve, reject) => {
    if (typeof document === 'undefined' || document.getElementById(id)) {
      resolve();
      return;
    }

    const link = document.createElement('link');
    link.id = id;
    link.rel = 'stylesheet';
    link.href = href;

    link.onload = () => resolve();
    link.onerror = () => reject(new Error(`Failed to load stylesheet: ${href}`));

    document.head.appendChild(link);
  });
}