private hideExpandIcon(expandElement: any): void {

  if (!expandElement) {

    return;

  }

  const applyStyle = () => {

    const root = expandElement.shadowRoot;

    if (!root) {

      return;

    }

    const existingStyle = root.querySelector('#hide-expand-icon-style');

    if (existingStyle) {

      return;

    }

    const style = document.createElement('style');

    style.id = 'hide-expand-icon-style';

    style.textContent = `

      calcite-action,

      button {

        opacity: 0 !important;

        width: 0 !important;

        min-width: 0 !important;

        height: 0 !important;

        min-height: 0 !important;

        padding: 0 !important;

        margin: 0 !important;

        pointer-events: none !important;

      }

    `;

    root.appendChild(style);

  };

  applyStyle();

  setTimeout(applyStyle, 300);

  setTimeout(applyStyle, 800);