private async waitForLayerView(): Promise<void> {
  if (!this.view || !this.featureLayer) {
    return;
  }

  await new Promise((resolve) => requestAnimationFrame(resolve));

  try {
    await this.view.whenLayerView(this.featureLayer);
  } catch (layerViewError) {
    console.warn(
      '[-feature-layer] Layer was added, but LayerView was not ready yet',
      layerViewError
    );
  }
}