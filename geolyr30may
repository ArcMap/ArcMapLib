private _isOpeningPopup = false; // ensure this field exists at top of class

private setupPopupCloseWatcher(): void {
  try { this._popupVisibleWatchHandle?.remove?.(); } catch { }
  this._popupVisibleWatchHandle = null;

  // Do NOT watch popup.visible — it fires during ArcGIS
  // internal open/close cycles and interferes with our state.
  // Instead watch view.stationary to release stuck state.
  try {
    this._popupVisibleWatchHandle = reactiveUtils.watch(
      () => this.view?.stationary,
      (stationary: boolean) => {
        console.log(
          "[arc-geojson-layer] view.stationary changed:", stationary
        );
        if (stationary) {
          // Map stopped moving — release any stuck opening guard
          if (this._isOpeningPopup) {
            console.log(
              "[arc-geojson-layer] stationary: releasing stuck _isOpeningPopup"
            );
            this._isOpeningPopup = false;
          }
        }
      }
    );
  } catch (err) {
    console.warn(
      "[arc-geojson-layer] setupPopupCloseWatcher failed:", err
    );
  }
}

private showGraphicPopup(
  graphic: Graphic,
  mapPoint: Point,
  graphics: Graphic[]
): void {
  console.log("[arc-geojson-layer] showGraphicPopup called", {
    graphicsCount: graphics.length,
    hasInfoTemplate: !!this.infoTemplate,
    editorOpen: this._editorOpen,
    inDrawingMode: this.inDrawingMode,
    isOpeningPopup: this._isOpeningPopup,
    stationary: this.view?.stationary,
  });

  if (this._editorOpen) {
    console.warn("[arc-geojson-layer] showGraphicPopup: editor open, skipping");
    return;
  }
  if (this.inDrawingMode || this._isStartingDraw) {
    console.warn("[arc-geojson-layer] showGraphicPopup: drawing, skipping");
    return;
  }
  if (this.shouldSuppressPopup()) {
    console.warn("[arc-geojson-layer] showGraphicPopup: suppressed, skipping");
    return;
  }
  if (!this.infoTemplate) {
    console.warn("[arc-geojson-layer] showGraphicPopup: no infoTemplate, skipping");
    return;
  }

  // Always release any previous stuck guard before opening
  this._isOpeningPopup = false;

  const popupGraphics = graphics.filter(
    (g) => g?.geometry && g?.layer === this.featureLayer
  );

  console.log(
    "[arc-geojson-layer] showGraphicPopup: popupGraphics:", popupGraphics.length
  );

  if (popupGraphics.length === 0) {
    console.warn("[arc-geojson-layer] showGraphicPopup: no valid graphics");
    return;
  }

  // Build templates
  let builtAny = false;
  popupGraphics.forEach((g, i) => {
    const tpl = this.buildPopupTemplate(g);
    console.log(
      `[arc-geojson-layer] showGraphicPopup: template[${i}]:`, !!tpl
    );
    if (tpl) {
      g.popupTemplate = tpl;
      builtAny = true;
    }
  });

  if (!builtAny) {
    console.warn("[arc-geojson-layer] showGraphicPopup: no templates built");
    return;
  }

  const location =
    mapPoint ??
    ArcGeojsonLayer.getPopupPoint(graphic.geometry) ??
    undefined;

  const openPopup = () => {
    try {
      const popup = this.view?.popup;
      if (!popup) {
        console.error("[arc-geojson-layer] showGraphicPopup: no popup");
        return;
      }

      // Kill ArcGIS auto behavior
      popup.autoOpenEnabled = false;
      popup.highlightEnabled = false;
      try { popup.actions?.removeAll?.(); } catch { }

      // Set guard
      this._isOpeningPopup = true;
      this._popupOpen = true;

      // Set features and location
      popup.features = popupGraphics;
      popup.location = location;

      // Open using correct API
      if (typeof (this.view as any).openPopup === "function") {
        console.log(
          "[arc-geojson-layer] showGraphicPopup: using view.openPopup()"
        );
        (this.view as any).openPopup({
          features: popupGraphics,
          location,
          updateLocationEnabled: false,
        });
      } else {
        console.log(
          "[arc-geojson-layer] showGraphicPopup: using popup.open = true"
        );
        (popup as any).open = true;
        popup.visible = true;
      }

      // Remove zoom action
      setTimeout(() => {
        try { popup.actions?.removeAll?.(); } catch { }
      }, 50);

      // Release guard after ArcGIS settles
      // Use longer timeout to cover Angular change detection cycle
      setTimeout(() => {
        this._isOpeningPopup = false;
        console.log(
          "[arc-geojson-layer] showGraphicPopup: _isOpeningPopup released"
        );
      }, 800);

      console.log(
        "[arc-geojson-layer] showGraphicPopup: popup opened"
      );

    } catch (err) {
      console.error(
        "[arc-geojson-layer] showGraphicPopup open failed:", err
      );
      this._popupOpen = false;
      this._isOpeningPopup = false;
    }
  };

  // If map is not stationary wait for it to stop
  // before opening popup — prevents ArcGIS from
  // immediately closing it due to map movement
  if (!this.view.stationary) {
    console.log(
      "[arc-geojson-layer] showGraphicPopup: map not stationary, waiting..."
    );
    reactiveUtils.whenOnce(
      () => this.view?.stationary === true
    ).then(() => {
      console.log(
        "[arc-geojson-layer] showGraphicPopup: map now stationary, opening popup"
      );
      openPopup();
    }).catch(() => {
      openPopup();
    });
  } else {
    openPopup();
  }
}

public closePopup(): void {
  console.log("[arc-geojson-layer] closePopup called", {
    popupOpen: this._popupOpen,
    isOpeningPopup: this._isOpeningPopup,
  });

  // Never close if we are currently opening
  if (this._isOpeningPopup) {
    console.warn(
      "[arc-geojson-layer] closePopup: skipped — currently opening"
    );
    return;
  }

  this._popupOpen = false;

  try {
    const popup: any = this.view?.popup;
    if (popup) {
      try {
        if (typeof popup.close === "function") {
          popup.close();
          console.log("[arc-geojson-layer] closePopup: called popup.close()");
        } else {
          popup.open = false;
          console.log("[arc-geojson-layer] closePopup: set popup.open = false");
        }
      } catch { }
      try { popup.visible = false; } catch { }
      try { popup.features = []; } catch { }
    }
  } catch { }

  try { this._popupHighlightHandle?.remove?.(); } catch { }
  this._popupHighlightHandle = null;

  console.log("[arc-geojson-layer] closePopup: done");
}











const clickHandle = this.view.on("click", async (evt: any) => {
  if (this.isPopupDomTarget(evt?.native?.target)) {
    console.log("[arc-geojson-layer] click: popup DOM, ignoring");
    return;
  }

  if (this.inDrawingMode || this._isStartingDraw) {
    console.log("[arc-geojson-layer] click: drawing mode, ignoring");
    return;
  }

  // Always release stuck guard on any click
  // so map never stays stuck
  if (this._isOpeningPopup) {
    console.log(
      "[arc-geojson-layer] click: releasing stuck _isOpeningPopup"
    );
    this._isOpeningPopup = false;
  }

  try {
    const hit = await this.view.hitTest(evt);
    const allResults = hit?.results ?? [];

    console.log(
      "[arc-geojson-layer] click: hitTest results:", allResults.length
    );

    const thisLayerResults = allResults.filter(
      (r: any) =>
        r?.graphic?.geometry &&
        r?.graphic?.layer === this.featureLayer
    );

    console.log(
      "[arc-geojson-layer] click: thisLayerResults:", thisLayerResults.length
    );

    if (thisLayerResults.length === 0) {
      if (this._popupOpen) {
        console.log("[arc-geojson-layer] click: empty space, closing popup");
        this.closePopup();
      }
      return;
    }

    // Check if another layer is visually on top
    const topmostGraphic = allResults[0]?.graphic;
    if (
      topmostGraphic &&
      topmostGraphic.layer !== this.featureLayer
    ) {
      try {
        const topmostIndex = this.view.map.layers.indexOf(
          topmostGraphic.layer
        );
        const thisIndex = this.view.map.layers.indexOf(
          this.featureLayer
        );
        console.log(
          "[arc-geojson-layer] click: layer order — topmost:", topmostIndex,
          "this:", thisIndex
        );
        if (topmostIndex > thisIndex) {
          console.log(
            "[arc-geojson-layer] click: another layer on top, skipping"
          );
          return;
        }
      } catch { }
    }

    const thisLayerGraphics = thisLayerResults.map(
      (r: any) => r.graphic as Graphic
    );
    const topGraphic = thisLayerGraphics[0];

    console.log(
      "[arc-geojson-layer] click: topGraphic:", topGraphic?.attributes
    );

    this.emitLayerEvent(
      "layerClick",
      this.graphicToGeoJsonFeature(topGraphic),
      topGraphic,
      {
        event: {
          coordinates: {
            latitude: evt.mapPoint?.latitude ?? 0,
            longitude: evt.mapPoint?.longitude ?? 0,
          },
          attributes: topGraphic.attributes ?? {},
        },
      }
    );

    if (
      !this._editorOpen &&
      !this.inDrawingMode &&
      !this._isStartingDraw &&
      !this.shouldSuppressPopup()
    ) {
      this.showGraphicPopup(
        topGraphic,
        evt.mapPoint,
        thisLayerGraphics
      );
    }

    if (
      this.enableUserEdit &&
      !this._editorOpen &&
      !this.inDrawingMode
    ) {
      if (evt.native?.ctrlKey && this.enableUserEditRemove) {
        this.removeFromGeoJSON(topGraphic);
        this.graphicsEditor?.cancel();
        return;
      }
      await this.activateGraphicsEditor(topGraphic);
    }

  } catch (err) {
    console.error("[arc-geojson-layer] click handler failed:", err);
    // Always release guard on error
    this._isOpeningPopup = false;
  }
});

