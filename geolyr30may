private _isOpeningPopup = false; // Add this field at top of class

private setupPopupCloseWatcher(): void {
  try { this._popupVisibleWatchHandle?.remove?.(); } catch { }
  this._popupVisibleWatchHandle = null;

  const popup: any = this.view?.popup;
  if (!popup) return;

  try {
    this._popupVisibleWatchHandle = reactiveUtils.watch(
      () => this.view?.popup?.visible,
      (visible: boolean) => {
        console.log(
          "[arc-geojson-layer] popup visible changed:", visible,
          "isOpeningPopup:", this._isOpeningPopup
        );

        // If WE are currently opening the popup, ignore
        // the false->true->false flicker ArcGIS fires
        if (this._isOpeningPopup) {
          console.log(
            "[arc-geojson-layer] popup watcher: ignored during open sequence"
          );
          return;
        }

        if (!visible) {
          // Small delay to avoid reacting to ArcGIS
          // internal open/close flicker
          setTimeout(() => {
            // Re-check — if popup became visible again
            // in the meantime, do not reset
            const stillHidden = !this.view?.popup?.visible;
            console.log(
              "[arc-geojson-layer] popup watcher: stillHidden after delay:", stillHidden
            );
            if (stillHidden && !this._isOpeningPopup) {
              this._popupOpen = false;
              this.setViewCursor("default");
              console.log(
                "[arc-geojson-layer] popup closed externally, reset state"
              );
            }
          }, 300);
        }
      }
    );
  } catch (err) {
    console.warn(
      "[arc-geojson-layer] setupPopupCloseWatcher failed:", err
    );
  }
}

private showGraphicPopup(
  graphic: Graphic,
  mapPoint: Point,
  graphics: Graphic[]
): void {
  console.log("[arc-geojson-layer] showGraphicPopup called", {
    graphic,
    mapPoint,
    graphicsCount: graphics.length,
    infoTemplate: this.infoTemplate,
    editorOpen: this._editorOpen,
    inDrawingMode: this.inDrawingMode,
    isOpeningPopup: this._isOpeningPopup,
  });

  if (this._editorOpen) {
    console.warn("[arc-geojson-layer] showGraphicPopup: editor open, skipping");
    return;
  }
  if (this.inDrawingMode) {
    console.warn("[arc-geojson-layer] showGraphicPopup: drawing mode, skipping");
    return;
  }
  if (this._isStartingDraw) {
    console.warn("[arc-geojson-layer] showGraphicPopup: isStartingDraw, skipping");
    return;
  }
  if (this.shouldSuppressPopup()) {
    console.warn("[arc-geojson-layer] showGraphicPopup: suppressed, skipping");
    return;
  }
  if (!this.infoTemplate) {
    console.warn("[arc-geojson-layer] showGraphicPopup: no infoTemplate, skipping");
    return;
  }

  const popupGraphics = graphics.filter(
    (g) => g?.geometry && g?.layer === this.featureLayer
  );

  console.log(
    "[arc-geojson-layer] showGraphicPopup: popupGraphics:", popupGraphics.length
  );

  if (popupGraphics.length === 0) {
    console.warn("[arc-geojson-layer] showGraphicPopup: no valid graphics");
    return;
  }

  let builtAny = false;
  popupGraphics.forEach((g, i) => {
    const tpl = this.buildPopupTemplate(g);
    console.log(
      `[arc-geojson-layer] showGraphicPopup: template[${i}]:`, tpl
    );
    if (tpl) {
      g.popupTemplate = tpl;
      builtAny = true;
    }
  });

  if (!builtAny) {
    console.warn("[arc-geojson-layer] showGraphicPopup: no templates built");
    return;
  }

  const location =
    mapPoint ??
    ArcGeojsonLayer.getPopupPoint(graphic.geometry) ??
    undefined;

  try {
    const popup = this.view?.popup;
    if (!popup) {
      console.error("[arc-geojson-layer] showGraphicPopup: no popup on view");
      return;
    }

    popup.autoOpenEnabled = false;
    popup.highlightEnabled = false;
    try { popup.actions?.removeAll?.(); } catch { }

    // Set flag BEFORE opening so watcher ignores flicker
    this._isOpeningPopup = true;
    this._popupOpen = true;

    popup.features = popupGraphics;
    popup.location = location;

    if (typeof (this.view as any).openPopup === "function") {
      console.log(
        "[arc-geojson-layer] showGraphicPopup: using view.openPopup()"
      );
      (this.view as any).openPopup({
        features: popupGraphics,
        location,
        updateLocationEnabled: false,
      });
    } else {
      console.log(
        "[arc-geojson-layer] showGraphicPopup: using popup.open = true"
      );
      (popup as any).open = true;
      popup.visible = true;
    }

    // Clear zoom action
    setTimeout(() => {
      try {
        popup.actions?.removeAll?.();
        console.log("[arc-geojson-layer] showGraphicPopup: actions cleared");
      } catch { }
    }, 50);

    // Release the opening guard after ArcGIS settles
    setTimeout(() => {
      this._isOpeningPopup = false;
      console.log(
        "[arc-geojson-layer] showGraphicPopup: _isOpeningPopup released"
      );
    }, 500);

    console.log(
      "[arc-geojson-layer] showGraphicPopup: popup opened successfully"
    );

  } catch (err) {
    console.error("[arc-geojson-layer] showGraphicPopup failed:", err);
    this._popupOpen = false;
    this._isOpeningPopup = false;
  }
}



public closePopup(): void {
  console.log("[arc-geojson-layer] closePopup called", {
    popupOpen: this._popupOpen,
    isOpeningPopup: this._isOpeningPopup,
  });

  // Do not close if we are in the middle of opening
  if (this._isOpeningPopup) {
    console.warn(
      "[arc-geojson-layer] closePopup: skipped — popup is currently opening"
    );
    return;
  }

  this._popupOpen = false;

  try {
    const popup: any = this.view?.popup;
    if (popup) {
      try {
        if (typeof popup.close === "function") {
          popup.close();
        } else {
          popup.open = false;
        }
      } catch { }
      try { popup.visible = false; } catch { }
      try { popup.features = []; } catch { }
    }
  } catch { }

  try { this._popupHighlightHandle?.remove?.(); } catch { }
  this._popupHighlightHandle = null;

  console.log("[arc-geojson-layer] closePopup: done");
}
