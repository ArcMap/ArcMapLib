applySelectedLayerIds(layerIds: number[]): void {
  const selectedMap = this.selectedMap();
  if (!selectedMap) return;

  const selectedLayerIds = new Set(layerIds);

  const updatedLayers = selectedMap.layers.map((layerConfig) =>
    selectedLayerIds.has(layerConfig.layerId)
      ? { ...layerConfig, visible: true }
      : layerConfig,
  );

  this.setSelectedMap({
    ...selectedMap,
    layers: updatedLayers,
  });
}
