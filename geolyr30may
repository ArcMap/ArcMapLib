<div class="rename-row">
  <calcite-input-text
      class="rename-input"
      [value]="renameMapName()"
      (calciteInputTextInput)="onRenameMapNameInput($event)">
  </calcite-input-text>

  <div class="rename-actions">
    <calcite-action
        class="rename-cancel"
        icon="x"
        (click)="cancelRenameInstance()">
    </calcite-action>

    <calcite-action
        class="rename-save"
        icon="check"
        (click)="confirmRenameInstance(map.id)">
    </calcite-action>
  </div>
</div>



.rename-row {
  display: flex;
  width: 100%;
  align-items: stretch;
}

.rename-input {
  flex: 1;
  min-width: 0;
}

.rename-actions {
  display: flex;
}

.rename-cancel,
.rename-save {
  width: 36px;
  min-width: 36px;
  height: 32px;

  display: flex;
  align-items: center;
  justify-content: center;

  border: 1px solid var(--calcite-input-text-border-color);
  border-left: none;
}

.rename-cancel {
  background: white;
  color: var(--calcite-color-text-2);
}

.rename-save {
  background: var(--calcite-color-brand);
  border-color: var(--calcite-color-brand);
  color: white;
}

.rename-save::part(icon) {
  color: white;
  fill: white;
}