private static sharedHitTests = new Map<string, Promise<any>>();
private static clickIds = new Map<string, number>();
private static latestClickId = 0;

private getClickSignature(evt: any): string {
  const nativeTime = evt?.native?.timeStamp ?? 0;
  const x = Math.round(evt?.x ?? evt?.screenPoint?.x ?? evt?.native?.offsetX ?? 0);
  const y = Math.round(evt?.y ?? evt?.screenPoint?.y ?? evt?.native?.offsetY ?? 0);

  return `${nativeTime}_${x}_${y}`;
}

private getClickId(evt: any): number {
  const signature = this.getClickSignature(evt);
  const existing = UpGeojsonLayer.clickIds.get(signature);

  if (existing) {
    return existing;
  }

  const clickId = ++UpGeojsonLayer.latestClickId;
  UpGeojsonLayer.clickIds.set(signature, clickId);

  setTimeout(() => {
    UpGeojsonLayer.clickIds.delete(signature);
  }, 5000);

  return clickId;
}

private isLatestClick(clickId: number): boolean {
  return clickId === UpGeojsonLayer.latestClickId;
}

private getSharedHitTest(evt: any): Promise<any> {
  const signature = this.getClickSignature(evt);
  const existing = UpGeojsonLayer.sharedHitTests.get(signature);

  if (existing) {
    return existing;
  }

  const start = performance.now();

  const hitTestPromise = this.view.hitTest(evt)
    .then((hit: any) => {
      const ms = Math.round(performance.now() - start);

      if (ms > 300) {
        console.warn("[popup-perf] shared hitTest slow", {
          ms,
          totalResults: hit?.results?.length ?? 0,
        });
      }

      return hit;
    })
    .finally(() => {
      UpGeojsonLayer.sharedHitTests.delete(signature);
    });

  UpGeojsonLayer.sharedHitTests.set(signature, hitTestPromise);

  return hitTestPromise;
}

private getGraphicPriority(graphic: Graphic): number {
  const type = graphic.geometry?.type;

  if (type === "point") return 3;
  if (type === "polyline") return 2;
  if (type === "polygon") return 1;

  return 0;
}

private getWinningGraphic(graphicResults: any[]): Graphic | undefined {
  const sortedResults = [...graphicResults].sort((a: any, b: any) => {
    const aPriority = this.getGraphicPriority(a.graphic);
    const bPriority = this.getGraphicPriority(b.graphic);

    return bPriority - aPriority;
  });

  return sortedResults[0]?.graphic as Graphic | undefined;
}