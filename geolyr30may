serializeDisplayedLayers(): string {
  const all = this.selectedMapLayers();
  const visible = this.visibleLayers();
  console.log('[serialize] selectedMapLayers =', all.map(l => ({id: l.id, visible: l.visible})));
  console.log('[serialize] visibleLayers =', visible.map(l => l.id));

  const displayedLayers = all.map((layer) => ({
    uniqueLayerId: layer.id,
    isChecked: layer.visible === true,
  }));
  return JSON.stringify({ displayedLayers });
}
