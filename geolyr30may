private async applyExtent(parsed: ParsedDeepLink): Promise<void> {
  if (!parsed.extent) return;

  const { xmin, ymin, xmax, ymax, wkid = 4326 } = parsed.extent;

  await this.mapFacade.setExtent({
    leftLongitude: xmin,
    bottomLatitude: ymin,
    rightLongitude: xmax,
    topLatitude: ymax,
    wkid
  });
}




if (parsed.extent) {
  await this.applyExtent(parsed);
} else {
  await this.applyLatLon(parsed);
}



async setExtent(extent: UpMapExtent): Promise<void> {
  const view = this.mapService.getView();

  if (!view) {
    console.error('MapView is not initialized');
    return;
  }

  await view.when();

  await view.goTo({
    xmin: extent.leftLongitude,
    ymin: extent.bottomLatitude,
    xmax: extent.rightLongitude,
    ymax: extent.topLatitude,
    spatialReference: {
      wkid: extent.wkid ?? 4326
    }
  }, {
    animate: false
  });
}