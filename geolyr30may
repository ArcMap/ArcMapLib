// arcgis-assets.ts
import esriConfig from "@arcgis/core/config.js";
import { setAssetPath } from "@arcgis/map-components";

let configured = false;

export function configureArcgisAssets(basePath = "assets/arcgis") {
  if (configured) return;
  esriConfig.assetsPath = `${basePath}/core`;
  setAssetPath(`${basePath}/map-components`);
  configured = true;
}
