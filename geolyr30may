<div class="rename-row">
  <calcite-input-text
    class="rename-input"
    [value]="renameMapName()"
    (calciteInputTextInput)="onRenameMapNameInput($event)">
  </calcite-input-text>

  <calcite-action
    class="rename-cancel"
    icon="x"
    (click)="cancelRenameInstance()">
  </calcite-action>

  <calcite-action
    class="rename-save"
    icon="check"
    (click)="confirmRenameInstance(map.id)">
  </calcite-action>
</div>


.rename-row {
  display: flex;
  width: 100%;
  align-items: stretch;
}

.rename-input {
  flex: 1;
}

.rename-cancel,
.rename-save {
  width: 36px;
  min-width: 36px;
  border: 1px solid var(--calcite-color-border-1);
  border-left: none;
  background: white;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.rename-save {
  background: var(--calcite-color-brand);
  color: white;
}

.rename-cancel {
  color: var(--calcite-color-text-2);
}