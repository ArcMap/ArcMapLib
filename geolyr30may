private async applyLatLon(
  parsed: ParsedDeepLink
): Promise<void> {
  if (
    parsed.lat === undefined ||
    parsed.lon === undefined
  ) {
    return;
  }

  await this.mapFacade.goToLatLon(
    parsed.lat,
    parsed.lon,
    parsed.zoom
  );

  if (parsed.label) {
    console.log(
      '[DeepLinkFacade.applyLatLon] Label:',
      parsed.label
    );
  }
}