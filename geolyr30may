loadSavedMap(id: string): void {
  const savedMap = this.savedMaps().find((map) => String(map.id) === String(id));
  if (savedMap?.rawMapLayerInfo) {
    this.currentSavedMapId.set(id);
    this.mapFacade.applySavedMap(savedMap.rawMapLayerInfo);

    // Reflect the saved map as the selected item → label shows its name
    const mapItem = this.toMapSelectionItem(savedMap);   // SavedMapFacade's own method (SavedMap input)
    this.layersFacade.setSelectedMapItem(mapItem);        // LayersFacade public method
    return;
  }
