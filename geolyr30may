import esriConfig from "@arcgis/core/config";
import { setAssetPath as setMapAssetPath } from "@arcgis/map-components";

let initializedPromise: Promise<void> | null = null;

export function configureArcgisAssets(): Promise<void> {
  if (initializedPromise) {
    return initializedPromise;
  }

  initializedPromise = initialize();
  return initializedPromise;
}

async function initialize(): Promise<void> {
  esriConfig.assetsPath = "assets";
  setMapAssetPath("assets");

  await Promise.all([
    addStylesheetOnce(
      "upmap-arcgis-core-css",
      "https://js.arcgis.com/5.0.19/esri/themes/light/main.css"
    ),
    addStylesheetOnce(
      "upmap-map-components-css",
      "https://js.arcgis.com/5.0.19/map-components/main.css"
    )
  ]);
}

function addStylesheetOnce(id: string, href: string): Promise<void> {
  return new Promise((resolve, reject) => {
    if (typeof document === "undefined") {
      resolve();
      return;
    }

    if (document.getElementById(id)) {
      resolve();
      return;
    }

    const link = document.createElement("link");
    link.id = id;
    link.rel = "stylesheet";
    link.href = href;
    link.onload = () => resolve();
    link.onerror = () => reject(new Error(`Failed to load stylesheet: ${href}`));

    document.head.appendChild(link);
  });
}