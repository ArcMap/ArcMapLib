private async buildGeoJsonLayer(): Promise<void> {
  const arcMapElement = this.closest('arc-map') as any;
  const loaderManager = arcMapElement?.getLoaderManager?.();

  if (!loaderManager) {
    await this.createGeoJsonLayer();
    return;
  }

  await loaderManager.run(async () => {
    await this.createGeoJsonLayer();

    if (this.view && this.featureLayer) {
      await this.view.whenLayerView(this.featureLayer);
    }
  });
}




private async buildEsriLayer(): Promise<void> {
  const arcMapElement = this.closest('arc-map') as any;
  const loaderManager = arcMapElement?.getLoaderManager?.();

  if (!loaderManager) {
    await this.createEsriLayer();
    return;
  }

  await loaderManager.run(async () => {
    await this.createEsriLayer();

    if (this.view && this.esriLayer) {
      await this.view.whenLayerView(this.esriLayer);
    }
  });
}