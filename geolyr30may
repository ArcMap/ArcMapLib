<div class="rename-container">

  <calcite-input-text
    class="rename-input"
    [value]="renameMapName()"
    (calciteInputTextInput)="onRenameMapNameInput($event)">
  </calcite-input-text>

  <div class="rename-actions">
    <calcite-button
      appearance="outline"
      scale="s"
      (click)="cancelRenameInstance()">
      Cancel
    </calcite-button>

    <calcite-button
      appearance="solid"
      scale="s"
      (click)="confirmRenameInstance(map.id)">
      Save
    </calcite-button>
  </div>

</div>