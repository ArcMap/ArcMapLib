private async activateGraphicsEditor(graphic: Graphic): Promise<void> {
  if (!this.isUserEditEnabled() || !graphic?.geometry) {
    return;
  }

  // Close popup first
  this.closePopup();
  this._suppressPopupUntil = Date.now() + 2000;

  // Ensure editor exists
  if (!this.graphicsEditor) {
    await this.createEditor();
  }

  if (!this.graphicsEditor) {
    console.error("[arc-geojson-layer] activateGraphicsEditor: no graphicsEditor");
    return;
  }

  // If SVM is busy, cancel first
  try {
    const state = (this.graphicsEditor as any).state;
    if (state === "active") {
      this.graphicsEditor.cancel();
      await new Promise((r) => setTimeout(r, 100));
    }
  } catch { }

  this._editorOpen = true;
  this.inDrawingMode = false;
  this._isStartingDraw = false;
  this.enableInfoPopupWindow(false);

  // Find the actual graphic in featureLayer by ID
  const id =
    graphic.attributes?.OBJECTID ??
    graphic.attributes?._featureIndex ??
    graphic.attributes?.[this.uniqueIdPropertyName] ??
    0;

  const sourceGraphic = this.featureLayer?.graphics?.find((g: Graphic) => {
    const gid =
      g.attributes?.OBJECTID ??
      g.attributes?._featureIndex ??
      0;
    return String(gid) === String(id);
  }) ?? graphic;

  // Remove from featureLayer
  try {
    this.featureLayer?.graphics?.remove(sourceGraphic);
  } catch { }

  // Clone to sketchLayer
  const editGraphic = sourceGraphic.clone();

  // Ensure correct attributes
  if (!editGraphic.attributes) editGraphic.attributes = {};
  const isCircle = this.isCircleGraphic(editGraphic);

  if (isCircle) {
    editGraphic.attributes.isCircle = true;
    editGraphic.attributes.drawGeometryType = "circle";
    editGraphic.attributes.shapeType = "circle";
    editGraphic.attributes.shape = "circle";
  }

  // Assign a valid symbol so SVM shows handles
  if (!editGraphic.symbol) {
    if (isCircle || editGraphic.geometry?.type === "polygon") {
      editGraphic.symbol = {
        type: "simple-fill",
        style: "solid",
        color: [0, 120, 255, 0.2],
        outline: {
          type: "simple-line",
          color: [0, 120, 255, 1],
          width: 2,
          style: "solid",
        },
      } as any;
    } else if (editGraphic.geometry?.type === "polyline") {
      editGraphic.symbol = {
        type: "simple-line",
        color: [0, 120, 255, 1],
        width: 3,
        style: "solid",
      } as any;
    } else {
      editGraphic.symbol = {
        type: "simple-marker",
        style: "circle",
        size: 18,
        color: [0, 120, 255, 1],
        outline: {
          type: "simple-line",
          color: [255, 255, 255, 1],
          width: 2,
        },
      } as any;
    }
  }

  editGraphic.popupTemplate = null as any;

  // Add to sketchLayer
  this.sketchLayer?.graphics?.removeAll();
  this.sketchLayer?.graphics?.add(editGraphic);

  // Pick the right tool
  const tool = isCircle ? "transform" : this.resolveUpdateTool(editGraphic);

  const updateOptions: any = isCircle
    ? {
        tool: "transform",
        enableRotation: false,
        enableScaling: true,
        preserveAspectRatio: true,
        multipleSelectionEnabled: false,
        toggleToolOnClick: false,
      }
    : {
        tool,
        enableRotation: this.enableUserEditRotating,
        enableScaling: this.enableUserEditScaling,
        preserveAspectRatio: this.enableUserEditUniformScaling,
        enableMoveAllGraphics: false,
        multipleSelectionEnabled: false,
        toggleToolOnClick: false,
      };

  try {
    await this.graphicsEditor.update([editGraphic], updateOptions);
    console.log("[arc-geojson-layer] activateGraphicsEditor: SVM update started", {
      tool,
      isCircle,
      geometry: editGraphic.geometry?.type,
    });
  } catch (err: any) {
    console.error("[arc-geojson-layer] activateGraphicsEditor: SVM update failed", err);
    // Rollback — put graphic back in featureLayer
    this.sketchLayer?.graphics?.remove(editGraphic);
    this.featureLayer?.graphics?.add(sourceGraphic);
    this._editorOpen = false;
    this.enableInfoPopupWindow(true);
  }
}



private bindEditorEvents(): void {
  this.editorHandles?.forEach((handle: any) => {
    try { handle?.remove?.(); } catch { }
  });
  this.editorHandles = [];

  if (!this.graphicsEditor) return;

  const createHandle = this.graphicsEditor.on("create", (event: any) => {
    if (event.state === "start" || event.state === "active") {
      this.inDrawingMode = true;
      this._isStartingDraw = true;
      this._editorOpen = false;
      this._suppressPopupUntil = Date.now() + 1500;
      this.enableInfoPopupWindow(false);
      return;
    }
    if (event.state === "complete") {
      const graphic = event.graphic as Graphic;
      if (!graphic?.geometry) {
        this.cancelDrawing();
        return;
      }
      graphic.attributes = {
        ...(graphic.attributes ?? {}),
        __isTemporaryDrawing: false,
      };
      this.handleCreateComplete(graphic);
      return;
    }
    if (event.state === "cancel") {
      this.cancelDrawing();
      return;
    }
  });

  const updateHandle = this.graphicsEditor.on("update", (event: any) => {
    if (event.state === "start") {
      this._editorOpen = true;
      this.inDrawingMode = false;
      this._isStartingDraw = false;
      this._suppressPopupUntil = Date.now() + 1500;
      this.enableInfoPopupWindow(false);
      console.log("[arc-geojson-layer] SVM update started");
      return;
    }

    if (event.state === "active") {
      // Live update GeoJSON as user drags
      const graphics = event.graphics ?? [];
      graphics.forEach((g: Graphic) => {
        if (!g?.geometry) return;
        this.updateGeoJsonWithChanges(g);
      });
      return;
    }

    if (event.state === "complete") {
      console.log("[arc-geojson-layer] SVM update complete");
      const graphics = event.graphics ?? [];

      graphics.forEach((g: Graphic) => {
        if (!g?.geometry) return;

        // Update GeoJSON
        this.updateGeoJsonWithChanges(g);

        // Move from sketchLayer back to featureLayer
        try {
          this.sketchLayer?.graphics?.remove(g);
        } catch { }

        // Apply final defaults and re-add to featureLayer
        const finalGraphic = g.clone();
        this.applyGraphicDefaults(finalGraphic);
        try {
          this.featureLayer?.graphics?.add(finalGraphic);
        } catch { }
      });

      this._editorOpen = false;
      this.enableInfoPopupWindow(true);
      this.refreshLabels();
    }
  });

  const deleteHandle = this.graphicsEditor.on("delete", (event: any) => {
    event.graphics?.forEach((graphic: Graphic) => {
      this.removeFromGeoJSON(graphic);
      try { this.sketchLayer?.graphics?.remove(graphic); } catch { }
    });
    this._editorOpen = false;
    this.enableInfoPopupWindow(true);
  });

  this.editorHandles.push(createHandle, updateHandle, deleteHandle);
}






// Inside the clickTimer setTimeout, after showGraphicPopup call:

if (
  this.enableUserEdit &&
  !this._editorOpen &&
  !this.inDrawingMode
) {
  if (evt.native?.ctrlKey && this.enableUserEditRemove) {
    this.removeFromGeoJSON(graphic);
    this.graphicsEditor?.cancel();
