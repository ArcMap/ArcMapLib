const validResults = allLayersResults.filter((r: any) => {
    const layer = r?.graphic?.layer;
    if (!r?.graphic?.geometry || !layer) return false;
    if (layer === this.sketchLayer) return false;
    if (layer === this.labelLayer) return false;
    // exclude internal ArcGIS overlay layers (popup handles, highlights etc.)
    return this.view?.map?.layers?.indexOf(layer) !== -1;
});

const thisLayerFirstIndex = validResults.findIndex(
    (r: any) => r?.graphic?.layer === this.featureLayer
);

const otherLayerFirstIndex = validResults.findIndex(
    (r: any) => r?.graphic?.layer !== this.featureLayer
);
