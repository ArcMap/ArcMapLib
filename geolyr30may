let zoomComponentPromise: Promise<void> | null = null;

export function loadZoomComponent(): Promise<void> {
  if (zoomComponentPromise) {
    return zoomComponentPromise;
  }

  zoomComponentPromise = initialize()
    .then(() => import('@arcgis/map-components/dist/components/arcgis-zoom'))
    .then(() => customElements.whenDefined('arcgis-zoom'))
    .then(() => undefined);

  return zoomComponentPromise;
}



public async showZoomSlider(): Promise<void> {
  await this.mapReady;

  await loadZoomComponent();

  console.log('arcgis-zoom registered:', customElements.get('arcgis-zoom'));

  this.showZoom = true;
  await this.updateComplete;
}