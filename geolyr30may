private applyLayers(parsed: ParsedDeepLink): void {
  if (!parsed.layers?.length) return;

  const requestedIds = new Set(
    parsed.layers.map((id) => Number(id)).filter((id) => !Number.isNaN(id)),
  );

  const matchedLayers = this.layerFacade
    .layers()
    .filter((layer) => requestedIds.has(layer.id));

  if (matchedLayers.length === 0) {
    console.warn('[DeepLinkFacade] no requested layer IDs matched the catalog — keeping default layers');
    return;
  }

  for (const layer of matchedLayers) {
    this.mapFacade.setLayerVisibility(layer.layerKey, true, layer.layerUrl);
  }

  this.navState.openPanel('maps-layers');
}
