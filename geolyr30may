it('should open Maps & Layers panel when layers query param exists', async () => {
    routerMock.url = '/?layers=someLayer';

    // ← ADD: make applyFromParams call openPanel for this test
    deepLinkFacadeSpy.applyFromParams.mockImplementation(async () => {
        navStateSpy.openPanel('maps-layers');
    });

    const fixture = TestBed.createComponent(AppShellComponent);
    fixture.detectChanges();
    await fixture.whenStable();
    fixture.detectChanges();

    expect(fixture.componentInstance.activeMode()).toBe('maps-layers');
});

