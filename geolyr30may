import {
  ChangeDetectionStrategy,
  Component,
  CUSTOM_ELEMENTS_SCHEMA,
  ElementRef,
  OnInit,
  ViewChild,
  signal,
} from '@angular/core';

type MeasureMode = 'distance' | 'area';

interface ArcMeasurementElement extends HTMLElement {
  reset?: () => void | Promise<void>;
  clear?: () => void | Promise<void>;
  startMeasurement?: (tool: MeasureMode) => void | Promise<void>;
}

@Component({
  selector: 'measure-panel',
  standalone: true,
  templateUrl: './measure-panel.component.html',
  styleUrls: ['./measure-panel.component.scss'],
  changeDetection: ChangeDetectionStrategy.OnPush,
  schemas: [CUSTOM_ELEMENTS_SCHEMA],
})
export class MeasurePanelComponent implements OnInit {
  readonly mode = signal<MeasureMode>('distance');

  /**
   * Determines whether the external Clear button is visible.
   */
  readonly hasDrawing = signal(false);

  @ViewChild('arcMeasurement', { read: ElementRef })
  private arcMeasurementRef?: ElementRef<ArcMeasurementElement>;

  ngOnInit(): void {
    // Keep your existing initialization here.
  }

  onModeChange(event: Event): void {
    const target = event.target as HTMLElement & {
      value?: string;
    };

    const value = target.getAttribute('value') ?? target.value;

    if (value !== 'distance' && value !== 'area') {
      return;
    }

    void this.changeMeasurementMode(value);
  }

  private async changeMeasurementMode(
    newMode: MeasureMode,
  ): Promise<void> {
    if (newMode === this.mode()) {
      return;
    }

    await this.resetMeasurement();

    this.mode.set(newMode);

    // Angular recreates arc-measurement because of the @if block.
    // Allow the new custom element to render.
    queueMicrotask(() => {
      const element = this.arcMeasurementRef?.nativeElement;

      if (typeof element?.startMeasurement === 'function') {
        void element.startMeasurement(newMode);
      }
    });
  }

  /**
   * Call when the user begins drawing on the map.
   */
  onMeasurementStart(): void {
    this.hasDrawing.set(true);
  }

  /**
   * Call when Arc Measurement reports a completed result.
   */
  onMeasurementComplete(): void {
    this.hasDrawing.set(true);
  }

  async onReset(): Promise<void> {
    await this.resetMeasurement();
  }

  private async resetMeasurement(): Promise<void> {
    const element = this.arcMeasurementRef?.nativeElement;

    if (!element) {
      console.warn('arc-measurement is not available.');
      this.hasDrawing.set(false);
      return;
    }

    try {
      if (typeof element.reset === 'function') {
        await element.reset();
      } else if (typeof element.clear === 'function') {
        await element.clear();
      } else {
        console.error(
          'arc-measurement does not expose reset() or clear().',
          element,
        );

        return;
      }

      this.hasDrawing.set(false);
    } catch (error) {
      console.error('Failed to clear Arc Measurement.', error);
    }
  }
}