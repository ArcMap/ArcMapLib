const clickHandle = this.view.on("click", async (evt: any) => {
  const popupStart = performance.now();

  console.log("[popup-click] entered", {
    layer: this.featureLayer?.title,
    sketchLayer: this.sketchLayer?.title,
    inDrawingMode: this.inDrawingMode,
    isStartingDraw: this.__isStartingDraw,
    editorOpen: this._editorOpen,
  });

  if (this.isPopupDomTarget(evt?.native?.target)) {
    console.log("[popup-click] ignored popup dom click", {
      layer: this.featureLayer?.title,
    });
    return;
  }

  if (this.inDrawingMode || this.__isStartingDraw) {
    console.log("[popup-click] ignored drawing mode", {
      layer: this.featureLayer?.title,
    });
    return;
  }

  this.__isOpeningPopup = false;

  try {
    const hitDecision = await this.getPrioritizedSharedHitTest(evt);

    const winningGraphic = hitDecision?.winningGraphic as Graphic | undefined;
    const graphicResults = hitDecision?.graphicResults ?? [];

    console.log("[popup-click] hit decision", {
      currentLayer: this.featureLayer?.title,
      winningLayer: winningGraphic?.layer?.title,
      winningGeometry: winningGraphic?.geometry?.type,
      resultCount: graphicResults.length,
    });

    if (!winningGraphic) {
      console.log("[popup-click] no winning graphic", {
        currentLayer: this.featureLayer?.title,
      });
      return;
    }

    const isThisLayerWinner =
      winningGraphic.layer === this.featureLayer ||
      winningGraphic.layer === this.sketchLayer;

    if (!isThisLayerWinner) {
      console.log("[popup-click] losing layer ignored", {
        currentLayer: this.featureLayer?.title,
        winningLayer: winningGraphic.layer?.title,
      });
      return;
    }

    const thisLayerGraphics = graphicResults
      .filter((result: any) => {
        return (
          result?.graphic?.layer === this.featureLayer ||
          result?.graphic?.layer === this.sketchLayer
        );
      })
      .map((result: any) => result.graphic as Graphic);

    console.log("[popup-click] winner layer will open popup", {
      currentLayer: this.featureLayer?.title,
      graphicsCount: thisLayerGraphics.length,
    });

    this.emitLayerEvent(
      "layerClick",
      this.graphicToGeoJsonFeature(winningGraphic),
      winningGraphic,
      {
        event: {
          coordinates: {
            latitude: evt.mapPoint?.latitude ?? 0,
            longitude: evt.mapPoint?.longitude ?? 0,
          },
          attributes: winningGraphic.attributes ?? {},
        },
      }
    );

    if (this.isUserEditEnabled()) {
      this.closePopup();

      if (evt.native?.ctrlKey || evt.native?.metaKey || evt.native?.altKey) {
        this.removeFromGeoJSON(winningGraphic);
        this.graphicsEditor?.cancel();
        return;
      }

      await this.activateGraphicsEditor(winningGraphic, "transform");
      return;
    }

    if (
      !this._editorOpen &&
      !this.inDrawingMode &&
      !this.__isStartingDraw &&
      !this.shouldSuppressPopup()
    ) {
      this.showGraphicPopup(
        winningGraphic,
        evt.mapPoint,
        thisLayerGraphics.length ? thisLayerGraphics : [winningGraphic]
      );

      requestAnimationFrame(() => {
        console.log("[popup-perf] popup requested", {
          currentLayer: this.featureLayer?.title,
          totalMs: Math.round(performance.now() - popupStart),
          popupLayer: winningGraphic.layer?.title,
          geometryType: winningGraphic.geometry?.type,
        });
      });
    }
  } catch (err) {
    console.error("[popup-click] failed", {
      currentLayer: this.featureLayer?.title,
      error: err,
    });

    this.__isOpeningPopup = false;
  }
});

this.eventHandles.push(clickHandle);