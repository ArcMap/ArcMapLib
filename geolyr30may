private syncZoomFromMapFacade(zoom: number, onSettled?: () => void): void {
  console.log('syncZoomFromMapFacade', zoom);
  if (this.upMapInstance.zoom === zoom) {
    onSettled?.();
    return;
  }
  const view = (this.upMapInstance as unknown as ZoomableMapViewHost).view;
  if (view && typeof view.goTo === 'function') {
    view.goTo({ zoom }, { animate: true, duration: 200 })
      .catch(() => {})
      .finally(() => onSettled?.());
  } else {
    onSettled?.();
  }
  this.upMapInstance.zoom = zoom;
}




setTimeout(() => {
  this.ignoreExtentChange = false;

  if (deepLinkZoom !== null) {
    this.syncZoomFromMapFacade(deepLinkZoom, () => {
      this.ignoreZoomChange = false;   // only unblock once OUR animation is done
    });
  } else {
    this.ignoreZoomChange = false;
  }
}, 500);
