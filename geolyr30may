applySelectedLayerIds(layerIds: number[], isDefaultView = false): void {
  const selectedMap = this.selectedMap();
  if (!selectedMap) return;

  const selectedLayerIds = new Set(layerIds);

  if (isDefaultView) {
    // Default view — keep ONLY the saved layers (your existing logic, unchanged).
    const matchedLayerIds = this.layers()
      .filter((layer) => layer.id !== null && selectedLayerIds.has(layer.id))
      .sort((left, right) => left.drawOrderId - right.drawOrderId)
      .map((layer) => layer.id as number);
    const orderedLayerIds = matchedLayerIds.length > 0 ? matchedLayerIds : layerIds;

    this.setSelectedMap({
      ...selectedMap,
      layers: orderedLayerIds.map((layerId, index) => ({ layerId, visible: true, order: index })),
    });
    return;
  }

  // Other maps — keep the FULL catalog (disabled layers included), just toggle visibility.
  const ordered = this.layers()
    .filter((layer) => layer.id !== null)
    .sort((left, right) => left.drawOrderId - right.drawOrderId);

  this.setSelectedMap({
    ...selectedMap,
    layers: ordered.map((layer, index) => ({
      layerId: layer.id as number,
      visible: selectedLayerIds.has(layer.id as number),
      order: index,
    })),
  });
}
