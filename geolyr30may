// src/arcgis-assets.ts

let initializedPromise: Promise<void> | null = null;

export function configureArcgisAssets(): Promise<void> {
  if (initializedPromise) {
    return initializedPromise;
  }

  initializedPromise = initialize();
  return initializedPromise;
}

async function initialize(): Promise<void> {
  await Promise.all([
    addStyleSheetOnce(
      "arcgis-css",
      "https://js.arcgis.com/5.0/esri/themes/light/main.css"
    ),

    addScriptOnce(
      "arcgis-js",
      "https://js.arcgis.com/5.0/"
    )
  ]);
}

function addStyleSheetOnce(id: string, href: string): Promise<void> {
  return new Promise((resolve) => {
    if (document.getElementById(id)) {
      resolve();
      return;
    }

    const link = document.createElement("link");
    link.id = id;
    link.rel = "stylesheet";
    link.href = href;
    link.onload = () => resolve();

    document.head.appendChild(link);
  });
}

function addScriptOnce(id: string, src: string): Promise<void> {
  return new Promise((resolve) => {
    if (document.getElementById(id)) {
      resolve();
      return;
    }

    const script = document.createElement("script");
    script.id = id;
    script.src = src;
    script.async = true;
    script.onload = () => resolve();

    document.head.appendChild(script);
  });
}