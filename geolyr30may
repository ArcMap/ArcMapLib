private updateEllipsisTooltips(): void {
  requestAnimationFrame(() => {
    const textElements = document.querySelectorAll(
      '.autocomplete-ellipsis-text'
    );

    textElements.forEach((element) => {
      const textElement = element as HTMLElement;

      const tooltipElement =
        textElement.parentElement?.querySelector(
          '.autocomplete-name-tooltip'
        ) as HTMLElement | null;

      if (!tooltipElement) {
        return;
      }

      const hasEllipsis =
        textElement.scrollWidth > textElement.clientWidth;

      if (hasEllipsis) {
        tooltipElement.removeAttribute('hidden');
      } else {
        tooltipElement.setAttribute('hidden', '');
      }
    });
  });
}



<span
  class="autocomplete-text-wrapper"
  style="${this.getAutocompleteTextWrapperStyle()}"
>
  <span
    class="autocomplete-ellipsis-text"
    data-tooltip-text="${displayText}"
    style="${this.getAutocompleteTextStyle()}"
  >
    ${displayText}
  </span>

  <up-tooltip
    class="autocomplete-name-tooltip"
    popover="manual"
    placement="top"
    show-arrow
    hidden
  >
    ${displayText}
  </up-tooltip>
</span>