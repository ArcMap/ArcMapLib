private syncExtentFromMapFacade(
  extent: UpMapExtent | null
): void {
  const currentExtent =
    typeof this.upMapInstance.extent === 'string'
      ? null
      : this.upMapInstance.extent;

  if (this.extentsEqual(currentExtent, extent)) {
    return;
  }

  if (extent !== null && !this.isValidExtent(extent)) {
    console.warn(
      '[MapViewComponent] Skipping invalid extent:',
      extent
    );
    return;
  }

  this.upMapInstance.extent = extent;
}