public addLayerByElement(newLayer: any, element: Element): void {
  if (!this.map || !newLayer) {
    return;
  }

  this.map.add(newLayer);

  queueMicrotask(() => {
    this.applyDomLayerOrder();
  });
}

private applyDomLayerOrder(): void {
  if (!this.map?.layers) {
    return;
  }

  const layerElements = Array.from(
    this.querySelectorAll(
      "up-esri-feature-layer, up-geojson-layer, up-image-service-layer, up-tiled-map-service-layer, up-wms-layer"
    )
  ) as HTMLElement[];

  layerElements.forEach((element: any, domIndex: number) => {
    const layerId =
      element.featureLayer?.id ??
      element.layer?.id ??
      element.graphicsLayer?.id ??
      element.mapLayer?.id;

    if (!layerId) {
      return;
    }

    const layer = this.map.layers.find((item: any) => item.id === layerId);

    if (!layer) {
      return;
    }

    // HTML top = map bottom, HTML bottom = map top
    this.map.reorder(layer, domIndex);
  });

  console.log(
    "[arc-map] final layer order",
    this.map.layers.toArray().map((layer: any, index: number) => ({
      index,
      id: layer.id,
      type: layer.type,
      title: layer.title,
    }))
  );
}