private isPopupDomTarget(target: EventTarget | null | undefined): boolean {
  const element = target as HTMLElement | null;

  if (!element) {
    return false;
  }

  return !!element.closest(
    ".esri-popup__button, .esri-popup__action, .esri-popup__header-buttons, .esri-popup__footer"
  );
}



