ngAfterViewInit(): void {
  setTimeout(async () => {
    const el = this.upMeasurement.nativeElement as any;

    await customElements.whenDefined('up-measurement');
    await el.updateComplete;

    const root = el.shadowRoot;
    const distExpand = root?.querySelector('#dist-expand') as any;
    const areaExpand = root?.querySelector('#area-expand') as any;

    if (areaExpand) {
      areaExpand.expanded = false;
    }

    if (distExpand) {
      distExpand.expanded = true;
    }
  }, 800);
}