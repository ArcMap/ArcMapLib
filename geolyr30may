setTimeout(() => {
  const upMapElement =
    this.upMapElement().nativeElement as HTMLElement;

  const searchRoot =
    upMapElement.shadowRoot ?? upMapElement;

  const elements =
    searchRoot.querySelectorAll<HTMLElement>('*');

  console.log(
    '[MapViewComponent.initializeMap] Search root:',
    searchRoot,
  );

  console.log(
    '[MapViewComponent.initializeMap] Elements found:',
    elements.length,
  );

  elements.forEach((element) => {
    const tagName = element.tagName.toLowerCase();

    if (!tagName.startsWith('up-')) {
      return;
    }

    console.log(
      '[MapViewComponent.initializeMap] Dispatching to:',
      tagName,
      element,
    );

    element.dispatchEvent(
      new CustomEvent('upMapDeferredReady', {
        detail: {
          map: mapView.map,
          view: mapView,
        },
        bubbles: false,
        composed: true,
      }),
    );
  });
}, 0);