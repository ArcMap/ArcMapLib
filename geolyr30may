private async activatePanelDefaultTool(): Promise<void> {
    const distEl = this.shadowRoot?.querySelector(
        "arcgis-distance-measurement-2d"
    ) as any;

    if (!distEl) {
        return;
    }

    await distEl.componentOnReady?.();

    setTimeout(() => {
        distEl.clear?.();
        distEl.start?.();
    }, 300);
}



.measurement-panel-mode {
    position: absolute;
    left: 20px;
    top: 100px;
    width: 230px;
    z-index: 1000;
    background: white;
}

arcgis-distance-measurement-2d {
    display: block;
    width: 230px;
    min-height: 140px;
}