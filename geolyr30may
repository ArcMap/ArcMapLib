// ✅ Legacy way — uses arc-map's addLayer which preserves DOM order
const arcMap = this.closest('arc-map') as any;
if (arcMap?.addLayer) {
  await arcMap.addLayer(this.featureLayer, this);
  await arcMap.addLayer(this.labelLayer, this);
  await arcMap.addLayer(this.sketchLayer, this);
} else {
  // Fallback
  map.add(this.featureLayer, map.layers.length);
  map.add(this.labelLayer, map.layers.length);
  map.add(this.sketchLayer, map.layers.length);
}
