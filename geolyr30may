private async resolveAndAttach(): Promise<void> {
  const mapElement = this.resolveMapElement();

  if (!mapElement) {
    console.warn('<layer-list> could not find related <map>');
    return;
  }

  const loaderManager = (mapElement as any)?.getLoaderManager?.();

  const attachLayerList = async (): Promise<void> => {
    if (typeof (mapElement as any).componentOnReady === 'function') {
      await (mapElement as any).componentOnReady();
    }

    const view = await (mapElement as any).getViewInstance();

    if (!view) {
      console.warn('<layer-list> could not resolve MapView from <up-map>');
      return;
    }

    await view.when();

    this.attachToMapView(view);
  };

  if (!loaderManager) {
    await attachLayerList();
    return;
  }

  await loaderManager.run(async () => {
    await attachLayerList();
  });
}