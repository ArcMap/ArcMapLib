.rename-cancel {
  width: 36px;
  min-width: 36px;
  height: 32px;
  padding: 0;
  border: none;
  box-sizing: border-box;
  flex: 0 0 36px;
}

.rename-cancel::part(button) {
  width: 100%;
  height: 100%;
  min-height: 32px;
  padding: 0;
  box-sizing: border-box;
  border: 1px solid var(--calcite-color-border-1);
  border-radius: 0;
}