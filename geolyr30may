private initializeDeferredChildren(): void {
  requestAnimationFrame(() => {
    Array.from(this.children).forEach((child: Element, index: number) => {
      child.dispatchEvent(
        new CustomEvent("upMapDeferredReady", {
          detail: {
            map: this.map,
            view: this.view,
            layerIndex: index
          },
          bubbles: false,
          composed: true
        })
      );
    });
  });
}




const layerIndex = event.detail?.layerIndex ?? undefined;

if (layerIndex !== undefined) {
  this.view.map.add(this.featureLayer, layerIndex);
} else {
  this.view.map.add(this.featureLayer);
}