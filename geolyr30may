private finishActiveEditor(): void {
  if (!this._editorOpen) return;

  try {
    this.graphicsEditor?.complete();
  } catch { }

  // Move any remaining sketch graphics back to featureLayer
  try {
    const sketchGraphics = this.sketchLayer?.graphics?.toArray() ?? [];
    sketchGraphics.forEach((g: Graphic) => {
      this.sketchLayer?.graphics?.remove(g);
      const finalGraphic = g.clone();
      this.applyGraphicDefaults(finalGraphic);
      this.featureLayer?.graphics?.add(finalGraphic);
    });
  } catch { }

  this._editorOpen = false;
  this.enableInfoPopupWindow(true);
  this.setViewCursor("default");
}





public cancelDrawing(): void {
  try { this.graphicsEditor?.cancel(); } catch { }

  // Move any sketch graphics back to featureLayer
  try {
    const sketchGraphics = this.sketchLayer?.graphics?.toArray() ?? [];
    sketchGraphics.forEach((g: Graphic) => {
      if (g.attributes?.__isTemporaryDrawing) {
        // Discard temporary drawings
        this.sketchLayer?.graphics?.remove(g);
      } else {
        // Keep non-temporary graphics — move back
        this.sketchLayer?.graphics?.remove(g);
        const finalGraphic = g.clone();
        this.applyGraphicDefaults(finalGraphic);
        this.featureLayer?.graphics?.add(finalGraphic);
      }
    });
  } catch { }

  this.inDrawingMode = false;
  this._isStartingDraw = false;
  this._editorOpen = false;
  this._currentDrawGeometryType = undefined;
  this._lastCreatedByDrawing = false;

  this.closePopup();

  this._activeVisibleType = null;
  this.filterGraphicsByActiveType(null);
  this.enableInfoPopupWindow(true);
  this.setViewCursor("default");
}

