it('applies map by ID and opens maps-layers panel', async () => {
    const mapDto: UserMapDto = {
        mapID: 'map-1',
        mapName: 'Test Map',
        userID: 'user',
        mapLayerInfo: '{"basemap":"streets"}',
    };

    parserSpy.parse.mockReturnValue({ map: 'map-1' });
    parserSpy.isEmpty.mockReturnValue(false);
    mapsApiSpy.readPredefinedMaps.mockReturnValue(of([])); // ← ADD THIS LINE
    mapsApiSpy.readUserMaps.mockReturnValue(of([mapDto]));
    mapsApiSpy.readBookmarks.mockReturnValue(of([]));

    await facade.applyFromParams(emptyParams);

    expect(mapFacadeSpy.applySavedMap).toHaveBeenCalledWith('{"basemap":"streets"}');
    expect(navStateSpy.openPanel).toHaveBeenCalledWith('maps-layers');
});
