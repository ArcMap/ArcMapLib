async function initialize(): Promise<void> {
  const arcgisBaseUrl = "https://js.arcgis.com/5.0.19";

  await Promise.all([
    addPreconnectOnce("upmap-preconnect-js-arcgis", "https://js.arcgis.com"),
    addPreconnectOnce("upmap-preconnect-basemaps", "https://basemaps.arcgis.com"),
    addPreconnectOnce("upmap-preconnect-static-arcgis", "https://static.arcgis.com"),

    addStylesheetOnce(
      "upmap-arcgis-core-css",
      `${arcgisBaseUrl}/esri/themes/light/main.css`
    ),
    addStylesheetOnce(
      "upmap-map-components-css",
      `${arcgisBaseUrl}/map-components/main.css`
    )
  ]);
}


function addPreconnectOnce(id: string, href: string): Promise<void> {
  return new Promise((resolve) => {
    if (typeof document === "undefined" || document.getElementById(id)) {
      resolve();
      return;
    }

    const link = document.createElement("link");
    link.id = id;
    link.rel = "preconnect";
    link.href = href;
    link.crossOrigin = "anonymous";

    document.head.appendChild(link);
    resolve();
  });
}