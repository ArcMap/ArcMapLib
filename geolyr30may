setCurrentSavedMapAsDefault(checked: boolean): void {
  const currentMapId = this.currentSavedMapId();
  this.saveAsDefaultForNextSave.set(checked);

  if (!currentMapId) {
    console.warn('[SavedMapFacade] setCurrentSavedMapAsDefault skipped: no saved map is open');
    return;
  }

  if (checked) {
    this.addFavoriteMapId(currentMapId);

    const savedMap = this.savedMaps().find((map) => map.id === currentMapId);
    if (savedMap) {
      this.savePredefinedMap({
        id: currentMapId,
        name: savedMap.name,
        layers: savedMap.layers,
      }).subscribe({
        error: (err) =>
          console.error('[SavedMapFacade] savePredefinedMap failed', err),
      });
    }

    this.userFacade.setPreference('userDefaultSavedMap', currentMapId);
    return;
  }

  this.removeFavoriteMapId(currentMapId);
}
