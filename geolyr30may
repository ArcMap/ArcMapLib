private updateEllipsisTooltips(): void {
  requestAnimationFrame(() => {
    const tooltipElements = document.querySelectorAll('.autocomplete-name-tooltip');

    tooltipElements.forEach((tooltipElement) => {
      const textElement = tooltipElement.querySelector(
        '.autocomplete-ellipsis-text'
      ) as HTMLElement | null;

      if (!textElement) {
        return;
      }

      const isEllipsisVisible = textElement.scrollWidth > textElement.clientWidth;

      if (isEllipsisVisible) {
        tooltipElement.removeAttribute('disabled');
      } else {
        tooltipElement.setAttribute('disabled', 'true');
      }
    });
  });
}