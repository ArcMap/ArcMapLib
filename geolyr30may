let zoomComponentPromise: Promise<void> | null = null;
let homeComponentPromise: Promise<void> | null = null;
let locateComponentPromise: Promise<void> | null = null;
let scaleBarComponentPromise: Promise<void> | null = null;

export function loadZoomComponent(): Promise<void> {
  if (zoomComponentPromise) {
    return zoomComponentPromise;
  }

  zoomComponentPromise = initialize().then(() =>
    import('@arcgis/map-components/dist/components/arcgis-zoom').then(() => undefined)
  );

  return zoomComponentPromise;
}

