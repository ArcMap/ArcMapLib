private openDistanceMeasurementPopupOnLoad(): void {

  setTimeout(async () => {

    const upMeasurement = this.upMeasurement?.nativeElement as any;

    if (!upMeasurement) {

      return;

    }

    await customElements.whenDefined('up-measurement');

    await upMeasurement.updateComplete;

    const root = upMeasurement.shadowRoot;

    if (!root) {

      return;

    }

    const distanceExpand = root.querySelector('#dist-expand') as any;

    const areaExpand = root.querySelector('#area-expand') as any;

    const coordExpand = root.querySelector('#coord-expand') as any;

    if (areaExpand) {

      areaExpand.expanded = false;

      this.hideExpandIcon(areaExpand);

    }

    if (coordExpand) {

      coordExpand.expanded = false;

      this.hideExpandIcon(coordExpand);

    }

    if (distanceExpand) {

      distanceExpand.expanded = true;

      this.hideExpandIcon(distanceExpand);

    }

  }, 800);

}

private hideExpandIcon(expandElement: any): void {

  if (!expandElement) {

    return;

  }

  const applyHide = () => {

    const root = expandElement.shadowRoot;

    if (!root) {

      return;

    }

    const style = document.createElement('style');

    style.textContent = `

      calcite-action,

      button {

        opacity: 0 !important;

        width: 0 !important;

        min-width: 0 !important;

        height: 0 !important;

        min-height: 0 !important;

        padding: 0 !important;

        margin: 0 !important;

        pointer-events: none !important;

      }

    `;

    root.appendChild(style);

  };

  applyHide();

  setTimeout(applyHide, 300);

  setTimeout(applyHide, 800