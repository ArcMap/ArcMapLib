.rename-row {
  display: flex;
  width: 100%;
  align-items: stretch;
}

.rename-input {
  flex: 1;
}

.rename-cancel,
.rename-save {
  width: 38px;
  min-width: 38px;
  height: 32px;
  border: 1px solid var(--calcite-input-text-border-color);
  border-left: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.rename-cancel {
  background: white;
  color: var(--calcite-color-text-2);
}

.rename-save {
  background: var(--calcite-color-brand);
  color: white;
  border-color: var(--calcite-color-brand);
}

.rename-save::part(icon) {
  color: white;
  fill: white;
}