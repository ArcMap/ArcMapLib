public add(layer: Layer, element?: Element): void {
  if (!this.map || !layer) {
    return;
  }

  const layerElements = Array.from(
    this.querySelectorAll(
      "up-esri-feature-layer, up-geojson-layer, up-image-service-layer, up-tiled-map-service-layer, up-wms-layer"
    )
  ) as Element[];

  const domIndex = element ? layerElements.indexOf(element) : -1;

  let mapIndex = this.map.layers.length;

  if (domIndex !== -1) {
    mapIndex = domIndex;
  }

  this.map.add(layer, mapIndex);

  console.log("[arc-map] add layer by DOM order", {
    domIndex,
    mapIndex,
    layerId: layer.id,
    layerType: layer.type,
    order: this.map.layers.toArray().map((l: any, index: number) => ({
      index,
      id: l.id,
      type: l.type,
    })),
  });
}