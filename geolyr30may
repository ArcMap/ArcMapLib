private showGraphicPopup(
  graphic: Graphic,
  mapPoint: Point,
  graphics: Graphic[],
): void {
  if (
    this._editorOpen ||
    this.inDrawingMode ||
    this._isStartingDraw ||
    this.shouldSuppressPopup()
  ) return;

  if (!this.infoTemplate) {
    console.warn('[popup-debug] showGraphicPopup: no infoTemplate set');
    return;
  }

  const popupGraphics = graphics.length > 1 ? graphics : [graphic];
  const popupGraphic = popupGraphics[0];
  if (!popupGraphic || !this.view?.popup) return;

  // Build templates synchronously before touching the popup
  let builtCount = 0;
  popupGraphics.forEach((g) => {
    const tpl = this.buildPopupTemplateFromCurrent(g);
    if (tpl) {
      g.popupTemplate = tpl;
      builtCount++;
    }
  });

  if (builtCount === 0) {
    console.warn('[popup-debug] showGraphicPopup: no templates built');
    return;
  }

  const location =
    mapPoint ??
    ArcGeojsonLayer.getPopupPoint(popupGraphic.geometry) ??
    undefined;

  // Kill ArcGIS default popup state first
  this._killArcGISDefaultPopup();

  // Now open OUR popup
  if (this.view.stationary === false) {
    const handle = this.view.watch("stationary", (isStationary: boolean) => {
      if (isStationary) {
        handle.remove();
        this._doOpenPopupMultiple(popupGraphics, location);
      }
    });
  } else {
    this._doOpenPopupMultiple(popupGraphics, location);
  }
}




private _doOpenPopupMultiple(graphics: Graphic[], location: any): void {
  try {
    // Briefly re-enable just to open our popup
    this.view.popupEnabled = true;

    const popup: any = this.view?.popup;
    if (!popup) return;

    popup.autoOpenEnabled = false;  // keep this off even while we open
    popup.highlightEnabled = false;

    // Remove "Zoom to" and other default actions
    try { popup.actions?.removeAll?.(); } catch { }

    try { popup.location = location ?? undefined; } catch { }
    try { popup.features = graphics; } catch { }
    try { (popup as any).updateLocationEnabled = false; } catch { }

    if (typeof popup.open === "function") {
      try {
        popup.open({ features: graphics, location: location ?? undefined });
      } catch { }
    } else {
      try { popup.open = true; } catch { }
    }

    try { popup.visible = true; } catch { }

    requestAnimationFrame(() => {
      try { popup.reposition?.(); } catch { }
      // Re-kill auto open after our popup is rendered
      try { popup.autoOpenEnabled = false; } catch { }
    });

    setTimeout(() => {
      try {
        const dom = document.querySelector(
          ".esri-popup-main-container"
        ) as HTMLElement;
        if (dom) {
          dom.style.display = "block";
          dom.style.visibility = "visible";
        }
      } catch { }
    }, 150);

  } catch (error) {
    console.warn('[popup-debug] _doOpenPopupMultiple FAILED', error);
  }
}
