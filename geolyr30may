private applyLatLon(parsed: ParsedDeepLink): void {
  if (parsed.lat !== undefined && parsed.lon !== undefined) {
    const DELTA = 0.05;
    this.mapFacade.setExtent({
      leftLongitude: parsed.lon - DELTA,
      bottomLatitude: parsed.lat - DELTA,
      rightLongitude: parsed.lon + DELTA,
      topLatitude: parsed.lat + DELTA,
    });
  }

  if (parsed.zoom !== undefined) {
    this.mapFacade.setZoom(parsed.zoom);
  }

  if (parsed.label) {
    console.log('[DeepLinkFacade] lat/lon label:', parsed.label);
  }
}


private ignoreZoomChange = true;

private readonly zoomHandler = (event: Event): void => {
  if (this.ignoreZoomChange) return;
  const customEvent = event as CustomEvent<number>;
  const zoom = customEvent.detail;
  if (typeof zoom === 'number') {
    this.mapFacade.setZoom(zoom);
    const scale = this.upMapInstance.view?.scale;
    if (typeof scale === 'number') {
      this.mapFacade.setScale(scale);
    }
  }
};



