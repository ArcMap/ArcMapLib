private handleStationaryChange(stationary: boolean): void {
  if (!stationary) {
    return;
  }

  const pendingZoom = this.mapFacade.consumePendingDeepLinkZoom();

  if (pendingZoom !== undefined) {
    this.setZoom(pendingZoom);
  }
}



private pendingDeepLinkZoom: number | undefined;

setPendingDeepLinkZoom(zoom: number): void {
  this.pendingDeepLinkZoom = zoom;
}

consumePendingDeepLinkZoom(): number | undefined {
  const zoom = this.pendingDeepLinkZoom;
  this.pendingDeepLinkZoom = undefined;
  return zoom;
}