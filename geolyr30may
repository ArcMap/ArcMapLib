async function initialize(): Promise<void> {
  esriConfig.assetsPath = "https://js.arcgis.com/5.0.19/assets";
  setMapAssetPath("https://js.arcgis.com/5.0.19/map-components/assets");

  await Promise.all([
    addStylesheetOnce(
      "upmap-arcgis-core-css",
      "https://js.arcgis.com/5.0.19/esri/themes/light/main.css"
    ),
    addStylesheetOnce(
      "upmap-map-components-css",
      "https://js.arcgis.com/5.0.19/map-components/main.css"
    )
  ]);
}