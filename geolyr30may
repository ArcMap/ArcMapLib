private mapResizeObserver?: ResizeObserver;

private setupMapResizeObserver(mapEl: HTMLElement): void {
  this.mapResizeObserver?.disconnect();

  this.mapResizeObserver = new ResizeObserver(() => {
    requestAnimationFrame(() => {
      this.repositionPopupAfterLayoutChange();

      requestAnimationFrame(() => {
        this.repositionPopupAfterLayoutChange();
      });
    });
  });

  this.mapResizeObserver.observe(mapEl);
}

private repositionPopupAfterLayoutChange(): void {
  if (!this.view?.popup?.visible) {
    return;
  }

  const popup = this.view.popup;
  const features = popup.features;
  const location = popup.location;

  if (!features?.length || !location) {
    return;
  }

  popup.close();

  requestAnimationFrame(() => {
    popup.open({
      features,
      location
    });
  });
}




disconnectedCallback(): void {
  this.mapResizeObserver?.disconnect();
  super.disconnectedCallback();
}