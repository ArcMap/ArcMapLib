<div class="rename-row">
  <calcite-input-text
    class="rename-input"
    [value]="renameMapName()"
    (calciteInputTextInput)="onRenameMapNameInput($event)">
  </calcite-input-text>

  <calcite-action
    class="rename-cancel"
    icon="x"
    (click)="cancelRenameInstance()">
  </calcite-action>

  <calcite-action
    class="rename-save"
    icon="check"
    (click)="confirmRenameInstance(map.id)">
  </calcite-action>
</div>