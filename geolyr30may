@ViewChild('measurementEl', { static: false })
measurementEl!: ElementRef<HTMLElement>;

ngAfterViewInit(): void {
  this.openMeasurementScreenByDefault();
}

private openMeasurementScreenByDefault(): void {
  setTimeout(async () => {
    const upMeasurement = this.measurementEl?.nativeElement as any;

    if (!upMeasurement) {
      return;
    }

    await customElements.whenDefined('up-measurement');
    await upMeasurement.updateComplete;

    const shadowRoot = upMeasurement.shadowRoot;

    if (!shadowRoot) {
      return;
    }

    const distanceExpand = shadowRoot.querySelector('#dist-expand') as any;
    const distanceMeasurement = shadowRoot.querySelector(
      'arcgis-distance-measurement-2d'
    ) as any;

    if (distanceExpand) {
      distanceExpand.expanded = true;
    }

    if (distanceMeasurement) {
      await distanceMeasurement.componentOnReady?.();
      distanceMeasurement.start?.();
    }
  }, 500);
}