private async openMeasurementPanelWithoutIcon(): Promise<void> {
  const upMeasurement = this.upMeasurement.nativeElement as any;

  await customElements.whenDefined('up-measurement');
  await upMeasurement.updateComplete;

  const shadowRoot = upMeasurement.shadowRoot;
  if (!shadowRoot) return;

  const distExpand = shadowRoot.querySelector('#dist-expand') as any;
  const areaExpand = shadowRoot.querySelector('#area-expand') as any;

  if (distExpand) {
    distExpand.expanded = true;
    this.hideExpandIcon(distExpand);
  }

  if (areaExpand) {
    areaExpand.expanded = false;
    this.hideExpandIcon(areaExpand);
  }
}

private hideExpandIcon(expandElement: any): void {
  if (!expandElement?.shadowRoot) return;

  const style = document.createElement('style');
  style.textContent = `
    calcite-action,
    button {
      display: none !important;
      width: 0 !important;
      height: 0 !important;
      opacity: 0 !important;
      pointer-events: none !important;
    }
  `;

  expandElement.shadowRoot.appendChild(style);
}

async onNewMeasurement(): Promise<void> {
  const upMeasurement = this.upMeasurement.nativeElement as any;
  const shadowRoot = upMeasurement.shadowRoot;
  if (!shadowRoot) return;

  const distExpand = shadowRoot.querySelector('#dist-expand') as any;
  const areaExpand = shadowRoot.querySelector('#area-expand') as any;

  const distanceEl = shadowRoot.querySelector(
    'arcgis-distance-measurement-2d'
  ) as any;

  const areaEl = shadowRoot.querySelector(
    'arcgis-area-measurement-2d'
  ) as any;

  if (this.mode() === 'distance') {
    areaExpand.expanded = false;
    distExpand.expanded = true;

    await distanceEl.componentOnReady?.();
    distanceEl.start?.();
    return;
  }

  distExpand.expanded = false;
  areaExpand.expanded = true;

  await areaEl.componentOnReady?.();
  areaEl.start?.();
}




<calcite-button width="full" (click)="onNewMeasurement()">
  New Measurement
</calcite-button>