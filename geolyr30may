private async openArcGisMeasurementPanel(): Promise<void> {

  setTimeout(async () => {

    const upMeasurement = this.upMeasurement.nativeElement as any;

    await customElements.whenDefined('up-measurement');

    await upMeasurement.updateComplete;

    const root = upMeasurement.shadowRoot;

    if (!root) return;

    const distExpand = root.querySelector('#dist-expand') as any;

    const areaExpand = root.querySelector('#area-expand') as any;

    const coordExpand = root.querySelector('#coord-expand') as any;

    if (coordExpand) coordExpand.expanded = false;

    if (areaExpand) areaExpand.expanded = false;

    if (distExpand) {

      distExpand.expanded = true;

      this.hideExpandIconOnly(distExpand);

    }

    this.hideExpandIconOnly(areaExpand);

    this.hideExpandIconOnly(coordExpand);

  }, 700);

}

private hideExpandIconOnly(expandEl: any): void {

  if (!expandEl) return;

  const apply = () => {

    const root = expandEl.shadowRoot;

    if (!root) return;

    const style = document.createElement('style');

    style.textContent = `

      calcite-action,

      button {

        opacity: 0 !important;

        width: 0 !important;

        min-width: 0 !important;

        pointer-events: none !important;

      }

    `;

    root.appendChild(style);

  };

  apply();

  setTimeout(apply, 500);

}

async onNewMeasurement(): Promise<void> {

  const upMeasurement = this.upMeasurement.nativeElement as any;

  const root = upMeasurement.shadowRoot;

  if (!root) return;

  const distExpand = root.querySelector('#dist-expand') as any;

  const areaExpand = root.querySelector('#area-expand') as any;

  const distanceEl = root.querySelector('arcgis-distance-measurement-2d') as any;

  const areaEl = root.querySelector('arcgis-area-measurement-2d') as any;

  if (this.mode === 'distance') {

    if (areaExpand) areaExpand.expanded = false;

    if (distExpand) distExpand.expanded = true;

    await distanceEl?.componentOnReady?.();

    distanceEl?.start?.();

    return;

  }

  if (distExpand) distExpand.expanded = false;

  if (areaExpand) areaExpand.expanded = true;

  await areaEl?.componentOnReady?.();

  areaEl?.start?.();

}