import path from "path";
import { fileURLToPath } from "url";
import resolve from "@rollup/plugin-node-resolve";
import commonjs from "@rollup/plugin-commonjs";
import typescript from "@rollup/plugin-typescript";
import replace from "@rollup/plugin-replace";
import postcss from "rollup-plugin-postcss";

const __filename = fileURLToPath(import.meta.url);
const __dirname = path.dirname(__filename);

const bundleForDev = process.env.DEV_BUNDLE === "true";

/**
 * Do NOT externalize ArcGIS.
 * Requirement: customer installs only UPMap.
 */
const peerExternals = [
  /^lit$/,
  /^lit\//,
  /^@elements\/core/
];

export default {
  input: path.resolve(__dirname, "src/index.ts"),

  output: {
    dir: bundleForDev ? "./dist-dev" : "./dist",
    format: "es",
    sourcemap: true,
    chunkFileNames: "chunks/[hash].js",

    manualChunks(id) {
      if (id.includes("@arcgis/core")) {
        return "arcgis-core";
      }

      if (id.includes("@arcgis/map-components")) {
        return "arcgis-map-components";
      }

      if (id.includes("@arcgis/lumina")) {
        return "arcgis-lumina";
      }

      if (id.includes("@esri/calcite-components")) {
        return "calcite-components";
      }
    }
  },

  external: bundleForDev ? [] : peerExternals,

  plugins: [
    resolve({
      browser: true,
      preferBuiltins: false,
      dedupe: ["lit", "@up-elements/core"]
    }),

    commonjs(),

    typescript({
      tsconfig: bundleForDev ? "./tsconfig.dev.json" : "./tsconfig.json"
    }),

    postcss({
      inject: true,
      minimize: true,
      extract: false
    }),

    replace({
      preventAssignment: true,
      "process.env.NODE_ENV": JSON.stringify(
        process.env.NODE_ENV || "development"
      )
    })
  ],

  onwarn(warning, warn) {
    if (warning.code === "CIRCULAR_DEPENDENCY") {
      return;
    }

    warn(warning);
  }
};