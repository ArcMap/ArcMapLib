private suppressNextDeepLinkApply = false;

private initializeMapItemsAndDeepLinking(): Promise<void> {
  ...
  this.activatedRoute.queryParamMap
    .pipe(takeUntilDestroyed(this.destroyRef))
    .subscribe((queryParams) => {
      if (this.suppressNextDeepLinkApply) {
        this.suppressNextDeepLinkApply = false;
        return;
      }
      this.tryApplyDeepLinkedMap(queryParams);
    });
}



private updateSelectedMapQueryParams(): void {
  const selectedMap = this.selectedMapItem();
  if (!selectedMap) return;

  const visibleLayerIds = this.layersFacade.visibleLayers().map((l) => l.id);

  this.suppressNextDeepLinkApply = true;
  void this.router.navigate(['/'], {
    queryParams: {
      layers: visibleLayerIds.length > 0 ? visibleLayerIds.join(',') : null,
      userMap: selectedMap.name,
      bookmarkId: null,
    },
    queryParamsHandling: 'merge',
    replaceUrl: true,
  });
}
