requestAnimationFrame(() => {
  const upMapElement =
    this.upMapElement().nativeElement as HTMLElement;

  const featureLayers =
    upMapElement.querySelectorAll<HTMLElement>(
      'up-esri-feature-layer',
    );

  console.log(
    '[MapViewComponent.initializeMap] Feature layers found:',
    featureLayers.length,
  );

  featureLayers.forEach((layer) => {
    console.log(
      '[MapViewComponent.initializeMap] Dispatching to layer:',
      layer,
    );

    layer.dispatchEvent(
      new CustomEvent('upMapDeferredReady', {
        detail: {
          map: mapView.map,
          view: mapView,
        },
        bubbles: false,
        composed: true,
      }),
    );
  });
});