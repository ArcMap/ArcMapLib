private dispatchDeferredReady(): void {
  const upMapElement =
    this.upMapElement().nativeElement as HTMLElement;

  const view = this.mapFacade.mapView();
  const map = view?.map;

  if (!view || !map) {
    return;
  }

  upMapElement
    .querySelectorAll<HTMLElement>(':scope > *')
    .forEach((child) => {
      child.dispatchEvent(
        new CustomEvent('upMapDeferredReady', {
          detail: {
            map,
            view,
          },
          bubbles: false,
          composed: true,
        }),
      );
    });
}



const mapView = await this.upMapInstance.getMapView();

this.mapFacade.setMapView(mapView);
this.mapReady.set(true);

requestAnimationFrame(() => {
  this.dispatchDeferredReady();
});