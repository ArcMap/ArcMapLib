private buildPopupTemplate(graphic: Graphic): PopupTemplate | null {
  if (!this.infoTemplate) return null;

  const attributes = graphic?.attributes ?? {};

  const resolveTokens = (str: string): string =>
    str.replace(/\$\{([^}]+)\}/g, (_, key: string) => {
      const val = attributes[key.trim()];
      return val !== undefined && val !== null ? String(val) : "";
    });

  const tmpl: any =
    typeof this.infoTemplate === "string"
      ? (() => { try { return JSON.parse(this.infoTemplate as string); } catch { return { content: this.infoTemplate }; } })()
      : this.infoTemplate;

  // ── Resolve title ──────────────────────────────────────────
  let title: any = tmpl?.title ?? tmpl?.Title ?? "Details";
  if (typeof title === "function") title = title.call(tmpl, graphic);
  if (typeof title === "string")   title = resolveTokens(title);

  console.log("[arc-geojson-layer] buildPopupTemplate: resolved title:", title);

  // ── Resolve content ────────────────────────────────────────
  let rawContent: any =
    tmpl?.content ??
    tmpl?.Content ??
    tmpl?.details ??
    tmpl?.body ??
    null;

  console.log("[arc-geojson-layer] buildPopupTemplate: rawContent typeof:", typeof rawContent);

  let content: any = null;

  if (typeof rawContent === "function") {
    // ✅ Call function, get back HTML string
    const result = rawContent.call(tmpl, graphic);
    console.log("[arc-geojson-layer] buildPopupTemplate: content is string from function");
    if (typeof result === "string" && result.trim()) {
      content = resolveTokens(result);
    } else {
      content = result ?? null;
    }
  } else if (typeof rawContent === "string" && rawContent.trim()) {
    // ✅ Plain string template
    content = resolveTokens(rawContent);
    console.log("[arc-geojson-layer] buildPopupTemplate: content resolved from string:", content);
  } else if (Array.isArray(rawContent) || (rawContent !== null && typeof rawContent === "object")) {
    // ✅ ArcGIS content array/object — pass through as-is, do NOT serialize
    content = rawContent;
  }
  // ❌ null/undefined → content stays null, no JSON dump

  console.log("[arc-geojson-layer] buildPopupTemplate: hasValidAttributes:", true);
  console.log("[arc-geojson-layer] buildPopupTemplate: hasResolvedContent:", !!content);

  // ── Skip popup if nothing to show ─────────────────────────
  if (!content) {
    console.warn("[arc-geojson-layer] buildPopupTemplate: no content resolved, skipping popup");
    return null;
  }

  console.log("[arc-geojson-layer] buildPopupTemplate: using string content");
  console.log("[arc-geojson-layer] buildPopupTemplate: final template:");

  return new PopupTemplate({ title, content });
}
