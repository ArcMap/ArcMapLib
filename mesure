import { LitElement, html, css } from 'lit';
import { customElement, property, state } from 'lit/decorators.js';

@customElement('arc-measurement')
export class ArcMeasurement extends LitElement {

  @property({ type: String, reflect: true }) mapId: string = '';
  @state() private view: any = null;

  static styles = css`
    :host { display: block; }
    .measurement-container {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }
  `;

  async firstUpdated() {
    await this.componentDidLoad();
  }

  disconnectedCallback() {
    super.disconnectedCallback();
    this.componentDidUnload();
  }

  private resolveMapElement(): any | null {
    if (this.mapId) {
      const el = document.querySelector(`arc-map[id="${this.mapId}"]`);
      if (!el) {
        console.error(`No <arc-map> found with id "${this.mapId}"`);
        return null;
      }
      return el;
    } else {
      const el = document.querySelector('arc-map');
      if (!el) {
        console.error('No <arc-map> found on page. Please provide a mapId.');
        return null;
      }
      return el;
    }
  }

  async componentDidLoad() {
    const mapElement = this.resolveMapElement();
    if (!mapElement) return;

    const view = await mapElement.getViewInstance();
    if (!view) {
      console.error('Could not get MapView from <arc-map>');
      return;
    }

    await view.when();
    this.view = view;

    await Promise.all([
      customElements.whenDefined('arcgis-expand'),
      customElements.whenDefined('arcgis-area-measurement-2d'),
      customElements.whenDefined('arcgis-distance-measurement-2d'),
    ]);

    await this.updateComplete;

    const areaEl = this.shadowRoot?.querySelector('arcgis-area-measurement-2d') as any;
    const distEl = this.shadowRoot?.querySelector('arcgis-distance-measurement-2d') as any;

    if (areaEl) areaEl.view = this.view;
    if (distEl) distEl.view = this.view;

    // Auto-start when expand opens
    const areaExpand = this.shadowRoot?.querySelector('#area-expand') as any;
    const distExpand = this.shadowRoot?.querySelector('#dist-expand') as any;

    areaExpand?.addEventListener('arcgisExpand', async () => {
      // Close distance expand if open
      if (distExpand?.expanded) {
        distExpand.expanded = false;
        distEl?.clear();
      }
      await areaEl?.componentOnReady();
      areaEl?.start();
    });

    areaExpand?.addEventListener('arcgisCollapse', () => {
      areaEl?.clear();
    });

    distExpand?.addEventListener('arcgisExpand', async () => {
      // Close area expand if open
      if (areaExpand?.expanded) {
        areaExpand.expanded = false;
        areaEl?.clear();
      }
      await distEl?.componentOnReady();
      distEl?.start();
    });

    distExpand?.addEventListener('arcgisCollapse', () => {
      distEl?.clear();
    });
  }

  componentDidUnload() {
    const areaEl = this.shadowRoot?.querySelector('arcgis-area-measurement-2d') as any;
    const distEl = this.shadowRoot?.querySelector('arcgis-distance-measurement-2d') as any;
    areaEl?.destroy();
    distEl?.destroy();
  }

  render() {
    return html`
      <div class="measurement-container">

        <arcgis-expand
          id="area-expand"
          expand-icon="measure-area"
          expanded-icon="measure-area"
          expand-tooltip="Measure Area">
          <arcgis-area-measurement-2d></arcgis-area-measurement-2d>
        </arcgis-expand>

        <arcgis-expand
          id="dist-expand"
          expand-icon="measure-line"
          expanded-icon="measure-line"
          expand-tooltip="Measure Distance">
          <arcgis-distance-measurement-2d></arcgis-distance-measurement-2d>
        </arcgis-expand>

      </div>
    `;
  }
}

declare global {
  interface HTMLElementTagNameMap {
    'arc-measurement': ArcMeasurement;
  }
}
