import { LitElement, html, css } from 'lit';
import { customElement, property, state } from 'lit/decorators.js';

@customElement('arc-measurement')
export class ArcMeasurement extends LitElement {

  @property({ type: String, reflect: true }) mapId: string = '';

  /**
   * Default tool selected on start up.
   * Valid choices are "area", "distance", "location".
   * If not provided, all three tools are shown.
   */
  @property({ type: String, reflect: true }) defaultTool: 'area' | 'distance' | 'location' | null = null;

  @state() private view: any = null;

  static styles = css`
    :host { display: block; }
    .measurement-container {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }
    .hidden { display: none; }
  `;

  async firstUpdated() {
    await this.componentDidLoad();
  }

  disconnectedCallback() {
    super.disconnectedCallback();
    this.componentDidUnload();
  }

  private resolveMapElement(): any | null {
    if (this.mapId) {
      const el = document.querySelector(`arc-map[id="${this.mapId}"]`);
      if (!el) {
        console.error(`No <arc-map> found with id "${this.mapId}"`);
        return null;
      }
      return el;
    } else {
      const el = document.querySelector('arc-map');
      if (!el) {
        console.error('No <arc-map> found on page. Please provide a mapId.');
        return null;
      }
      return el;
    }
  }

  async componentDidLoad() {
    const mapElement = this.resolveMapElement();
    if (!mapElement) return;

    const view = await mapElement.getViewInstance();
    if (!view) {
      console.error('Could not get MapView from <arc-map>');
      return;
    }

    await view.when();
    this.view = view;

    await Promise.all([
      customElements.whenDefined('arcgis-expand'),
      customElements.whenDefined('arcgis-area-measurement-2d'),
      customElements.whenDefined('arcgis-distance-measurement-2d'),
      customElements.whenDefined('arcgis-coordinate-conversion'),
    ]);

    await this.updateComplete;

    const areaEl = this.shadowRoot?.querySelector('arcgis-area-measurement-2d') as any;
    const distEl = this.shadowRoot?.querySelector('arcgis-distance-measurement-2d') as any;
    const coordEl = this.shadowRoot?.querySelector('arcgis-coordinate-conversion') as any;

    if (areaEl) areaEl.view = this.view;
    if (distEl) distEl.view = this.view;
    if (coordEl) coordEl.view = this.view;

    const areaExpand = this.shadowRoot?.querySelector('#area-expand') as any;
    const distExpand = this.shadowRoot?.querySelector('#dist-expand') as any;
    const coordExpand = this.shadowRoot?.querySelector('#coord-expand') as any;

    // ── Area expand events ──────────────────────────────────────────────
    areaExpand?.addEventListener('arcgisExpand', async () => {
      if (distExpand?.expanded) { distExpand.expanded = false; distEl?.clear(); }
      if (coordExpand?.expanded) { coordExpand.expanded = false; }
      await areaEl?.componentOnReady();
      areaEl?.start();
    });

    areaExpand?.addEventListener('arcgisCollapse', () => {
      areaEl?.clear();
    });

    // ── Distance expand events ──────────────────────────────────────────
    distExpand?.addEventListener('arcgisExpand', async () => {
      if (areaExpand?.expanded) { areaExpand.expanded = false; areaEl?.clear(); }
      if (coordExpand?.expanded) { coordExpand.expanded = false; }
      await distEl?.componentOnReady();
      distEl?.start();
    });

    distExpand?.addEventListener('arcgisCollapse', () => {
      distEl?.clear();
    });

    // ── Coordinate expand events ────────────────────────────────────────
    coordExpand?.addEventListener('arcgisExpand', async () => {
      if (areaExpand?.expanded) { areaExpand.expanded = false; areaEl?.clear(); }
      if (distExpand?.expanded) { distExpand.expanded = false; distEl?.clear(); }
      await coordEl?.componentOnReady();
    });

    // ── Auto-open defaultTool if provided ───────────────────────────────
    if (this.defaultTool === 'area' && areaExpand) {
      areaExpand.expanded = true;
      await areaEl?.componentOnReady();
      areaEl?.start();
    } else if (this.defaultTool === 'distance' && distExpand) {
      distExpand.expanded = true;
      await distEl?.componentOnReady();
      distEl?.start();
    } else if (this.defaultTool === 'location' && coordExpand) {
      coordExpand.expanded = true;
      await coordEl?.componentOnReady();
    }
  }

  componentDidUnload() {
    const areaEl = this.shadowRoot?.querySelector('arcgis-area-measurement-2d') as any;
    const distEl = this.shadowRoot?.querySelector('arcgis-distance-measurement-2d') as any;
    const coordEl = this.shadowRoot?.querySelector('arcgis-coordinate-conversion') as any;
    areaEl?.destroy();
    distEl?.destroy();
    coordEl?.destroy();
  }

  private shouldShow(tool: 'area' | 'distance' | 'location'): boolean {
    // If no defaultTool set, show all three
    // If defaultTool set, show only that tool
    return this.defaultTool === null || this.defaultTool === tool;
  }

  render() {
    return html`
      <div class="measurement-container">

        <!-- Area -->
        <arcgis-expand
          id="area-expand"
          expand-icon="measure-area"
          expanded-icon="measure-area"
          expand-tooltip="Measure Area"
          class="${this.shouldShow('area') ? '' : 'hidden'}">
          <arcgis-area-measurement-2d></arcgis-area-measurement-2d>
        </arcgis-expand>

        <!-- Distance -->
        <arcgis-expand
          id="dist-expand"
          expand-icon="measure-line"
          expanded-icon="measure-line"
          expand-tooltip="Measure Distance"
          class="${this.shouldShow('distance') ? '' : 'hidden'}">
          <arcgis-distance-measurement-2d></arcgis-distance-measurement-2d>
        </arcgis-expand>

        <!-- Location -->
        <arcgis-expand
          id="coord-expand"
          expand-icon="pin-plus"
          expanded-icon="pin-plus"
          expand-tooltip="Capture Location"
          class="${this.shouldShow('location') ? '' : 'hidden'}">
          <arcgis-coordinate-conversion></arcgis-coordinate-conversion>
        </arcgis-expand>

      </div>
    `;
  }
}

declare global {
  interface HTMLElementTagNameMap {
    'arc-measurement': ArcMeasurement;
  }
}
