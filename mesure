import { LitElement, html, css } from 'lit';
import { customElement, property, state } from 'lit/decorators.js';
import MapUtils from '../common/map-utils';

@customElement('arc-measurement')
export class ArcMeasurement extends LitElement {

  @property({ type: String, reflect: true }) mapId: string = '';

  /**
   * Default tool selected on start up. Valid choices are "area", "distance".
   * If a default is not provided then no tool is selected.
   */
  @property({ type: String, reflect: true }) defaultTool: string | null = null;

  @state() private view: __esri.MapView | null = null;

  static styles = css`
    :host { display: block; }
    .tool-container { display: none; }
    .tool-container.active { display: block; }
  `;

  async firstUpdated() {
    await this.componentDidLoad();
  }

  disconnectedCallback() {
    super.disconnectedCallback();
    this.componentDidUnload();
  }

  async componentDidLoad() {
    const mapElement = MapUtils.findUpMapByIdOrDefault(this.mapId);
    if (!mapElement) return;

    const mapPromise = MapUtils.getEsriMapPromiseFromUpMapElement(mapElement);
    this.view = await mapPromise;

    await Promise.all([
      customElements.whenDefined('arcgis-area-measurement-2d'),
      customElements.whenDefined('arcgis-distance-measurement-2d'),
    ]);

    // Set view on both widgets after they are defined
    const areEl = this.shadowRoot?.querySelector('arcgis-area-measurement-2d') as any;
    const distEl = this.shadowRoot?.querySelector('arcgis-distance-measurement-2d') as any;

    if (areEl) areEl.view = this.view;
    if (distEl) distEl.view = this.view;

    if (this.defaultTool === 'area' || this.defaultTool === 'distance') {
      // activating tool is handled by showing the correct widget
    } else {
      console.log(
        'Measurement tool: No default tool selected. Valid choices are area, distance, or location.'
      );
    }
  }

  componentDidUnload() {
    // web components clean up themselves
  }

  render() {
    const showArea = this.defaultTool === 'area';
    const showDistance = this.defaultTool === 'distance';

    return html`
      <div class="tool-container ${showArea ? 'active' : ''}">
        <arcgis-area-measurement-2d></arcgis-area-measurement-2d>
      </div>
      <div class="tool-container ${showDistance ? 'active' : ''}">
        <arcgis-distance-measurement-2d></arcgis-distance-measurement-2d>
      </div>
    `;
  }
}
