  describe('updateLabelJson', () => {
    it('updates labeljson and refreshes labels', async () => {
      const { layer } = await makeLayer({ geojson: makePointCollection() as any });
      const spy = jest.spyOn(layer as any, 'refreshLabels');
      layer.updateLabelJson({ someField: 'value' });
      expect(spy).toHaveBeenCalled();
    });
  });

  // ── updateInfoTemplate ─────────────────────────────────────────────────────

  describe('updateInfoTemplate', () => {
    it('does nothing when featureLayer is not initialized', async () => {
      const layer = new ArcGeojsonLayer();
      expect(() => layer.updateInfoTemplate({ listItem: 'Title', details: 'Body' })).not.toThrow();
    });

    it('sets popupTemplate on graphics when valid infoTemplate provided', async () => {
      const { layer } = await makeLayer({ geojson: makePointCollection() as any });
      layer.updateInfoTemplate({ listItem: 'My Title', details: 'My Details' });
      (layer as any).featureLayer.graphics.toArray().forEach((g: any) => {
        expect(g.popupTemplate).toBeDefined();
      });
    });
  });

