describe('ArcGeoJsonLayer – public API', () => {
  test('getLayerId returns featureLayer.id when set', async () => {
    const el = await buildComponent() as any;
    el.featureLayer.id = 'test-layer-id';
    const id = await el.getLayerId();
    expect(id).toBe('test-layer-id');
  });

  test('findFeatureByUniqueId returns correct graphic', async () => {
    const el = await buildComponent() as any;
    const mockGraphic = { attributes: { id: 'abc' } };
    el.uniqueIdPropertyName = 'id';
    el.featureLayer.graphics.find = jest.fn((cb: any) => {
      return cb(mockGraphic) ? mockGraphic : undefined;
    });
    const result = await el.findFeatureByUniqueId('abc');
    expect(result).toBe(mockGraphic);
  });

  test('zoomTo calls view.goTo for a point feature', async () => {
    const el = await buildComponent() as any;
    const mockGraphic = {
      geometry: { type: 'point', x: -96, y: 41 },
    };
    el.findFeatureByUniqueId = jest.fn().mockResolvedValue(mockGraphic);
    await el.zoomTo('abc');
    expect(el.view.goTo).toHaveBeenCalled();
  });

  test('zoomTo calls view.goTo for a polygon feature', async () => {
    const el = await buildComponent() as any;
    const mockGraphic = {
      geometry: {
        type: 'polygon',
        extent: { expand: jest.fn().mockReturnValue({}) },
        centroid: { x: -96, y: 41 },
      },
    };
    el.findFeatureByUniqueId = jest.fn().mockResolvedValue(mockGraphic);
    await el.zoomTo('poly-1');
    expect(el.view.goTo).toHaveBeenCalled();
  });

  test('toFeatureCollectionFromLayer returns FeatureCollection', async () => {
    const el = await buildComponent() as any;
    const mockGraphic = {
      geometry: { type: 'point', x: -96, y: 41, spatialReference: { isWGS84: true } },
      attributes: { id: 1 },
    };
    el.featureLayer.graphics.toArray = jest.fn().mockReturnValue([mockGraphic]);
    const fc = el.toFeatureCollectionFromLayer();
    expect(fc.type).toBe('FeatureCollection');
    expect(Array.isArray(fc.features)).toBe(true);
  });
});

