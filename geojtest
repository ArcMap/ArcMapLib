describe('ArcGeoJsonLayer – editor / SketchViewModel', () => {
  test('createEditor initialises SketchViewModel', async () => {
    const SketchViewModel = require('@arcgis/core/widgets/Sketch/SketchViewModel').default;
    const el = await buildComponent() as any;
    expect(SketchViewModel).toHaveBeenCalled();
    expect(el.graphicsEditor).toBeDefined();
  });

  test('startDrawing sets inDrawingMode = true', async () => {
    const el = await buildComponent() as any;
    el.featureLayer.graphics.getItemAt = jest.fn();
    await el.startDrawing('POINT');
    expect(el.inDrawingMode).toBe(true);
  });

  test('cancelDrawing sets inDrawingMode = false', async () => {
    const el = await buildComponent() as any;
    el.inDrawingMode = true;
    await el.cancelDrawing();
    expect(el.inDrawingMode).toBe(false);
  });

  test('updateEditing disables popupTemplates when enableUserEdit=true', async () => {
    const el = await buildComponent() as any;
    const mockGraphic = { popupTemplate: {} };
    el.featureLayer.graphics.forEach = jest.fn((cb: any) => cb(mockGraphic));
    await el.updateEditing(true);
    expect(mockGraphic.popupTemplate).toBeNull();
  });

  test('updateEditing restores popupTemplates when enableUserEdit=false', async () => {
    const el = await buildComponent() as any;
    const mockGraphic = { popupTemplate: null, geometry: { type: 'point' }, attributes: {} };
    el.featureLayer.graphics.forEach = jest.fn((cb: any) => cb(mockGraphic));
    await el.updateEditing(false);
    expect(mockGraphic.popupTemplate).not.toBeUndefined();
  });
});

describe('ArcGeoJsonLayer – labels', () => {
  test('refreshLabels clears and re-adds label graphics', async () => {
    const pointGeoJson = JSON.stringify({
      type: 'FeatureCollection',
      features: [
        {
          type: 'Feature',
          geometry: { type: 'Point', coordinates: [-96, 41] },
          properties: { LABEL: 'UP' },
        },
      ],
    });
    const el = await buildComponent({ geojson: pointGeoJson } as any) as any;

    const mockGraphic = {
      geometry: { type: 'point', x: -96, y: 41 },
      attributes: { LABEL: 'UP' },
    };
    el.featureLayer.graphics.forEach = jest.fn((cb: any) => cb(mockGraphic));

    el.refreshLabels();

    expect(el.labelLayer.removeAll).toHaveBeenCalled();
    expect(el.labelLayer.add).toHaveBeenCalled();
  });

  test('refreshLabels skips graphics with no LABEL attribute', async () => {
    const el = await buildComponent() as any;
    const mockGraphic = {
      geometry: { type: 'point' },
      attributes: {},
    };
    el.featureLayer.graphics.forEach = jest.fn((cb: any) => cb(mockGraphic));
    el.labelLayer.removeAll.mockClear();
    el.labelLayer.add.mockClear();

    el.refreshLabels();

    expect(el.labelLayer.add).not.toHaveBeenCalled();
  });
});

