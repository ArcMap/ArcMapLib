describe('ArcGeoJsonLayer – updated() lifecycle', () => {
  test('updateGeoJson called when geojson prop changes', async () => {
    const el = await buildComponent() as any;
    const spy = jest.spyOn(el, 'updateGeoJson').mockResolvedValue(undefined);
    el.blockGeoJsonUpdate = false;
    el.updated(new Map([['geojson', 'old-value']]));
    expect(spy).toHaveBeenCalled();
  });

  test('updateInfoTemplate called when infoTemplate changes', async () => {
    const el = await buildComponent() as any;
    const spy = jest.spyOn(el, 'updateInfoTemplate').mockImplementation(() => {});
    el.updated(new Map([['infoTemplate', '{}']]));
    expect(spy).toHaveBeenCalled();
  });

  test('updateRenderer called when renderer changes', async () => {
    const el = await buildComponent() as any;
    const spy = jest.spyOn(el, 'updateRenderer').mockImplementation(() => {});
    el.updated(new Map([['renderer', '{}']]));
    expect(spy).toHaveBeenCalled();
  });

  test('updateLabelJson called when labelJson changes', async () => {
    const el = await buildComponent() as any;
    const spy = jest.spyOn(el, 'updateLabelJson').mockImplementation(() => {});
    el.updated(new Map([['labelJson', '{}']]));
    expect(spy).toHaveBeenCalled();
  });

  test('refreshLabels called when labelColor changes', async () => {
    const el = await buildComponent() as any;
    const spy = jest.spyOn(el, 'refreshLabels').mockImplementation(() => {});
    el.updated(new Map([['labelColor', '[255,0,0,255]']]));
    expect(spy).toHaveBeenCalled();
  });

  test('refreshLabels called when labelSize changes', async () => {
    const el = await buildComponent() as any;
    const spy = jest.spyOn(el, 'refreshLabels').mockImplementation(() => {});
    el.updated(new Map([['labelSize', 14]]));
    expect(spy).toHaveBeenCalled();
  });

  test('updateEditing called when enableUserEdit changes', async () => {
    const el = await buildComponent() as any;
    const spy = jest.spyOn(el, 'updateEditing').mockResolvedValue(undefined);
    el.updated(new Map([['enableUserEdit', true]]));
    expect(spy).toHaveBeenCalled();
  });
});
