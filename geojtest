// Rename: up-geojson-layer → arc-geojson-layer  /  UpGeoJsonLayer → ArcGeoJsonLayer
import { UpGeoJsonLayer as ArcGeoJsonLayer } from '../src/geojson-layer/geojson-layer';

// ── Helpers ──────────────────────────────────────────────────────────────────
function makeView() {
  const GraphicsLayer = require('@arcgis/core/layers/GraphicsLayer').default;
  return {
    map: { add: jest.fn(), remove: jest.fn() },
    popup: { close: jest.fn(), visible: false },
    hitTest: jest.fn().mockResolvedValue({ results: [] }),
    on: jest.fn().mockReturnValue({ remove: jest.fn() }),
    goTo: jest.fn().mockResolvedValue(undefined),
    openPopup: jest.fn(),
  };
}

function makeAncestorMap(view: any) {
  return {
    componentOnReady: jest.fn().mockResolvedValue(undefined),
    getViewInstance: jest.fn().mockResolvedValue(view),
  };
}

async function buildComponent(props: Partial<ArcGeoJsonLayer> = {}): Promise<ArcGeoJsonLayer> {
  const el = new ArcGeoJsonLayer() as any;

  const view = makeView();
  const ancestorMap = makeAncestorMap(view);

  // Stub DOM traversal used by resolveAncestorMapAndView
  el.closest = jest.fn().mockReturnValue(ancestorMap);

  // Apply any extra props
  Object.assign(el, props);

  await el.connectedCallback();
  return el;
}

