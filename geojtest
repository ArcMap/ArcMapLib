// ── buildPopupTemplateFromCurrent ─────────────────────────────────────────────
describe('JsonUtils.buildPopupTemplateFromCurrent', () => {
  const mockGraphic = {
    attributes: { id: 1, name: 'Test Feature', OBJECTID: 1 },
    geometry: { type: 'point' },
  };

  test('builds popup template with string listItem', () => {
    const result = JsonUtils.buildPopupTemplateFromCurrent(
      mockGraphic,
      JSON.stringify({ listItem: 'Feature Title', details: 'Feature Details' }),
      'id',
      'Details'
    );
    expect(result).not.toBeNull();
  });

  test('builds popup template with function listItem', () => {
    const infoTemplate = {
      listItem: (g: any) => `Title: ${g.attributes.name}`,
      details: 'Static content',
    };
    const result = JsonUtils.buildPopupTemplateFromCurrent(
      mockGraphic,
      infoTemplate,
      'id',
      'Details'
    );
    expect(result).not.toBeNull();
  });

  test('returns null when infoTemplate is empty string', () => {
    const result = JsonUtils.buildPopupTemplateFromCurrent(
      mockGraphic, '', 'id', 'Details'
    );
    expect(result).toBeNull();
  });

  test('uses fallbackTitle when uniqueId attribute is undefined', () => {
    const graphicNoId = { attributes: {}, geometry: { type: 'point' } };
    const result = JsonUtils.buildPopupTemplateFromCurrent(
      graphicNoId,
      { listItem: undefined, details: 'some content' },
      'id',
      'My Fallback'
    );
    expect(result).not.toBeNull();
  });
});

