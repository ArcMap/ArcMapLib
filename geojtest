      'esriGeometryPoint', [255, 0, 0, 255], 10, 2, 2
    ) as any;
    expect(result.symbol.type).toBe('esriSMS');
  });

  test('multipoint nested symbol type is esriSMS', () => {
    const result = JsonUtils.getJsonSymbolFor(
      'multipoint', [255, 0, 0, 255], 10, 2, 2
    ) as any;
    expect(result.symbol.type).toBe('esriSMS');
  });

  test('polyline nested symbol type is esriSLS', () => {
    const result = JsonUtils.getJsonSymbolFor(
      'polyline', [0, 0, 255, 255], 10, 2, 2
    ) as any;
    expect(result.symbol.type).toBe('esriSLS');
  });

  test('esriGeometryPolyline nested symbol type is esriSLS', () => {
    const result = JsonUtils.getJsonSymbolFor(
      'esriGeometryPolyline', [0, 0, 255, 255], 10, 2, 2
    ) as any;
    expect(result.symbol.type).toBe('esriSLS');
  });

  test('polygon nested symbol type is esriSFS', () => {
    const result = JsonUtils.getJsonSymbolFor(
      'polygon', [0, 255, 0, 255], 10, 2, 2
    ) as any;
    expect(result.symbol.type).toBe('esriSFS');
  });

  test('esriGeometryPolygon nested symbol type is esriSFS', () => {
    const result = JsonUtils.getJsonSymbolFor(
      'esriGeometryPolygon', [0, 255, 0, 255], 10, 2, 2
    ) as any;
    expect(result.symbol.type).toBe('esriSFS');
  });
});

// ── getSymbolJson ─────────────────────────────────────────────────────────────
describe('JsonUtils.getSymbolJson', () => {
  test('returns defined object for point', () => {
    const result = JsonUtils.getSymbolJson(
      'point', [255, 0, 0, 255], 10,
      JsonUtils.DEFAULT_SYMBOL_LINE_WIDTH,
      JsonUtils.DEFAULT_SYMBOL_POLYGON_WIDTH
    ) as any;
    expect(result).toBeDefined();
    expect(typeof result).toBe('object');
  });

  test('returns defined object for polyline', () => {
    const result = JsonUtils.getSymbolJson(
      'esriGeometryPolyline', [0, 0, 255, 255], 10,
      JsonUtils.DEFAULT_SYMBOL_LINE_WIDTH,
      JsonUtils.DEFAULT_SYMBOL_POLYGON_WIDTH
    ) as any;
    expect(result).toBeDefined();
  });

  test('returns defined object for polygon', () => {
    const result = JsonUtils.getSymbolJson(
      'esriGeometryPolygon', [0, 128, 0, 255], 10,
      JsonUtils.DEFAULT_SYMBOL_LINE_WIDTH,
      JsonUtils.DEFAULT_SYMBOL_POLYGON_WIDTH
    ) as any;
    expect(result).toBeDefined();
  });

  test('reduces alpha to 100 for polygon', () => {
    const color = [0, 128, 0, 255];
    JsonUtils.getSymbolJson('esriGeometryPolygon', color, 10, 2, 2);
    expect(color[3]).toBe(100);
  });

  test('does not reduce alpha for point', () => {
    const color = [255, 0, 0, 255];
    JsonUtils.getSymbolJson('point', color, 10, 2, 2);
    expect(color[3]).toBe(255);
  });

  test('uses widthGeomLine for polyline', () => {
    const result = JsonUtils.getSymbolJson(
      'esriGeometryPolyline', [0, 0, 0, 255], 10, 5, 2
    ) as any;
    expect(result).toBeDefined();
  });

  test('uses widthGeomPolygon for polygon', () => {
    const result = JsonUtils.getSymbolJson(
      'esriGeometryPolygon', [0, 0, 0, 100], 10, 2, 6
    ) as any;
    expect(result).toBeDefined();
  });
});

