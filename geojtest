// ── Minimal LitElement stub ──────────────────────────────────────────────────
class LitElementStub extends HTMLElement {
  static properties: Record<string, any> = {};
  private _updateCallbacks: Array<(map: Map<string, unknown>) => void> = [];

  connectedCallback() {}
  disconnectedCallback() {}
  requestUpdate() {}

  protected createRenderRoot() {
    return this;
  }

  render() {
    return null;
  }

  protected updated(_changedProps: Map<string, unknown>) {}

  // Helper used by tests to simulate property changes
  simulateUpdate(changedProps: Record<string, unknown>) {
    this.updated(new Map(Object.entries(changedProps)));
  }
}

jest.mock('lit', () => ({ LitElement: LitElementStub }));
jest.mock('lit/decorators.js', () => ({
  customElement: () => () => {},
  property: () => () => {},
}));

