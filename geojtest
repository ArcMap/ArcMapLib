describe('ArcGeoJsonLayer – initialization', () => {
  test('connectedCallback creates featureLayer and labelLayer', async () => {
    const GraphicsLayer = require('@arcgis/core/layers/GraphicsLayer').default;
    const el = await buildComponent();

    expect(GraphicsLayer).toHaveBeenCalledTimes(2); // featureLayer + labelLayer
    expect((el as any).featureLayer).toBeDefined();
    expect((el as any).labelLayer).toBeDefined();
  });

  test('view is resolved from ancestor arc-map', async () => {
    const el = await buildComponent();
    expect((el as any).view).toBeDefined();
  });

  test('featureLayer and labelLayer are added to map', async () => {
    const el = await buildComponent() as any;
    expect(el.view.map.add).toHaveBeenCalledWith(el.featureLayer);
    expect(el.view.map.add).toHaveBeenCalledWith(el.labelLayer);
  });
});

describe('ArcGeoJsonLayer – GeoJSON rendering', () => {
  const pointGeoJson = JSON.stringify({
    type: 'FeatureCollection',
    features: [
      {
        type: 'Feature',
        geometry: { type: 'Point', coordinates: [-96, 41] },
        properties: { name: 'Test Point' },
      },
    ],
  });

  test('renders point features from GeoJSON string', async () => {
    const el = await buildComponent({ geojson: pointGeoJson } as any) as any;
    expect(el.featureLayer.add).toHaveBeenCalled();
  });

  test('renders polygon features', async () => {
    const polygonGeoJson = JSON.stringify({
      type: 'FeatureCollection',
      features: [
        {
          type: 'Feature',
          geometry: {
            type: 'Polygon',
            coordinates: [[[-96, 41], [-97, 42], [-95, 42], [-96, 41]]],
          },
          properties: {},
        },
      ],
    });
    const el = await buildComponent({ geojson: polygonGeoJson } as any) as any;
    expect(el.featureLayer.add).toHaveBeenCalled();
  });

  test('renders polyline features', async () => {
    const lineGeoJson = JSON.stringify({
      type: 'FeatureCollection',
      features: [
        {
          type: 'Feature',
          geometry: {
            type: 'LineString',
            coordinates: [[-96, 41], [-97, 42]],
          },
          properties: {},
        },
      ],
    });
    const el = await buildComponent({ geojson: lineGeoJson } as any) as any;
    expect(el.featureLayer.add).toHaveBeenCalled();
  });

  test('handles invalid GeoJSON gracefully', async () => {
    const el = await buildComponent({ geojson: 'not-valid-json' } as any);
    expect((el as any).featureLayer).toBeDefined(); // should not throw
  });

  test('handles FeatureCollection object (not string)', async () => {
    const fc = {
      type: 'FeatureCollection',
      features: [
        {
          type: 'Feature',
          geometry: { type: 'Point', coordinates: [-96, 41] },
          properties: {},
        },
      ],
    };
    const el = await buildComponent({ geojson: fc } as any) as any;
    expect(el.featureLayer.add).toHaveBeenCalled();
  });
});

