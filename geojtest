// ── resolveTemplateValue ──────────────────────────────────────────────────────
describe('JsonUtils.resolveTemplateValue', () => {
  const mockGraphic = { attributes: { name: 'UP Railroad' } };

  test('returns string value directly', () => {
    const result = JsonUtils.resolveTemplateValue('Static Title', mockGraphic as any);
    expect(result).toBe('Static Title');
  });

  test('calls function and returns result', () => {
    const fn = (g: any) => `Hello ${g.attributes.name}`;
    const result = JsonUtils.resolveTemplateValue(fn, mockGraphic as any);
    expect(result).toBe('Hello UP Railroad');
  });

  test('returns empty string when function throws', () => {
    const fn = () => { throw new Error('oops'); };
    const result = JsonUtils.resolveTemplateValue(fn as any, mockGraphic as any);
    expect(result).toBe('');
  });

  test('returns empty string for undefined', () => {
    const result = JsonUtils.resolveTemplateValue(undefined as any, mockGraphic as any);
    expect(result).toBe('');
  });
});

// ── getGeoLabelJson ───────────────────────────────────────────────────────────
describe('JsonUtils.getGeoLabelJson', () => {
  test('returns label from color/size when userLabel is empty string', () => {
    const result = JsonUtils.getGeoLabelJson('', [255, 0, 0, 255], 12);
    expect(Array.isArray(result)).toBe(true);
    expect(result[0]).toHaveProperty('labelExpressionInfo');
  });

  test('returns label from color/size when userLabel is whitespace', () => {
    const result = JsonUtils.getGeoLabelJson('   ', [0, 0, 255, 255], 14);
    expect(Array.isArray(result)).toBe(true);
  });

  test('parses and returns custom label json array', () => {
    const labelArr = [
      { labelExpressionInfo: { expression: '$feature.NAME' }, symbol: { type: 'text' } }
    ];
    const result = JsonUtils.getGeoLabelJson(
      JSON.stringify(labelArr), [0, 0, 0, 255], 12
    );
    expect(Array.isArray(result)).toBe(true);
  });

  test('parses and returns single custom label json object wrapped in array', () => {
    const labelObj = {
      labelExpressionInfo: { expression: '$feature.NAME' },
      symbol: { type: 'text' }
    };
    const result = JsonUtils.getGeoLabelJson(
      JSON.stringify(labelObj), [0, 0, 0, 255], 12
    );
    expect(Array.isArray(result)).toBe(true);
  });

  test('falls back to color/size for invalid label json', () => {
    const result = JsonUtils.getGeoLabelJson('{bad json}', [0, 0, 0, 255], 12);
    expect(Array.isArray(result)).toBe(true);
    expect(result[0]).toHaveProperty('labelExpressionInfo');
  });
});

// ── normalizeLegacyLabelClass ─────────────────────────────────────────────────
describe('JsonUtils.normalizeLegacyLabelClass', () => {
  test('returns default label for null input', () => {
    const result = JsonUtils.normalizeLegacyLabelClass(null, [0, 0, 0, 255], 12);
    expect(result).toHaveProperty('labelExpressionInfo');
  });

  test('normalizes esriTS type symbol', () => {
    const labelClass = {
      labelExpressionInfo: { expression: '$feature.NAME' },
      symbol: {
        type: 'esriTS',
        color: [255, 0, 0, 255],
        font: { size: 14, family: 'Arial', weight: 'bold' },
      },
    };
    const result = JsonUtils.normalizeLegacyLabelClass(
      labelClass, [0, 0, 0, 255], 12
    );
    expect(result.symbol.type).toBe('text');
  });

  test('normalizes text type symbol', () => {
    const labelClass = {
      labelExpressionInfo: { expression: '$feature.NAME' },
      symbol: { type: 'text', color: [0, 255, 0, 255], font: { size: 10 } },
    };
    const result = JsonUtils.normalizeLegacyLabelClass(
      labelClass, [0, 0, 0, 255], 12
    );
    expect(result.symbol.type).toBe('text');
  });

  test('adds labelExpressionInfo if missing', () => {
    const labelClass = { symbol: { type: 'text', color: [0, 0, 0, 255] } };
    const result = JsonUtils.normalizeLegacyLabelClass(
      labelClass, [0, 0, 0, 255], 12
    );
    expect(result.labelExpressionInfo).toBeDefined();
    expect(result.labelExpressionInfo.expression).toBe('$feature.LABEL');
  });
});

// ── normalizeLegacyLabelSymbol ────────────────────────────────────────────────
describe('JsonUtils.normalizeLegacyLabelSymbol', () => {
  test('returns default text symbol for null', () => {
    const result = JsonUtils.normalizeLegacyLabelSymbol(null, [0, 0, 0, 255], 12);
    expect(result.type).toBe('text');
  });

  test('normalizes esriTS to text type', () => {
    const symbol = { type: 'esriTS', color: [255, 0, 0, 255], font: { size: 14 } };
    const result = JsonUtils.normalizeLegacyLabelSymbol(
      symbol, [0, 0, 0, 255], 12
    );
    expect(result.type).toBe('text');
  });

  test('normalizes text type with fallbacks', () => {
    const symbol = { type: 'text' };
    const result = JsonUtils.normalizeLegacyLabelSymbol(
      symbol, [0, 0, 255, 255], 16
    );
    expect(result.type).toBe('text');
    expect(result.font.size).toBeDefined();
  });

  test('uses user color override', () => {
    const symbol = { type: 'text', color: null };
    const result = JsonUtils.normalizeLegacyLabelSymbol(
      symbol, [200, 100, 50, 255], 12
    );
    expect(Array.isArray(result.color)).toBe(true);
  });
});

// ── updateLabelJson ───────────────────────────────────────────────────────────
describe('JsonUtils.updateLabelJson', () => {
  test('sets labelingInfo on featureLayer for valid label JSON array', () => {
    const mockFeatureLayer = { labelingInfo: null };
    const labelArr = [{ labelExpressionInfo: { expression: '$feature.NAME' } }];
    JsonUtils.updateLabelJson(JSON.stringify(labelArr), mockFeatureLayer);
    expect(mockFeatureLayer.labelingInfo).not.toBeNull();
  });

  test('does nothing for null label json', () => {
    const mockFeatureLayer = { labelingInfo: null };
    JsonUtils.updateLabelJson(null, mockFeatureLayer);
    expect(mockFeatureLayer.labelingInfo).toBeNull();
  });

  test('handles single object label json', () => {
    const mockFeatureLayer = { labelingInfo: null };
    const labelObj = { labelExpressionInfo: { expression: '$feature.NAME' } };
    JsonUtils.updateLabelJson(JSON.stringify(labelObj), mockFeatureLayer);
    expect(mockFeatureLayer.labelingInfo).not.toBeNull();
  });
});

