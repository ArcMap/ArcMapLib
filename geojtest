test('sets popupTemplate with title and details', async () => {
  const mapElement = makeMockMapElement(); // ← NOT null
  const featureLayer = makeMockFeatureLayer();
  const infoTemplate = '{"listItem":"Test Title","details":"Test Details"}';

  await PopupUtils.updatePopup(infoTemplate, mapElement as any, featureLayer as any);

  expect(featureLayer.popupTemplate).not.toBeNull();
  expect(featureLayer.popupTemplate.title).toBe('Test Title');
  expect(featureLayer.popupTemplate.content).toBe('Test Details');
});

test('sets popupTemplate with "No Details Available" if details is null', async () => {
  const mapElement = makeMockMapElement(); // ← NOT null
  const featureLayer = makeMockFeatureLayer();
  const infoTemplate = '{"listItem":"Title","details":null}';

  await PopupUtils.updatePopup(infoTemplate, mapElement as any, featureLayer as any);

  expect(featureLayer.popupTemplate).not.toBeNull();
  expect(featureLayer.popupTemplate.content).toBe('No Details Available');
});
