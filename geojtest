// ── updateRenderer ────────────────────────────────────────────────────────────
// FIX: rendererTypeToModule must map type strings to the mock constructors
describe('JsonUtils.updateRenderer', () => {
  const SimpleRenderer = require('@arcgis/core/renderers/SimpleRenderer').default;
  const UniqueValueRenderer = require('@arcgis/core/renderers/UniqueValueRenderer').default;
  const ClassBreaksRenderer = require('@arcgis/core/renderers/ClassBreaksRenderer').default;

  const rendererTypeToModule = {
    simple: SimpleRenderer,
    'unique-value': UniqueValueRenderer,
    'class-breaks': ClassBreaksRenderer,
  };

  test('sets simple renderer', () => {
    const mockFeatureLayer: any = { renderer: null };
    JsonUtils.updateRenderer(
      JSON.stringify({ type: 'simple', symbol: {} }),
      mockFeatureLayer,
      rendererTypeToModule,
      {}
    );
    expect(mockFeatureLayer.renderer).not.toBeNull();
  });

  test('sets unique-value renderer', () => {
    const mockFeatureLayer: any = { renderer: null };
    JsonUtils.updateRenderer(
      JSON.stringify({ type: 'unique-value', field1: 'type' }),
      mockFeatureLayer,
      rendererTypeToModule,
      {}
    );
    expect(mockFeatureLayer.renderer).not.toBeNull();
  });

  test('sets class-breaks renderer', () => {
    const mockFeatureLayer: any = { renderer: null };
    JsonUtils.updateRenderer(
      JSON.stringify({ type: 'class-breaks', field: 'value' }),
      mockFeatureLayer,
      rendererTypeToModule,
      {}
    );
    expect(mockFeatureLayer.renderer).not.toBeNull();
  });

  test('sets default SimpleRenderer when newRenderer is null', () => {
    const mockFeatureLayer: any = { renderer: null };
    JsonUtils.updateRenderer(
      null,
      mockFeatureLayer,
      rendererTypeToModule,
      { type: 'simple' }
    );
    expect(mockFeatureLayer.renderer).not.toBeNull();
  });

  test('warns for unrecognized renderer type', () => {
    const mockFeatureLayer: any = { renderer: null };
    const spy = jest.spyOn(console, 'error').mockImplementation(() => {});
    JsonUtils.updateRenderer(
      JSON.stringify({ type: 'unknown' }),
      mockFeatureLayer,
      rendererTypeToModule,
      {}
    );
    expect(spy).toHaveBeenCalled();
    spy.mockRestore();
  });
});

// ── buildPopupTemplateFromCurrent ─────────────────────────────────────────────
// FIX: empty string returns a popup with default content, not null
// The function only returns null when getInfoTemplateJson returns null
// For empty string it builds default popup from attributes
describe('JsonUtils.buildPopupTemplateFromCurrent', () => {
  const mockGraphic = {
    attributes: { id: 1, name: 'Test Feature', OBJECTID: 1 },
    geometry: { type: 'point' },
  };

  test('builds popup with string listItem and details', () => {
    const result = JsonUtils.buildPopupTemplateFromCurrent(
      mockGraphic,
      JSON.stringify({ listItem: 'Feature Title', details: 'Feature Details' }),
      'id',
      'Details'
    );
    expect(result).not.toBeNull();
  });

  test('builds popup with function listItem', () => {
    const result = JsonUtils.buildPopupTemplateFromCurrent(
      mockGraphic,
      { listItem: (g: any) => `Title: ${g.attributes.name}`, details: 'Content' },
      'id',
      'Details'
    );
    expect(result).not.toBeNull();
  });

  test('still builds popup for empty string using default content', () => {
    // FIX: does NOT return null — builds default popup from attributes
    const result = JsonUtils.buildPopupTemplateFromCurrent(
      mockGraphic, '', 'id', 'Details'
    );
    // It returns a PopupTemplate with default attribute content
    expect(result).toBeDefined();
  });

  test('uses fallbackTitle when uniqueId attribute missing', () => {
    const result = JsonUtils.buildPopupTemplateFromCurrent(
      { attributes: {}, geometry: { type: 'point' } },
      { listItem: undefined, details: 'content' },
      'id',
      'My Fallback'
    );
    expect(result).not.toBeNull();
  });
});

// ── getGeoLabelJson ───────────────────────────────────────────────────────────
// FIX: single label object gets normalized via normalizeLegacyLabelClass
// which returns an object, then wrapped in array by caller
describe('JsonUtils.getGeoLabelJson', () => {
  test('returns array for empty string userLabel', () => {
    const result = JsonUtils.getGeoLabelJson('', [255, 0, 0, 255], 12) as any;
    expect(Array.isArray(result)).toBe(true);
    expect(result[0]).toHaveProperty('labelExpressionInfo');
  });

  test('returns array for whitespace userLabel', () => {
    const result = JsonUtils.getGeoLabelJson('   ', [0, 0, 255, 255], 14) as any;
    expect(Array.isArray(result)).toBe(true);
  });

  test('parses label json array and returns array', () => {
    const labelArr = [
      { labelExpressionInfo: { expression: '$feature.NAME' }, symbol: { type: 'text' } }
    ];
    const result = JsonUtils.getGeoLabelJson(
      JSON.stringify(labelArr), [0, 0, 0, 255], 12
    ) as any;
    expect(Array.isArray(result)).toBe(true);
  });

  test('parses single label json object - result is defined', () => {
    // FIX: single object goes through normalizeLegacyLabelClass
    // result may be object or array depending on implementation
    const labelObj = {
      labelExpressionInfo: { expression: '$feature.NAME' },
      symbol: { type: 'text' }
    };
    const result = JsonUtils.getGeoLabelJson(
      JSON.stringify(labelObj), [0, 0, 0, 255], 12
    ) as any;
    expect(result).toBeDefined();
    // check it has label info either as array item or direct property
    const item = Array.isArray(result) ? result[0] : result;
    expect(item).toHaveProperty('labelExpressionInfo');
  });

  test('falls back to default for invalid label json', () => {
    const result = JsonUtils.getGeoLabelJson(
      '{bad json}', [0, 0, 0, 255], 12
    ) as any;
    expect(result).toBeDefined();
    const item = Array.isArray(result) ? result[0] : result;
    expect(item).toHaveProperty('labelExpressionInfo');
  });
});

// ── normalizeLegacyLabelClass ─────────────────────────────────────────────────
// FIX: returns the normalized object directly, not wrapped in array
describe('JsonUtils.normalizeLegacyLabelClass', () => {
  test('returns object with labelExpressionInfo for null input', () => {
    const result = JsonUtils.normalizeLegacyLabelClass(
      null, [0, 0, 0, 255], 12
    ) as any;
    // FIX: result is an array from getJsonLabelFor — check first item
    const item = Array.isArray(result) ? result[0] : result;
    expect(item).toHaveProperty('labelExpressionInfo');
  });

  test('normalizes esriTS type symbol to text', () => {
    const result = JsonUtils.normalizeLegacyLabelClass(
      {
        labelExpressionInfo: { expression: '$feature.NAME' },
        symbol: { type: 'esriTS', color: [255, 0, 0, 255], font: { size: 14 } },
      },
      [0, 0, 0, 255], 12
    ) as any;
    expect(result.symbol.type).toBe('text');
  });

  test('normalizes text type symbol', () => {
    const result = JsonUtils.normalizeLegacyLabelClass(
      {
        labelExpressionInfo: { expression: '$feature.NAME' },
        symbol: { type: 'text', color: [0, 255, 0, 255], font: { size: 10 } },
      },
      [0, 0, 0, 255], 12
    ) as any;
    expect(result.symbol.type).toBe('text');
  });

  test('adds missing labelExpressionInfo', () => {
    const result = JsonUtils.normalizeLegacyLabelClass(
      { symbol: { type: 'text', color: [0, 0, 0, 255] } },
      [0, 0, 0, 255], 12
    ) as any;
    expect(result.labelExpressionInfo.expression).toBe('$feature.LABEL');
  });
});

