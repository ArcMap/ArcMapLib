    graphics = {
      forEach: (cb: any) => this._items.forEach(cb),
      toArray: () => [...this._items],
      find: (cb: any) => this._items.find(cb),
      includes: (g: any) => this._items.includes(g),
      getItemAt: (i: number) => this._items[i] ?? null
    };
    constructor(props: any = {}) { Object.assign(this, props); }
    add(g: any) { this._items.push(g); }
    remove(g: any) {
