// ── getJsonSymbolFor ──────────────────────────────────────────────────────────
describe('JsonUtils.getJsonSymbolFor', () => {
  test('returns object with symbol property', () => {
    const result = JsonUtils.getJsonSymbolFor(
      'esriGeometryPoint', [255, 0, 0, 255], 10, 2, 2
    ) as any;
    expect(result).toHaveProperty('symbol');
  });

  test('point symbol type is esriSMS', () => {
    const result = JsonUtils.getJsonSymbolFor(
      'point', [255, 0, 0, 255], 10, 2, 2
    ) as any;
    expect(result.symbol.type).toBe('esriSMS');
  });

  test('multipoint symbol type is esriSMS', () => {
    const result = JsonUtils.getJsonSymbolFor(
      'multipoint', [255, 0, 0, 255], 10, 2, 2
    ) as any;
    expect(result.symbol.type).toBe('esriSMS');
  });

  test('polyline symbol type is esriSLS', () => {
    const result = JsonUtils.getJsonSymbolFor(
      'polyline', [0, 0, 255, 255], 10, 2, 2
    ) as any;
    expect(result.symbol.type).toBe('esriSLS');
  });

  test('esriGeometryLine symbol type is esriSLS', () => {
    const result = JsonUtils.getJsonSymbolFor(
      'esriGeometryLine', [0, 0, 255, 255], 10, 2, 2
    ) as any;
    expect(result.symbol.type).toBe('esriSLS');
  });

  test('polygon symbol type is esriSFS', () => {
    const result = JsonUtils.getJsonSymbolFor(
      'polygon', [0, 255, 0, 255], 10, 2, 2
    ) as any;
    expect(result.symbol.type).toBe('esriSFS');
  });

  test('wrapper type is simple', () => {
    const result = JsonUtils.getJsonSymbolFor(
      'point', [255, 0, 0, 255], 10, 2, 2
    ) as any;
    expect(result.type).toBe('simple');
  });

  test('wrapper label is LABEL', () => {
    const result = JsonUtils.getJsonSymbolFor(
      'point', [255, 0, 0, 255], 10, 2, 2
    ) as any;
    expect(result.label).toBe('LABEL');
