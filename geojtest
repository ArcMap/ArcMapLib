// ─── Import after mocks ───────────────────────────────────────────────────────

import { ArcGeojsonLayer } from './arc-geojson-layer';

// ─── Helpers ──────────────────────────────────────────────────────────────────

function makeMockView() {
  return {
    map: { add: jest.fn(), remove: jest.fn() },
    popup: { open: jest.fn(), close: jest.fn(), visible: false },
    goTo: jest.fn().mockResolvedValue(undefined),
    hitTest: jest.fn().mockResolvedValue({ results: [] }),
    on: jest.fn().mockReturnValue({ remove: jest.fn() }),
    spatialReference: { isWGS84: true }
  };
}

function makeMockArcMap(view: any) {
  return {
    componentOnReady: jest.fn().mockResolvedValue(undefined),
    getView: jest.fn().mockResolvedValue(view)
  };
}

function makePointCollection() {
  return {
    type: 'FeatureCollection',
    features: [
      {
        type: 'Feature',
        geometry: { type: 'Point', coordinates: [-93.0, 42.0] },
        properties: { id: 'f1', name: 'Feature 1', LABEL: 'Label A' }
      },
      {
        type: 'Feature',
        geometry: { type: 'Point', coordinates: [-94.0, 43.0] },
        properties: { id: 'f2', name: 'Feature 2' }
      }
    ]
  };
}

function makeLineCollection() {
  return {
    type: 'FeatureCollection',
    features: [{
      type: 'Feature',
      geometry: {
        type: 'LineString',
        coordinates: [[-93.0, 42.0], [-94.0, 43.0]]
      },
      properties: { id: 'l1' }
    }]
  };
}

function makePolygonCollection() {
  return {
    type: 'FeatureCollection',
    features: [{
      type: 'Feature',
      geometry: {
        type: 'Polygon',
        coordinates: [[[-93.0, 42.0], [-94.0, 42.0], [-94.0, 43.0], [-93.0, 42.0]]]
      },
      properties: { id: 'p1' }
    }]
  };
}

function makeMultiLineCollection() {
  return {
    type: 'FeatureCollection',
    features: [{
      type: 'Feature',
      geometry: {
        type: 'MultiLineString',
        coordinates: [
          [[-93.0, 42.0], [-94.0, 43.0]],
          [[-95.0, 44.0], [-96.0, 45.0]]
        ]
      },
      properties: { id: 'ml1' }
    }]
  };
}

function makeMultiPolygonCollection() {
  return {
    type: 'FeatureCollection',
    features: [{
      type: 'Feature',
      geometry: {
        type: 'MultiPolygon',
        coordinates: [
          [[[-93.0, 42.0], [-94.0, 42.0], [-94.0, 43.0], [-93.0, 42.0]]],
          [[[-95.0, 44.0], [-96.0, 44.0], [-96.0, 45.0], [-95.0, 44.0]]]
        ]
      },
      properties: { id: 'mp1' }
    }]
  };
}

async function makeLayer(overrides: Partial<ArcGeojsonLayer> = {}) {
  const view = makeMockView();
  const arcMap = makeMockArcMap(view);
  const layer = new ArcGeojsonLayer();

  layer.id = 'test-layer';
  layer.name = 'Test Layer';

  jest.spyOn(layer, 'closest').mockReturnValue(arcMap as any);
  Object.assign(layer, overrides);

  await layer.connectedCallback();
  return { layer, view, arcMap };
}

// ─── Test suite ───────────────────────────────────────────────────────────────

describe('ArcGeojsonLayer', () => {

  beforeEach(() => jest.clearAllMocks());

  // ── parseJson ──────────────────────────────────────────────────────────────

  describe('parseJson', () => {
    it('parses a valid JSON string', () => {
      const r = ArcGeojsonLayer.parseJson('{"a":1}');
      expect(r.parsedJson).toEqual({ a: 1 });
    });

    it('passes through an object unchanged', () => {
      const obj = { a: 1 };
      expect(ArcGeojsonLayer.parseJson(obj).parsedJson).toBe(obj);
    });

    it('passes through an array unchanged', () => {
      const arr = [1, 2, 3];
      expect(ArcGeojsonLayer.parseJson(arr).parsedJson).toBe(arr);
    });

    it('passes through a number', () => {
      expect(ArcGeojsonLayer.parseJson(42).parsedJson).toBe(42);
    });

    it('returns error for invalid JSON string', () => {
      expect(ArcGeojsonLayer.parseJson('not-json').error).toBeInstanceOf(Error);
    });

    it('returns error for null', () => {
      expect(ArcGeojsonLayer.parseJson(null).error).toBeInstanceOf(Error);
    });

    it('returns error for undefined', () => {
      expect(ArcGeojsonLayer.parseJson(undefined).error).toBeInstanceOf(Error);
    });
  });

  // ── connectedCallback ──────────────────────────────────────────────────────

  describe('connectedCallback', () => {
    it('throws if no ancestor arc-map found', async () => {
      const layer = new ArcGeojsonLayer();
      jest.spyOn(layer, 'closest').mockReturnValue(null);
      await expect(layer.connectedCallback()).rejects.toThrow('descendant');
    });

    it('throws if arc-map does not expose getView', async () => {
      const layer = new ArcGeojsonLayer();
      jest.spyOn(layer, 'closest').mockReturnValue({
        componentOnReady: jest.fn()
      } as any);
      await expect(layer.connectedCallback()).rejects.toThrow('getView');
    });

    it('throws if getView returns undefined', async () => {
      const layer = new ArcGeojsonLayer();
      jest.spyOn(layer, 'closest').mockReturnValue({
        componentOnReady: jest.fn(),
        getView: jest.fn().mockResolvedValue(undefined)
      } as any);
      await expect(layer.connectedCallback()).rejects.toThrow('returned undefined');
    });

    it('adds featureLayer and labelLayer to map', async () => {
      const { view } = await makeLayer();
      expect(view.map.add).toHaveBeenCalledTimes(2);
    });

    it('registers click event handler', async () => {
      const { view } = await makeLayer();
      const events = view.on.mock.calls.map((c: any) => c[0]);
      expect(events).toContain('click');
    });

    it('registers double-click event handler', async () => {
      const { view } = await makeLayer();
      const events = view.on.mock.calls.map((c: any) => c[0]);
      expect(events).toContain('double-click');
    });

    it('registers pointer-move event handler', async () => {
      const { view } = await makeLayer();
      const events = view.on.mock.calls.map((c: any) => c[0]);
      expect(events).toContain('pointer-move');
    });

    it('calls componentOnReady if available on arc-map', async () => {
      const { arcMap } = await makeLayer();
      expect(arcMap.componentOnReady).toHaveBeenCalled();
    });
  });

  // ── disconnectedCallback ───────────────────────────────────────────────────

  describe('disconnectedCallback', () => {
    it('removes featureLayer from map', async () => {
      const { layer, view } = await makeLayer();
      layer.disconnectedCallback();
      expect(view.map.remove).toHaveBeenCalledTimes(2);
    });

    it('calls remove on all event handles', async () => {
      const removeMock = jest.fn();
      const view = makeMockView();
      view.on.mockReturnValue({ remove: removeMock });
      const layer = new ArcGeojsonLayer();
      jest.spyOn(layer, 'closest').mockReturnValue(makeMockArcMap(view) as any);
      await layer.connectedCallback();
      layer.disconnectedCallback();
      expect(removeMock).toHaveBeenCalled();
    });

    it('cancels graphicsEditor on disconnect', async () => {
      const { layer } = await makeLayer();
      const spy = jest.spyOn((layer as any).graphicsEditor, 'cancel');
      layer.disconnectedCallback();
      expect(spy).toHaveBeenCalled();
    });

    it('clears eventHandles array after disconnect', async () => {
      const { layer } = await makeLayer();
      layer.disconnectedCallback();
      expect((layer as any).eventHandles).toHaveLength(0);
    });
  });

  // ── geojson loading ────────────────────────────────────────────────────────

  describe('geojson loading', () => {
    it('loads 2 point features', async () => {
      const { layer } = await makeLayer({ geojson: makePointCollection() as any });
      expect((layer as any).featureLayer.graphics.toArray()).toHaveLength(2);
    });

    it('loads 1 line feature', async () => {
      const { layer } = await makeLayer({ geojson: makeLineCollection() as any });
      expect((layer as any).featureLayer.graphics.toArray()).toHaveLength(1);
    });

    it('loads 1 polygon feature', async () => {
      const { layer } = await makeLayer({ geojson: makePolygonCollection() as any });
      expect((layer as any).featureLayer.graphics.toArray()).toHaveLength(1);
    });

    it('loads MultiLineString feature', async () => {
      const { layer } = await makeLayer({ geojson: makeMultiLineCollection() as any });
      expect((layer as any).featureLayer.graphics.toArray()).toHaveLength(1);
    });

    it('loads MultiPolygon feature', async () => {
      const { layer } = await makeLayer({ geojson: makeMultiPolygonCollection() as any });
      expect((layer as any).featureLayer.graphics.toArray()).toHaveLength(1);
    });

    it('accepts geojson as JSON string', async () => {
      const { layer } = await makeLayer({
        geojson: JSON.stringify(makePointCollection()) as any
      });
      expect((layer as any).featureLayer.graphics.toArray()).toHaveLength(2);
    });

    it('handles empty FeatureCollection', async () => {
      const { layer } = await makeLayer({
        geojson: { type: 'FeatureCollection', features: [] } as any
      });
      expect((layer as any).featureLayer.graphics.toArray()).toHaveLength(0);
    });

    it('assigns OBJECTID to features missing it', async () => {
      const { layer } = await makeLayer({ geojson: makePointCollection() as any });
      (layer as any).featureLayer.graphics.toArray().forEach((g: any) => {
        expect(g.attributes.OBJECTID).toBeDefined();
      });
    });

    it('assigns uniqueIdPropertyName value to features missing it', async () => {
      const { layer } = await makeLayer({ geojson: makePointCollection() as any });
      (layer as any).featureLayer.graphics.toArray().forEach((g: any) => {
        expect(g.attributes[(layer as any).uniqueIdPropertyName]).toBeDefined();
      });
    });
  });

  // ── updateGeojson ──────────────────────────────────────────────────────────

  describe('updateGeojson', () => {
    it('replaces graphics when geojson changes', async () => {
      const { layer } = await makeLayer({ geojson: makePointCollection() as any });
      await layer.updateGeojson({
        type: 'FeatureCollection',
        features: [{
          type: 'Feature',
          geometry: { type: 'Point', coordinates: [-90.0, 40.0] },
          properties: { id: 'new-1' }
        }]
      } as any);
      expect((layer as any).featureLayer.graphics.toArray()).toHaveLength(1);
    });

    it('skips update when enableUserEdit is true', async () => {
      const { layer } = await makeLayer({
        geojson: makePointCollection() as any,
        enableUserEdit: true
      });
      const spy = jest.spyOn((layer as any).featureLayer, 'removeAll');
      await layer.updateGeojson({ type: 'FeatureCollection', features: [] } as any);
      expect(spy).not.toHaveBeenCalled();
    });

    it('skips update when inDrawingMode is true', async () => {
      const { layer } = await makeLayer({ geojson: makePointCollection() as any });
      (layer as any).inDrawingMode = true;
      const spy = jest.spyOn((layer as any).featureLayer, 'removeAll');
      await layer.updateGeojson({ type: 'FeatureCollection', features: [] } as any);
      expect(spy).not.toHaveBeenCalled();
    });

    it('skips update when blockGeoJsonUpdate is true', async () => {
      const { layer } = await makeLayer({ geojson: makePointCollection() as any });
      (layer as any).blockGeoJsonUpdate = true;
      const spy = jest.spyOn((layer as any).featureLayer, 'removeAll');
      await layer.updateGeojson({ type: 'FeatureCollection', features: [] } as any);
      expect(spy).not.toHaveBeenCalled();
    });

    it('clears label layer on update', async () => {
      const { layer } = await makeLayer({ geojson: makePointCollection() as any });
      const spy = jest.spyOn((layer as any).labelLayer, 'removeAll');
      await layer.updateGeojson({ type: 'FeatureCollection', features: [] } as any);
      expect(spy).toHaveBeenCalled();
    });
  });

  // ── labels ─────────────────────────────────────────────────────────────────

  describe('labels', () => {
    it('creates 1 label for feature with LABEL attribute', async () => {
      const { layer } = await makeLayer({ geojson: makePointCollection() as any });
      expect((layer as any).labelLayer.graphics.toArray()).toHaveLength(1);
    });

    it('creates no labels when no features have LABEL', async () => {
      const { layer } = await makeLayer({ geojson: makeLineCollection() as any });
      expect((layer as any).labelLayer.graphics.toArray()).toHaveLength(0);
    });

    it('refreshes labels after updateGeojson', async () => {
      const { layer } = await makeLayer({ geojson: makePointCollection() as any });
      await layer.updateGeojson({
        type: 'FeatureCollection',
        features: [{
          type: 'Feature',
          geometry: { type: 'Point', coordinates: [-90.0, 40.0] },
          properties: { id: 'x', LABEL: 'New Label' }
        }]
      } as any);
      expect((layer as any).labelLayer.graphics.toArray()).toHaveLength(1);
    });

    it('clears labels when updated geojson has no LABEL', async () => {
      const { layer } = await makeLayer({ geojson: makePointCollection() as any });
      await layer.updateGeojson({
        type: 'FeatureCollection',
        features: [{
          type: 'Feature',
          geometry: { type: 'Point', coordinates: [-90.0, 40.0] },
          properties: { id: 'x' }
        }]
      } as any);
      expect((layer as any).labelLayer.graphics.toArray()).toHaveLength(0);
    });
  });

  // ── renderer ───────────────────────────────────────────────────────────────

  describe('updateRenderer', () => {
    it('applies renderer symbol to each graphic', async () => {
      const { layer } = await makeLayer({ geojson: makePointCollection() as any });
      layer.updateRenderer(JSON.stringify({
        type: 'simple',
        symbol: { type: 'esriSMS', style: 'esriSMSTriangle', color: [255, 0, 0, 255], size: 35 }
      }));
      (layer as any).featureLayer.graphics.toArray().forEach((g: any) => {
        expect(g.symbol).toBeDefined();
      });
    });

    it('falls back to default symbol when renderer JSON is invalid', async () => {
      const { layer } = await makeLayer({ geojson: makePointCollection() as any });
      layer.updateRenderer('not-valid-json');
      (layer as any).featureLayer.graphics.toArray().forEach((g: any) => {
        expect(g.symbol).toBeDefined();
      });
    });

    it('falls back to default symbol when fromJSON throws', async () => {
      const jsonUtils = require('@arcgis/core/renderers/support/jsonUtils');
      jsonUtils.fromJSON.mockImplementationOnce(() => { throw new Error('bad'); });
      const { layer } = await makeLayer({ geojson: makePointCollection() as any });
      layer.updateRenderer({ type: 'simple', symbol: {} });
      (layer as any).featureLayer.graphics.toArray().forEach((g: any) => {
        expect(g.symbol).toBeDefined();
      });
    });

    it('does nothing when featureLayer is not initialized', async () => {
      const layer = new ArcGeojsonLayer();
      expect(() => layer.updateRenderer({})).not.toThrow();
    });
  });

  // ── findFeatureByUniqueId ──────────────────────────────────────────────────

  describe('findFeatureByUniqueId', () => {
    it('finds feature by id', async () => {
      const { layer } = await makeLayer({ geojson: makePointCollection() as any });
      const result = await layer.findFeatureByUniqueId('f1');
      expect(result).toBeDefined();
      expect(result?.attributes?.id).toBe('f1');
    });

    it('returns undefined for unknown id', async () => {
      const { layer } = await makeLayer({ geojson: makePointCollection() as any });
      const result = await layer.findFeatureByUniqueId('does-not-exist');
      expect(result).toBeUndefined();
    });
  });

  // ── getLayerId ─────────────────────────────────────────────────────────────

  describe('getLayerId', () => {
    it('returns featureLayer id', async () => {
      const { layer } = await makeLayer();
      const id = await layer.getLayerId();
      expect(id).toBe('test-layer-graphics');
    });
  });

  // ── updateLayerClass ───────────────────────────────────────────────────────

  describe('updateLayerClass', () => {
    it('sets className on featureLayer', async () => {
      const { layer } = await makeLayer();
      layer.updateLayerClass('my-class');
      expect((layer as any).featureLayer.className).toBe('my-class');
    });

    it('sets className on labelLayer with -labels suffix', async () => {
      const { layer } = await makeLayer();
      layer.updateLayerClass('my-class');
      expect((layer as any).labelLayer.className).toBe('my-class-labels');
    });
  });

  // ── updateEditing ──────────────────────────────────────────────────────────

  describe('updateEditing', () => {
    it('nulls popupTemplates when enableUserEdit turns on', async () => {
      const { layer } = await makeLayer({ geojson: makePointCollection() as any });
      await layer.updateEditing(true);
      (layer as any).featureLayer.graphics.toArray().forEach((g: any) => {
        expect(g.popupTemplate).toBeNull();
      });
    });

    it('cancels active graphicsEditor', async () => {
      const { layer } = await makeLayer();
      (layer as any).graphicsEditor.state = 'active';
      const spy = jest.spyOn((layer as any).graphicsEditor, 'cancel');
      await layer.updateEditing(false);
      expect(spy).toHaveBeenCalled();
    });

    it('does not cancel if editor is not active', async () => {
      const { layer } = await makeLayer();
      (layer as any).graphicsEditor.state = 'idle';
      const spy = jest.spyOn((layer as any).graphicsEditor, 'cancel');
      await layer.updateEditing(false);
      expect(spy).not.toHaveBeenCalled();
    });
  });

  // ── startDrawing / cancelDrawing ───────────────────────────────────────────

  describe('drawing', () => {
    it('sets inDrawingMode true on startDrawing', async () => {
      const { layer } = await makeLayer();
      await layer.startDrawing('POINT');
      expect((layer as any).inDrawingMode).toBe(true);
    });

    it('calls create with point tool', async () => {
      const { layer } = await makeLayer();
      const spy = jest.spyOn((layer as any).graphicsEditor, 'create');
      await layer.startDrawing('POINT');
      expect(spy).toHaveBeenCalledWith('point');
    });

    it('calls create with polyline tool', async () => {
      const { layer } = await makeLayer();
      const spy = jest.spyOn((layer as any).graphicsEditor, 'create');
      await layer.startDrawing('POLYLINE');
      expect(spy).toHaveBeenCalledWith('polyline');
    });

    it('calls create with polygon tool', async () => {
      const { layer } = await makeLayer();
      const spy = jest.spyOn((layer as any).graphicsEditor, 'create');
      await layer.startDrawing('POLYGON');
      expect(spy).toHaveBeenCalledWith('polygon');
    });

    it('calls create with rectangle tool', async () => {
      const { layer } = await makeLayer();
      const spy = jest.spyOn((layer as any).graphicsEditor, 'create');
      await layer.startDrawing('RECTANGLE');
      expect(spy).toHaveBeenCalledWith('rectangle');
    });

    it('calls create with circle tool', async () => {
      const { layer } = await makeLayer();
      const spy = jest.spyOn((layer as any).graphicsEditor, 'create');
      await layer.startDrawing('CIRCLE');
      expect(spy).toHaveBeenCalledWith('circle');
    });

    it('sets inDrawingMode false on cancelDrawing', async () => {
      const { layer } = await makeLayer();
      await layer.startDrawing('POINT');
      await layer.cancelDrawing();
      expect((layer as any).inDrawingMode).toBe(false);
    });

    it('calls graphicsEditor.cancel on cancelDrawing', async () => {
      const { layer } = await makeLayer();
      const spy = jest.spyOn((layer as any).graphicsEditor, 'cancel');
      await layer.cancelDrawing();
      expect(spy).toHaveBeenCalled();
    });

    it('does not start drawing if geometry type mismatch', async () => {
      const { layer } = await makeLayer({ geojson: makePointCollection() as any });
      const spy = jest.spyOn((layer as any).graphicsEditor, 'create');
      await layer.startDrawing('POLYGON');
      expect(spy).not.toHaveBeenCalled();
    });
  });

  // ── enableInfoPopupWindow ──────────────────────────────────────────────────

  describe('enableInfoPopupWindow', () => {
    it('closes popup when enable is false and popup is visible', async () => {
      const { layer, view } = await makeLayer();
      view.popup.visible = true;
      layer.enableInfoPopupWindow(false);
      expect(view.popup.close).toHaveBeenCalled();
    });

    it('does not close popup when enable is true', async () => {
      const { layer, view } = await makeLayer();
      view.popup.visible = true;
      layer.enableInfoPopupWindow(true);
      expect(view.popup.close).not.toHaveBeenCalled();
    });

    it('does not close popup when popup is not visible', async () => {
      const { layer, view } = await makeLayer();
      view.popup.visible = false;
      layer.enableInfoPopupWindow(false);
      expect(view.popup.close).not.toHaveBeenCalled();
    });
  });

  // ── zoomTo ─────────────────────────────────────────────────────────────────

  describe('zoomTo', () => {
    it('calls goTo with center and zoom for point', async () => {
      const { layer, view } = await makeLayer({ geojson: makePointCollection() as any });
      await layer.zoomTo('f1', 10);
      expect(view.goTo).toHaveBeenCalledWith(
        expect.objectContaining({ zoom: 10 })
      );
    });

    it('does nothing for unknown id', async () => {
      const { layer, view } = await makeLayer({ geojson: makePointCollection() as any });
      await layer.zoomTo('unknown');
      expect(view.goTo).not.toHaveBeenCalled();
    });
  });

