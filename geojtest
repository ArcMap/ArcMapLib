    proto.updateRenderer = jest.fn();
    el.updated(new Map([['renderer', '{}']]));
    expect(proto.updateRenderer).toHaveBeenCalled();
    delete proto.updateRenderer;
  });

  test('updateLabelJson called when labelJson changes', async () => {
    const el = await buildComponent() as any;
    const proto = Object.getPrototypeOf(el);
    proto.updateLabelJson = jest.fn();
    el.updated(new Map([['labelJson', '{}']]));
    expect(proto.updateLabelJson).toHaveBeenCalled();
    delete proto.updateLabelJson;
  });

  test('refreshLabels called when labelColor changes', async () => {
    const el = await buildComponent() as any;
    const proto = Object.getPrototypeOf(el);
    proto.refreshLabels = jest.fn();
    el.updated(new Map([['labelColor', '[255,0,0]']]));
    expect(proto.refreshLabels).toHaveBeenCalled();
    delete proto.refreshLabels;
  });

  test('refreshLabels called when labelSize changes', async () => {
    const el = await buildComponent() as any;
    const proto = Object.getPrototypeOf(el);
    proto.refreshLabels = jest.fn();
    el.updated(new Map([['labelSize', 14]]));
    expect(proto.refreshLabels).toHaveBeenCalled();
    delete proto.refreshLabels;
  });

  test('updateEditing called when enableUserEdit changes', async () => {
    const el = await buildComponent() as any;
    const proto = Object.getPrototypeOf(el);
    proto.updateEditing = jest.fn().mockResolvedValue(undefined);
    el.updated(new Map([['enableUserEdit', true]]));
    expect(proto.updateEditing).toHaveBeenCalled();
    delete proto.updateEditing;
  });
});
