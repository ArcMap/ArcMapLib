// ── clonePlain ────────────────────────────────────────────────────────────────
describe('JsonUtils.clonePlain', () => {
  test('deep clones an object', () => {
    const original = { a: { b: 1 } };
    const clone = JsonUtils.clonePlain(original);
    expect(clone).toEqual(original);
    expect(clone).not.toBe(original);
  });

  test('returns null as-is', () => {
    expect(JsonUtils.clonePlain(null)).toBeNull();
  });

  test('returns undefined as-is', () => {
    expect(JsonUtils.clonePlain(undefined)).toBeUndefined();
  });
});

// ── resolveLabelColor ─────────────────────────────────────────────────────────
describe('JsonUtils.resolveLabelColor', () => {
  test('returns color array when given a valid number[] of 4', () => {
    const result = JsonUtils.resolveLabelColor([255, 0, 0, 255]);
    expect(result).toEqual([255, 0, 0, 255]);
  });

  test('returns color array when given a valid number[] of 3', () => {
    const result = JsonUtils.resolveLabelColor([100, 150, 200]);
    expect(result[0]).toBe(100);
    expect(result[1]).toBe(150);
    expect(result[2]).toBe(200);
    expect(result[3]).toBe(255);
  });

  test('parses color from JSON string', () => {
    const result = JsonUtils.resolveLabelColor('[255, 128, 0, 255]');
    expect(result[0]).toBe(255);
    expect(result[1]).toBe(128);
  });

  test('returns default [0,0,0,255] for invalid input', () => {
    const result = JsonUtils.resolveLabelColor('not-a-color');
    expect(result).toEqual([0, 0, 0, 255]);
  });

  test('returns default array for undefined', () => {
    const result = JsonUtils.resolveLabelColor(undefined as any);
    expect(Array.isArray(result)).toBe(true);
  });
});

