// ── getJsonLabelFor ───────────────────────────────────────────────────────────
describe('JsonUtils.getJsonLabelFor', () => {
  test('returns an array', () => {
    const result: any[] = JsonUtils.getJsonLabelFor([255, 0, 0, 255], 12) as any[];
    expect(Array.isArray(result)).toBe(true);
    expect(result.length).toBeGreaterThan(0);
  });

  test('first element has labelExpressionInfo', () => {
    const result: any[] = JsonUtils.getJsonLabelFor([255, 0, 0, 255], 12) as any[];
    expect(result[0]).toHaveProperty('labelExpressionInfo');
  });

  test('labelExpressionInfo expression is $feature.LABEL', () => {
    const result: any[] = JsonUtils.getJsonLabelFor([255, 0, 0, 255], 12) as any[];
    expect(result[0].labelExpressionInfo.expression).toBe('$feature.LABEL');
  });

  test('symbol exists on first element', () => {
    const result: any[] = JsonUtils.getJsonLabelFor([0, 0, 0, 255], 10) as any[];
    expect(result[0]).toHaveProperty('symbol');
  });

  test('symbol type is text', () => {
    const result: any[] = JsonUtils.getJsonLabelFor([0, 0, 0, 255], 10) as any[];
    expect(result[0].symbol.type).toBe('text');
  });

  test('symbol font exists', () => {
    const result: any[] = JsonUtils.getJsonLabelFor([0, 0, 0, 255], 16) as any[];
    expect(result[0].symbol).toHaveProperty('font');
  });

  test('symbol font size matches input', () => {
    const result: any[] = JsonUtils.getJsonLabelFor([0, 0, 0, 255], 16) as any[];
    expect(result[0].symbol.font.size).toBe(16);
  });

  test('symbol has haloColor black', () => {
    const result: any[] = JsonUtils.getJsonLabelFor([0, 0, 0, 255], 12) as any[];
    expect(result[0].symbol.haloColor).toBe('black');
  });

  test('symbol has xoffset 3', () => {
    const result: any[] = JsonUtils.getJsonLabelFor([0, 0, 0, 255], 12) as any[];
    expect(result[0].symbol.xoffset).toBe(3);
  });

  test('symbol has yoffset 3', () => {
    const result: any[] = JsonUtils.getJsonLabelFor([0, 0, 0, 255], 12) as any[];
    expect(result[0].symbol.yoffset).toBe(3);
  });
});

