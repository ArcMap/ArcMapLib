// ── getRandomColor ────────────────────────────────────────────────────────────
describe('JsonUtils.getRandomColor', () => {
  test('returns array of 4 numbers', () => {
    const color = JsonUtils.getRandomColor();
    expect(Array.isArray(color)).toBe(true);
    expect(color).toHaveLength(4);
  });

  test('each value is between 0 and 255', () => {
    const color = JsonUtils.getRandomColor();
    color.forEach((v) => {
      expect(v).toBeGreaterThanOrEqual(0);
      expect(v).toBeLessThanOrEqual(255);
    });
  });

  test('last value alpha is 255', () => {
    const color = JsonUtils.getRandomColor();
    expect(color[3]).toBe(255);
  });
});

// ── getGeoJsonFor ─────────────────────────────────────────────────────────────
describe('JsonUtils.getGeoJsonFor', () => {
  test('returns parsedJson for valid JSON string', () => {
    const result = JsonUtils.getGeoJsonFor('{"type":"Point"}');
    expect(result.parsedJson).toEqual({ type: 'Point' });
    expect(result.error).toBeUndefined();
  });

  test('returns parsedJson for object input', () => {
    const obj = { type: 'FeatureCollection', features: [] };
    const result = JsonUtils.getGeoJsonFor(obj);
    expect(result.parsedJson).toEqual(obj);
  });

  test('returns error for invalid JSON string', () => {
    const result = JsonUtils.getGeoJsonFor('not-valid-json{{{');
    expect(result.error).toBeDefined();
    expect(result.parsedJson).toBeUndefined();
  });

  test('returns parsedJson undefined for null', () => {
    const result = JsonUtils.getGeoJsonFor(null);
    expect(result.parsedJson).toBeUndefined();
  });

  test('returns parsedJson undefined for undefined', () => {
    const result = JsonUtils.getGeoJsonFor(undefined);
    expect(result.parsedJson).toBeUndefined();
  });

  test('returns parsedJson undefined for empty string', () => {
    const result = JsonUtils.getGeoJsonFor('   ');
    expect(result.parsedJson).toBeUndefined();
  });
});

