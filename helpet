
// NOTE: replace existing doubleClick dispatchEvent with this
// adds mapPoint coordinates to match the docs' expected detail shape
this.dispatchEvent(new CustomEvent('doubleClick', {
  detail: {
    graphic,
    uniqueId,
    attributes: graphic.attributes ?? {},
    mapPoint: {
      x: evt.clientX - rect.left,
      y: evt.clientY - rect.top
    }
  },
  bubbles: true,
  composed: true
}));


// NOTE: entirely new — add after the view.on('click') handle block
// Tracks which graphic the mouse is currently over to avoid
// firing mouseOver repeatedly for the same graphic.
let currentHoveredId: string | number | null = null;

this.handles.add(
  this.view.on('pointer-move', async (event: any) => {
    if (!this.view || this.inDrawingMode || this.editorActive) return;

    const hit = await this.view.hitTest(event);
    const result = (hit.results ?? []).find((r: any) =>
      r?.type === 'graphic' && r?.graphic?.layer === this.displayLayer
    ) as any;

    const graphic = result?.graphic as Graphic | undefined;
    const uniqueId = graphic?.attributes?.[this.uniqueIdPropertyName] ?? null;

    if (graphic && uniqueId !== currentHoveredId) {
      // Fired mouseOut for the previously hovered graphic
      if (currentHoveredId !== null) {
        const prevGraphic = this.findDisplayGraphic(currentHoveredId);
        this.dispatchEvent(new CustomEvent('layerMouseOut', {
          detail: {
            graphic: prevGraphic ?? null,
            uniqueId: currentHoveredId,
            attributes: prevGraphic?.attributes ?? {}
          },
          bubbles: true,
          composed: true
        }));
      }

      // Fire mouseOver for newly hovered graphic
      currentHoveredId = uniqueId;
      this.dispatchEvent(new CustomEvent('layerMouseOver', {
        detail: {
          graphic,
          uniqueId,
          attributes: graphic.attributes ?? {},
          mapPoint: hit.results[0]?.mapPoint ?? null
        },
        bubbles: true,
        composed: true
      }));

      // Change cursor to pointer to signal interactivity
      if (this.view) {
        (this.view as any).cursor = 'pointer';
      }

    } else if (!graphic && currentHoveredId !== null) {
      // Mouse left a feature and is now over empty map
      const prevGraphic = this.findDisplayGraphic(currentHoveredId);
      this.dispatchEvent(new CustomEvent('layerMouseOut', {
        detail: {
          graphic: prevGraphic ?? null,
          uniqueId: currentHoveredId,
          attributes: prevGraphic?.attributes ?? {}
        },
        bubbles: true,
        composed: true
      }));

      currentHoveredId = null;

      // Restore default cursor
      if (this.view) {
        (this.view as any).cursor = 'default';
      }
    }
  }),
  'pointer-move'
);
