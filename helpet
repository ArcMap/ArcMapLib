// NOTE: add this right after this.view.map?.add(this.displayLayer)
if (this.layerClass) {
  (this.displayLayer as any).layerClass = this.layerClass;
}

// NOTE: add this block alongside the other changed.has() blocks
if (changed.has('layerClass')) {
  this.applyLayerClass(this.layerClass);
}

// NOTE: entirely new method.
// GraphicsLayer does not have a built-in className prop like FeatureLayer.
// We wait for the view to finish rendering then find the layer's
// DOM container and apply the CSS class directly to it.
private applyLayerClass(className: string): void {
  if (!this.view || !this.displayLayer) return;

  // Use whenLayerView to get the LayerView, then find its container
  (this.view as any).whenLayerView(this.displayLayer)
    .then((layerView: any) => {
      // The underlying canvas/svg container is on the layerView
      const el =
        layerView?.container?.element ??   // ArcGIS 4.x canvas renderer
        layerView?.container ??
        null;

      if (!el) {
        // Fallback: search the view's container for the layer's element
        const viewContainer = (this.view as any).container as HTMLElement | null;
        if (!viewContainer) return;

        // ArcGIS renders each GraphicsLayer into a <canvas> or <div>
        // tagged with the layer id
        const layerId = (this.displayLayer as any).id;
        const layerEl = viewContainer.querySelector(
          `[data-layer-id="${layerId}"], #${layerId}`
        ) as HTMLElement | null;

        if (layerEl && className) {
          // Clear old classes first
          layerEl.className = layerEl.className
            .split(' ')
            .filter(c => !c.startsWith('gc-'))  // remove old layer classes
            .join(' ');
          layerEl.classList.add(className);
        }
        return;
      }

      if (className) {
        (el as HTMLElement).classList.add(className);
      }
    })
    .catch(() => {
      // LayerView not ready yet — retry after view is ready
      if (typeof (this.view as any).when === 'function') {
        (this.view as any).when().then(() => this.applyLayerClass(className));
      }
    });
}

// NOTE: add before displayLayer is destroyed
if (this.layerClass && this.view && this.displayLayer) {
  (this.view as any).whenLayerView(this.displayLayer)
    .then((layerView: any) => {
      const el = layerView?.container?.element ?? layerView?.container;
      if (el) (el as HTMLElement).classList.remove(this.layerClass);
    })
    .catch(() => {/* ignore on disconnect */});
}
