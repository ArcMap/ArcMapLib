private zoomWidget: Zoom | null = null;
private locateWidget: Locate | null = null;
private homeWidget: Home | null = null;
private scaleBar: ScaleBar | null = null;
private syncMapWidgets(): void {
  if (!this.view) return;

  // ZOOM
  if (this.showZoom) {
    if (!this.zoomWidget) {
      this.zoomWidget = new Zoom({
        view: this.view,
        id: 'arc-zoom',
      });

      this.view.ui.add(this.zoomWidget, {
        position: 'bottom-left',
        index: 0,
      });
    }
  } else if (this.zoomWidget) {
    this.view.ui.remove(this.zoomWidget);
    this.zoomWidget.destroy();
    this.zoomWidget = null;
  }

  // LOCATE
  if (this.showLocate) {
    if (!this.locateWidget) {
      this.locateWidget = new Locate({
        view: this.view,
        id: 'arc-locate',
      });

      this.view.ui.add(this.locateWidget, {
        position: 'bottom-left',
        index: 1,
      });
    }
  } else if (this.locateWidget) {
    this.view.ui.remove(this.locateWidget);
    this.locateWidget.destroy();
    this.locateWidget = null;
  }

  // HOME
  if (this.showHome) {
    if (!this.homeWidget) {
      this.homeWidget = new Home({
        view: this.view,
        id: 'arc-home',
      });

      this.view.ui.add(this.homeWidget, {
        position: 'bottom-left',
        index: 2,
      });
    }
  } else if (this.homeWidget) {
    this.view.ui.remove(this.homeWidget);
    this.homeWidget.destroy();
    this.homeWidget = null;
  }

  // SCALE BAR
  if (this.showScaleBar) {
    if (!this.scaleBar) {
      this.scaleBar = new ScaleBar({
        view: this.view,
        unit: 'dual',
      });

      this.view.ui.add(this.scaleBar, {
        position: 'bottom-left',
        index: 3,
      });
    }
  } else if (this.scaleBar) {
    this.view.ui.remove(this.scaleBar);
    this.scaleBar.destroy();
    this.scaleBar = null;
  }
}

protected updated(changedProperties: PropertyValues): void {
  if (
    changedProperties.has('showZoom') ||
    changedProperties.has('showLocate') ||
    changedProperties.has('showHome') ||
    changedProperties.has('showScaleBar')
  ) {
    this.syncMapWidgets();
  }
}

disconnectedCallback(): void {
  super.disconnectedCallback();

  if (this.zoomWidget) {
    this.view?.ui.remove(this.zoomWidget);
    this.zoomWidget.destroy();
    this.zoomWidget = null;
  }

  if (this.locateWidget) {
    this.view?.ui.remove(this.locateWidget);
    this.locateWidget.destroy();
    this.locateWidget = null;
  }

  if (this.homeWidget) {
    this.view?.ui.remove(this.homeWidget);
    this.homeWidget.destroy();
    this.homeWidget = null;
  }

  if (this.scaleBar) {
    this.view?.ui.remove(this.scaleBar);
    this.scaleBar.destroy();
    this.scaleBar = null;
  }
}
