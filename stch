// Get ALL properties of up-autocomplete
const el = document.querySelector('up-autocomplete');
const allProps = [];
let obj = el;
while(obj) {
  Object.getOwnPropertyNames(obj).forEach(p => {
    if(!allProps.includes(p)) allProps.push(p);
  });
  obj = Object.getPrototypeOf(obj);
}
console.log(allProps.filter(p => 
  !['constructor','toString','valueOf'].includes(p)
));
