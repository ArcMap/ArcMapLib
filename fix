async connectedCallback(): Promise<void> {
  super.connectedCallback();

  try {
    this.ancestormap = this.closest('arc-map') as any;

    if (!this.ancestormap) {
      console.error('arc-geojson-layer must be inside arc-map');
      return;
    }

    await this.ancestormap.updateComplete;

    // ✅ WAIT for view
    await this._getView();

    console.log('VIEW READY', this.view);

    // ✅ ONLY AFTER view exists
    this.createLayer(this.geojson);

  } catch (e) {
    console.error('connectedCallback error', e);
  }
}

private async _getView(): Promise<MapView> {
  if (!this.ancestormap?.getViewInstance) {
    throw new Error('arc-map must expose getViewInstance()');
  }

  const view = await this.ancestormap.getViewInstance();

  if (!view) {
    throw new Error('getViewInstance returned null');
  }

  this.view = view;
  return view;
}

if (!this.view || !this.view.map) {
  console.error('createLayer blocked: view/map not ready');
  return;
}