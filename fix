import { LitElement, html } from 'lit';
import { customElement, property } from 'lit/decorators.js';

import Graphic from '@arcgis/core/Graphic';
import GraphicsLayer from '@arcgis/core/layers/GraphicsLayer';
import MapView from '@arcgis/core/views/MapView';
import Point from '@arcgis/core/geometry/Point';
import Polyline from '@arcgis/core/geometry/Polyline';
import Polygon from '@arcgis/core/geometry/Polygon';
import Multipoint from '@arcgis/core/geometry/Multipoint';
import Extent from '@arcgis/core/geometry/Extent';
import PopupTemplate from '@arcgis/core/PopupTemplate';
import SketchViewModel from '@arcgis/core/widgets/Sketch/SketchViewModel';
import * as webMercatorUtils from '@arcgis/core/geometry/support/webMercatorUtils';
import SimpleMarkerSymbol from '@arcgis/core/symbols/SimpleMarkerSymbol';
import SimpleLineSymbol from '@arcgis/core/symbols/SimpleLineSymbol';
import SimpleFillSymbol from '@arcgis/core/symbols/SimpleFillSymbol';
import TextSymbol from '@arcgis/core/symbols/TextSymbol';

type GeoJsonPointGeometry = {
  type: 'Point';
  coordinates: number[];
};

type GeoJsonMultiPointGeometry = {
  type: 'MultiPoint';
  coordinates: number[][];
};

type GeoJsonLineStringGeometry = {
  type: 'LineString';
  coordinates: number[][];
};

type GeoJsonMultiLineStringGeometry = {
  type: 'MultiLineString';
  coordinates: number[][][];
};

type GeoJsonPolygonGeometry = {
  type: 'Polygon';
  coordinates: number[][][];
};

type GeoJsonMultiPolygonGeometry = {
  type: 'MultiPolygon';
  coordinates: number[][][][];
};

type GeoJsonGeometry =
  | GeoJsonPointGeometry
  | GeoJsonMultiPointGeometry
  | GeoJsonLineStringGeometry
  | GeoJsonMultiLineStringGeometry
  | GeoJsonPolygonGeometry
  | GeoJsonMultiPolygonGeometry;

type Feature = {
  type: 'Feature';
  geometry: GeoJsonGeometry;
  properties: Record<string, any>;
};

type FeatureCollection = {
  type: 'FeatureCollection';
  features: Feature[];
};

type InfoTemplateDetails = {
  listItem: string | ((graphic: Graphic) => string);
  details: string | ((graphic: Graphic) => string);
};

type LayerMouseEvent = {
  coordinates: {
    latitude: number;
    longitude: number;
  };
  attributes: any;
};

type PopupEvent = {
  features: Graphic[];
  selectedIndex: number;
};

type ArcLayerGeometry = Point | Polyline | Polygon | Multipoint | Extent;

type ArcMapElement = HTMLElement & {
  getViewInstant?: () => Promise<MapView> | MapView;
};

enum DrawGeometryTypes {
  FREEHAND_POLYLINE = 'FREEHAND_POLYLINE',
  LINE = 'LINE',
  POLYLINE = 'POLYLINE',
  MULTI_POINT = 'MULTI_POINT',
  POINT = 'POINT',
  ARROW = 'ARROW',
  CIRCLE = 'CIRCLE',
  DOWN_ARROW = 'DOWN_ARROW',
  ELLIPSE = 'ELLIPSE',
  EXTENT = 'EXTENT',
  FREEHAND_POLYGON = 'FREEHAND_POLYGON',
  LEFT_ARROW = 'LEFT_ARROW',
  POLYGON = 'POLYGON',
  RECTANGLE = 'RECTANGLE',
  RIGHT_ARROW = 'RIGHT_ARROW',
  TRIANGLE = 'TRIANGLE',
  UP_ARROW = 'UP_ARROW'
}

@customElement('arc-geojson-layer')
export class ArcGeojsonLayer extends LitElement {
  private static readonly DEFAULT_SYMBOL_COLOR: number[] = [0, 0, 255, 255];
  private static readonly DEFAULT_LABEL_SIZE = 10;
  private static readonly DEFAULT_SYMBOL_MARKER_SIZE = 12;
  private static readonly DEFAULT_SYMBOL_LINE_WIDTH = 2;
  private static readonly DEFAULT_SYMBOL_POLYGON_WIDTH = 2;

  @property({ attribute: false })
  geojson: string | FeatureCollection = {
    type: 'FeatureCollection',
    features: []
  };

  @property({ attribute: false })
  infoTemplate: string | InfoTemplateDetails | null = null;

  @property({ attribute: false })
  labelcolor: string | number[] = '';

  @property({ attribute: false })
  labeljson: string | object | object[] = '';

  @property({ type: Number })
  labelsize = ArcGeojsonLayer.DEFAULT_LABEL_SIZE;

  @property({ type: String })
  layerClass = '';

  @property({ type: String })
  name = '';

  @property({ attribute: false })
  renderer: any = null;

  @property({ type: String })
  uniqueIdPropertyName = 'id';

  @property({ type: Boolean })
  enableUserEdit = false;

  @property({ type: Boolean })
  enableUserEditMove = true;

  @property({ type: Boolean })
  enableUserEditRemove = true;

  @property({ type: Boolean })
  enableUserEditVertices = true;

  @property({ type: Boolean })
  enableUserEditAddVertices = true;

  @property({ type: Boolean })
  enableUserEditDeleteVertices = true;

  @property({ type: Boolean })
  enableUserEditScaling = true;

  @property({ type: Boolean })
  enableUserEditRotating = true;

  @property({ type: Boolean })
  enableUserEditUniformScaling = true;

  private ancestorMap: ArcMapElement | null = null;
  private view: MapView | null = null;
  private featureLayer: GraphicsLayer | null = null;
  private labelLayer: GraphicsLayer | null = null;
  private graphicsEditor: SketchViewModel | null = null;
  private blockGeoJsonUpdate = false;
  private inDrawingMode = false;
  private hoveredGraphicId: string | number | null = null;
  private currentGeometryType: string | undefined;
  private viewHandles: Array<{ remove: () => void }> = [];

  protected render() {
    return html``;
  }

  async connectedCallback(): Promise<void> {
    super.connectedCallback();

    try {
      this.ancestorMap = this.closest('arc-map') as ArcMapElement | null;

      if (!this.ancestorMap) {
        console.error('arc-geojson-layer must be a descendent of an arc-map element');
        return;
      }

      if (typeof this.ancestorMap.getViewInstant !== 'function') {
        console.error('ancestor map must expose getViewInstant()');
        return;
      }

      const resolvedView = await this.ancestorMap.getViewInstant();
      this.view = resolvedView ?? null;

      if (!this.view) {
        console.error('getViewInstant() returned no view');
        return;
      }

      this.createLayer(this.geojson);
    } catch (error) {
      console.error('arc-geojson-layer failed during connectedCallback', error);
    }
  }

  disconnectedCallback(): void {
    super.disconnectedCallback();

    this.viewHandles.forEach((handle: { remove: () => void }) => {
      try {
        handle.remove();
      } catch (error) {
        console.warn('Failed to remove view handle', error);
      }
    });
    this.viewHandles = [];

    if (this.graphicsEditor) {
      try {
        this.graphicsEditor.cancel();
        this.graphicsEditor.destroy();
      } catch (error) {
        console.warn('Failed to destroy graphics editor', error);
      }
      this.graphicsEditor = null;
    }

    if (this.view?.map && this.featureLayer) {
      this.view.map.remove(this.featureLayer);
    }

    if (this.view?.map && this.labelLayer) {
      this.view.map.remove(this.labelLayer);
    }

    this.featureLayer = null;
    this.labelLayer = null;
    this.view = null;
    this.ancestorMap = null;
  }

  protected updated(changedProperties: Map<string, unknown>): void {
    if (changedProperties.has('geojson') && !this.blockGeoJsonUpdate) {
      void this.updateGeojson(this.geojson);
    }

    if (changedProperties.has('renderer')) {
      this.updateRenderer(this.renderer);
    }

    if (
      changedProperties.has('labeljson') ||
      changedProperties.has('labelcolor') ||
      changedProperties.has('labelsize')
    ) {
      this.refreshLabels();
    }

    if (changedProperties.has('infoTemplate')) {
      this.updateInfoTemplate(this.infoTemplate);
    }

    if (changedProperties.has('layerClass')) {
      this.updateLayerClass(this.layerClass);
    }

    if (changedProperties.has('name')) {
      this.updateLayerName(this.name);
    }
  }

  async updateGeojson(newGeojson: string | FeatureCollection): Promise<void> {
    if (!this.featureLayer) {
      this.createLayer(newGeojson);
      return;
    }

    const fsInfo = this.getArcGISJson(newGeojson);
    if (!fsInfo) {
      return;
    }

    this.featureLayer.removeAll();
    this.labelLayer?.removeAll();

    for (const graphic of fsInfo.graphics) {
      this.featureLayer.add(graphic);
    }

    this.currentGeometryType = fsInfo.geometryType;
    this.updateRenderer(this.renderer);
    this.refreshLabels();
    this.updateInfoTemplate(this.infoTemplate);

    this.blockGeoJsonUpdate = true;
    this.geojson = this.toFeatureCollectionFromLayer();
    this.blockGeoJsonUpdate = false;
  }

  updateInfoTemplate(newInfoTemplate: any): void {
    this.infoTemplate = newInfoTemplate;

    if (!this.featureLayer) {
      return;
    }

    this.featureLayer.graphics.forEach((graphic: Graphic) => {
      graphic.popupTemplate = this.buildPopupTemplateFromCurrent(graphic);
    });
  }

  updateLabelJson(newLabelJson: string | object | object[]): void {
    this.labeljson = newLabelJson;
    this.refreshLabels();
  }

  updateLayerClass(newLayerClass: string): void {
    this.layerClass = newLayerClass;
    // GraphicsLayer has no DOM className equivalent in ArcGIS core.
    // Kept for API compatibility.
  }

  async startDrawing(drawGeometryType: string): Promise<void> {
    if (!this.view || !this.featureLayer) {
      return;
    }

    if (!this.graphicsEditor) {
      await this.createEditor();
    }

    if (!this.graphicsEditor) {
      return;
    }

    this.inDrawingMode = true;
    this.closePopup();

    const createTool = this.mapDrawGeometryTypeToSketchCreateTool(drawGeometryType);
    if (!createTool) {
      console.error('The geometry type', drawGeometryType, 'is invalid. Drawing cancelled.');
      this.inDrawingMode = false;
      return;
    }

    this.graphicsEditor.create(createTool as any);
  }

  cancelDrawing(): void {
    this.inDrawingMode = false;

    if (this.graphicsEditor) {
      this.graphicsEditor.cancel();
    }
  }

  async findFeatureByUniqueId(uniqueId: string | number): Promise<Graphic | undefined> {
    return this.featureLayer?.graphics.find((graphic: Graphic) => {
      return graphic.attributes?.[this.uniqueIdPropertyName] === uniqueId;
    });
  }

  async getLayerId(): Promise<string> {
    return this.featureLayer?.id ?? '';
  }

  async openPopup(id: string | number): Promise<void> {
    const graphicMatch = await this.findFeatureByUniqueId(id);
    if (!graphicMatch) {
      console.warn(
        'No feature found with a',
        this.uniqueIdPropertyName,
        'value of',
        id,
        '. Cannot open popup.'
      );
      return;
    }

    const popupPoint = ArcGeojsonLayer.getPopupPoint(graphicMatch.geometry as ArcLayerGeometry | null | undefined);
    this.showGraphicPopup(graphicMatch, popupPoint);
  }

  async zoomTo(id: string | number, zoomLevel = 9): Promise<void> {
    if (!this.view) {
      return;
    }

    const graphicMatch = await this.findFeatureByUniqueId(id);
    if (!graphicMatch) {
      console.warn(
        'No feature found with a',
        this.uniqueIdPropertyName,
        'value of',
        id,
        '. Cannot zoom to.'
      );
      return;
    }

    const geometry = graphicMatch.geometry as ArcLayerGeometry | null | undefined;
    if (!geometry) {
      return;
    }

    if (ArcGeojsonLayer.isPoint(geometry)) {
      await this.view.goTo({
        center: geometry,
        zoom: zoomLevel
      });
      return;
    }

    const target = ArcGeojsonLayer.isPolygon(geometry) || ArcGeojsonLayer.isPolyline(geometry)
      ? geometry.extent
      : geometry.extent;

    if (target) {
      await this.view.goTo(target);
    }
  }

  private createLayer(geojson: string | FeatureCollection): void {
    if (!this.view) {
      return;
    }

    const parsedGeojson = geojson ?? {
      type: 'FeatureCollection',
      features: []
    };

    const fsInfo = this.getArcGISJson(parsedGeojson);
    if (!fsInfo) {
      console.error('arc-geojson-layer unable to create layer, geojson property contains invalid data');
      return;
    }

    if (!this.featureLayer) {
      this.featureLayer = new GraphicsLayer({
        id: this.id || 'arc-geojson-layer',
        title: this.name || this.id || 'Arc GeoJSON Layer',
        listMode: 'show'
      });
    }

    if (!this.labelLayer) {
      this.labelLayer = new GraphicsLayer({
        id: `${this.id || 'arc-geojson-layer'}-labels`,
        title: `${this.name || this.id || 'Arc GeoJSON Layer'} Labels`,
        listMode: 'hide'
      });
    }

    if (this.view.map && !this.view.map.layers.includes(this.featureLayer)) {
      this.view.map.add(this.featureLayer);
    }

    if (this.view.map && !this.view.map.layers.includes(this.labelLayer)) {
      this.view.map.add(this.labelLayer);
    }

    this.featureLayer.removeAll();
    this.labelLayer.removeAll();

    for (const graphic of fsInfo.graphics) {
      this.featureLayer.add(graphic);
    }

    this.currentGeometryType = fsInfo.geometryType;

    this.updateRenderer(this.renderer);
    this.refreshLabels();
    this.updateInfoTemplate(this.infoTemplate);
    this.updateLayerClass(this.layerClass);
    this.updateLayerName(this.name);

    void this.createEditor();
    this.wireViewEvents();

    this.blockGeoJsonUpdate = true;
    this.geojson = this.toFeatureCollectionFromLayer();
    this.blockGeoJsonUpdate = false;
  }

  private async createEditor(): Promise<void> {
    if (!this.view || !this.featureLayer) {
      return;
    }

    if (this.graphicsEditor) {
      return;
    }

    this.graphicsEditor = new SketchViewModel({
      view: this.view,
      layer: this.featureLayer,
      defaultUpdateOptions: {
        enableRotation: this.enableUserEditRotating,
        enableScaling: this.enableUserEditScaling,
        multipleSelectionEnabled: false,
        preserveAspectRatio: this.enableUserEditUniformScaling,
        toggleToolOnClick: false
      },
      updateOnGraphicClick: false
    });

    this.wireEditorEvents();
  }

  private wireEditorEvents(): void {
    if (!this.graphicsEditor) {
      return;
    }

    this.graphicsEditor.on('create', (event: any): void => {
      if (event.state === 'start') {
        this.inDrawingMode = true;
        this.closePopup();
      }

      if (event.state === 'complete' && event.graphic) {
        this.inDrawingMode = false;
        this.addToGeojson(event.graphic as Graphic);
      }

      if (event.state === 'cancel') {
        this.inDrawingMode = false;
      }
    });

    this.graphicsEditor.on('update', (event: any): void => {
      if (event.state === 'start') {
        this.closePopup();
      }

      if (event.state === 'complete' && Array.isArray(event.graphics)) {
        event.graphics.forEach((graphic: Graphic) => {
          this.updateGeojsonWithChanges(graphic);
        });
      }

      if (event.state === 'cancel') {
        // no-op
      }
    });

    this.graphicsEditor.on('delete', (event: any): void => {
      if (Array.isArray(event.graphics)) {
        event.graphics.forEach((graphic: Graphic) => {
          this.removeFromGeojson(graphic);
        });
      }
    });
  }

  private wireViewEvents(): void {
    if (!this.view || this.viewHandles.length > 0) {
      return;
    }

    const clickHandle = this.view.on('click', async (event: any): Promise<void> => {
      const graphic = await this.getGraphicFromViewEvent(event);
      if (!graphic) {
        return;
      }

      this.emitLayerEvent('layerClick', this.buildLayerMouseEvent(graphic, event));

      const nativeEvent = event?.native;
      const ctrlKey = Boolean(nativeEvent?.ctrlKey || nativeEvent?.metaKey);

      if (this.enableUserEdit) {
        if (ctrlKey && this.enableUserEditRemove) {
          this.removeFromGeojson(graphic);
          return;
        }

        await this.activateGraphicsEditor(graphic);
        return;
      }

      const popupPoint = event?.mapPoint ?? ArcGeojsonLayer.getPopupPoint(graphic.geometry as ArcLayerGeometry | null | undefined);
      this.showGraphicPopup(graphic, popupPoint);
    });

    const doubleClickHandle = this.view.on('double-click', async (event: any): Promise<void> => {
      event.stopPropagation();

      const graphic = await this.getGraphicFromViewEvent(event);
      if (!graphic) {
        return;
      }

      this.emitLayerEvent('doubleClick', this.buildLayerMouseEvent(graphic, event));

      if (this.enableUserEdit) {
        await this.activateGraphicsEditor(graphic);
      }
    });

    const pointerMoveHandle = this.view.on('pointer-move', async (event: any): Promise<void> => {
      const graphic = await this.getGraphicFromViewEvent(event);
      const newHoverId = graphic?.attributes?.[this.uniqueIdPropertyName] ?? null;

      if (this.hoveredGraphicId === newHoverId) {
        return;
      }

      if (this.hoveredGraphicId !== null) {
        const previous = this.featureLayer?.graphics.find((g: Graphic) => {
          return g.attributes?.[this.uniqueIdPropertyName] === this.hoveredGraphicId;
        });

        if (previous) {
          this.emitLayerEvent('layerMouseOut', this.buildLayerMouseEvent(previous, event));
        }
      }

      if (graphic) {
        this.emitLayerEvent('layerMouseOver', this.buildLayerMouseEvent(graphic, event));
      }

      this.hoveredGraphicId = newHoverId;
    });

    this.viewHandles.push(clickHandle, doubleClickHandle, pointerMoveHandle);
  }

  private async activateGraphicsEditor(graphic: Graphic): Promise<void> {
    if (!this.enableUserEdit || !this.graphicsEditor) {
      return;
    }

    this.closePopup();

    const updateOptions: any = {
      enableRotation: this.enableUserEditRotating,
      enableScaling: this.enableUserEditScaling,
      preserveAspectRatio: this.enableUserEditUniformScaling,
      toggleToolOnClick: false,
      multipleSelectionEnabled: false,
      tool: this.getUpdateTool()
    };

    this.graphicsEditor.update([graphic], updateOptions);
  }

  private getUpdateTool(): 'move' | 'reshape' | 'transform' {
    if (this.enableUserEditScaling || this.enableUserEditRotating) {
      return 'transform';
    }

    if (this.enableUserEditVertices || this.enableUserEditAddVertices || this.enableUserEditDeleteVertices) {
      return 'reshape';
    }

    return 'move';
  }

  private showGraphicPopup(graphic: Graphic, mapPoint?: Point): void {
    if (!this.view || this.enableUserEdit || this.inDrawingMode) {
      return;
    }

    const location = mapPoint ?? ArcGeojsonLayer.getPopupPoint(graphic.geometry as ArcLayerGeometry | null | undefined);
    const popupTemplate = this.buildPopupTemplateFromCurrent(graphic);

    graphic.popupTemplate = popupTemplate;

    this.view.popup.open({
      location,
      features: [graphic]
    });

    this.emitLayerEvent('popupChangeEvent', {
      features: [graphic],
      selectedIndex: 0
    } as PopupEvent);
  }

  private buildPopupTemplateFromCurrent(graphic: Graphic): PopupTemplate {
    const parsed = this.getInfoTemplateJson(this.infoTemplate);
    const attributes = graphic.attributes ?? {};

    const title = parsed?.listItem
      ? this.resolveTemplateValue(parsed.listItem, graphic)
      : attributes[this.uniqueIdPropertyName] !== undefined
        ? `${this.uniqueIdPropertyName}: ${attributes[this.uniqueIdPropertyName]}`
        : this.name || 'Details';

    const content = parsed?.details
      ? this.resolveTemplateValue(parsed.details, graphic)
      : this.buildDefaultPopupContent(attributes);

    return new PopupTemplate({
      title,
      content
    });
  }

  private refreshLabels(): void {
    if (!this.featureLayer || !this.labelLayer) {
      return;
    }

    this.labelLayer.removeAll();

    const labelConfig = this.getLabelJson(this.labeljson, this.labelcolor, this.labelsize);

    if (!labelConfig) {
      return;
    }

    this.featureLayer.graphics.forEach((graphic: Graphic): void => {
      const textValue = this.resolveLabelText(graphic);
      if (!textValue) {
        return;
      }

      const popupPoint = ArcGeojsonLayer.getPopupPoint(graphic.geometry as ArcLayerGeometry | null | undefined);
      const labelGraphic = new Graphic({
        geometry: popupPoint,
        attributes: {
          sourceId: graphic.attributes?.[this.uniqueIdPropertyName]
        },
        symbol: new TextSymbol({
          text: textValue,
          color: labelConfig.symbol.color,
          haloColor: labelConfig.symbol.haloColor,
          haloSize: labelConfig.symbol.haloSize,
          xoffset: labelConfig.symbol.xoffset,
          yoffset: labelConfig.symbol.yoffset,
          font: labelConfig.symbol.font
        })
      });

      this.labelLayer?.add(labelGraphic);
    });
  }

  private addToGeojson(newGraphic: Graphic): void {
    if (!this.featureLayer) {
      return;
    }

    if (!newGraphic.attributes) {
      newGraphic.attributes = {};
    }

    if (newGraphic.attributes[this.uniqueIdPropertyName] === undefined) {
      newGraphic.attributes[this.uniqueIdPropertyName] = Date.now();
    }

    if (newGraphic.attributes.OBJECTID === undefined) {
      newGraphic.attributes.OBJECTID = Date.now();
    }

    newGraphic.symbol = this.getDefaultSymbolForGraphic(newGraphic);
    newGraphic.popupTemplate = this.buildPopupTemplateFromCurrent(newGraphic);

    if (!this.featureLayer.graphics.includes(newGraphic)) {
      this.featureLayer.add(newGraphic);
    }

    this.blockGeoJsonUpdate = true;
    this.geojson = this.toFeatureCollectionFromLayer();
    this.blockGeoJsonUpdate = false;

    this.refreshLabels();
    this.emitLayerEvent('userEditItemAdded', this.graphicToGeoJsonFeature(newGraphic));
  }

  private removeFromGeojson(graphicToRemove: Graphic): void {
    if (!this.featureLayer) {
      return;
    }

    this.featureLayer.remove(graphicToRemove);

    this.blockGeoJsonUpdate = true;
    this.geojson = this.toFeatureCollectionFromLayer();
    this.blockGeoJsonUpdate = false;

    this.refreshLabels();
    this.emitLayerEvent('userEditItemRemoved', this.graphicToGeoJsonFeature(graphicToRemove));
  }

  private updateGeojsonWithChanges(graphicToUpdate: Graphic): void {
    if (!this.featureLayer) {
      return;
    }

    graphicToUpdate.popupTemplate = this.buildPopupTemplateFromCurrent(graphicToUpdate);
    graphicToUpdate.symbol = this.getDefaultSymbolForGraphic(graphicToUpdate);

    this.blockGeoJsonUpdate = true;
    this.geojson = this.toFeatureCollectionFromLayer();
    this.blockGeoJsonUpdate = false;

    this.refreshLabels();
    this.emitLayerEvent('userEditItemUpdated', this.graphicToGeoJsonFeature(graphicToUpdate));
  }

  private toFeatureCollectionFromLayer(): FeatureCollection {
    return {
      type: 'FeatureCollection',
      features: (this.featureLayer?.graphics.toArray() ?? []).map((graphic: Graphic) =>
        this.graphicToGeoJsonFeature(graphic)
      )
    };
  }

  private graphicToGeoJsonFeature(graphic: Graphic): Feature {
    const geometry = this.arcGeometryToGeojsonGeometry(graphic.geometry as ArcLayerGeometry | null | undefined);

    return {
      type: 'Feature',
      geometry: geometry ?? {
        type: 'Point',
        coordinates: [0, 0]
      },
      properties: {
        ...(graphic.attributes ?? {})
      }
    };
  }

  private arcGeometryToGeojsonGeometry(
    geometry: ArcLayerGeometry | null | undefined
  ): GeoJsonGeometry | null {
    if (!geometry) {
      return null;
    }

    if (ArcGeojsonLayer.isPoint(geometry)) {
      const geographic = this.toGeographicPoint(geometry);
      return {
        type: 'Point',
        coordinates: [geographic.x, geographic.y]
      };
    }

    if (ArcGeojsonLayer.isPolyline(geometry)) {
      const polyline = this.toGeographicPolyline(geometry);
      const paths = polyline.paths ?? [];

      if (paths.length <= 1) {
        return {
          type: 'LineString',
          coordinates: paths[0] ?? []
        };
      }

      return {
        type: 'MultiLineString',
        coordinates: paths
      };
    }

    if (ArcGeojsonLayer.isPolygon(geometry)) {
      const polygon = this.toGeographicPolygon(geometry);
      return {
        type: 'Polygon',
        coordinates: polygon.rings as number[][][]
      };
    }

    if (geometry.type === 'multipoint') {
      const multipoint = geometry as Multipoint;
      const converted = webMercatorUtils.webMercatorToGeographic(multipoint) as Multipoint;
      return {
        type: 'MultiPoint',
        coordinates: converted.points as number[][]
      };
    }

    return null;
  }

  private getArcGISJson(
    geojson: string | FeatureCollection
  ): { graphics: Graphic[]; geometryType: string | undefined } | null {
    const geojsonParseResult = this.getJsonFor(geojson);

    if (geojsonParseResult.error || !geojsonParseResult.parsedJson) {
      console.error('Unable to parse geojson string', geojsonParseResult.error);
      return null;
    }

    const parsedGeojson = geojsonParseResult.parsedJson as FeatureCollection;

    if (!parsedGeojson || parsedGeojson.type !== 'FeatureCollection' || !Array.isArray(parsedGeojson.features)) {
      return null;
    }

    const graphics: Graphic[] = [];
    let geometryType: string | undefined;

    parsedGeojson.features.forEach((feature: Feature, index: number): void => {
      const graphic = this.geojsonFeatureToGraphic(feature, index);
      if (graphic) {
        if (geometryType === undefined) {
          geometryType = graphic.geometry?.type;
        }
        graphics.push(graphic);
      }
    });

    return {
      graphics,
      geometryType
    };
  }

  private geojsonFeatureToGraphic(feature: Feature, index: number): Graphic | null {
    const geometry = this.geojsonGeometryToArcGeometry(feature?.geometry ?? null);
    if (!geometry) {
      return null;
    }

    const properties: any = {
      ...(feature?.properties ?? {})
    };

    if (properties[this.uniqueIdPropertyName] === undefined) {
      properties[this.uniqueIdPropertyName] = index;
    }

    if (properties.OBJECTID === undefined) {
      properties.OBJECTID = index;
    }

    if (properties.LABEL === undefined && properties.label !== undefined) {
      properties.LABEL = properties.label;
    }

    const graphic = new Graphic({
      geometry,
      attributes: properties,
      symbol: this.getDefaultSymbolForGeometry(geometry),
      popupTemplate: this.buildPopupTemplateFromCurrent(new Graphic({ attributes: properties }))
    });

    graphic.popupTemplate = this.buildPopupTemplateFromCurrent(graphic);

    return graphic;
  }

  private geojsonGeometryToArcGeometry(geometry: GeoJsonGeometry | null): ArcLayerGeometry | null {
    if (!geometry) {
      return null;
    }

    switch (geometry.type) {
      case 'Point': {
        const [x, y] = geometry.coordinates as number[];
        return new Point({
          x,
          y,
          spatialReference: { wkid: 4326 }
        });
      }

      case 'MultiPoint': {
        return new Multipoint({
          points: geometry.coordinates as number[][],
          spatialReference: { wkid: 4326 }
        });
      }

      case 'LineString': {
        return new Polyline({
          paths: [geometry.coordinates as number[][]],
          spatialReference: { wkid: 4326 }
        });
      }

      case 'MultiLineString': {
        return new Polyline({
          paths: geometry.coordinates as number[][][],
          spatialReference: { wkid: 4326 }
        });
      }

      case 'Polygon': {
        return new Polygon({
          rings: geometry.coordinates as number[][][],
          spatialReference: { wkid: 4326 }
        });
      }

      case 'MultiPolygon': {
        const rings: number[][][] = [];
        (geometry.coordinates as number[][][][]).forEach((polygonCoordinates: number[][][]) => {
          polygonCoordinates.forEach((ring: number[][]) => rings.push(ring));
        });

        return new Polygon({
          rings,
          spatialReference: { wkid: 4326 }
        });
      }

      default:
        return null;
    }
  }

  private getDefaultSymbolForGraphic(graphic: Graphic): any {
    return this.resolveGraphicSymbol(graphic) ?? this.getDefaultSymbolForGeometry(graphic.geometry as ArcLayerGeometry | null | undefined);
  }

  private getDefaultSymbolForGeometry(geometry: ArcLayerGeometry | null | undefined): any {
    if (!geometry) {
      return new SimpleMarkerSymbol({
        style: 'circle',
        color: ArcGeojsonLayer.DEFAULT_SYMBOL_COLOR as any,
        size: ArcGeojsonLayer.DEFAULT_SYMBOL_MARKER_SIZE,
        outline: {
          color: [0, 0, 0, 200] as any,
          width: 1
        }
      });
    }

    if (ArcGeojsonLayer.isPoint(geometry) || geometry.type === 'multipoint') {
      return new SimpleMarkerSymbol({
        style: 'circle',
        color: ArcGeojsonLayer.DEFAULT_SYMBOL_COLOR as any,
        size: ArcGeojsonLayer.DEFAULT_SYMBOL_MARKER_SIZE,
        outline: {
          color: [0, 0, 0, 200] as any,
          width: 1
        }
      });
    }

    if (ArcGeojsonLayer.isPolyline(geometry)) {
      return new SimpleLineSymbol({
        style: 'solid',
        color: ArcGeojsonLayer.DEFAULT_SYMBOL_COLOR as any,
        width: ArcGeojsonLayer.DEFAULT_SYMBOL_LINE_WIDTH
      });
    }

    return new SimpleFillSymbol({
      style: 'solid',
      color: [
        ArcGeojsonLayer.DEFAULT_SYMBOL_COLOR[0],
        ArcGeojsonLayer.DEFAULT_SYMBOL_COLOR[1],
        ArcGeojsonLayer.DEFAULT_SYMBOL_COLOR[2],
        100
      ] as any,
      outline: {
        color: [110, 110, 110, 255] as any,
        width: ArcGeojsonLayer.DEFAULT_SYMBOL_POLYGON_WIDTH
      }
    });
  }

  private updateRenderer(newRenderer: any): void {
    if (!this.featureLayer) {
      return;
    }

    this.renderer = newRenderer;

    this.featureLayer.graphics.forEach((graphic: Graphic): void => {
      graphic.symbol = this.resolveGraphicSymbol(graphic) ?? this.getDefaultSymbolForGeometry(graphic.geometry as ArcLayerGeometry | null | undefined);
    });
  }

  private resolveGraphicSymbol(graphic: Graphic): any {
    const geometry = graphic.geometry as ArcLayerGeometry | null | undefined;
    const defaultSymbol = this.getDefaultSymbolForGeometry(geometry);
    const rendererParseResult = this.getJsonFor(this.renderer);

    if (!rendererParseResult.parsedJson || rendererParseResult.error) {
      return defaultSymbol;
    }

    const rendererConfig = this.clonePlain(rendererParseResult.parsedJson);
    const type = rendererConfig?.type;

    if (type === 'simple') {
      return this.normalizeLegacySymbol(rendererConfig.symbol) ?? defaultSymbol;
    }

    if (type === 'uniqueValue') {
      const fieldName = rendererConfig.field1;
      const fieldValue = graphic.attributes?.[fieldName];
      const info = (rendererConfig.uniqueValueInfos ?? []).find((item: any) => item.value === fieldValue);
      return this.normalizeLegacySymbol(info?.symbol ?? rendererConfig.defaultSymbol) ?? defaultSymbol;
    }

    if (type === 'classBreaks') {
      const fieldName = rendererConfig.field;
      const fieldValue = Number(graphic.attributes?.[fieldName]);
      const info = (rendererConfig.classBreakInfos ?? []).find((item: any) => {
        const min = item.minValue ?? Number.NEGATIVE_INFINITY;
        const max = item.maxValue ?? Number.POSITIVE_INFINITY;
        return fieldValue >= min && fieldValue <= max;
      });
      return this.normalizeLegacySymbol(info?.symbol ?? rendererConfig.defaultSymbol) ?? defaultSymbol;
    }

    return defaultSymbol;
  }

  private getLabelJson(
    userLabel: string | object | object[],
    userColor: string | number[],
    userSize: number
  ): any {
    const labelJson = this.getJsonFor(userLabel);

    if (typeof userLabel === 'string' && userLabel.trim() === '') {
      return this.getJsonLabelFor(this.resolveLabelColor(userColor), this.resolveLabelSize(userSize));
    }

    if (labelJson.error || !labelJson.parsedJson) {
      console.warn('Could not parse label json, falling back to color and size properties', labelJson.error);
      return this.getJsonLabelFor(this.resolveLabelColor(userColor), this.resolveLabelSize(userSize));
    }

    return labelJson.parsedJson;
  }

  private getJsonLabelFor(color: number[], fontsize: number): any {
    return {
      labelExpressionInfo: {
        expression: '$feature.LABEL'
      },
      symbol: {
        type: 'text',
        color,
        haloColor: 'black',
        haloSize: 1,
        xoffset: 3,
        yoffset: 3,
        font: {
          size: fontsize,
          family: 'sans-serif',
          weight: 'bold'
        }
      }
    };
  }

  private resolveLabelText(graphic: Graphic): string {
    const attrs = graphic.attributes ?? {};
    if (attrs.LABEL !== undefined && attrs.LABEL !== null) {
      return String(attrs.LABEL);
    }

    if (attrs.label !== undefined && attrs.label !== null) {
      return String(attrs.label);
    }

    return '';
  }

  private resolveLabelColor(userColor: string | number[]): number[] {
    if (Array.isArray(userColor) && userColor.length >= 3) {
      return [
        Number(userColor[0]) || 0,
        Number(userColor[1]) || 0,
        Number(userColor[2]) || 0,
        userColor.length > 3 ? Number(userColor[3]) || 255 : 255
      ];
    }

    const colorJson = this.getJsonFor(userColor);
    if (Array.isArray(colorJson.parsedJson)) {
      const parsedColor = colorJson.parsedJson as number[];
      return [
        Number(parsedColor[0]) || 0,
        Number(parsedColor[1]) || 0,
        Number(parsedColor[2]) || 0,
        parsedColor.length > 3 ? Number(parsedColor[3]) || 255 : 255
      ];
    }

    return [0, 0, 0, 255];
  }

  private resolveLabelSize(userSize: number): number {
    if (!Number.isNaN(userSize) && userSize > 0) {
      return userSize;
    }
    return ArcGeojsonLayer.DEFAULT_LABEL_SIZE;
  }

  private normalizeLegacySymbol(symbol: any): any {
    const safe = this.clonePlain(symbol);

    if (!safe || typeof safe !== 'object') {
      return safe;
    }

    const type = safe.type;

    if (type === 'esriSMS') {
      return new SimpleMarkerSymbol({
        style: this.normalizeLegacyMarkerStyle(safe.style),
        color: safe.color ?? ArcGeojsonLayer.DEFAULT_SYMBOL_COLOR,
        size: safe.size ?? ArcGeojsonLayer.DEFAULT_SYMBOL_MARKER_SIZE,
        angle: safe.angle ?? 0,
        xoffset: safe.xoffset ?? 0,
        yoffset: safe.yoffset ?? 0,
        outline: safe.outline
          ? {
              color: safe.outline.color ?? [0, 0, 0, 200],
              width: safe.outline.width ?? 1,
              style: this.normalizeLegacyLineStyle(safe.outline.style)
            }
          : undefined
      });
    }

    if (type === 'esriSLS') {
      return new SimpleLineSymbol({
        style: this.normalizeLegacyLineStyle(safe.style),
        color: safe.color ?? ArcGeojsonLayer.DEFAULT_SYMBOL_COLOR,
        width: safe.width ?? ArcGeojsonLayer.DEFAULT_SYMBOL_LINE_WIDTH
      });
    }

    if (type === 'esriSFS') {
      return new SimpleFillSymbol({
        style: this.normalizeLegacyFillStyle(safe.style),
        color: safe.color ?? [0, 0, 255, 100],
        outline: safe.outline
          ? {
              color: safe.outline.color ?? [110, 110, 110, 255],
              width: safe.outline.width ?? ArcGeojsonLayer.DEFAULT_SYMBOL_POLYGON_WIDTH,
              style: this.normalizeLegacyLineStyle(safe.outline.style)
            }
          : undefined
      });
    }

    if (type === 'simple-marker' || type === 'simple-line' || type === 'simple-fill') {
      return safe;
    }

    return safe;
  }

  private normalizeLegacyMarkerStyle(style: string | undefined): any {
    switch ((style ?? '').toLowerCase()) {
      case 'esrismscircle':
      case 'circle':
        return 'circle';
      case 'esrismssquare':
      case 'square':
        return 'square';
      case 'esrismsdiamond':
      case 'diamond':
        return 'diamond';
      case 'esrismscross':
      case 'cross':
        return 'cross';
      case 'esrismsx':
      case 'x':
        return 'x';
      case 'esrismstriangle':
      case 'triangle':
        return 'triangle';
      default:
        return 'circle';
    }
  }

  private normalizeLegacyLineStyle(style: string | undefined): any {
    switch ((style ?? '').toLowerCase()) {
      case 'esrislssolid':
      case 'solid':
        return 'solid';
      case 'esrislsdash':
      case 'dash':
        return 'dash';
      case 'esrislsdot':
      case 'dot':
        return 'dot';
      case 'esrislsdashdot':
      case 'dash-dot':
        return 'dash-dot';
      case 'esrislsdashdotdot':
      case 'long-dash-dot-dot':
        return 'long-dash-dot-dot';
      default:
        return 'solid';
    }
  }

  private normalizeLegacyFillStyle(style: string | undefined): any {
    switch ((style ?? '').toLowerCase()) {
      case 'esrisfssolid':
      case 'solid':
        return 'solid';
      case 'esrisfsbackwarddiagonal':
      case 'backward-diagonal':
        return 'backward-diagonal';
      case 'esrisfscross':
      case 'cross':
        return 'cross';
      case 'esrisfsdiagonalcross':
      case 'diagonal-cross':
        return 'diagonal-cross';
      case 'esrisfsforwarddiagonal':
      case 'forward-diagonal':
        return 'forward-diagonal';
      case 'esrifsnull':
      case 'none':
        return 'none';
      case 'esrisfshorizontal':
      case 'horizontal':
        return 'horizontal';
      case 'esrisfsvertical':
      case 'vertical':
        return 'vertical';
      default:
        return 'solid';
    }
  }

  private getInfoTemplateJson(value: any): InfoTemplateDetails | null {
    const parsed = this.getJsonFor(value);

    if (typeof value === 'string' && value.trim() === '') {
      return null;
    }

    if (parsed.error || !parsed.parsedJson) {
      return null;
    }

    return parsed.parsedJson as InfoTemplateDetails;
  }

  private resolveTemplateValue(value: string | ((graphic: Graphic) => string), graphic: Graphic): string {
    if (typeof value === 'function') {
      try {
        return value(graphic);
      } catch (error) {
        console.warn('Failed to resolve popup template function', error);
        return '';
      }
    }

    return value ?? '';
  }

  private buildDefaultPopupContent(attributes: Record<string, any>): string {
    const rows = Object.entries(attributes)
      .map(([key, value]) => `<div><strong>${key}:</strong> ${String(value)}</div>`)
      .join('');

    return rows || '<div>No Details Available</div>';
  }

  private updateLayerName(newName: string): void {
    if (this.featureLayer) {
      this.featureLayer.title = newName || this.id || 'Arc GeoJSON Layer';
    }

    if (this.labelLayer) {
      this.labelLayer.title = `${newName || this.id || 'Arc GeoJSON Layer'} Labels`;
    }
  }

  private async getGraphicFromViewEvent(event: any): Promise<Graphic | null> {
    if (!this.view || !this.featureLayer) {
      return null;
    }

    const hitTestResult = await this.view.hitTest(event);
    const result = (hitTestResult?.results ?? []).find((item: any) => {
      return item?.graphic?.layer === this.featureLayer;
    });

    return (result?.graphic as Graphic) ?? null;
  }

  private buildLayerMouseEvent(graphic: Graphic, event: any): LayerMouseEvent {
    const mapPoint = event?.mapPoint
      ? webMercatorUtils.webMercatorToGeographic(event.mapPoint)
      : ArcGeojsonLayer.getPopupPoint(graphic.geometry as ArcLayerGeometry | null | undefined);

    return {
      coordinates: {
        latitude: (mapPoint as Point)?.y ?? 0,
        longitude: (mapPoint as Point)?.x ?? 0
      },
      attributes: graphic.attributes
    };
  }

  private emitLayerEvent(name: string, detail: any): void {
    this.dispatchEvent(
      new CustomEvent(name, {
        detail,
        bubbles: true,
        composed: true
      })
    );
  }

  private closePopup(): void {
    if (this.view?.popup) {
      this.view.popup.close();
    }
  }

  private getJsonFor(jsonObj: any): { error?: Error; parsedJson?: any } {
    if (jsonObj === undefined || jsonObj === null) {
      return { parsedJson: undefined };
    }

    if (typeof jsonObj === 'string') {
      if (jsonObj.trim() === '') {
        return { parsedJson: undefined };
      }

      try {
        return {
          parsedJson: JSON.parse(jsonObj)
        };
      } catch (error) {
        return {
          error: error as Error
        };
      }
    }

    return {
      parsedJson: jsonObj
    };
  }

  private clonePlain<T>(value: T): T {
    if (value === undefined || value === null) {
      return value;
    }

    return JSON.parse(JSON.stringify(value)) as T;
  }

  private mapDrawGeometryTypeToSketchCreateTool(
    drawGeometryType: string
  ): 'point' | 'polyline' | 'polygon' | 'rectangle' | 'circle' | null {
    switch ((drawGeometryType || '').toUpperCase()) {
      case DrawGeometryTypes.POINT:
      case DrawGeometryTypes.MULTI_POINT:
        return 'point';

      case DrawGeometryTypes.LINE:
      case DrawGeometryTypes.POLYLINE:
      case DrawGeometryTypes.FREEHAND_POLYLINE:
        return 'polyline';

      case DrawGeometryTypes.RECTANGLE:
      case DrawGeometryTypes.EXTENT:
        return 'rectangle';

      case DrawGeometryTypes.CIRCLE:
        return 'circle';

      case DrawGeometryTypes.POLYGON:
      case DrawGeometryTypes.FREEHAND_POLYGON:
      case DrawGeometryTypes.ARROW:
      case DrawGeometryTypes.DOWN_ARROW:
      case DrawGeometryTypes.ELLIPSE:
      case DrawGeometryTypes.LEFT_ARROW:
      case DrawGeometryTypes.RIGHT_ARROW:
      case DrawGeometryTypes.TRIANGLE:
      case DrawGeometryTypes.UP_ARROW:
        return 'polygon';

      default:
        return null;
    }
  }

  private toGeographicPoint(point: Point): Point {
    if (point.spatialReference?.isWGS84) {
      return point;
    }

    return (webMercatorUtils.webMercatorToGeographic(point) as Point) ?? point;
  }

  private toGeographicPolyline(polyline: Polyline): Polyline {
    if (polyline.spatialReference?.isWGS84) {
      return polyline;
    }

    return (webMercatorUtils.webMercatorToGeographic(polyline) as Polyline) ?? polyline;
  }

  private toGeographicPolygon(polygon: Polygon): Polygon {
    if (polygon.spatialReference?.isWGS84) {
      return polygon;
    }

    return (webMercatorUtils.webMercatorToGeographic(polygon) as Polygon) ?? polygon;
  }

  private static getPopupPoint(geometry: ArcLayerGeometry | null | undefined): Point {
    if (!geometry) {
      return new Point({ x: 0, y: 0, spatialReference: { wkid: 4326 } });
    }

    if (ArcGeojsonLayer.isPoint(geometry)) {
      return geometry;
    }

    if (ArcGeojsonLayer.isPolyline(geometry)) {
      const path = geometry.paths?.[0] ?? [];
      const mid = path[Math.floor(path.length / 2)] ?? [0, 0];
      return new Point({
        x: mid[0],
        y: mid[1],
        spatialReference: geometry.spatialReference
      });
    }

    if (ArcGeojsonLayer.isPolygon(geometry)) {
      return geometry.centroid ?? geometry.extent?.center ?? new Point({ x: 0, y: 0, spatialReference: geometry.spatialReference });
    }

    if (geometry.type === 'multipoint') {
      const multipoint = geometry as Multipoint;
      const first = multipoint.points?.[0] ?? [0, 0];
      return new Point({
        x: first[0],
        y: first[1],
        spatialReference: multipoint.spatialReference
      });
    }

    return geometry.extent?.center ?? new Point({ x: 0, y: 0, spatialReference: { wkid: 4326 } });
  }

  private static isPoint(geometry: ArcLayerGeometry): geometry is Point {
    return geometry.type === 'point';
  }

  private static isPolyline(geometry: ArcLayerGeometry): geometry is Polyline {
    return geometry.type === 'polyline';
  }

  private static isPolygon(geometry: ArcLayerGeometry): geometry is Polygon {
    return geometry.type === 'polygon';
  }
}

