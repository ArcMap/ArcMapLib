private createLayer(geojson: string | FeatureCollection): void {
  if (!this.view || !this.view.map) {
    console.error('createLayer blocked: view/map not ready');
    return;
  }

  console.log('raw geojson in createLayer', geojson);

  const fsInfo = this.getArcGISJson(geojson);
  console.log('fsInfo in createLayer', fsInfo);

  if (!fsInfo) {
    console.error('createLayer blocked: fsInfo is null');
    return;
  }

  if (!Array.isArray(fsInfo.graphics)) {
    console.error('createLayer blocked: fsInfo.graphics is not an array', fsInfo.graphics);
    return;
  }

  if (!this.featureLayer) {
    this.featureLayer = new GraphicsLayer({
      id: this.id || 'arc-geojson-layer',
      title: this.name || this.id || 'Arc GeoJSON Layer',
      listMode: 'show'
    });
  }

  if (!this.labelLayer) {
    this.labelLayer = new GraphicsLayer({
      id: `${this.id || 'arc-geojson-layer'}-labels`,
      title: `${this.name || this.id || 'Arc GeoJSON Layer'} Labels`,
      listMode: 'hide'
    });
  }

  const map = this.view.map;

  if (!(this.featureLayer instanceof GraphicsLayer)) {
    console.error('createLayer blocked: featureLayer is not GraphicsLayer');
    return;
  }

  if (!(this.labelLayer instanceof GraphicsLayer)) {
    console.error('createLayer blocked: labelLayer is not GraphicsLayer');
    return;
  }

  const existingLayers = map.layers?.toArray?.() ?? [];

  if (!existingLayers.includes(this.featureLayer)) {
    map.add(this.featureLayer);
  }

  if (!existingLayers.includes(this.labelLayer)) {
    map.add(this.labelLayer);
  }

  this.featureLayer.removeAll();
  this.labelLayer.removeAll();

  for (const graphic of fsInfo.graphics) {
    if (!graphic || !graphic.geometry) {
      console.warn('Skipping invalid graphic', graphic);
      continue;
    }

    this.featureLayer.add(graphic);
  }

  console.log('graphics count after add', this.featureLayer.graphics.length);

  this.currentGeometryType = fsInfo.geometryType;

  this.updateInfoTemplate(this.infoTemplate);
  this.refreshLabels();
  this.updateLayerClass(this.layerClass);
  this.updateLayerName(this.name);

  void this.createEditor();
  this.bindViewEvents();

  this.blockGeoJsonUpdate = true;
  this.geojson = this.toFeatureCollectionFromLayer();
  this.blockGeoJsonUpdate = false;
}

