private bindEditorEvents(): void {
  if (!this.graphicsEditor) {
    return;
  }

  this.graphicsEditor.on('create', (event: any): void => {
    if (event.state === 'start') {
      this.inDrawingMode = true;
      this.editorActive = true;
      this.closePopup();
      return;
    }

    if (event.state === 'complete') {
      if (event.graphic) {
        this.addToGeojson(event.graphic as Graphic);
      }

      this.inDrawingMode = false;
      this.editorActive = false;

      this.graphicsEditor?.cancel();

      this.ignoreNextMapClick = true;
      setTimeout(() => {
        this.ignoreNextMapClick = false;
      }, 150);

      return;
    }

    if (event.state === 'cancel') {
      this.inDrawingMode = false;
      this.editorActive = false;
    }
  });

  this.graphicsEditor.on('update', (event: any): void => {
    if (event.state === 'start') {
      this.editorActive = true;
      this.closePopup();
      return;
    }

    if (event.state === 'complete') {
      if (Array.isArray(event.graphics)) {
        event.graphics.forEach((graphic: Graphic): void => {
          this.updateGeojsonWithChanges(graphic);
        });
      }

      this.editorActive = false;
      this.graphicsEditor?.cancel();

      this.ignoreNextMapClick = true;
      setTimeout(() => {
        this.ignoreNextMapClick = false;
      }, 150);

      return;
    }

    if (event.state === 'cancel') {
      this.editorActive = false;
    }
  });

  this.graphicsEditor.on('delete', (event: any): void => {
    if (Array.isArray(event.graphics)) {
      event.graphics.forEach((graphic: Graphic): void => {
        this.removeFromGeojson(graphic);
      });
    }

    this.editorActive = false;
    this.inDrawingMode = false;
    this.graphicsEditor?.cancel();

    this.ignoreNextMapClick = true;
    setTimeout(() => {
      this.ignoreNextMapClick = false;
    }, 150);
  });
}



this.clickHandle = this.view.on('click', async (evt: any): Promise<void> => {
  if (this.ignoreNextMapClick) {
    return;
  }

  const graphic = await this.getGraphicFromViewEvent(evt);
  if (!graphic) {
    return;
  }

  this.emitLayerEvent('layerClick', this.buildLayerMouseEvent(graphic, evt));

  const ctrlKey = Boolean(evt?.native?.ctrlKey || evt?.native?.metaKey);

  if (this.enableUserEdit) {
    this.closePopup();

    if (ctrlKey && this.enableUserEditRemove) {
      this.removeFromGeojson(graphic);
      return;
    }

    await this.activateGraphicsEditor(graphic);
    return;
  }

  if (!this.editorActive && !this.inDrawingMode) {
    const popupPoint =
      evt?.mapPoint ??
      JsonUtils.getPopupPoint(
        graphic.geometry as ArcLayerGeometry | null | undefined
      );

    this.showGraphicPopup(graphic, popupPoint);
  }
});

this.doubleClickHandle = this.view.on('double-click', async (evt: any): Promise<void> => {
  evt.stopPropagation();

  if (this.ignoreNextMapClick) {
    return;
  }

  const graphic = await this.getGraphicFromViewEvent(evt);
  if (!graphic) {
    return;
  }

  this.emitLayerEvent('doubleClick', this.buildLayerMouseEvent(graphic, evt));

  if (this.enableUserEdit) {
    this.closePopup();
    await this.activateGraphicsEditor(graphic);
    return;
  }

  if (!this.editorActive && !this.inDrawingMode) {
    const popupPoint =
      evt?.mapPoint ??
      JsonUtils.getPopupPoint(
        graphic.geometry as ArcLayerGeometry | null | undefined
      );

    this.showGraphicPopup(graphic, popupPoint);
  }
});




private showGraphicPopup(graphic: Graphic, mapPoint?: Point): void {
  if (!this.view || this.enableUserEdit || this.editorActive || this.inDrawingMode) {
    return;
  }

  const popupTemplate = JsonUtils.buildPopupTemplateFromCurrent(
    graphic,
    this.infoTemplate,
    this.uniqueIdPropertyName,
    this.name || 'Details'
  );

  const location =
    mapPoint ??
    JsonUtils.getPopupPoint(graphic.geometry as ArcLayerGeometry | null | undefined);

  graphic.popupTemplate = popupTemplate;

  this.view.openPopup({
    location,
    features: [graphic]
  });

  this.emitLayerEvent('popupChangeEvent', {
    features: [graphic],
    selectedIndex: 0
  });
}

private closePopup(): void {
  this.view?.closePopup();
}