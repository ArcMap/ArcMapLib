private createLayer(geojson: any): void {
  if (!this.view) {
    console.error('view not ready');
    return;
  }

  const fsInfo = JsonUtils.getArcGISJson(geojson);

  if (!fsInfo || !fsInfo.graphics.length) {
    console.warn('No features to render');
    return;
  }

  // Create layers ONLY ONCE
  if (!this.featureLayer) {
    this.featureLayer = new GraphicsLayer();
  }

  if (!this.labelLayer) {
    this.labelLayer = new GraphicsLayer();
  }

  // Add layers ONLY ONCE
  if (!this.featureLayer.parent) {
    this.view.map.add(this.featureLayer);
  }

  if (!this.labelLayer.parent) {
    this.view.map.add(this.labelLayer);
  }

  // Clear old graphics
  this.featureLayer.removeAll();
  this.labelLayer.removeAll();

  // Add new graphics
  for (const graphic of fsInfo.graphics) {
    this.featureLayer.add(graphic);
  }

  console.log('graphics count after add', fsInfo.graphics.length);
}