private normalizeFeatureLayerGeometryType(
  geometryType: string
): 'point' | 'multipoint' | 'polyline' | 'polygon' {
  switch (geometryType) {
    case 'esriGeometryPoint':
      return 'point';
    case 'esriGeometryMultipoint':
      return 'multipoint';
    case 'esriGeometryPolyline':
      return 'polyline';
    case 'esriGeometryPolygon':
      return 'polygon';
    default:
      return geometryType as 'point' | 'multipoint' | 'polyline' | 'polygon';
  }
}