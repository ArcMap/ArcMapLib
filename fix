private isExtentObject(value: unknown): value is UpMapExtent {
  return !!value &&
    typeof value === 'object' &&
    'leftLongitude' in value &&
    'rightLongitude' in value &&
    'topLatitude' in value &&
    'bottomLatitude' in value;
}


render() {
  const centerValue = this.center;
  const parsedCenter =
    centerValue &&
    typeof centerValue === 'object' &&
    'longitude' in centerValue &&
    'latitude' in centerValue &&
    typeof centerValue.longitude === 'number' &&
    typeof centerValue.latitude === 'number'
      ? [centerValue.longitude, centerValue.latitude]
      : undefined;

  const extentValue = this.extent;
  const parsedExtent =
    this.isExtentObject(extentValue) &&
    typeof extentValue.leftLongitude === 'number' &&
    typeof extentValue.rightLongitude === 'number' &&
    typeof extentValue.topLatitude === 'number' &&
    typeof extentValue.bottomLatitude === 'number'
      ? {
          xmin: extentValue.leftLongitude,
          ymin: extentValue.bottomLatitude,
          xmax: extentValue.rightLongitude,
          ymax: extentValue.topLatitude,
          spatialReference: { wkid: 4326 }
        }
      : undefined;

  return html`
    <div class="map-wrapper">
      <arcgis-map
        class="map"
        .basemap=${this.basemap ?? 'gray'}
        .extent=${parsedExtent}
        .center=${!parsedExtent ? parsedCenter : undefined}
        .zoom=${!parsedExtent ? this.zoom : undefined}
        .maxZoom=${this.maxZoom}
        .minZoom=${this.minZoom}
      >
      </arcgis-map>
    </div>
  `;
}