async connectedCallback(): Promise<void> {
  super.connectedCallback();

  try {
    this.ancestormap = this.closest('up-map') as any;

    if (!this.ancestormap) {
      console.error('<arc-geojson-layer> must be a descendant of an <up-map> element');
      return;
    }

    if (typeof this.ancestormap.componentOnReady === 'function') {
      await this.ancestormap.componentOnReady();
    }

    if ('updateComplete' in this.ancestormap) {
      await this.ancestormap.updateComplete;
    }

    await this._getView();

    console.log('this.view in connectedCallback of geojson layer', this.view);

    if (!this.view) {
      console.error('GeoJSON layer could not resolve view');
      return;
    }

    this.createLayer(this.geojson);
  } catch (error) {
    console.error('connectedCallback failed', error);
  }
}

private async _getView(): Promise<MapView | null> {
  if (!this.ancestormap || typeof this.ancestormap.getViewInstance !== 'function') {
    console.error('ancestor map must expose getViewInstance()');
    return null;
  }

  const result = await this.ancestormap.getViewInstance();
  this.view = result as MapView;

  console.log('result of getViewInstance of geojson layer', result);
  console.log('this.view after setting in getViewInstance of geojson layer', this.view);

  return this.view;
}

private createLayer(geojson: string | FeatureCollection): void {
  if (!this.view) {
    console.error('createLayer: view is missing');
    return;
  }

  const fsInfo = this.getArcGISJson(geojson);
  console.log('createLayer fsInfo', fsInfo);

  if (!fsInfo) {
    console.error('createLayer: fsInfo is null');
    return;
  }

  if (!this.featureLayer) {
    this.featureLayer = new GraphicsLayer({
      id: this.id || 'arc-geojson-layer',
      title: this.name || this.id || 'Arc GeoJSON Layer',
      listMode: 'show'
    });
  }

  if (!this.labelLayer) {
    this.labelLayer = new GraphicsLayer({
      id: `${this.id || 'arc-geojson-layer'}-labels`,
      title: `${this.name || this.id || 'Arc GeoJSON Layer'} Labels`,
      listMode: 'hide'
    });
  }

  console.log('featureLayer before add', this.featureLayer);
  console.log('labelLayer before add', this.labelLayer);
  console.log('featureLayer instanceof GraphicsLayer', this.featureLayer instanceof GraphicsLayer);
  console.log('labelLayer instanceof GraphicsLayer', this.labelLayer instanceof GraphicsLayer);

  const arcMap = this.getArcMapInstance();
  if (!arcMap) {
    console.error('createLayer: map is missing');
    return;
  }

  try {
    const existingLayers = arcMap.layers?.toArray?.() ?? [];

    if (this.featureLayer && !existingLayers.includes(this.featureLayer)) {
      arcMap.add(this.featureLayer as any);
    }

    if (this.labelLayer && !existingLayers.includes(this.labelLayer)) {
      arcMap.add(this.labelLayer as any);
    }
  } catch (error) {
    console.error('createLayer: failed adding layers to map', error);
    return;
  }

  this.featureLayer.removeAll();
  this.labelLayer.removeAll();

  for (const graphic of fsInfo.graphics) {
    this.featureLayer.add(graphic);
  }

  this.currentGeometryType = fsInfo.geometryType;

  this.updateRenderer(this.renderer);
  this.updateInfoTemplate(this.infoTemplate);
  this.refreshLabels();
}