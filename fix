private createLayer(geojson: string | FeatureCollection): void {
  if (!this.view) {
    console.error('createLayer: view is missing');
    return;
  }

  const fsInfo = this.getArcGISJson(geojson);
  console.log('createLayer fsInfo', fsInfo);

  if (!fsInfo) {
    console.error('createLayer: fsInfo is null');
    return;
  }

  if (!this.featureLayer) {
    this.featureLayer = new GraphicsLayer({
      id: this.id || 'arc-geojson-layer',
      title: this.name || this.id || 'Arc GeoJSON Layer',
      listMode: 'show'
    });
  }

  if (!this.labelLayer) {
    this.labelLayer = new GraphicsLayer({
      id: `${this.id || 'arc-geojson-layer'}-labels`,
      title: `${this.name || this.id || 'Arc GeoJSON Layer'} Labels`,
      listMode: 'hide'
    });
  }

  console.log('featureLayer before add', this.featureLayer);
  console.log('labelLayer before add', this.labelLayer);
  console.log('featureLayer instanceof GraphicsLayer', this.featureLayer instanceof GraphicsLayer);
  console.log('labelLayer instanceof GraphicsLayer', this.labelLayer instanceof GraphicsLayer);

  if (this.view.map) {
    const mapLayers = this.view.map.layers.toArray();

    if (this.featureLayer && !mapLayers.includes(this.featureLayer)) {
      this.view.map.add(this.featureLayer);
    }

    if (this.labelLayer && !mapLayers.includes(this.labelLayer)) {
      this.view.map.add(this.labelLayer);
    }
  }

  this.featureLayer.removeAll();
  this.labelLayer.removeAll();

  for (const graphic of fsInfo.graphics) {
    this.featureLayer.add(graphic);
  }

  this.currentGeometryType = fsInfo.geometryType;

  this.updateRenderer(this.renderer);
  this.updateInfoTemplate(this.infoTemplate);
  this.refreshLabels();
}