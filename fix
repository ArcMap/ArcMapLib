static updateRenderer(newRenderer: any, featureLayer: any): void {
  if (!newRenderer) {
    return;
  }

  const rendererParseResult = JsonUtils.getJsonFor(newRenderer);

  if (rendererParseResult.error) {
    console.warn('Invalid renderer JSON', rendererParseResult.error);
    return;
  }

  const parsed = JsonUtils.normalizeLegacyRendererJson(
    rendererParseResult.parsedJson
  );

  let renderer: any;

  switch (parsed.type) {
    case 'simple':
      renderer = new SimpleRenderer(parsed);
      break;

    case 'unique-value':
      renderer = new UniqueValueRenderer(parsed);
      break;

    case 'class-breaks':
      renderer = new ClassBreaksRenderer(parsed);
      break;

    default:
      console.error('Unsupported renderer type:', parsed.type);
      return;
  }

  featureLayer.renderer = renderer;
}