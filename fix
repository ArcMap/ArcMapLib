
private setupViewWatchers(): void {
  if (!this.view) return;

  this.eventHandles.add(
    reactiveUtils.watch(
      () => this.view?.zoom,
      (newZoom, oldZoom) => {
        if (
          typeof newZoom === 'number' &&
          typeof oldZoom === 'number' &&
          newZoom !== oldZoom
        ) {
          this.reflectOnlyZoom = newZoom;

          this.dispatchEvent(
            new CustomEvent<number>('zoom', {
              detail: newZoom,
              bubbles: true,
              composed: true
            })
          );
        }
      }
    )
  );

  this.eventHandles.add(
    reactiveUtils.watch(
      () => this.view?.extent,
      (newExtent) => {
        if (!newExtent) return;
        if (this.suspendExtentTracking) return;

        this.reflectCurrentMapState();
      }
    )
  );

  this.eventHandles.add(
    reactiveUtils.watch(
      () => this.view?.center,
      (newCenter) => {
        if (!newCenter) return;
        if (this.suspendExtentTracking) return;

        const center: LatLongPoint = {
          latitude: ValidationService.validateLatitude(
            newCenter.latitude,
            ArcMap.DEFAULT_CENTER_LATITUDE
          ),
          longitude: ValidationService.validateLongitude(
            newCenter.longitude,
            ArcMap.DEFAULT_CENTER_LONGITUDE
          )
        };

        this.reflectOnlyCenter = center;

        this.dispatchEvent(
          new CustomEvent<LatLongPoint>('center-change', {
            detail: center,
            bubbles: true,
            composed: true
          })
        );
      }
    )
  );
}

private syncPopupOptions(): void {
  if (!this.view) return;

  this.view.popupEnabled = this.popupComponentEnabled;

  const popup = this.view.popup;
  if (!popup) return;

  popup.visibleElements = {
    ...popup.visibleElements,
    closeButton: this.isPopupVisible
  };

  if (!this.popupComponentEnabled && popup.visible) {
    popup.close();
    return;
  }

  if (this.usePopupContentOnly && this.customPopupContent) {
    this.setPopupContent(this.customPopupContent, true);
  }
}