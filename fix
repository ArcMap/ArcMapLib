private geojsonFeatureToGraphic(feature: Feature, index: number): Graphic | null {
  if (!feature || feature.type !== 'Feature') {
    console.warn('Invalid feature', feature);
    return null;
  }

  const geometry = this.geojsonGeometryToArcGeometry(feature.geometry ?? null);

  if (!geometry) {
    console.warn('Could not convert feature geometry', feature);
    return null;
  }

  const properties: any = {
    ...(feature.properties ?? {})
  };

  if (properties[this.uniqueIdPropertyName] === undefined) {
    properties[this.uniqueIdPropertyName] = index;
  }

  if (properties.OBJECTID === undefined) {
    properties.OBJECTID = index + 1;
  }

  if (properties.LABEL === undefined && properties.label !== undefined) {
    properties.LABEL = properties.label;
  }

  const graphic = new Graphic({
    geometry,
    attributes: properties,
    symbol: JsonUtils.getDefaultSymbolForGeometry(geometry)
  });

  graphic.popupTemplate = JsonUtils.buildPopupTemplateFromCurrent(
    graphic,
    this.infoTemplate,
    this.uniqueIdPropertyName,
    this.name || 'Details'
  );

  return graphic;
}

private geojsonGeometryToArcGeometry(geometry: GeoJsonGeometry | null): ArcLayerGeometry | null {
  if (!geometry || !geometry.type) {
    return null;
  }

  switch (geometry.type) {
    case 'Point': {
      const coords = geometry.coordinates as number[];
      if (!Array.isArray(coords) || coords.length < 2) {
        return null;
      }

      return new Point({
        x: coords[0],
        y: coords[1],
        spatialReference: { wkid: 4326 }
      });
    }

    case 'MultiPoint': {
      const coords = geometry.coordinates as number[][];
      if (!Array.isArray(coords) || coords.length === 0) {
        return null;
      }

      return new Multipoint({
        points: coords,
        spatialReference: { wkid: 4326 }
      });
    }

    case 'LineString': {
      const coords = geometry.coordinates as number[][];
      if (!Array.isArray(coords) || coords.length < 2) {
        return null;
      }

      return new Polyline({
        paths: [coords],
        spatialReference: { wkid: 4326 }
      });
    }

    case 'MultiLineString': {
      const coords = geometry.coordinates as number[][][];
      if (!Array.isArray(coords) || coords.length === 0) {
        return null;
      }

      return new Polyline({
        paths: coords,
        spatialReference: { wkid: 4326 }
      });
    }

    case 'Polygon': {
      const coords = geometry.coordinates as number[][][];
      if (!Array.isArray(coords) || coords.length === 0) {
        return null;
      }

      return new Polygon({
        rings: coords,
        spatialReference: { wkid: 4326 }
      });
    }

    case 'MultiPolygon': {
      const coords = geometry.coordinates as number[][][][];
      if (!Array.isArray(coords) || coords.length === 0) {
        return null;
      }

      const rings: number[][][] = [];
      coords.forEach((polygonCoords: number[][][]) => {
        polygonCoords.forEach((ring: number[][]) => {
          rings.push(ring);
        });
      });

      if (!rings.length) {
        return null;
      }

      return new Polygon({
        rings,
        spatialReference: { wkid: 4326 }
      });
    }

    default:
      console.warn('Unsupported geometry type', geometry.type);
      return null;
  }
}

