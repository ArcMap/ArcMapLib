
private setupViewWatchers(): void {
  if (!this.view) return;

  this.eventHandles.add(
    reactiveUtils.watch(
      () => this.view?.zoom,
      (newZoom, oldZoom) => {
        if (
          typeof newZoom === 'number' &&
          typeof oldZoom === 'number' &&
          newZoom !== oldZoom
        ) {
          this.reflectOnlyZoom = newZoom;

          this.dispatchEvent(
            new CustomEvent<number>('zoom', {
              detail: newZoom,
              bubbles: true,
              composed: true
            })
          );
        }
      }
    )
  );

  this.eventHandles.add(
    reactiveUtils.watch(
      () => this.view?.extent,
      (newExtent) => {
        if (!newExtent) return;
        if (this.suspendExtentTracking) return;

        this.reflectCurrentMapState();
      }
    )
  );

  this.eventHandles.add(
    reactiveUtils.watch(
      () => this.view?.center,
      (newCenter) => {
        if (!newCenter) return;
        if (this.suspendExtentTracking) return;

        const center: LatLongPoint = {
          latitude: ValidationService.validateLatitude(
            newCenter.latitude,
            ArcMap.DEFAULT_CENTER_LATITUDE
          ),
          longitude: ValidationService.validateLongitude(
            newCenter.longitude,
            ArcMap.DEFAULT_CENTER_LONGITUDE
          )
        };

        this.reflectOnlyCenter = center;

        this.dispatchEvent(
          new CustomEvent<LatLongPoint>('center-change', {
            detail: center,
            bubbles: true,
            composed: true
          })
        );
      }
    )
  );
}

private syncPopupOptions(): void {
  if (!this.view) return;

  this.view.popupEnabled = this.popupComponentEnabled;

  const popup = this.view.popup;
  if (!popup) return;

  popup.visibleElements = {
    ...popup.visibleElements,
    closeButton: this.isPopupVisible
  };

  if (!this.popupComponentEnabled && popup.visible) {
    popup.close();
    return;
  }

  if (this.usePopupContentOnly && this.customPopupContent) {
    this.setPopupContent(this.customPopupContent, true);
  }
}


render() {
  const parsedCenter = this.center
    ? [this.center.longitude, this.center.latitude]
    : undefined;

  const parsedExtent = this.extent
    ? {
        xmin: this.extent.leftLongitude,
        ymin: this.extent.bottomLatitude,
        xmax: this.extent.rightLongitude,
        ymax: this.extent.topLatitude,
        spatialReference: { wkid: 4326 }
      }
    : undefined;

  return html`
    <arcgis-map
      basemap=${this.basemap ?? 'gray'}
      .extent=${parsedExtent}
      .center=${!parsedExtent ? parsedCenter : undefined}
      .zoom=${!parsedExtent ? this.zoom : undefined}
    >
    </arcgis-map>
  `;
}



render() {
  // SAFE CENTER PARSE
  const parsedCenter =
    this.center &&
    typeof this.center === 'object' &&
    typeof this.center.longitude === 'number' &&
    typeof this.center.latitude === 'number'
      ? [this.center.longitude, this.center.latitude]
      : undefined;

  // SAFE EXTENT PARSE
  const parsedExtent =
    this.extent &&
    typeof this.extent.leftLongitude === 'number' &&
    typeof this.extent.rightLongitude === 'number' &&
    typeof this.extent.topLatitude === 'number' &&
    typeof this.extent.bottomLatitude === 'number'
      ? {
          xmin: this.extent.leftLongitude,
          ymin: this.extent.bottomLatitude,
          xmax: this.extent.rightLongitude,
          ymax: this.extent.topLatitude,
          spatialReference: { wkid: 4326 }
        }
      : undefined;

  return html`
    <div class="map-wrapper">
      <arcgis-map
        class="map"
        .basemap=${this.basemap ?? 'gray'}

        ${parsedExtent
          ? html` .extent=${parsedExtent} `
          : parsedCenter
          ? html`
              .center=${parsedCenter}
              .zoom=${this.zoom}
            `
          : html`
              .center=${[-98, 39]}
              .zoom=${4}
            `}

        .maxZoom=${this.maxZoom}
        .minZoom=${this.minZoom}
      >
      </arcgis-map>
    </div>
  `;
}
