private static areExtentsEqual(
  a?: ArcMapExtent | string | null,
  b?: ArcMapExtent | string | null
): boolean {
  if (!a || !b) return false;

  const extentA =
    typeof a === 'string' ? (JSON.parse(a) as ArcMapExtent) : a;
  const extentB =
    typeof b === 'string' ? (JSON.parse(b) as ArcMapExtent) : b;

  return (
    extentA.leftLongitude === extentB.leftLongitude &&
    extentA.rightLongitude === extentB.rightLongitude &&
    extentA.bottomLatitude === extentB.bottomLatitude &&
    extentA.topLatitude === extentB.topLatitude
  );
}

private async updateCenter(
  newCenter: LatLongPoint | string | null
): Promise<void> {
  if (!this.view || !newCenter) return;

  if (
    this.reflectOnlyCenter &&
    ArcMap.areLatLongEqual(this.reflectOnlyCenter, newCenter)
  ) {
    return;
  }

  const validCenter = ArcMap.parseValidateAndConvertLatLongPoint(newCenter);
  if (!validCenter) return;

  this.pendingExtentChanges = this.pendingExtentChanges.then(async () => {
    this.reflectOnlyCenter = undefined;

    await this.view.goTo({
      center: [validCenter.longitude, validCenter.latitude]
    });
  });

  await this.pendingExtentChanges;
}

private async updateExtent(
  extentInput: ArcMapExtent | string | null
): Promise<void> {
  if (!this.view || !extentInput) return;

  if (
    this.reflectOnlyExtent &&
    ArcMap.areExtentsEqual(this.reflectOnlyExtent, extentInput)
  ) {
    return;
  }

  const validExtent = await ArcMap.parseValidateAndConvertExtent(extentInput)
    .then((extent) => extent)
    .catch(() => null);

  if (!validExtent) return;

  this.pendingExtentChanges = this.pendingExtentChanges.then(async () => {
    this.reflectOnlyExtent = undefined;
    await this.view.goTo(validExtent);
  });

  await this.pendingExtentChanges;
}

private static areExtentsEqual(
  a?: ArcMapExtent | string | null,
  b?: ArcMapExtent | string | null
): boolean {
  if (!a || !b) return false;

  const extentA =
    typeof a === 'string' ? (JSON.parse(a) as ArcMapExtent) : a;
  const extentB =
    typeof b === 'string' ? (JSON.parse(b) as ArcMapExtent) : b;

  return (
    extentA.leftLongitude === extentB.leftLongitude &&
    extentA.rightLongitude === extentB.rightLongitude &&
    extentA.bottomLatitude === extentB.bottomLatitude &&
    extentA.topLatitude === extentB.topLatitude
  );
}

private static async parseValidateAndConvertExtent(
  extent: ArcMapExtent | string
): Promise<Extent> {
  let parsedExtent: ArcMapExtent;

  if (typeof extent === 'string') {
    try {
      parsedExtent = JSON.parse(extent) as ArcMapExtent;
    } catch (e) {
      console.warn('Could not parse extent as json, ignoring this property', e);
      return Promise.reject();
    }
  } else {
    parsedExtent = extent;
  }

  if (!ValidationService.isValidArcMapExtent(parsedExtent)) {
    console.warn('Invalid value for extent, ignoring this property');
    return Promise.reject();
  }

  return new Extent({
    xmin: parsedExtent.leftLongitude,
    ymin: parsedExtent.bottomLatitude,
    xmax: parsedExtent.rightLongitude,
    ymax: parsedExtent.topLatitude,
    spatialReference: { wkid: 4326 }
  });
}

private static parseValidateAndConvertLatLongPoint(
  latLong: LatLongPoint | string
): LatLongPoint | undefined {
  let parsedLatLong: LatLongPoint;

  if (typeof latLong === 'string') {
    try {
      parsedLatLong = JSON.parse(latLong) as LatLongPoint;
    } catch (e) {
      console.warn('Could not parse center as json, ignoring this property', e);
      return;
    }
  } else {
    parsedLatLong = latLong;
  }

  if (!ValidationService.isValidLatLongPoint(parsedLatLong)) {
    console.warn('Invalid value for center point, ignoring this property');
    return;
  }

  return {
    longitude: parsedLatLong.longitude,
    latitude: parsedLatLong.latitude
  };
}

