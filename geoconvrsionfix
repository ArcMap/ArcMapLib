private _getDefaultSymbol(geomType: string): any {
  switch (geomType) {
    case 'point':
    case 'multipoint':
      return new SimpleMarkerSymbol({
        color: this.DEFAULT_SYMBOL_COLOR,
        size: 10,
        outline: {
          color: [0, 0, 0, 255],
          width: 1,
        },
      });
    case 'polyline':
      return new SimpleLineSymbol({
        color: this.DEFAULT_SYMBOL_COLOR,
        width: 2,
      });
    case 'polygon':
    default:
      return new SimpleFillSymbol({
        color: [
          this.DEFAULT_SYMBOL_COLOR[0],
          this.DEFAULT_SYMBOL_COLOR[1],
          this.DEFAULT_SYMBOL_COLOR[2],
          100,
        ],
        outline: new SimpleLineSymbol({
          color: this.DEFAULT_SYMBOL_COLOR,
          width: 1,
        }),
      });
  }
}

static getLabelJson(userLabel: any, userColor: any, userSize: any): any {
  // ✅ Guard empty/null label json
  if (!userLabel || userLabel === '') {
    // Skip parsing, go straight to default
    let labelColor = this.DEFAULT_LABEL_COLOR;
    const colorJson = this.getJsonFor(userColor);
    if (!colorJson.error && colorJson.parsedJson) {
      labelColor = colorJson.parsedJson;
    }
    let labelSize = this.DEFAULT_LABEL_SIZE;
    if (!isNaN(userSize) && userSize > 0) {
      labelSize = userSize;
    }
    return this.getJsonLabelFor(labelColor, labelSize);
  }

  const labelJson = this.getJsonFor(userLabel);
  if (labelJson.error || !labelJson.parsedJson) {
    if (labelJson.error) {
      console.warn('Could not parse label json', labelJson.error);
    }
    return this.getJsonLabelFor(this.DEFAULT_LABEL_COLOR, this.DEFAULT_LABEL_SIZE);
  }
  return labelJson.parsedJson;
}


private _arcGisGraphicToGeoJson(graphic: Graphic): any {
  // ✅ Guard against undefined/null graphic
  if (!graphic) {
    console.warn('_arcGisGraphicToGeoJson: graphic is undefined');
    return null;
  }

  // ✅ Guard against missing geometry
  if (!graphic.geometry) {
    return {
      type: 'Feature',
      id: graphic.attributes?.[this.uniqueIdPropertyName],
      geometry: null,
      properties: { ...graphic.attributes },
    };
  }

  const geometryJson = graphic.geometry.toJSON();

  // Convert ArcGIS geometry JSON to GeoJSON format
  let geoJsonGeometry: any = null;

  switch (graphic.geometry.type) {
    case 'point': {
      const g = graphic.geometry as Point;
      geoJsonGeometry = {
        type: 'Point',
        coordinates: [g.longitude, g.latitude],
      };
      break;
    }
    case 'polyline': {
      const g = graphic.geometry as Polyline;
      geoJsonGeometry = {
        type: g.paths.length === 1 ? 'LineString' : 'MultiLineString',
        coordinates: g.paths.length === 1 ? g.paths[0] : g.paths,
      };
      break;
    }
    case 'polygon': {
      const g = graphic.geometry as Polygon;
      geoJsonGeometry = {
        type: 'Polygon',
        coordinates: g.rings,
      };
      break;
    }
    default:
      geoJsonGeometry = null;
  }

  return {
    type: 'Feature',
    id: graphic.attributes?.[this.uniqueIdPropertyName],
    geometry: geoJsonGeometry,
    properties: { ...graphic.attributes },
  };
}
