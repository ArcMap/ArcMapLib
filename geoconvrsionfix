private _updateRenderer(newRenderer: any) {
  if (!this.featureLayer) return;

  // If no custom renderer provided, apply default symbol — bypass JsonUtils
  if (!newRenderer) {
    this.featureLayer.renderer = {
      type: 'simple',
      symbol: this._getDefaultSymbol(this.featureLayer.geometryType),
    } as any;
    return;
  }

  // Custom renderer — ensure symbol has type property for ArcGIS 5.0 autocast
  try {
    const rendererJson = typeof newRenderer === 'string'
      ? JSON.parse(newRenderer)
      : newRenderer;

    this.featureLayer.renderer = {
      type: rendererJson.type ?? 'simple',
      symbol: rendererJson.symbol ?? this._getDefaultSymbol(this.featureLayer.geometryType),
      ...rendererJson,
    } as any;
  } catch {
    // Fallback to default
    this.featureLayer.renderer = {
      type: 'simple',
      symbol: this._getDefaultSymbol(this.featureLayer.geometryType),
    } as any;
  }
}




private _getDefaultSymbol(esriGeomType: string): any {
  switch (esriGeomType) {
    case 'esriGeometryPoint':
    case 'esriGeometryMultipoint':
      return new SimpleMarkerSymbol({
        color: this.DEFAULT_SYMBOL_COLOR,
        size: UpGeoJsonLayer.DEFAULT_SYMBOL_MARKER_SIZE,
      });
    case 'esriGeometryPolyline':
      return new SimpleLineSymbol({
        color: this.DEFAULT_SYMBOL_COLOR,
        width: UpGeoJsonLayer.DEFAULT_SYMBOL_LINE_WIDTH,
      });
    case 'esriGeometryPolygon':
      return new SimpleFillSymbol({
        color: this.DEFAULT_SYMBOL_COLOR,
        outline: {
          color: this.DEFAULT_SYMBOL_COLOR,
          width: UpGeoJsonLayer.DEFAULT_SYMBOL_LINE_WIDTH,
        },
      });
    default:
      return new SimpleMarkerSymbol();
  }
}




private async createLayer(geojson: string | FeatureCollection): Promise<void> {
  if (!geojson) geojson = { type: 'FeatureCollection', features: [] };

  const parsed = this._parseGeojson(geojson) ?? { type: 'FeatureCollection', features: [] } as FeatureCollection;
  const esriGeomType = parsed.features.length > 0
    ? getEsriGeometryType(parsed.features[0].geometry?.type ?? '')
    : 'esriGeometryPoint';

  // ArcGIS 5.0: FeatureLayer.source must be Graphic[], not raw JSON
  const graphics: Graphic[] = parsed.features.map((feature, index) =>
    new Graphic(geojsonFeatureToArcGIS(feature, index))
  );

  const featureLayer = new FeatureLayer({
    id: (this as any).id || undefined,
    source: graphics,
    geometryType: esriGeomType as any,
    spatialReference: { wkid: 4326 },
    fields: [this.objectIdField as any],
    objectIdField: 'OBJECTID',
    title: this.name,
  });

  this.featureLayer = featureLayer;

  // MUST await — handles z-order insertion
  await this.ancestorMap.addLayer(this.featureLayer, this);

  // Apply CSS class after layer is on the map
  if (this.layerClass) {
    this.featureLayer.when(() => {
      try { (this.featureLayer as any).set?.('className', this.layerClass); } catch (_) { /**/ }
    });
  }

  // Renderer
  if (this.renderer && graphics.length > 0) {
    this._updateRenderer(this.renderer);
  } else {
    const symbolJson = this.getSymbolJson(esriGeomType);
    this.featureLayer.renderer = new SimpleRenderer(symbolJson as any);
  }

  // Labels
  const labelJson = JsonUtils.getLabelJson(this.labelJson, this.labelColor, this.labelSize);
  JsonUtils.updateLabelJson(labelJson, this.featureLayer);
  this.featureLayer.labelsVisible = true;

  // Popup
  PopupUtils.updatePopup(this.infoTemplate, this.ancestorMap, this.featureLayer);

  // Get the view for all event wiring
  const view = await this.ancestorMap.getEsriMap();

  // ─── Mouse events via view.hitTest (ArcGIS 5.0 — FeatureLayer.on('click') removed) ───

  // Track hover state for mouseOver / mouseOut
  let isHovered = false;

  const clickHandle = (view as any).on('click', async (evt: any) => {
    const hitResult = await view.hitTest(evt);
    const hit = hitResult.results.find(
      (r: any) => r.graphic?.layer === this.featureLayer
    );
    if (!hit) return;

    const graphic = (hit as any).graphic;
    const { webMercatorToGeographic } = await import(
      '@arcgis/core/geometry/support/webMercatorUtils'
    );
    const coords = webMercatorToGeographic(evt.mapPoint) as any;

    this.dispatchEvent(new CustomEvent('layerClick', {
      detail: {
        coordinates: { latitude: coords?.y, longitude: coords?.x },
        attributes: graphic?.attributes,
      },
      bubbles: true,
      composed: true,
    }));
  });
  this.eventHandles.push(clickHandle);

  const dblClickHandle = (view as any).on('double-click', async (evt: any) => {
    const hitResult = await view.hitTest(evt);
    const hit = hitResult.results.find(
      (r: any) => r.graphic?.layer === this.featureLayer
    );
    if (!hit) return;

    const graphic = (hit as any).graphic;
    const { webMercatorToGeographic } = await import(
      '@arcgis/core/geometry/support/webMercatorUtils'
    );
    const coords = webMercatorToGeographic(evt.mapPoint) as any;

    this.dispatchEvent(new CustomEvent('doubleClick', {
      detail: {
        coordinates: { latitude: coords?.y, longitude: coords?.x },
        attributes: graphic?.attributes,
      },
      bubbles: true,
      composed: true,
    }));
  });
  this.eventHandles.push(dblClickHandle);

  const pointerMoveHandle = (view as any).on('pointer-move', async (evt: any) => {
    const hitResult = await view.hitTest(evt);
    const hit = hitResult.results.find(
      (r: any) => r.graphic?.layer === this.featureLayer
    );

    if (hit && !isHovered) {
      isHovered = true;
      const graphic = (hit as any).graphic;
      const { webMercatorToGeographic } = await import(
        '@arcgis/core/geometry/support/webMercatorUtils'
      );
      const coords = webMercatorToGeographic(evt.mapPoint) as any;

      this.dispatchEvent(new CustomEvent('layerMouseOver', {
        detail: {
          coordinates: { latitude: coords?.y, longitude: coords?.x },
          attributes: graphic?.attributes,
        },
        bubbles: true,
        composed: true,
      }));
    } else if (!hit && isHovered) {
      isHovered = false;
      this.dispatchEvent(new CustomEvent('layerMouseOut', {
        detail: {},
        bubbles: true,
        composed: true,
      }));
    }
  });
  this.eventHandles.push(pointerMoveHandle);

  // ─── Editor setup ────────────────────────────────────────────────────────
  await this.createEditor();

  // Sync internal geojson without triggering the watcher
  this.blockGeoJsonUpdate = true;
  this.geojson = geojson;
  this.blockGeoJsonUpdate = false;
}


private async createEditor(): Promise<void> {
  if (!this.featureLayer) return;

  const view = await this.ancestorMap.getEsriMap();
  const sketchLayer = new GraphicsLayer({ listMode: 'hide' });
  (view as any).map.add(sketchLayer);

  this.graphicsEditor = new SketchViewModel({
    view: view as any,
    layer: sketchLayer,
  });

  // ArcGIS 4.x/5.0: all edit events come through 'update'
  this.graphicsEditor.on('update', (evt: any) => {
    if (!evt.toolEventInfo) return;
    const type: string = evt.toolEventInfo.type;

    if (type === 'move-start') this.graphicMoved = false;
    if (type === 'move') this.graphicMoved = true;

    if (['rotate-stop', 'scale-stop', 'vertex-add', 'vertex-remove', 'reshape-stop'].includes(type)) {
      evt.graphics?.forEach((g: Graphic) => this.updateGeoJsonWithChanges(g));
    }
    if (type === 'move-stop' && this.graphicMoved) {
      this.graphicMoved = false;
      evt.graphics?.forEach((g: Graphic) => this.updateGeoJsonWithChanges(g));
    }
  });

  // ArcGIS 5.0: use view.on('click') + hitTest instead of featureLayer.on('click')
  const clickHandle = (view as any).on('click', async (evt: any) => {
    if (!this.enableUserEdit) return;

    const hitResult = await view.hitTest(evt);
    const hit = hitResult.results.find(
      (r: any) => r.graphic?.layer === this.featureLayer
    );
    if (!hit) return;

    const graphic = (hit as any).graphic;

    if (evt.native?.ctrlKey && this.enableUserEditRemove) {
      this.removingItem = true;
      this.removeFromGeoJson(graphic);
      this.graphicsEditor.cancel();
      this.removingItem = false;
      return;
    }

    this.activateGraphicsEditor(graphic);
  });
  this.eventHandles.push(clickHandle);
}
