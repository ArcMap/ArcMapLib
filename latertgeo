<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>arc-geojson-layer test</title>
  <style>
    html, body {
      margin: 0;
      padding: 0;
      width: 100%;
      height: 100%;
    }
    arc-map {
      display: block;
      width: 100%;
      height: 100vh;
    }
  </style>
</head>
<body>
  <arc-map
    id="map"
    center='{"longitude": -80.87, "latitude": 35.215}'
    basemap="dark-gray-vector"
    zoom="4"
  >

    <arc-geojson-layer
      id="testLayer"
      name="Test Layer"
      unique-id-property-name="id"
      geojson='{
        "type": "FeatureCollection",
        "features": [
          {
            "type": "Feature",
            "geometry": {
              "type": "Point",
              "coordinates": [-80.87, 35.215]
            },
            "properties": {
              "id": "1",
              "TestField": "Value A",
              "OtherField": "Other A",
              "listDescription": "Description A"
            }
          },
          {
            "type": "Feature",
            "geometry": {
              "type": "Point",
              "coordinates": [-90.0, 38.5]
            },
            "properties": {
              "id": "2",
              "TestField": "Value B",
              "OtherField": "Other B",
              "listDescription": "Description B"
            }
          },
          {
            "type": "Feature",
            "geometry": {
              "type": "Point",
              "coordinates": [-73.5, 40.7]
            },
            "properties": {
              "id": "3",
              "TestField": "Value C",
              "OtherField": "Other C",
              "listDescription": "Description C"
            }
          }
        ]
      }'
      info-template='{
        "listItem": "${listDescription}",
        "details": "<p><b>Test Field:</b> ${TestField}</p><p><b>Other Field:</b> ${OtherField}</p>"
      }'
    ></arc-geojson-layer>

  </arc-map>

  <script type="module" src="./index.ts"></script>

  <script>
    // Test event listeners
    const layer = document.getElementById('testLayer');

    layer.addEventListener('layerClick', (e) => {
      console.log('layerClick fired:', e.detail);
    });

    layer.addEventListener('layerMouseOver', (e) => {
      console.log('layerMouseOver fired:', e.detail);
    });

    layer.addEventListener('layerMouseOut', (e) => {
      console.log('layerMouseOut fired');
    });

    layer.addEventListener('doubleClick', (e) => {
      console.log('doubleClick fired:', e.detail);
    });
  </script>
</body>
</html>
