import { LitElement } from 'lit';
import { customElement, property } from 'lit/decorators.js';

import Graphic from '@arcgis/core/Graphic';
import GraphicsLayer from '@arcgis/core/layers/GraphicsLayer';
import SketchViewModel from '@arcgis/core/widgets/Sketch/SketchViewModel';
import MapView from '@arcgis/core/views/MapView';
import PopupTemplate from '@arcgis/core/PopupTemplate';
import * as webMercatorUtils from '@arcgis/core/geometry/support/webMercatorUtils';
import Point from '@arcgis/core/geometry/Point';
import Polyline from '@arcgis/core/geometry/Polyline';
import Polygon from '@arcgis/core/geometry/Polygon';

import JsonUtils from '../../common/json-utils';
import DrawEditUtils from '../../common/draw-edit-utils';
import PopupUtils from '../../common/popup-utils';
import MapUtils from '../../common/map-utils';

@customElement('arc-geojson-layer')
export class ArcGeojsonLayer extends LitElement {

  private view!: MapView;
  private featureLayer!: GraphicsLayer;
  private labelLayer!: GraphicsLayer;
  private sketch!: SketchViewModel;

  private inDrawingMode = false;

  // ---------------- PROPERTIES ----------------

  @property({ type: Boolean }) enableUserEdit = false;
  @property({ type: Boolean }) enableUserEditMove = true;
  @property({ type: Boolean }) enableUserEditVertices = true;
  @property({ type: Boolean }) enableUserEditScaling = true;
  @property({ type: Boolean }) enableUserEditRotating = true;
  @property({ type: Boolean }) enableUserEditUniformScaling = true;
  @property({ type: Boolean }) enableUserEditAddVertices = true;
  @property({ type: Boolean }) enableUserEditDeleteVertices = true;
  @property({ type: Boolean }) enableUserEditRemove = true;

  @property({ attribute: false }) geojson: any = { type: 'FeatureCollection', features: [] };
  @property({ attribute: false }) infoTemplate: any;

  @property({ attribute: false }) renderer: any;
  @property({ attribute: false }) labeljson: any;
  @property({ attribute: false }) labelcolor: any;
  @property({ attribute: false }) labelsize: any;

  @property() uniqueIdPropertyName = 'id';

  // ---------------- LIFECYCLE ----------------

  async connectedCallback() {
    super.connectedCallback();
    await this.initializeLayer();
  }

  async initializeLayer() {
    const mapElement = this.closest('arc-map') as any;

    this.view = await mapElement.getView();

    this.featureLayer = new GraphicsLayer({ id: this.getLayerId() });
    this.labelLayer = new GraphicsLayer({ id: this.getLayerId() + '-labels' });

    this.view.map.add(this.featureLayer);
    this.view.map.add(this.labelLayer);

    this.initializeEditor();
    this.bindMapClick();

    this.refreshGeoJSON();
  }

  // ---------------- EDITOR ----------------

  initializeEditor() {
    this.sketch = new SketchViewModel({
      view: this.view,
      layer: this.featureLayer,
      updateOnGraphicClick: false
    });

    this.sketch.on('update', (event) => {
      if (event.state === 'start') {
        this.inDrawingMode = true;
      }

      if (event.state === 'complete') {
        this.inDrawingMode = false;
        this.syncToGeoJSON();
      }
    });

    this.sketch.on('create', (event) => {
      if (event.state === 'complete') {
        this.inDrawingMode = false;
        this.syncToGeoJSON();
      }
    });
  }

  // ---------------- DRAW ----------------

  startDrawing(type: string) {
    this.inDrawingMode = true;
    const tool = DrawEditUtils.toSketchCreateTool(type);
    this.sketch.create(tool);
  }

  cancelDrawing() {
    this.sketch.cancel();
    this.inDrawingMode = false;
  }

  // ---------------- MAP CLICK ----------------

  bindMapClick() {
    this.view.on('click', async (event) => {

      const hit = await this.view.hitTest(event);
      const graphic = hit.results.find(r => r.graphic.layer === this.featureLayer)?.graphic;

      if (!graphic) return;

      // ❗ Disable popup during edit
      if (!PopupUtils.shouldOpenPopup(this.enableUserEdit, this.inDrawingMode)) {
        return;
      }

      this.openPopup(graphic, event.mapPoint);
    });
  }

  // ---------------- POPUP ----------------

  openPopup(graphic: Graphic, mapPoint: any) {
    const content = PopupUtils.buildPopupContent(this.infoTemplate, graphic);

    this.view.popup.open({
      location: mapPoint,
      features: [graphic],
      title: content.title,
      content: content.content
    });
  }

  // ---------------- EDIT ACTION ----------------

  editGraphic(graphic: Graphic) {
    if (!this.enableUserEdit) return;

    this.inDrawingMode = true;

    this.sketch.update(graphic, {
      tool: 'reshape',
      enableRotation: this.enableUserEditRotating,
      enableScaling: this.enableUserEditScaling,
      preserveAspectRatio: this.enableUserEditUniformScaling,
      enableMoveAllGraphics: this.enableUserEditMove
    });
  }

  // ---------------- GEOJSON ----------------

  refreshGeoJSON() {
    if (!this.geojson?.features) return;

    this.featureLayer.removeAll();
    this.labelLayer.removeAll();

    this.geojson.features.forEach((feature: any) => {
      const graphic = this.createGraphicFromGeoJSON(feature);
      if (!graphic) return;

      this.featureLayer.add(graphic);

      const label = JsonUtils.buildLabelGraphic(graphic, this.labelcolor, this.labelsize);
      if (label) this.labelLayer.add(label);
    });
  }

  createGraphicFromGeoJSON(feature: any): Graphic | null {
    const geometry = feature.geometry;

    let esriGeometry: any;

    switch (geometry.type) {
      case 'Point':
        esriGeometry = new Point({
          longitude: geometry.coordinates[0],
          latitude: geometry.coordinates[1]
        });
        break;

      case 'LineString':
        esriGeometry = new Polyline({
          paths: [geometry.coordinates]
        });
        break;

      case 'Polygon':
        esriGeometry = new Polygon({
          rings: geometry.coordinates
        });
        break;

      default:
        return null;
    }

    const symbolJson = this.renderer || JsonUtils.getJsonSymbolFor(
      esriGeometry.type,
      JsonUtils.getRandomColor(),
      10
    );

    const symbol = JsonUtils.buildArcgisSymbol(symbolJson, esriGeometry.type);

    return new Graphic({
      geometry: esriGeometry,
      attributes: feature.properties,
      symbol
    });
  }

  syncToGeoJSON() {
    const features = this.featureLayer.graphics.map((g: Graphic) => {
      const geo = this.convertToGeoJSON(g);
      return {
        type: 'Feature',
        geometry: geo,
        properties: g.attributes
      };
    });

    this.geojson = {
      type: 'FeatureCollection',
      features
    };
  }

  convertToGeoJSON(graphic: Graphic) {
    const geom = graphic.geometry;

    if (geom.type === 'point') {
      const geo = webMercatorUtils.webMercatorToGeographic(geom);
      return {
        type: 'Point',
        coordinates: [geo.x, geo.y]
      };
    }

    if (geom.type === 'polyline') {
      return {
        type: 'LineString',
        coordinates: geom.paths[0]
      };
    }

    if (geom.type === 'polygon') {
      return {
        type: 'Polygon',
        coordinates: geom.rings
      };
    }

    return null;
  }

  // ---------------- HELPERS ----------------

  getLayerId(): string {
    return `arc-geojson-${Math.random().toString(36).substring(2)}`;
  }

  findFeatureByUniqueId(id: any): Graphic | undefined {
    return this.featureLayer.graphics.find(g => g.attributes?.[this.uniqueIdPropertyName] === id);
  }

  zoomTo(graphic: Graphic) {
    this.view.goTo(graphic.geometry);
  }

  render() {
    return null;
  }
}