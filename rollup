output: {
  dir: './dist',
  format: 'es',
  chunkFileNames: 'chunks/[hash].js',
  paths: (id) => {
    if (id.startsWith('@arcgis/core/')) {
      const path = id.replace('@arcgis/core/', '');
      const withExt = path.endsWith('.js') ? path : path + '.js';
      return 'https://js.arcgis.com/5.0/@arcgis/core/' + withExt;
    }
    return id;
  }
},
external: (id) => {
  if (id.includes('@arcgis/core')) return true;
  if (id.includes('@arcgis/map-components')) return true;
  if (id.includes('@esri/calcite-components')) return true;
  if (id.includes('@up-elements')) return true;
  return false;
},
