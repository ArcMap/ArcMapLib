onwarn(warning, warn) {
  // This will show us which @arcgis imports are NOT being externalized
  if (warning.code === 'UNRESOLVED_IMPORT') {
    console.log('NOT EXTERNAL:', warning.source);
  }
  warn(warning);
},
external: (id) => {
  if (id.includes('@arcgis/core')) return true;  // broader match
  if (id.includes('@arcgis/map-components')) return true;
  if (id.includes('@esri/calcite-components')) return true;
  if (id.includes('@up-elements')) return true;
  return false;
},
