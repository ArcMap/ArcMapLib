<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Arc GeoJSON Layer Demo</title>

    <!-- ArcGIS CSS -->
    <link
      rel="stylesheet"
      href="https://js.arcgis.com/4.29/esri/themes/light/main.css"
    />

    <style>
      html,
      body {
        margin: 0;
        padding: 0;
        height: 100%;
        width: 100%;
      }

      arc-map {
        display: block;
        height: 100vh;
        width: 100%;
      }
    </style>
  </head>

  <body>
    <!-- arc-map is your LitElement map component -->
    <arc-map id="mainMap">

      <!-- ✅ POINT layer -->
      <arc-geojson-layer
        id="point-layer"
        name="Point Layer"
        unique-id-property-name="id"
      ></arc-geojson-layer>

      <!-- ✅ LINESTRING layer -->
      <arc-geojson-layer
        id="line-layer"
        name="Line Layer"
        unique-id-property-name="id"
      ></arc-geojson-layer>

      <!-- ✅ POLYGON layer -->
      <arc-geojson-layer
        id="polygon-layer"
        name="Polygon Layer"
        unique-id-property-name="id"
      ></arc-geojson-layer>

    </arc-map>

    <!-- Your compiled Lit component bundle -->
    <script type="module" src="/dist/index.js"></script>

    <script type="module">
      // ✅ Wait for Lit components to be defined and ready
      await customElements.whenDefined('arc-map');
      await customElements.whenDefined('arc-geojson-layer');

      const mapEl = document.getElementById('mainMap');

      // Wait for arc-map to be fully ready
      await mapEl.updateComplete;

      // ─── POINT GeoJSON ──────────────────────────────────────────
      const pointLayer = document.getElementById('point-layer');
      pointLayer.geojson = {
        type: 'FeatureCollection',
        features: [
          {
            type: 'Feature',
            id: 'point-1',
            geometry: {
              type: 'Point',
              coordinates: [-87.6298, 41.8781], // Chicago
            },
            properties: {
              name: 'Chicago',
              LABEL: 'Chicago',
            },
          },
          {
            type: 'Feature',
            id: 'point-2',
            geometry: {
              type: 'Point',
              coordinates: [-73.9857, 40.7484], // New York
            },
            properties: {
              name: 'New York',
              LABEL: 'New York',
            },
          },
          {
            type: 'Feature',
            id: 'point-3',
            geometry: {
              type: 'Point',
              coordinates: [-118.2437, 34.0522], // Los Angeles
            },
            properties: {
              name: 'Los Angeles',
              LABEL: 'Los Angeles',
            },
          },
        ],
      };

      // ─── LINESTRING GeoJSON ─────────────────────────────────────
      const lineLayer = document.getElementById('line-layer');
      lineLayer.geojson = {
        type: 'FeatureCollection',
        features: [
          {
            type: 'Feature',
            id: 'line-1',
            geometry: {
              type: 'LineString',
              coordinates: [
                [-87.6298, 41.8781], // Chicago
                [-80.1918, 25.7617], // Miami
              ],
            },
            properties: {
              name: 'Chicago to Miami',
              LABEL: 'Chicago - Miami',
            },
          },
          {
            type: 'Feature',
            id: 'line-2',
            geometry: {
              type: 'LineString',
              coordinates: [
                [-118.2437, 34.0522], // Los Angeles
                [-73.9857, 40.7484],  // New York
              ],
            },
            properties: {
              name: 'LA to New York',
              LABEL: 'LA - New York',
            },
          },
        ],
      };

      // ─── POLYGON GeoJSON ────────────────────────────────────────
      const polygonLayer = document.getElementById('polygon-layer');
      polygonLayer.geojson = {
        type: 'FeatureCollection',
        features: [
          {
            type: 'Feature',
            id: 'polygon-1',
            geometry: {
              type: 'Polygon',
              coordinates: [
                [
                  [-90.0, 35.0],
                  [-85.0, 35.0],
                  [-85.0, 40.0],
                  [-90.0, 40.0],
                  [-90.0, 35.0], // ✅ close the ring
                ],
              ],
            },
            properties: {
              name: 'Test Rectangle',
              LABEL: 'Rectangle',
            },
          },
          {
            type: 'Feature',
            id: 'polygon-2',
            geometry: {
              type: 'Polygon',
              coordinates: [
                [
                  [-120.0, 30.0],
                  [-115.0, 30.0],
                  [-115.0, 35.0],
                  [-120.0, 35.0],
                  [-120.0, 30.0], // ✅ close the ring
                ],
              ],
            },
            properties: {
              name: 'West Rectangle',
              LABEL: 'West Rect',
            },
          },
        ],
      };

      console.log('All GeoJSON layers set successfully');
    </script>
  </body>
</html>
