const clickHandle = (view as any).on('click', async (evt: any) => {

  // Step 1: Use hitTest but don't await it for popup
  // Instead fire hitTest and show popup as soon as we get first result
  view.hitTest(evt, { include: [this.featureLayer] }).then((hitResult: any) => {
    const hit = hitResult.results[0] as any;
    if (!hit?.graphic) return;

    const graphic: Graphic = hit.graphic;

    // Open popup immediately when hitTest resolves
    if (this.infoTemplate && !this.enableUserEdit && !this.inDrawingMode) {
      const popup = (view as any).popup;
      if (popup) {
        popup.features = [graphic];
        popup.location = ArcGeoJsonLayer.getPopupPoint(graphic.geometry);
        popup.visible = true;
      }
    }

    // Dispatch event
    try {
      if (webMercatorToGeographic) {
        const coords = webMercatorToGeographic(evt.mapPoint ?? graphic.geometry) as any;
        this.dispatchEvent(new CustomEvent('layerClick', {
          detail: {
            coordinates: { latitude: coords?.y, longitude: coords?.x },
            attributes: graphic?.attributes,
          },
          bubbles: true, composed: true,
        }));
      }
    } catch (_) { /**/ }
  });
});


