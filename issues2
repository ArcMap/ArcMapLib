private async updateGeoJson(
  value: string | FeatureCollection<GeoJsonGeometry, GeoJsonProperties> | null
): Promise<void> {
  if (!this.featureLayer || this._isUpdatingGeoJson) {
    return;
  }

  if (this.blockGeoJsonUpdate) {
    return;
  }

  const signature = JSON.stringify(value ?? {});

  if (signature === this._lastGeoJsonSignature) {
    return;
  }

  this._lastGeoJsonSignature = signature;
  this._isUpdatingGeoJson = true;

  try {
    const parsedResult = this.getJsonForAny(value);

    if (parsedResult.error || !parsedResult.parsedJson) {
      return;
    }

    // FIX: Deep clone IMMEDIATELY after parsing.
    // Angular/NgRx passes frozen/immutable store objects.
    // Any mutation without deep clone writes back into the store.
    const parsedGeoJson: any = JSON.parse(
      JSON.stringify(parsedResult.parsedJson)
    );

    if (
      parsedGeoJson.type !== "FeatureCollection" ||
      !Array.isArray(parsedGeoJson.features)
    ) {
      return;
    }

    if (!this._editorOpen) {
      this.clearGeoJSONLayer();
    }

    const graphics: Graphic[] = [];

    parsedGeoJson.features.forEach((feature: any, index: number) => {
      const graphic = this.geoJsonFeatureToGraphic(feature, index);
      if (!graphic) {
        return;
      }
      graphics.push(graphic);
    });

    if (graphics.length > 0) {
      this.featureLayer.addMany(graphics);
    }

    this.refreshLabels();
    this.filterGraphicsByActiveType(this._activeVisibleType);

  } catch (error) {
    console.error("[arc-geojson-layer] updateGeoJson failed", error);
  } finally {
    this._isUpdatingGeoJson = false;
  }
}




private geoJsonFeatureToGraphic(
  feature: Feature,
  featureIndex: number,
  parent?: FeatureCollection<GeoJsonGeometry, GeoJsonProperties>
): Graphic | null {
  if (!feature?.geometry) {
    return null;
  }

  const geometry = this.geoJsonGeometryToUpGeometry(feature.geometry);
  if (!geometry) {
    return null;
  }

  // FIX: Deep clone so Angular store is never touched
  const properties = JSON.parse(
    JSON.stringify(feature.properties ?? {})
  ) as Record<string, any>;

  // Snapshot original user fields BEFORE we add anything
  const originalId   = properties.id;
  const originalName = properties.name;

  // Only add internal tracking fields
  // NEVER overwrite user fields like name, id, etc.
  properties.OBJECTID        = featureIndex;
  properties._featureIndex   = featureIndex;

  // Restore user fields explicitly in case anything above touched them
  if (originalId !== undefined) {
    properties.id = originalId;
  }
  if (originalName !== undefined) {
    properties.name = originalName;
  }

  const graphic = new Graphic({
    geometry,
    attributes: properties,
  });

  // Pass featureIndex so applyGraphicDefaults
  // does NOT generate a new ID
  this.applyGraphicDefaults(graphic, featureIndex);

  return graphic;
}




private applyGraphicDefaults(
  graphic: Graphic,
  featureIndex?: number
): void {
  if (!graphic.attributes) {
    graphic.attributes = {};
  }

  const attrs = graphic.attributes as Record<string, any>;

  // Snapshot ALL user fields before doing anything
  const originalId   = attrs.id;
  const originalName = attrs.name;

  // OBJECTID = array index only
  const objectId =
    typeof featureIndex === "number" && !Number.isNaN(featureIndex)
      ? featureIndex
      : typeof attrs._featureIndex === "number"
      ? attrs._featureIndex
      : typeof attrs.OBJECTID === "number"
      ? attrs.OBJECTID
      : 0;

  // Only write OBJECTID and _featureIndex
  attrs.OBJECTID      = objectId;
  attrs._featureIndex = objectId;

  // Explicitly restore — guarantee name and id are never overwritten
  if (originalId !== undefined) {
    attrs.id = originalId;
  }
  if (originalName !== undefined) {
    attrs.name = originalName;
  }

  // Symbol
  const rendererSymbol = this.getSymbolFromRendererConfig(
    this.renderer,
    graphic
  );

  const selectedSymbol =
    rendererSymbol ??
    graphic.symbol ??
    this.getDefaultSymbolForGeometry(graphic.geometry);

  graphic.symbol = this.coerceSymbolForGeometry(
    selectedSymbol,
    graphic.geometry
  );

  // Popup — null during editing
  graphic.popupTemplate =
    this._editorOpen || this.inDrawingMode || this._isStartingDraw
      ? (null as any)
      : this.buildPopupTemplateFromCurrent(graphic);
}



private graphicToGeoJsonFeature(
  graphic: Graphic,
  index?: number
): Feature | null {
  if (!graphic?.geometry) {
    return null;
  }

  const geometry = this.arcGeometryToGeoJson(graphic.geometry);
  if (!geometry) {
    return null;
  }

  // Deep clone attrs so we can safely delete internal fields
  const attrs = JSON.parse(
    JSON.stringify(graphic.attributes ?? {})
  ) as Record<string, any>;

  const objectId =
    typeof index === "number" && !Number.isNaN(index)
      ? index
      : typeof attrs._featureIndex === "number"
      ? attrs._featureIndex
      : typeof attrs.OBJECTID === "number"
      ? attrs.OBJECTID
      : 0;

  // Capture user fields
  const originalId   = attrs.id;
  const originalName = attrs.name;

  // Remove internal tracking fields
  delete attrs._parentFeatureCollection;
  delete attrs._featureIndex;

  return {
    type: "Feature",
    id: originalId,
    geometry,
    properties: {
      // All original attrs (already cleaned)
      ...attrs,

      // Index-based OBJECTID
      OBJECTID: objectId,

      // Guarantee user fields are never overwritten
      id:   originalId,
      name: originalName,
    },
  };
}
