private registerViewHandles(): void {
  if (!this.view || !this.featureLayer) return;

  this.eventHandles.removeAll();

  const clickHandle = this.view.on("click", async (event: any) => {
    const response = await this.view!.hitTest(event);

    const clickedResult = response.results.find((result: any) => {
      return (
        result.graphic &&
        result.graphic.layer &&
        result.graphic.layer.id === this.featureLayer!.id
      );
    });

    if (!clickedResult) return;

    const hasTemplate = PopupUtils.hasValidInfoTemplate(this.infoTemplate);

    if (!hasTemplate) {
      this.featureLayer!.popupEnabled = false;
      (this.featureLayer as any).popupTemplate = undefined;

      if (this.view?.popup?.visible) {
        this.view.popup.close();
      }

      return;
    }

    this.featureLayer!.popupEnabled = true;
    (this.featureLayer as any).popupTemplate = PopupUtils.updatePopup(
      this.infoTemplate,
      this.ancestorMap,
      this.featureLayer!,
    );

    this.view!.popup.open({
      features: [clickedResult.graphic],
      location: event.mapPoint,
    });

    this.dispatchEvent(this.layerClick);
  });

  this.eventHandles.add(clickHandle);
}

const feature = new FeatureLayer({
  url: this.url,
  id: this.id || this.generatedElementId,
  title: this.name,
  popupEnabled: false,
  popupTemplate: undefined,
});