const INTERNAL_KEYS = new Set([
  'OBJECTID',
  'isCircle',
  'isTemporaryDrawing',
  'drawGeometryType',
  'shapeType',
  'shape',
  this.uniqueIdPropertyName,
]);

const fieldInfos = Object.keys(attributes)
  .filter((key) => !INTERNAL_KEYS.has(key))
  .filter((key) => {
    const value = attributes[key];
    return value !== undefined && 
           value !== null && 
           typeof value !== 'object';
  })
  .map((key) => ({
    fieldName: key,
    label: key,
    visible: true,
  }));
