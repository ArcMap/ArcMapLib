private updateInfoTemplate(newInfoTemplate: any): void {
  if (!this.featureLayer) return;

  const hasTemplate =
    newInfoTemplate &&
    typeof newInfoTemplate === "object" &&
    Object.keys(newInfoTemplate).length > 0;

  if (!hasTemplate) {
    // Disable popup completely for THIS layer only
    this.featureLayer.popupEnabled = false;
    this.featureLayer.popupTemplate = null as any;

    // Close popup if currently opened for this layer
    if (this.view?.popup?.visible) {
      this.view.popup.close();
    }

    return;
  }

  // Enable popup only when template exists
  this.featureLayer.popupEnabled = true;

  this.featureLayer.popupTemplate =
    PopupUtils.updatePopup(
      newInfoTemplate,
      this.ancestorMap,
      this.featureLayer
    );
}