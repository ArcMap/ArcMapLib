private static warnArcGis3xMigration(
  methodName: string,
  propertyName: string,
  oldValue: any,
  newValue: any,
  context?: string
): void {
  if (oldValue === undefined || oldValue === null) {
    return;
  }

  if (oldValue === newValue) {
    return;
  }

  console.warn(
    `[ArcGIS Migration Warning] ${methodName}: ` +
      `Detected old ArcGIS 3.x ${propertyName} "${oldValue}". ` +
      `It has been normalized to ArcGIS Maps SDK 5.x value "${newValue}".` +
      `${context ? " " + context : ""}`
  );
}