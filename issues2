private buildPopupTemplate(infoTemplate: any): any {

  if (!PopupUtils.hasValidInfoTemplate(infoTemplate)) {
    return undefined;
  }

  // STRING TEMPLATE
  if (typeof infoTemplate === "string") {

    return {
      title: "",
      content: infoTemplate.trim(),
    };
  }

  // ARRAY TEMPLATE
  if (Array.isArray(infoTemplate)) {

    return {
      title: "",
      content: infoTemplate
        .filter((item) => item != null)
        .map((item) => String(item))
        .join("<br/>"),
    };
  }

  // OBJECT TEMPLATE
  if (typeof infoTemplate === "object") {

    const title =
      typeof infoTemplate.title === "string"
        ? infoTemplate.title.trim()
        : "";

    let content = "";

    // Direct content
    if (typeof infoTemplate.content === "string") {
      content = infoTemplate.content.trim();
    }

    // details fallback
    else if (typeof infoTemplate.details === "string") {
      content = infoTemplate.details.trim();
    }

    // description fallback
    else if (typeof infoTemplate.description === "string") {
      content = infoTemplate.description.trim();
    }

    // listItem fallback
    else if (typeof infoTemplate.listItem === "string") {
      content = infoTemplate.listItem.trim();
    }

    // fields fallback
    else if (
      Array.isArray(infoTemplate.fields) &&
      infoTemplate.fields.length > 0
    ) {

      content = infoTemplate.fields
        .map((field: any) => {

          const label =
            field.label ||
            field.fieldName ||
            "";

          const value =
            field.value ||
            `{${field.fieldName || ""}}`;

          return `
            <div>
              <b>${label}</b>: ${value}
            </div>
          `;
        })
        .join("");
    }

    // NOTHING VALID
    if (!title && !content) {
      return undefined;
    }

    return {
      title,
      content,
    };
  }

  return undefined;
}