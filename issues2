private async showGraphicPopup(graphic: Graphic, mapPoint?: Point): Promise<void> {
  if (
    !this.view ||
    !graphic?.geometry ||
    this.enableUserEdit ||
    this._editorOpen ||
    this._inDrawingMode ||
    this._isStartingDraw ||
    this.shouldSuppressPopup()
  ) {
    this.closePopup();
    return;
  }

  const popupTemplate = this.buildPopupTemplateForCurrent(graphic);
  if (!popupTemplate) {
    return;
  }

  const popupGraphic = graphic.clone();
  popupGraphic.attributes = { ...(graphic.attributes ?? {}) };
  popupGraphic.popupTemplate = popupTemplate;

  const popupPoint =
    mapPoint ??
    UpGeojsonLayer.getPopupPoint(popupGraphic.geometry) ??
    UpGeojsonLayer.getPopupPoint(graphic.geometry);

  if (!popupPoint) {
    return;
  }

  await this.openPopup(popupGraphic, popupPoint);
}





private async openPopup(
  graphicMatch: Graphic,
  popupPoint?: Point | null
): Promise<void> {
  if (!this.view || !graphicMatch || !popupPoint || this.shouldSuppressPopup()) {
    return;
  }

  try {
    this.closePopup();

    this.view.popupEnabled = true;

    if (typeof (this.view as any).openPopup === "function") {
      (this.view as any).openPopup({
        location: popupPoint,
        features: [graphicMatch],
      });
      return;
    }

    if (this.view.popup) {
      this.view.popup.location = popupPoint;
      this.view.popup.features = [graphicMatch];
      (this.view.popup as any).open = true;
      (this.view.popup as any).visible = true;
    }
  } catch (error) {
    console.warn("[arc-geojson-layer] openPopup failed", error);
  }
}





private buildPopupTemplateForCurrent(graphic: Graphic): PopupTemplate | null {
  if (!graphic || !this.infoTemplate) {
    return null;
  }

  const popupData = this.buildPopupContentFromInfoTemplate(graphic);
  if (!popupData?.content) {
    return null;
  }

  return this.createHtmlPopupTemplate(
    popupData.title ?? this.name ?? "Details",
    popupData.content
  );
}



private createHtmlPopupTemplate(
  title: string,
  htmlContent: string
): PopupTemplate {
  const customContent = new CustomContent({
    outFields: ["*"],
    creator: () => {
      const wrapper = document.createElement("div");

      wrapper.className = "arc-geojson-popup-content";
      wrapper.style.background = "transparent";
      wrapper.style.margin = "0";
      wrapper.style.padding = "0";
      wrapper.style.border = "0";
      wrapper.style.boxShadow = "none";
      wrapper.style.minWidth = "240px";

      wrapper.innerHTML = htmlContent ?? "";

      return wrapper;
    },
  });

  return new PopupTemplate({
    title: title || this.name || "Details",
    outFields: ["*"],
    content: [customContent],
  });
}



