l@property({ attribute: false })
get geojson(): string | FeatureCollection | null {
  return this._geojson;
}

set geojson(value: string | FeatureCollection | null) {
  const oldValue = this._geojson;

  if (
    value !== null &&
    value !== undefined &&
    typeof value === 'object'
  ) {
    // Deep clone — replicates what Stencil @Prop() did automatically
    this._geojson = JSON.parse(JSON.stringify(value));
  } else {
    this._geojson = value as string | null;
  }

  this.requestUpdate('geojson', oldValue);
}

private _geojson: string | FeatureCollection | null = null;
