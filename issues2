private geoJsonFeatureToGraphic(
  feature: Feature,
  featureIndex: number,
  parent?: FeatureCollection<GeoJsonGeometry, GeoJsonProperties>
): Graphic | null {
  if (!feature?.geometry) {
    return null;
  }

  const geometry = this.geoJsonGeometryToArcGeometry(feature.geometry);

  if (!geometry) {
    return null;
  }

  const properties = {
    ...(feature.properties ?? {}),
  } as Record<string, any>;

  // Store internal tracking only. Do not mutate user fields.
  properties.OBJECTID = featureIndex;
  properties._featureIndex = featureIndex;
  properties._parentFeatureCollection = parent;

  const graphic = new Graphic({
    geometry,
    attributes: properties,
  });

  this.applyGraphicDefaults(graphic, featureIndex);

  return graphic;
}


private applyGraphicDefaults(graphic: Graphic, featureIndex?: number): void {
  if (!graphic.attributes) {
    graphic.attributes = {};
  }

  const attrs = graphic.attributes as Record<string, any>;

  const objectId =
    typeof featureIndex === "number" && !Number.isNaN(featureIndex)
      ? featureIndex
      : typeof attrs._featureIndex === "number"
        ? attrs._featureIndex
        : typeof attrs.OBJECTID === "number"
          ? attrs.OBJECTID
          : 0;

  // OBJECTID is always index.
  attrs.OBJECTID = objectId;
  attrs._featureIndex = objectId;

  // Preserve name exactly. Never assign ID/fence id into name.
  if (attrs.name !== undefined) {
    attrs.name = attrs.name;
  }

  // Preserve business id exactly. Do not replace string id with OBJECTID.
  if (attrs.id !== undefined) {
    attrs.id = attrs.id;
  }

  // Only write unique id when safe.
  if (
    this.uniqueIdPropertyName &&
    this.uniqueIdPropertyName !== "name" &&
    this.uniqueIdPropertyName !== "id" &&
    attrs[this.uniqueIdPropertyName] === undefined
  ) {
    attrs[this.uniqueIdPropertyName] = objectId;
  }

  const rendererSymbol = this.getSymbolFromRendererConfig(this.renderer, graphic);

  const selectedSymbol =
    rendererSymbol ??
    graphic.symbol ??
    this.getDefaultSymbolForGeometry(graphic.geometry);

  graphic.symbol = this.coerceSymbolForGeometry(selectedSymbol, graphic.geometry);

  graphic.popupTemplate = null as any;
}


private graphicToGeoJsonFeature(
  graphic: Graphic,
  index?: number
): Feature | null {
  if (!graphic?.geometry) {
    return null;
  }

  const geometry = this.arcGeometryToGeoJson(graphic.geometry);

  if (!geometry) {
    return null;
  }

  const attrs = {
    ...(graphic.attributes ?? {}),
  } as Record<string, any>;

  const objectId =
    typeof index === "number" && !Number.isNaN(index)
      ? index
      : typeof attrs._featureIndex === "number"
        ? attrs._featureIndex
        : typeof attrs.OBJECTID === "number"
          ? attrs.OBJECTID
          : 0;

  const originalId = attrs.id;
  const originalName = attrs.name;

  delete attrs._parentFeatureCollection;

  return {
    type: "Feature",
    id: originalId,
    geometry,
    properties: {
      ...attrs,

      // Always index.
      OBJECTID: objectId,
      _featureIndex: objectId,

      // Preserve exactly.
      id: originalId,
      name: originalName,
    },
  };
}



parsedGeoJson.features.forEach((feature: any, idx: number) => {
  const graphic = this.geoJsonFeatureToGraphic(feature, idx, parsedGeoJson);

  if (!graphic) {
    return;
  }

  this.applyGraphicDefaults(graphic, idx);
  graphics.push(graphic);
});