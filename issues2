private static readonly _warnedMigrationMessages: Set<string> = new Set();

private static warnArcGisMigration(
  methodName: string,
  category: string,
  oldValue: any,
  newValue: any
): void {
  if (oldValue === undefined || oldValue === null || newValue === undefined || newValue === null) {
    return;
  }

  if (String(oldValue).toLowerCase() === String(newValue).toLowerCase()) {
    return;
  }

  const warningKey = `${methodName}:${category}:${oldValue}:${newValue}`;

  if (JsonUtils._warnedMigrationMessages.has(warningKey)) {
    return;
  }

  JsonUtils._warnedMigrationMessages.add(warningKey);

  console.warn(
    `[ArcGIS Migration Warning] ${methodName}: Detected old ArcGIS 3.x ${category} "${oldValue}". ` +
      `It has been converted to ArcGIS Maps SDK 5.x value "${newValue}". ` +
      `Please update your JSON to use "${newValue}" going forward.`
  );
}


