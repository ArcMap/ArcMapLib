public static hasValidInfoTemplate(infoTemplate: any): boolean {
  if (!infoTemplate) return false;

  if (typeof infoTemplate === "string") {
    return infoTemplate.trim().length > 0;
  }

  if (Array.isArray(infoTemplate)) {
    return infoTemplate.some((item) => PopupUtils.hasValidInfoTemplate(item));
  }

  if (typeof infoTemplate === "object") {
    const title =
      infoTemplate.title ??
      infoTemplate.header ??
      infoTemplate.name ??
      "";

    const content =
      infoTemplate.content ??
      infoTemplate.details ??
      infoTemplate.description ??
      infoTemplate.listItem ??
      "";

    return (
      String(title).trim().length > 0 ||
      String(content).trim().length > 0
    );
  }

  return false;
}

private updateInfoTemplate(newInfoTemplate: any): void {
  if (!this.featureLayer) return;

  const hasTemplate = PopupUtils.hasValidInfoTemplate(newInfoTemplate);

  if (!hasTemplate) {
    this.infoTemplate = null;
    this.featureLayer.popupEnabled = false;
    (this.featureLayer as any).popupTemplate = undefined;
    return;
  }

  this.infoTemplate = newInfoTemplate;
  this.featureLayer.popupEnabled = true;
  (this.featureLayer as any).popupTemplate = PopupUtils.updatePopup(
    newInfoTemplate,
    this.ancestorMap,
    this.featureLayer,
  );
}