private clearPopupHighlight(): void {
  try {
    this._popupHighlightHandle?.remove?.();
  } catch {}

  this._popupHighlightHandle = null;

  try {
    const popup = this.view?.popup as any;

    if (popup) {
      popup.features = [];

      // Do NOT use this in ArcGIS 5.x:
      // popup.selectedFeature = null;

      if ("highlightEnabled" in popup) {
        popup.highlightEnabled = false;
      }
    }
  } catch {}
}


private closePopup(): void {
  try {
    const popup = this.view?.popup as any;

    if (popup) {
      if (typeof popup.close === "function") {
        popup.close();
      } else {
        popup.visible = false;
        popup.open = false;
      }

      popup.features = [];

      // Do NOT use this in ArcGIS 5.x:
      // popup.selectedFeature = null;

      if ("highlightEnabled" in popup) {
        popup.highlightEnabled = false;
      }
    }
  } catch {}

  this.clearPopupHighlight();
}