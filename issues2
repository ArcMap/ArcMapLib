private async getHitGraphic(evt: any): Promise<Graphic | null> {
  if (!this.view || !this.featureLayer || !evt) {
    return null;
  }

  try {
    const hit = await this.view.hitTest(evt, {
      include: [this.featureLayer],
    });

    const result = (hit.results ?? []).find((r: any) => {
      const graphic = r?.graphic as Graphic | undefined;

      return (
        !!graphic &&
        !!graphic.geometry &&
        (graphic.layer === this.featureLayer ||
          (graphic.layer as any)?.id === this.featureLayer?.id)
      );
    });

    return (result?.graphic as Graphic) ?? null;
  } catch (error) {
    console.warn("[geojson-layer] getHitGraphic failed", error);
    return null;
  }
}


private async getHitGraphics(evt: any): Promise<Graphic[]> {
  if (!this.view || !this.featureLayer || !evt) {
    return [];
  }

  try {
    const hit = await this.view.hitTest(evt, {
      include: [this.featureLayer],
    });

    const graphics = (hit.results ?? [])
      .map((r: any) => r?.graphic as Graphic)
      .filter((graphic: Graphic | null | undefined) => {
        return (
          !!graphic &&
          !!graphic.geometry &&
          (graphic.layer === this.featureLayer ||
            (graphic.layer as any)?.id === this.featureLayer?.id)
        );
      });

    const uniqueGraphics = new Map<string, Graphic>();

    graphics.forEach((graphic: Graphic, index: number) => {
      const attributes = graphic.attributes ?? {};

      const objectId =
        attributes[this.uniqueIdPropertyName] ??
        attributes.OBJECTID ??
        attributes.objectId ??
        attributes.id ??
        `${graphic.geometry?.type}-${index}`;

      uniqueGraphics.set(String(objectId), graphic);
    });

    return Array.from(uniqueGraphics.values());
  } catch (error) {
    console.warn("[geojson-layer] getHitGraphics failed", error);
    return [];
  }
}