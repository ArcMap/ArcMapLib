private handleArcgisMapReady = (event: Event) => {
  // The event target is the arcgis-map element
  const arcgisMap = event.target as any;
  this.map = arcgisMap.map;
  this.view = arcgisMap.view;
  this.requestUpdate();

  // Resolve all pending promises with the map instance
  this._mapReadyResolvers.forEach((resolver) => resolver(this.map!));
  this._mapReadyResolvers = [];
  this._viewReadyResolvers.forEach((resolver) => resolver(this.view!));
  this._viewReadyResolvers = [];

  // Pre-warm the <arcgis-popup> component to avoid first-click layout glitch.
  // The new component caches layout on its first open; opening + closing once
  // during init makes the user's first real click render at correct height.
  void this.prewarmPopup();
};

/**
 * Opens and immediately closes the popup once on init.
 * This avoids the first-click empty-space layout bug in <arcgis-popup>.
 */
private async prewarmPopup(): Promise<void> {
  if (!this.view) return;
  try {
    await this.view.when();
    await this.view.openPopup({
      title: " ",
      content: " ",
      location: this.view.center,
    });
    this.view.closePopup();
    console.log("[prewarmPopup] popup pre-warmed successfully");
  } catch (err) {
    // Best-effort; ignore failures
    console.warn("[prewarmPopup] pre-warm failed (non-critical):", err);
  }
}
