private buildPopupTemplateFromCurrent(
  graphic: Graphic
): PopupTemplate | null {
  console.log("[geojson-layer] buildPopupTemplateFromCurrent called", {
    graphic,
    infoTemplate: this.infoTemplate,
    attributes: graphic?.attributes,
  });

  if (!graphic || !this.infoTemplate) {
    return null;
  }

  const attributes = graphic.attributes ?? {};

  const replaceTokens = (value: string): string => {
    return value.replace(/\$\{([^}]+)\}/g, (_match: string, key: string) => {
      const attributeValue = attributes[key.trim()];
      return attributeValue === undefined || attributeValue === null
        ? ""
        : String(attributeValue);
    });
  };

  const resolveTitle = (): string => {
    const rawTitle =
      this.infoTemplate?.title ??
      this.infoTemplate?.listTitle ??
      this.infoTemplate?.listItem ??
      this.name ??
      "Details";

    return typeof rawTitle === "string"
      ? replaceTokens(rawTitle)
      : String(rawTitle);
  };

  const stripHtml = (value: string): string => {
    const div = document.createElement("div");
    div.innerHTML = value;
    return (div.textContent || div.innerText || "").trim();
  };

  const buildFieldsFromDetailsHtml = (detailsHtml: string): any[] => {
    const resolvedHtml = replaceTokens(detailsHtml);

    const wrapper = document.createElement("div");
    wrapper.innerHTML = resolvedHtml;

    const fieldInfos: any[] = [];
    const usedNames = new Set<string>();

    const rows = wrapper.querySelectorAll(
      ".info-template-data, div, li, p, span"
    );

    rows.forEach((row: Element, index: number) => {
      const labelElement =
        row.querySelector(".info-template-label") ??
        row.querySelector("label");

      const valueElement =
        row.querySelector(".info-template-value") ??
        row.querySelector("value");

      let label = labelElement
        ? stripHtml(labelElement.innerHTML)
        : "";

      let value = valueElement
        ? stripHtml(valueElement.innerHTML)
        : "";

      if (!label || !value) {
        const text = stripHtml(row.innerHTML);

        if (text.includes(":")) {
          const parts = text.split(":");
          label = parts.shift()?.trim() ?? "";
          value = parts.join(":").trim();
        }
      }

      if (!label || value === undefined || value === null || value === "") {
        return;
      }

      let fieldName = `popup_field_${index}`;

      while (usedNames.has(fieldName)) {
        fieldName = `popup_field_${index}_${usedNames.size}`;
      }

      usedNames.add(fieldName);

      graphic.attributes[fieldName] = value;

      fieldInfos.push({
        fieldName,
        label,
        visible: true,
      });
    });

    return fieldInfos;
  };

  try {
    let fieldInfos: any[] = [];

    if (Array.isArray(this.infoTemplate?.fieldInfos)) {
      console.log("[geojson-layer] popup using user fieldInfos");

      fieldInfos = this.infoTemplate.fieldInfos
        .map((field: any) => {
          const fieldName = field.fieldName ?? field.name ?? field.key;

          if (!fieldName) {
            return null;
          }

          return {
            fieldName,
            label: field.label ?? field.title ?? fieldName,
            visible: field.visible !== false,
          };
        })
        .filter(Boolean);
    } else if (typeof this.infoTemplate?.details === "string") {
      console.log("[geojson-layer] popup converting details string to fields table");

      fieldInfos = buildFieldsFromDetailsHtml(this.infoTemplate.details);
    } else if (typeof this.infoTemplate?.details === "function") {
      console.log("[geojson-layer] popup converting details function result to fields table");

      const html = this.infoTemplate.details(graphic);

      if (typeof html === "string") {
        fieldInfos = buildFieldsFromDetailsHtml(html);
      }
    } else if (typeof this.infoTemplate?.content === "string") {
      console.log("[geojson-layer] popup converting content string to fields table");

      fieldInfos = buildFieldsFromDetailsHtml(this.infoTemplate.content);
    } else if (typeof this.infoTemplate === "string") {
      console.log("[geojson-layer] popup converting plain string to fields table");

      fieldInfos = buildFieldsFromDetailsHtml(this.infoTemplate);
    }

    if (!fieldInfos.length) {
      console.warn("[geojson-layer] popup skipped: no popup fields resolved", {
        infoTemplate: this.infoTemplate,
        attributes,
      });
      return null;
    }

    return new PopupTemplate({
      title: resolveTitle(),
      content: [
        {
          type: "fields",
          fieldInfos,
        },
      ],
    });
  } catch (error) {
    console.error("[geojson-layer] buildPopupTemplateFromCurrent failed", error);
    return null;
  }
}