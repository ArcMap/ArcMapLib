private buildPopupTemplate(infoTemplate: any): any {
  if (!PopupUtils.hasValidInfoTemplate(infoTemplate)) {
    return undefined;
  }

  return {
    title: infoTemplate.title ?? "",
    content: (feature: any) => {
      if (typeof infoTemplate.details === "function") {
        return infoTemplate.details(feature.graphic);
      }

      if (typeof infoTemplate.content === "function") {
        return infoTemplate.content(feature.graphic);
      }

      return String(
        infoTemplate.content ??
        infoTemplate.details ??
        infoTemplate.description ??
        "",
      )
        .replace(/^{|}$/g, "")
        .replace(/"/g, "")
        .trim();
    },
  };
}