if (typeof config.details === "string" && config.listItem !== undefined) {
  // Resolve title from listItem
  let title = config.listItem;
  if (attributes && typeof title === "string") {
    title = title.replace(/\$\{([^}]+)\}/g, (_: string, key: string) => {
      const val = attributes[key.trim()];
      return val !== undefined && val !== null ? String(val) : "";
    });
  }
  
  // Get HTML and COMPRESS whitespace (the technical fix!)
  let htmlContent = config.details;
  
  // 👇 ADD THESE 3 LINES — Strip whitespace between tags
  htmlContent = htmlContent
    .replace(/>\s+</g, '><')           // Remove whitespace between tags
    .replace(/\n\s*/g, '')             // Remove newlines and following spaces
    .trim();                           // Trim leading/trailing whitespace
  
  // Replace ${field} placeholders
  if (attributes) {
    htmlContent = htmlContent.replace(/\$\{([^}]+)\}/g, (_: string, key: string) => {
      const val = attributes[key.trim()];
      return val !== undefined && val !== null ? String(val) : "";
    });
  }
  
  return new PopupTemplate({
    title,
    content: [{ type: "text", text: htmlContent }]
  });
}
