private isUserEditEnabled(): boolean {
  const attrValue = this.getAttribute("enable-user-edit");
  const camelAttrValue = this.getAttribute("enableUserEdit");

  return (
    this.enableUserEdit === true ||
    String(this.enableUserEdit) === "true" ||
    attrValue === "" ||
    attrValue === "true" ||
    camelAttrValue === "" ||
    camelAttrValue === "true"
  );
}





