lprivate async handleEditorDoubleClick(evtOrMapPoint: any, source: string): Promise<void> {
  this._suppressPopupUntil = Date.now() + 2000;
  this.enableInfoPopupWindow(false);

  try {
    this.view!.popupEnabled = false;
    this.view?.popup?.close();
  } catch {}

  const hitGraphic = await this.getHitGraphic(evtOrMapPoint);

  if (!hitGraphic) {
    return;
  }

  const editableGraphic = this.findLiveGraphicFromLayer(hitGraphic);

  if (!editableGraphic) {
    return;
  }

  if (!this.isUserEditEnabled()) {
    console.warn("[arc-geojson-layer] editor blocked: this layer edit is false", {
      enableUserEdit: this.enableUserEdit,
      attrEnableUserEdit: this.getAttribute("enable-user-edit"),
      source,
      layerId: this.featureLayer?.id,
      hitLayerId: (hitGraphic.layer as any)?.id,
    });
    return;
  }

  if (this._editorOpen) {
    this.finishActiveEditor();
    return;
  }

  await this.activateGraphicsEditor(editableGraphic);
}


return (
  graphic &&
  graphic.geometry &&
  (
    graphic.layer === this.featureLayer ||
    (graphic.layer as any)?.id === this.featureLayer?.id
  )
);