const replaceTokens = (value: string): string => {
  return value.replace(/\$\{([^}]+)\}/g, (_match: string, key: string) => {
    const cleanKey = key.trim();

    // IMPORTANT:
    // infoTemplate title/content supports only ${name}
    if (cleanKey !== "name") {
      return "";
    }

    const nameValue = attributes.name;
    return nameValue === undefined || nameValue === null
      ? ""
      : String(nameValue);
  });
};



const resolvedTitle = replaceTokens(rawTitle);
const resolvedContent = replaceTokens(rawContent);

if (!resolvedTitle.trim() && !resolvedContent.trim()) {
  return null;
}