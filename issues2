if (
  changedProperties.has("extent") &&
  this.extent &&
  this.extent.leftLongitude != null &&
  this.extent.rightLongitude != null &&
  this.extent.topLatitude != null &&
  this.extent.bottomLatitude != null
) {
  await this.updateExtent(this.extent);
} else if (changedProperties.has("center")) {
  if (this._isReflectingCenterFromView) {
    this._isReflectingCenterFromView = false;
  } else {
    await this.updateCenter(this.center);
  }
}

if (changedProperties.has("zoom")) {
  if (this._isReflectingZoomFromView) {
    this._isReflectingZoomFromView = false;
  } else {
    const newZoom =
      typeof this.zoom === "number"
        ? this.zoom
        : UpMap.DEFAULT_ZOOM;

    if (this.view.zoom !== newZoom) {
      this.view.zoom = newZoom;
    }
  }
}


if (
  this.extent &&
  this.extent.leftLongitude != null
) {
  await this.updateExtent(this.extent);
} else {
  await this.updateCenter(this.center);

  if (typeof this.zoom === "number") {
    this.view.zoom = this.zoom;
  }
}