import { LitElement } from "lit";
import { customElement, property } from "lit/decorators.js";

import Graphic from "@arcgis/core/Graphic";
import GraphicsLayer from "@arcgis/core/layers/GraphicsLayer";
import SketchViewModel from "@arcgis/core/widgets/Sketch/SketchViewModel";

import Point from "@arcgis/core/geometry/Point";
import Polygon from "@arcgis/core/geometry/Polygon";
import Polyline from "@arcgis/core/geometry/Polyline";
import Geometry from "@arcgis/core/geometry/Geometry";
import SpatialReference from "@arcgis/core/geometry/SpatialReference";

import type {
  Feature,
  FeatureCollection,
  Geometry as GeoJsonGeometry,
  GeoJsonProperties,
} from "geojson";

@customElement("art-geojson-layer")
export class ArtMapGeojsonLayer extends LitElement {
  private view: any;
  private ancestorMapElement: any;

  private featureLayer?: GraphicsLayer;
  private labelLayer?: GraphicsLayer;
  private sketchLayer?: GraphicsLayer;
  private graphicsEditor?: SketchViewModel;

  private eventHandles: any[] = [];
  private editorHandles: any[] = [];

  private initComplete = false;

  private _editorOpen = false;
  private _inDrawingMode = false;
  private _isStartingDraw = false;
  private _suppressPopupUntil = 0;
  private _lastHoveredGraphic: Graphic | null = null;
  private _currentCursor: "default" | "pointer" = "default";

  private _libraryPopupElement: HTMLDivElement | null = null;
  private _libraryPopupGraphic: Graphic | null = null;
  private _libraryPopupPoint: Point | null = null;
  private _libraryPopupViewMoveHandle: any = null;

  @property({ attribute: "name" })
  name = "";

  @property({ attribute: false })
  geojson: string | FeatureCollection<GeoJsonGeometry, GeoJsonProperties> | null = null;

  @property({ attribute: false })
  renderer: any = null;

  @property({ attribute: "info-template" })
  infoTemplate: any = null;

  @property({ attribute: "unique-id-property-name" })
  uniqueIdPropertyName = "id";

  @property({ type: Boolean, attribute: "enable-user-edit" })
  enableUserEdit = false;

  @property({ type: Boolean, attribute: "enable-user-edit-move" })
  enableUserEditMove = true;

  @property({ type: Boolean, attribute: "enable-user-edit-vertices" })
  enableUserEditVertices = true;

  @property({ type: Boolean, attribute: "enable-user-edit-add-vertices" })
  enableUserEditAddVertices = true;

  @property({ type: Boolean, attribute: "enable-user-edit-delete-vertices" })
  enableUserEditDeleteVertices = true;

  @property({ type: Boolean, attribute: "enable-user-edit-scaling" })
  enableUserEditScaling = true;

  @property({ type: Boolean, attribute: "enable-user-edit-rotating" })
  enableUserEditRotating = true;

  @property({ type: Boolean, attribute: "enable-user-edit-uniform-scaling" })
  enableUserEditUniformScaling = true;

  createRenderRoot(): HTMLElement {
    return this;
  }

  render(): null {
    return null;
  }

  async connectedCallback(): Promise<void> {
    super.connectedCallback();

    if (this.initComplete) {
      return;
    }

    await this.resolveAncestorMapAndView();
    await this.createLayer();

    if (this.geojson) {
      await this.updateGeoJson(this.geojson);
    }

    await this.updateEditing(this.enableUserEdit);
    this.bindViewEvents();

    this.initComplete = true;
  }

  disconnectedCallback(): void {
    super.disconnectedCallback();

    this.cleanupViewEvents();
    this.cleanupEditor();
    this.closePopup();

    try {
      if (this.featureLayer) this.view?.map?.remove(this.featureLayer);
      if (this.labelLayer) this.view?.map?.remove(this.labelLayer);
      if (this.sketchLayer) this.view?.map?.remove(this.sketchLayer);
    } catch {}

    this.featureLayer = undefined;
    this.labelLayer = undefined;
    this.sketchLayer = undefined;
    this.graphicsEditor = undefined;
    this.initComplete = false;
  }

  protected updated(changedProps: Map<string, any>): void {
    if (changedProps.has("geojson") && this.initComplete) {
      void this.updateGeoJson(this.geojson);
    }

    if (changedProps.has("enableUserEdit") && this.initComplete) {
      void this.updateEditing(this.enableUserEdit);
    }
  }

  private async resolveAncestorMapAndView(): Promise<void> {
    const artMap = this.closest("art-map") || this.closest("ArtMap");

    if (!artMap) {
      throw new Error("[art-geojson-layer] ancestor art-map not found");
    }

    this.ancestorMapElement = artMap;

    if ((artMap as any).view) {
      this.view = (artMap as any).view;
    } else if (typeof (artMap as any).getViewInstance === "function") {
      this.view = await (artMap as any).getViewInstance();
    } else if (typeof (artMap as any).getView === "function") {
      this.view = await (artMap as any).getView();
    }

    if (!this.view) {
      throw new Error("[art-geojson-layer] map view not resolved");
    }

    if (typeof this.view.when === "function") {
      await this.view.when();
    }

    try {
      this.view.popupEnabled = false;
    } catch {}
  }

  private async createLayer(): Promise<void> {
    const layerId = this.name || `art-geojson-layer-${Date.now()}`;

    this.featureLayer = new GraphicsLayer({
      id: `${layerId}-graphics`,
      title: `${layerId}-graphics`,
      listMode: "show",
    });

    this.labelLayer = new GraphicsLayer({
      id: `${layerId}-labels`,
      title: `${layerId}-labels`,
      listMode: "hide",
    });
    (this.labelLayer as any).pickingEnabled = false;

    this.sketchLayer = new GraphicsLayer({
      id: `${layerId}-sketch`,
      title: `${layerId}-sketch`,
      listMode: "hide",
    });
    (this.sketchLayer as any).pickingEnabled = false;

    this.view.map.add(this.featureLayer);
    this.view.map.add(this.labelLayer);
    this.view.map.add(this.sketchLayer);
  }

  private async updateEditing(enabled: boolean): Promise<void> {
    if (enabled) {
      this.enableInfoPopupWindow(false);
      await this.createEditor();
      return;
    }

    this.finishActiveEditor();
    this.enableInfoPopupWindow(true);
  }

  private async createEditor(): Promise<void> {
    if (!this.view || !this.sketchLayer) {
      return;
    }

    if (this.graphicsEditor) {
      return;
    }

    this.graphicsEditor = new SketchViewModel({
      view: this.view,
      layer: this.sketchLayer,
      defaultUpdateOptions: {
        tool: "reshape",
        multipleSelectionEnabled: false,
        toggleToolOnClick: false,
      } as any,
    });

    this.bindEditorEvents();
  }

  private bindEditorEvents(): void {
    this.editorHandles.forEach((handle) => {
      try {
        handle.remove?.();
      } catch {}
    });
    this.editorHandles = [];

    if (!this.graphicsEditor) {
      return;
    }

    const updateHandle = this.graphicsEditor.on("update", (event: any) => {
      if (event.state === "start") {
        this._editorOpen = true;
        this._suppressPopupUntil = Date.now() + 1500;
        this.enableInfoPopupWindow(false);
        this.closePopup();
        return;
      }

      if (event.state === "complete") {
        this._editorOpen = false;
        this.enableInfoPopupWindow(true);
      }
    });

    const createHandle = this.graphicsEditor.on("create", (event: any) => {
      if (event.state === "start" || event.state === "active") {
        this._inDrawingMode = true;
        this._isStartingDraw = true;
        this._suppressPopupUntil = Date.now() + 1500;
        this.enableInfoPopupWindow(false);
        this.closePopup();
        return;
      }

      if (event.state === "complete") {
        this._inDrawingMode = false;
        this._isStartingDraw = false;

        const graphic = event.graphic as Graphic;
        if (graphic?.geometry && this.featureLayer) {
          this.applyGraphicDefaults(graphic);
          this.sketchLayer?.graphics.remove(graphic);
          this.featureLayer.graphics.add(graphic);
          this.addToGeoJson(graphic);
        }

        this.enableInfoPopupWindow(true);
      }
    });

    this.editorHandles.push(updateHandle, createHandle);
  }

  private finishActiveEditor(): void {
    try {
      this.graphicsEditor?.complete();
    } catch {}

    this._editorOpen = false;
    this._inDrawingMode = false;
    this._isStartingDraw = false;
    this.enableInfoPopupWindow(true);
  }

  private async activateGraphicsEditor(graphic: Graphic): Promise<void> {
    if (!this.enableUserEdit || !graphic?.geometry) {
      return;
    }

    await this.createEditor();

    if (!this.graphicsEditor || !this.featureLayer || !this.sketchLayer) {
      return;
    }

    this._editorOpen = true;
    this._suppressPopupUntil = Date.now() + 1500;
    this.enableInfoPopupWindow(false);
    this.closePopup();

    const sourceGraphic = this.findSourceGraphic(graphic) ?? graphic;

    try {
      this.featureLayer.graphics.remove(sourceGraphic);
    } catch {}

    this.sketchLayer.graphics.add(sourceGraphic);

    const updateTool = this.isCircleGraphic(sourceGraphic)
      ? "transform"
      : sourceGraphic.geometry.type === "polygon"
        ? "reshape"
        : "move";

    await this.graphicsEditor.update([sourceGraphic], {
      tool: updateTool,
      enableRotation: this.enableUserEditRotating,
      enableScaling: this.enableUserEditScaling,
      preserveAspectRatio: this.enableUserEditUniformScaling,
      multipleSelectionEnabled: false,
      toggleToolOnClick: false,
    } as any);
  }

  private async handleEditorDoubleClick(evtOrMapPoint: any, source: string): Promise<void> {
    if (!this.enableUserEdit) {
      return;
    }

    this._suppressPopupUntil = Date.now() + 1500;
    this.enableInfoPopupWindow(false);
    this.closePopup();

    if (this._editorOpen) {
      this.finishActiveEditor();
      return;
    }

    const graphic = await this.getHitGraphic(evtOrMapPoint);
    if (graphic) {
      await this.activateGraphicsEditor(graphic);
    }
  }

  private bindViewEvents(): void {
    if (!this.view || !this.featureLayer) {
      return;
    }

    this.cleanupViewEvents();

    let clickTimer: any = null;

    const clickHandle = this.view.on("click", async (evt: any) => {
      if (clickTimer) {
        clearTimeout(clickTimer);
        clickTimer = null;
        return;
      }

      clickTimer = setTimeout(async () => {
        clickTimer = null;

        const graphic = await this.getHitGraphic(evt);
        if (!graphic) {
          return;
        }

        this.emitLayerEvent(
          "layerClick",
          this.graphicToGeoJsonFeature(graphic),
          graphic,
          {
            coordinates: {
              latitude: evt.mapPoint?.latitude ?? 0,
              longitude: evt.mapPoint?.longitude ?? 0,
            },
            attributes: graphic.attributes ?? {},
          }
        );

        if (this.enableUserEdit) {
          this._suppressPopupUntil = Date.now() + 1500;
          this.enableInfoPopupWindow(false);
          this.closePopup();
          await this.activateGraphicsEditor(graphic);
          return;
        }

        if (this.infoTemplate && !this.shouldSuppressPopup()) {
          await this.showGraphicPopup(graphic, evt.mapPoint);
        }
      }, 150);
    });

    const doubleClickHandle = this.view.on("double-click", async (evt: any) => {
      evt.stopPropagation();
      evt.preventDefault();

      if (clickTimer) {
        clearTimeout(clickTimer);
        clickTimer = null;
      }

      this._suppressPopupUntil = Date.now() + 1500;
      this.enableInfoPopupWindow(false);
      this.closePopup();

      const graphic = await this.getHitGraphic(evt);
      if (!graphic) {
        return;
      }

      this.emitLayerEvent(
        "doubleClick",
        this.graphicToGeoJsonFeature(graphic),
        graphic,
        {
          coordinates: {
            latitude: evt.mapPoint?.latitude ?? 0,
            longitude: evt.mapPoint?.longitude ?? 0,
          },
          attributes: graphic.attributes ?? {},
        }
      );

      if (this.enableUserEdit) {
        await this.activateGraphicsEditor(graphic);
      }
    });

    const nativeDoubleClick = async (event: MouseEvent) => {
      event.preventDefault();
      event.stopPropagation();
      event.stopImmediatePropagation();

      if (clickTimer) {
        clearTimeout(clickTimer);
        clickTimer = null;
      }

      this._suppressPopupUntil = Date.now() + 1500;
      this.enableInfoPopupWindow(false);
      this.closePopup();

      const rect = this.view.container.getBoundingClientRect();
      const screenPoint = {
        x: event.clientX - rect.left,
        y: event.clientY - rect.top,
      };

      const mapPoint = this.view.toMap(screenPoint);

      await this.handleEditorDoubleClick(
        {
          x: screenPoint.x,
          y: screenPoint.y,
          mapPoint,
        },
        "native-double-click"
      );
    };

    this.view.container.addEventListener("dblclick", nativeDoubleClick, true);

    const pointerMoveHandle = this.view.on("pointer-move", async (evt: any) => {
      if (this._editorOpen || this._inDrawingMode) {
        this._lastHoveredGraphic = null;
        this.setMapCursor("default");
        return;
      }

      const graphic = await this.getHitGraphic(evt);

      if (graphic) {
        if (this._lastHoveredGraphic !== graphic) {
          if (this._lastHoveredGraphic) {
            this.emitLayerEvent(
              "layerMouseOut",
              this.graphicToGeoJsonFeature(this._lastHoveredGraphic),
              this._lastHoveredGraphic,
              {
                coordinates: {
                  latitude: evt.mapPoint?.latitude ?? 0,
                  longitude: evt.mapPoint?.longitude ?? 0,
                },
                attributes: this._lastHoveredGraphic.attributes ?? {},
              }
            );
          }

          this._lastHoveredGraphic = graphic;

          this.emitLayerEvent(
            "layerMouseOver",
            this.graphicToGeoJsonFeature(graphic),
            graphic,
            {
              coordinates: {
                latitude: evt.mapPoint?.latitude ?? 0,
                longitude: evt.mapPoint?.longitude ?? 0,
              },
              attributes: graphic.attributes ?? {},
            }
          );
        }

        this.setMapCursor("pointer");
        return;
      }

      if (this._lastHoveredGraphic) {
        this.emitLayerEvent(
          "layerMouseOut",
          this.graphicToGeoJsonFeature(this._lastHoveredGraphic),
          this._lastHoveredGraphic,
          {
            coordinates: {
              latitude: evt.mapPoint?.latitude ?? 0,
              longitude: evt.mapPoint?.longitude ?? 0,
            },
            attributes: this._lastHoveredGraphic.attributes ?? {},
          }
        );

        this._lastHoveredGraphic = null;
      }

      this.setMapCursor("default");
    });

    this.eventHandles.push(
      clickHandle,
      doubleClickHandle,
      pointerMoveHandle,
      {
        remove: () => {
          this.view?.container?.removeEventListener(
            "dblclick",
            nativeDoubleClick,
            true
          );
        },
      }
    );
  }

  private async getHitGraphic(evt: any): Promise<Graphic | null> {
    if (!this.view || !this.featureLayer) {
      return null;
    }

    try {
      const hit = await this.view.hitTest(evt);
      const results = hit?.results ?? [];

      if (!results.length) {
        return null;
      }

      const currentLayerId = this.featureLayer.id;

      const validHits = results
        .map((result: any) => {
          const graphic = result.graphic as Graphic;
          const layer =
            result.layer ??
            (graphic as any)?.layer ??
            (graphic as any)?.origin?.layer ??
            null;

          const layerId =
            layer?.id ??
            (graphic as any)?.layer?.id ??
            (graphic as any)?.origin?.layer?.id ??
            (graphic as any)?.origin?.layerId ??
            "";

          return {
            graphic,
            layer,
            layerId,
          };
        })
        .filter((item: any) => {
          if (!item.graphic?.geometry) {
            return false;
          }

          const layerId = String(item.layerId ?? "");

          if (layerId.includes("-labels") || layerId.includes("-sketch")) {
            return false;
          }

          return true;
        });

      if (!validHits.length) {
        return null;
      }

      const topHit = validHits[0];

      if (
        topHit.layer &&
        topHit.layer !== this.featureLayer &&
        topHit.layerId !== currentLayerId
      ) {
        return null;
      }

      if (topHit.layerId && topHit.layerId !== currentLayerId) {
        return null;
      }

      const hitGraphic = topHit.graphic;

      return this.findSourceGraphic(hitGraphic) ?? hitGraphic;
    } catch (error) {
      console.warn("[art-geojson-layer] getHitGraphic failed", error);
      return null;
    }
  }

  private async showGraphicPopup(graphic: Graphic, mapPoint?: Point): Promise<void> {
    if (
      !this.view ||
      !graphic?.geometry ||
      this.enableUserEdit ||
      this._editorOpen ||
      this._inDrawingMode ||
      this._isStartingDraw ||
      this.shouldSuppressPopup()
    ) {
      this.closePopup();
      return;
    }

    const popupData = this.buildPopupContentFromInfoTemplate(graphic);

    if (!popupData?.content) {
      return;
    }

    const popupPoint =
      mapPoint ??
      ArtMapGeojsonLayer.getPopupPoint(graphic.geometry);

    if (!popupPoint) {
      return;
    }

    (graphic as any).__artMapPopupTitle =
      popupData.title ?? this.name ?? "Details";
    (graphic as any).__artMapPopupContent = popupData.content;

    await this.openPopup(graphic, popupPoint);
  }

  private async openPopup(
    graphicMatch: Graphic,
    popupPoint?: Point | null
  ): Promise<void> {
    if (!this.view || !graphicMatch || !popupPoint || this.shouldSuppressPopup()) {
      return;
    }

    try {
      this.closePopup();

      this._libraryPopupGraphic = graphicMatch;
      this._libraryPopupPoint = popupPoint;

      const title =
        (graphicMatch as any).__artMapPopupTitle ??
        this.name ??
        "Details";

      const content =
        (graphicMatch as any).__artMapPopupContent ??
        "";

      const popup = document.createElement("div");
      popup.className = "art-map-geojson-popup";

      popup.innerHTML = `
        <div class="art-map-geojson-popup-header">
          <div class="art-map-geojson-popup-title">${this.escapeHtml(String(title))}</div>
          <button class="art-map-geojson-popup-close" type="button" aria-label="Close">×</button>
        </div>
        <div class="art-map-geojson-popup-body">
          ${content}
        </div>
      `;

      popup
        .querySelector(".art-map-geojson-popup-close")
        ?.addEventListener("click", () => this.closePopup());

      this.view.container.appendChild(popup);
      this._libraryPopupElement = popup;

      this.positionLibraryPopup(popupPoint);

      if (this.view?.watch && typeof this.view.watch === "function") {
        this._libraryPopupViewMoveHandle = this.view.watch("extent", () => {
          if (this._libraryPopupElement && this._libraryPopupPoint) {
            this.positionLibraryPopup(this._libraryPopupPoint);
          }
        });
      }
    } catch (error) {
      console.warn("[art-geojson-layer] openPopup failed", error);
    }
  }

  private closePopup(): void {
    try {
      if (this._libraryPopupElement) {
        this._libraryPopupElement.remove();
        this._libraryPopupElement = null;
      }

      this._libraryPopupGraphic = null;
      this._libraryPopupPoint = null;

      try {
        this._libraryPopupViewMoveHandle?.remove?.();
      } catch {}

      this._libraryPopupViewMoveHandle = null;

      const popup = this.view?.popup as any;
      if (popup) {
        popup.close?.();
        popup.features = [];
      }
    } catch {}
  }

  private positionLibraryPopup(popupPoint: Point): void {
    if (!this.view || !this._libraryPopupElement) {
      return;
    }

    const screenPoint = this.view.toScreen(popupPoint);
    this._libraryPopupElement.style.left = `${screenPoint.x}px`;
    this._libraryPopupElement.style.top = `${screenPoint.y}px`;
  }

  private shouldSuppressPopup(): boolean {
    return Date.now() < this._suppressPopupUntil;
  }

  private enableInfoPopupWindow(enable: boolean): void {
    if (!this.view) {
      return;
    }

    try {
      this.view.popupEnabled = false;
    } catch {}

    if (!enable) {
      this.closePopup();
    }
  }

  private buildPopupContentFromInfoTemplate(
    graphic: Graphic
  ): { title: string; content: string } | null {
    if (!graphic || !this.infoTemplate) {
      return null;
    }

    const attributes = graphic.attributes ?? {};

    if (
      typeof this.infoTemplate === "object" &&
      typeof this.infoTemplate.details === "function"
    ) {
      let title = this.name || "Details";

      if (typeof this.infoTemplate.listTitle === "string") {
        title = this.replaceTemplateTokens(this.infoTemplate.listTitle, attributes);
      }

      let content = "";
      try {
        content = this.infoTemplate.details(graphic) ?? "";
      } catch (error) {
        console.warn("[art-geojson-layer] infoTemplate.details failed", error);
      }

      return content ? { title, content: String(content) } : null;
    }

    if (typeof this.infoTemplate === "string") {
      return {
        title: this.name || "Details",
        content: this.replaceTemplateTokens(this.infoTemplate, attributes),
      };
    }

    if (typeof this.infoTemplate === "object") {
      const title = this.replaceTemplateTokens(
        String(this.infoTemplate.title ?? this.infoTemplate.listTitle ?? this.name ?? "Details"),
        attributes
      );

      const content = this.replaceTemplateTokens(
        String(this.infoTemplate.content ?? this.infoTemplate.details ?? ""),
        attributes
      );

      return content ? { title, content } : null;
    }

    return null;
  }

  private replaceTemplateTokens(template: string, attributes: Record<string, any>): string {
    return template.replace(/\$\{([^}]+)\}/g, (_match, key) => {
      const value = attributes[String(key).trim()];
      return value === undefined || value === null ? "" : String(value);
    });
  }

  private setMapCursor(cursor: "default" | "pointer"): void {
    if (this._currentCursor === cursor) {
      return;
    }

    this._currentCursor = cursor;

    const container = this.view?.container as HTMLElement | undefined;
    if (!container) {
      return;
    }

    const value = cursor === "pointer" ? "pointer" : "default";

    container.style.setProperty("cursor", value, "important");

    const canvas = container.querySelector("canvas") as HTMLElement | null;
    if (canvas) {
      canvas.style.cursor = value;
    }
  }

  private async updateGeoJson(
    value: string | FeatureCollection<GeoJsonGeometry, GeoJsonProperties> | null
  ): Promise<void> {
    if (!this.featureLayer) {
      return;
    }

    const parsed = this.parseGeoJson(value);

    if (!parsed || parsed.type !== "FeatureCollection") {
      return;
    }

    const graphics: Graphic[] = [];

    parsed.features.forEach((feature: Feature) => {
      const graphic = this.geoJsonFeatureToGraphic(feature);
      if (graphic) {
        graphics.push(graphic);
      }
    });

    this.featureLayer.graphics.removeAll();
    this.featureLayer.graphics.addMany(graphics);
  }

  private parseGeoJson(
    value: string | FeatureCollection<GeoJsonGeometry, GeoJsonProperties> | null
  ): FeatureCollection<GeoJsonGeometry, GeoJsonProperties> | null {
    if (!value) {
      return null;
    }

    if (typeof value === "string") {
      try {
        return JSON.parse(value);
      } catch {
        return null;
      }
    }

    return value;
  }

  private geoJsonFeatureToGraphic(feature: Feature): Graphic | null {
    if (!feature?.geometry) {
      return null;
    }

    const geometry = this.geoJsonGeometryToArcGeometry(feature.geometry);
    if (!geometry) {
      return null;
    }

    const attributes = {
      ...(feature.properties ?? {}),
    } as Record<string, any>;

    const id =
      feature.id ??
      attributes[this.uniqueIdPropertyName] ??
      attributes.OBJECTID ??
      attributes.id ??
      `${Date.now()}-${Math.random()}`;

    attributes[this.uniqueIdPropertyName] = id;
    attributes.OBJECTID = id;
    attributes.id = id;

    const graphic = new Graphic({
      geometry,
      attributes,
      symbol: this.getDefaultSymbolForGeometry(geometry),
    });

    this.applyGraphicDefaults(graphic);

    return graphic;
  }

  private geoJsonGeometryToArcGeometry(geometry: GeoJsonGeometry): Geometry | null {
    const sr = new SpatialReference({ wkid: 4326 });

    if (geometry.type === "Point") {
      const c = geometry.coordinates as number[];
      return new Point({
        longitude: c[0],
        latitude: c[1],
        spatialReference: sr,
      });
    }

    if (geometry.type === "LineString") {
      return new Polyline({
        paths: geometry.coordinates as number[][],
        spatialReference: sr,
      });
    }

    if (geometry.type === "Polygon") {
      return new Polygon({
        rings: geometry.coordinates as number[][][],
        spatialReference: sr,
      });
    }

    if (geometry.type === "MultiPolygon") {
      return new Polygon({
        rings: (geometry.coordinates as number[][][][]).flat(1),
        spatialReference: sr,
      });
    }

    return null;
  }

  private graphicToGeoJsonFeature(graphic: Graphic): Feature | null {
    if (!graphic?.geometry) {
      return null;
    }

    const geometry = this.arcGeometryToGeoJson(graphic.geometry);
    if (!geometry) {
      return null;
    }

    const id =
      graphic.attributes?.[this.uniqueIdPropertyName] ??
      graphic.attributes?.OBJECTID ??
      graphic.attributes?.id;

    return {
      type: "Feature",
      id,
      geometry,
      properties: {
        ...(graphic.attributes ?? {}),
      },
    };
  }

  private arcGeometryToGeoJson(geometry: any): GeoJsonGeometry | null {
    if (geometry.type === "point") {
      return {
        type: "Point",
        coordinates: [
          geometry.longitude ?? geometry.x,
          geometry.latitude ?? geometry.y,
        ],
      } as GeoJsonGeometry;
    }

    if (geometry.type === "polyline") {
      return {
        type: "LineString",
        coordinates: geometry.paths?.[0] ?? [],
      } as GeoJsonGeometry;
    }

    if (geometry.type === "polygon") {
      return {
        type: "Polygon",
        coordinates: geometry.rings ?? [],
      } as GeoJsonGeometry;
    }

    return null;
  }

  private applyGraphicDefaults(graphic: Graphic): void {
    if (!graphic.attributes) {
      graphic.attributes = {};
    }

    const id =
      graphic.attributes[this.uniqueIdPropertyName] ??
      graphic.attributes.OBJECTID ??
      graphic.attributes.id ??
      `${Date.now()}-${Math.random()}`;

    graphic.attributes[this.uniqueIdPropertyName] = id;
    graphic.attributes.OBJECTID = id;
    graphic.attributes.id = id;

    if (!graphic.symbol) {
      graphic.symbol = this.getDefaultSymbolForGeometry(graphic.geometry);
    }

    graphic.popupTemplate = null as any;
  }

  private getDefaultSymbolForGeometry(geometry: Geometry | undefined | null): any {
    if (!geometry) {
      return null;
    }

    if (geometry.type === "point") {
      return {
        type: "simple-marker",
        style: "circle",
        size: 12,
        color: [0, 120, 255, 0.35],
        outline: {
          type: "simple-line",
          color: [0, 120, 255, 1],
          width: 2,
        },
      };
    }

    if (geometry.type === "polyline") {
      return {
        type: "simple-line",
        color: [0, 120, 255, 1],
        width: 2,
      };
    }

    return {
      type: "simple-fill",
      style: "solid",
      color: [0, 120, 255, 0.12],
      outline: {
        type: "simple-line",
        color: [0, 120, 255, 1],
        width: 2,
        style: "solid",
      },
    };
  }

  private isCircleGraphic(graphic: Graphic): boolean {
    const attrs = graphic.attributes ?? {};

    return (
      graphic.geometry?.type === "polygon" &&
      (
        attrs.isCircle === true ||
        attrs.isCircle === "true" ||
        String(attrs.shapeType ?? "").toLowerCase() === "circle" ||
        String(attrs.shape ?? "").toLowerCase() === "circle" ||
        String(attrs.drawGeometryType ?? "").toLowerCase() === "circle" ||
        attrs.radius !== undefined
      )
    );
  }

  private findSourceGraphic(graphic: Graphic): Graphic | null {
    if (!this.featureLayer || !graphic?.attributes) {
      return null;
    }

    const hitId =
      graphic.attributes[this.uniqueIdPropertyName] ??
      graphic.attributes.OBJECTID ??
      graphic.attributes.objectId ??
      graphic.attributes.id;

    if (hitId === undefined || hitId === null) {
      return null;
    }

    return (
      this.featureLayer.graphics.find((sourceGraphic: Graphic) => {
        const sourceId =
          sourceGraphic.attributes?.[this.uniqueIdPropertyName] ??
          sourceGraphic.attributes?.OBJECTID ??
          sourceGraphic.attributes?.objectId ??
          sourceGraphic.attributes?.id;

        return String(sourceId) === String(hitId);
      }) as Graphic
    ) ?? null;
  }

  private addToGeoJson(graphic: Graphic): void {
    const feature = this.graphicToGeoJsonFeature(graphic);
    if (!feature) {
      return;
    }

    const parsed =
      this.parseGeoJson(this.geojson) ??
      ({
        type: "FeatureCollection",
        features: [],
      } as FeatureCollection);

    parsed.features.push(feature as any);
    this.geojson = parsed as any;

    this.emitLayerEvent("userDrawItemAdded", feature, graphic, {
      geojson: this.geojson,
    });
  }

  private cleanupViewEvents(): void {
    this.eventHandles.forEach((handle) => {
      try {
        handle.remove?.();
      } catch {}
    });

    this.eventHandles = [];
  }

  private cleanupEditor(): void {
    this.editorHandles.forEach((handle) => {
      try {
        handle.remove?.();
      } catch {}
    });

    this.editorHandles = [];

    try {
      this.graphicsEditor?.cancel();
      this.graphicsEditor?.destroy?.();
    } catch {}

    this.graphicsEditor = undefined;
  }

  private emitLayerEvent(
    eventName: string,
    feature?: Feature | null,
    graphic?: Graphic | null,
    extraData?: any
  ): void {
    const attributes = feature?.properties ?? graphic?.attributes ?? {};

    const id =
      (attributes as any)?.OBJECTID ??
      (attributes as any)?.objectId ??
      (attributes as any)?.id ??
      null;

    this.dispatchEvent(
      new CustomEvent(eventName, {
        detail: {
          type: eventName,
          OBJECTID: id,
          objectId: id,
          id,
          feature: feature ?? null,
          graphic: graphic ?? null,
          attributes,
          properties: attributes,
          geojson: this.geojson,
          layerId: this.featureLayer?.id ?? this.name ?? "art-geojson-layer",
          layerName: this.name ?? "art-geojson-layer",
          ...extraData,
        },
        bubbles: true,
        composed: true,
      })
    );
  }

  static getPopupPoint(geometry: Geometry | any): Point | null {
    if (!geometry) {
      return null;
    }

    if (geometry.type === "point") {
      return geometry as Point;
    }

    if (geometry.type === "polyline") {
      const path = (geometry as Polyline).paths?.[0];
      if (path?.length) {
        const middle = path[Math.floor(path.length / 2)];
        return new Point({
          x: middle[0],
          y: middle[1],
          spatialReference: geometry.spatialReference,
        });
      }
    }

    if (geometry.type === "polygon") {
      const polygon = geometry as Polygon;
      return polygon.centroid ?? polygon.extent?.center ?? null;
    }

    if (geometry.type === "extent") {
      return geometry.center ?? null;
    }

    return null;
  }

  private escapeHtml(value: string): string {
    return value.replace(/[&<>"']/g, (char) => {
      switch (char) {
        case "&":
          return "&amp;";
        case "<":
          return "&lt;";
        case ">":
          return "&gt;";
        case '"':
          return "&quot;";
        case "'":
          return "&#039;";
        default:
          return char;
      }
    });
  }
}

