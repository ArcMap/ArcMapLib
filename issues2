const popup: any = this.view.popup;
this.view.popupEnabled = true;

await this.waitForViewIdle();

popup.features = [];
popup.content = null;
popup.title = "";
popup.location = popupPoint;
popup.visible = false;

await new Promise<void>((resolve) => requestAnimationFrame(() => resolve()));

popup.features = validPopupGraphics;
popup.location = popupPoint;

if (typeof popup.open === "function") {
  popup.open({
    features: validPopupGraphics,
    location: popupPoint,
  });
} else {
  popup.open = true;
  popup.visible = true;
}