private normalizeZoom(value: number | undefined): number {
  if (typeof value !== "number" || Number.isNaN(value)) {
    return ArcMap.DEFAULT_ZOOM;
  }

  return Math.max(
    this.minZoom,
    Math.min(this.maxZoom, value),
  );
}



