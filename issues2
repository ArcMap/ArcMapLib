private applyGraphicDefaults(graphic: Graphic, featureIndex?: number): void {
  if (!graphic.attributes) {
    graphic.attributes = {};
  }

  const attrs = graphic.attributes as Record<string, any>;

  // OBJECTID is always the array index
  const objectId =
    typeof featureIndex === "number" && !Number.isNaN(featureIndex)
      ? featureIndex
      : typeof attrs._featureIndex === "number"
      ? attrs._featureIndex
      : typeof attrs.OBJECTID === "number"
      ? attrs.OBJECTID
      : 0;

  // Only set OBJECTID and _featureIndex — never touch name or id
  attrs.OBJECTID = objectId;
  attrs._featureIndex = objectId;

  // Preserve name exactly — never assign ID into name
  // name stays as-is from original properties

  // Preserve business id exactly — never replace with OBJECTID
  // attrs.id stays as-is from original properties

  const rendererSymbol = this.getSymbolFromRendererConfig(this.renderer, graphic);

  const selectedSymbol =
    rendererSymbol ??
    graphic.symbol ??
    this.getDefaultSymbolForGeometry(graphic.geometry);

  graphic.symbol = this.coerceSymbolForGeometry(selectedSymbol, graphic.geometry);

  graphic.popupTemplate = null as any;
}



private geoJsonFeatureToGraphic(
  feature: Feature,
  featureIndex: number,
  parent?: FeatureCollection<GeoJsonGeometry, GeoJsonProperties>
): Graphic | null {
  if (!feature?.geometry) {
    return null;
  }

  const geometry = this.geoJsonGeometryToUpGeometry(feature.geometry);

  if (!geometry) {
    return null;
  }

  const properties = {
    ...(feature.properties ?? {}),
  } as Record<string, any>;

  // Store internal tracking only — do NOT mutate user fields
  properties.OBJECTID = featureIndex;
  properties._featureIndex = featureIndex;
  properties._parentFeatureCollection = parent;

  const graphic = new Graphic({
    geometry,
    attributes: properties,
  });

  this.applyGraphicDefaults(graphic, featureIndex);

  return graphic;
}



private graphicToGeoJsonFeature(
  graphic: Graphic,
  index?: number
): Feature | null {
  if (!graphic?.geometry) {
    return null;
  }

  const geometry = this.arcGeometryToGeoJson(graphic.geometry);

  if (!geometry) {
    return null;
  }

  const attrs = {
    ...(graphic.attributes ?? {}),
  } as Record<string, any>;

  const objectId =
    typeof index === "number" && !Number.isNaN(index)
      ? index
      : typeof attrs._featureIndex === "number"
      ? attrs._featureIndex
      : typeof attrs.OBJECTID === "number"
      ? attrs.OBJECTID
      : 0;

  // Preserve original id and name exactly as they were
  const originalId   = attrs.id;
  const originalName = attrs.name;

  // Remove internal tracking fields before emitting
  delete attrs._parentFeatureCollection;

  return {
    type: "Feature",
    id: originalId,       // original business id preserved
    geometry,
    properties: {
      ...attrs,

      // Always index-based OBJECTID
      OBJECTID: objectId,
      _featureIndex: objectId,

      // Preserve exactly — never overwrite with OBJECTID
      id:   originalId,
      name: originalName,
    },
  };
}











private geoJsonFeatureToGraphic(
  feature: Feature,
  featureIndex: number,
  parent?: FeatureCollection<GeoJsonGeometry, GeoJsonProperties>
): Graphic | null {
  if (!feature?.geometry) {
    return null;
  }

  const geometry = this.geoJsonGeometryToUpGeometry(feature.geometry);
  if (!geometry) {
    return null;
  }

  // FIX: Deep clone via JSON round-trip so we NEVER mutate
  // the original Angular object that was passed in by reference.
  // Angular passes the same object reference on every change detection
  // cycle — without deep clone, our mutations bleed back into
  // the original Angular data model.
  const properties = JSON.parse(
    JSON.stringify(feature.properties ?? {})
  ) as Record<string, any>;

  // Safe to mutate now — this is our own copy
  properties.OBJECTID = featureIndex;
  properties._featureIndex = featureIndex;
  properties._parentFeatureCollection = parent;

  const graphic = new Graphic({
    geometry,
    attributes: properties,
  });

  this.applyGraphicDefaults(graphic, featureIndex);

  return graphic;
}



private async updateGeoJson(
  value: string | FeatureCollection<GeoJsonGeometry, GeoJsonProperties> | null
): Promise<void> {
  if (!this.featureLayer || this._isUpdatingGeoJson) {
    return;
  }

  if (this.blockGeoJsonUpdate) {
    return;
  }

  const signature = JSON.stringify(value ?? {});

  if (signature === this._lastGeoJsonSignature) {
    return;
  }

  this._lastGeoJsonSignature = signature;
  this._isUpdatingGeoJson = true;

  try {
    const parsedResult = this.getJsonForAny(value);

    if (parsedResult.error || !parsedResult.parsedJson) {
      return;
    }

    // FIX: Deep clone the entire parsed GeoJSON so Angular's
    // original object is never touched during processing.
    // This is the root cause of mutation from Angular —
    // we were processing the live Angular reference directly.
    const parsedGeoJson = JSON.parse(
      JSON.stringify(parsedResult.parsedJson)
    );

    if (
      parsedGeoJson.type !== "FeatureCollection" ||
      !Array.isArray(parsedGeoJson.features)
    ) {
      return;
    }

    if (!this._editorOpen) {
      this.clearGeoJSONLayer();
    }

    const graphics: Graphic[] = [];

    parsedGeoJson.features.forEach((feature: any, index: number) => {
      const graphic = this.geoJsonFeatureToGraphic(feature, index);
      if (!graphic) {
        return;
      }
      this.applyGraphicDefaults(graphic, index);
      graphics.push(graphic);
    });

    if (graphics.length > 0) {
      this.featureLayer.addMany(graphics);
    }

    this.refreshLabels();
    this.filterGraphicsByActiveType(this._activeVisibleType);

  } catch (error) {
    console.error("[arc-geojson-layer] updateGeoJson failed", error);
  } finally {
    this._isUpdatingGeoJson = false;
  }
}
