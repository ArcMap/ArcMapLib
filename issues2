private async showGraphicPopup(graphic: Graphic, mapPoint?: Point): Promise<void> {
  if (
    !this.view ||
    !graphic ||
    !graphic.geometry ||
    this.enableUserEdit ||
    this._editorOpen ||
    this._inDrawingMode ||
    this._isStartingDraw ||
    this.shouldSuppressPopup()
  ) {
    this.closePopup();
    return;
  }

  const popupTemplate = this.buildPopupTemplateForCurrent(graphic);

  if (!popupTemplate) {
    return;
  }

  const popupGraphic = graphic.clone();
  popupGraphic.attributes = {
    ...(graphic.attributes ?? {}),
  };
  popupGraphic.popupTemplate = popupTemplate;

  const location =
    mapPoint ??
    this.getPopupPoint(popupGraphic.geometry as any) ??
    this.getPopupPoint(graphic.geometry as any);

  if (!location) {
    console.warn("[arc-geojson-layer] popup location not found", graphic);
    return;
  }

  await this.openPopup(popupGraphic, location);
}



private async openPopup(
  graphicMatch: Graphic,
  popupPoint?: Point | null
): Promise<void> {
  if (!this.view || !graphicMatch || !popupPoint || this.shouldSuppressPopup()) {
    return;
  }

  try {
    this.view.popupEnabled = true;

    if (this.view.openPopup) {
      this.view.openPopup({
        location: popupPoint,
        features: [graphicMatch],
      });
      return;
    }

    if (this.view.popup) {
      this.view.popup.location = popupPoint;
      this.view.popup.features = [graphicMatch];
      (this.view.popup as any).open = true;
    }
  } catch (error) {
    console.warn("[arc-geojson-layer] openPopup failed", error);
  }
}



private buildPopupTemplateForCurrent(graphic: Graphic): PopupTemplate | null {
  if (!graphic || !this.infoTemplate) {
    return null;
  }

  const popupData = this.buildPopupContentFromInfoTemplate(graphic);

  if (!popupData || !popupData.content) {
    return null;
  }

  return this.createHtmlPopupTemplate(
    popupData.title ?? this.name ?? "Details",
    popupData.content
  );
}



private getPopupPoint(geometry: Geometry | any): Point | null {
  if (!geometry) {
    return null;
  }

  if (geometry.type === "point") {
    return geometry as Point;
  }

  if (geometry.type === "polyline") {
    const polyline = geometry as Polyline;
    const path = polyline.paths?.[0];

    if (path && path.length > 0) {
      const middle = path[Math.floor(path.length / 2)];
      return new Point({
        x: middle[0],
        y: middle[1],
        spatialReference: polyline.spatialReference,
      });
    }
  }

  if (geometry.type === "polygon" || geometry.type === "extent") {
    return (geometry as any).centroid ?? (geometry as any).center ?? null;
  }

  return null;
}