override connectedCallback(): void {
  super.connectedCallback();

  queueMicrotask(() => {
    void this.initializeAfterMapReady();
  });
}

private async initializeAfterMapReady(): Promise<void> {
  try {
    await this.resolveAncestorMapAndView();
    await this.createLayer();
  } catch (error) {
    console.error("[arc-esri-feature-layer] failed to initialize", error);
  }
}