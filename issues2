private async getHitGraphics(evt: any): Promise<Graphic[]> {
  if (!this.view || !this.featureLayer) {
    return [];
  }

  try {
    const hit = await this.view.hitTest(evt, {
      include: [this.featureLayer],
    });

    const graphics = (hit.results ?? [])
      .map((r: any) => r.graphic as Graphic)
      .filter((graphic: Graphic | null | undefined) => {
        return !!graphic && !!graphic.geometry;
      });

    const unique = new Map<string, Graphic>();

    graphics.forEach((graphic: Graphic, index: number) => {
      const attrs = graphic.attributes ?? {};
      const key =
        attrs[this.uniqueIdPropertyName] ??
        attrs.OBJECTID ??
        attrs.objectId ??
        attrs.id ??
        `${graphic.geometry?.type}-${index}`;

      unique.set(String(key), graphic);
    });

    return Array.from(unique.values());
  } catch (error) {
    console.warn("[geojson-layer] hitTest failed", error);
    return [];
  }
}





