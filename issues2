const clickHandle = this.view.on('click', async (evt: any) => {
  if (clickTimer) {
    clearTimeout(clickTimer);
    clickTimer = null;
    return;
  }

  // ✅ Call getHitGraphic ONCE and reuse
  const graphic = await this.getHitGraphic(evt);
  if (!graphic) {
    return;
  }

  // ✅ Emit layerClick immediately
  this.emitLayerEvent(
    'layerClick',
    this.graphicToGeoJsonFeature(graphic),
    graphic,
    {
      event: {
        coordinates: {
          latitude: evt.mapPoint?.latitude ?? 0,
          longitude: evt.mapPoint?.longitude ?? 0,
        },
        attributes: graphic.attributes ?? {},
      },
    }
  );

  clickTimer = setTimeout(() => {
    clickTimer = null;

    if (
      this._editorOpen ||
      this.inDrawingMode ||
      this._isStartingDraw ||
      this._shouldSuppressPopup()
    ) {
      try {
        this.view?.popup?.close();
      } catch {}
      return;
    }

    // ✅ Only show popup when edit NOT enabled
    // Use already-fetched graphic — no second getHitGraphic call
    if (!this.enableUserEdit) {
      this.showGraphicPopup(graphic, evt.mapPoint);
    } else {
      try {
        this.view?.popup?.close();
      } catch {}
    }

  }, 280); // ✅ Reduce to 280ms for snappiness
});
