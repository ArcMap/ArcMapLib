try {
  // DO NOT set view.popupEnabled = false. Leave the view alone.
  // The arcgis-popup component handles opening itself.

  // Set the template on the graphic
  graphic.popupTemplate = popupTemplate;
  console.log("[LOG 2] popupTemplate set on graphic:", graphic.popupTemplate);

  // Find the <arcgis-popup> component
  const arcMap = this.closest("arc-map") as any;
  const popupEl = arcMap?.shadowRoot?.querySelector("arcgis-popup");
  console.log("[LOG 3] popupEl found?", !!popupEl);

  if (!popupEl) {
    console.warn("[up-geojson-layer] <arcgis-popup> not found");
    return;
  }

  await popupEl.componentOnReady();

  // Set features and location as properties on the component
  popupEl.features = [graphic];
  popupEl.location = location;
  popupEl.visible = true;

  console.log("[LOG 3] popup opened via component properties");
  console.log("[LOG 3] popup features count:", popupEl.features?.length);
  console.log("[LOG 3] popup selectedFeature attrs:", popupEl.selectedFeature?.attributes);
} catch (err) {
  console.warn("[up-geojson-layer] showGraphicPopup failed", err);
}


private async prewarmPopup(): Promise<void> {
  if (!this.view) return;
  try {
    await this.view.when();
    const popupEl = this.shadowRoot?.querySelector("arcgis-popup") as any;
    if (!popupEl) return;
    await popupEl.componentOnReady();
    popupEl.features = [];
    popupEl.location = this.view.center;
    popupEl.visible = true;
    // Close immediately
    requestAnimationFrame(() => {
      popupEl.visible = false;
    });
    console.log("[prewarmPopup] popup pre-warmed");
  } catch (err) {
    console.warn("[prewarmPopup] failed (non-critical):", err);
  }
}
