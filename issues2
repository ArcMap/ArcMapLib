private async showGraphicPopup(
  graphic: Graphic,
  location?: Point
): Promise<void> {
  if (!this.view || !graphic) {
    return;
  }

  if (
    this._editorOpen ||
    this.inDrawingMode ||
    this._isStartingDraw ||
    this.shouldSuppressPopup()
  ) {
    this.closePopup();
    return;
  }

  const popupTemplate = this.buildPopupTemplateFromCurrent(graphic);
  if (!popupTemplate) {
    console.warn("[geojson-layer] popup skipped: no popup template", {
      infoTemplate: this.infoTemplate,
      attributes: graphic.attributes ?? {},
    });
    return;
  }

  const popupLocation =
    location ??
    UpGeojsonLayer.getPopupPoint(graphic.geometry) ??
    undefined;

  if (!popupLocation) {
    console.warn("[geojson-layer] popup skipped: no popup location", {
      geometry: graphic.geometry,
    });
    return;
  }

  try {
    this._popupGraphic = graphic;
    this._popupOpen = true;
    this._showPopup = true;

    graphic.popupTemplate = popupTemplate;

    const popup: any = this.view.popup;
    this.view.popupEnabled = true;

    /*
     * ArcGIS 5.x:
     * - Do NOT assign popup.selectedFeature because it is read-only.
     * - Use features/location/open/visible.
     * - Clear old popup state first so stale polygon/geofence popup does not remain.
     */
    popup.features = [];
    popup.content = null;
    popup.title = "";
    popup.location = popupLocation;

    await Promise.resolve();

    popup.features = [graphic];
    popup.location = popupLocation;
    popup.open = true;
    popup.visible = true;

    requestAnimationFrame(() => {
      try {
        popup.features = [graphic];
        popup.location = popupLocation;
        popup.open = true;
        popup.visible = true;
      } catch (error) {
        console.warn("[geojson-layer] popup force-open failed", error);
      }
    });
  } catch (error) {
    this._popupGraphic = null;
    this._popupOpen = false;
    this._showPopup = false;

    console.warn("[geojson-layer] popup open failed", error);
  }
}