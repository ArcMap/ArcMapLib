private static createTemplateFromObject(
  config: any,
  attributes?: Record<string, any>
): PopupTemplate {
  
  // 👇 NEW: Handle { listItem, details: string } format (your project's format)
  if (typeof config.details === "string" && config.listItem !== undefined) {
    // Resolve title from listItem
    let title = config.listItem;
    if (attributes && typeof title === "string") {
      title = title.replace(/\$\{([^}]+)\}/g, (_: string, key: string) => {
        const val = attributes[key.trim()];
        return val !== undefined && val !== null ? String(val) : "";
      });
    }
    
    // Resolve ${field} placeholders in details HTML
    let htmlContent = config.details;
    if (attributes) {
      htmlContent = htmlContent.replace(/\$\{([^}]+)\}/g, (_: string, key: string) => {
        const val = attributes[key.trim()];
        return val !== undefined && val !== null ? String(val) : "";
      });
    }
    
    return new PopupTemplate({
      title,
      content: [{ type: "text", text: htmlContent }]
    });
  }

  // 👇 EXISTING: Handle callback-based details
  if (typeof config.details === "function") {
    // ... your existing code
  }

  // 👇 EXISTING: Handle title/content object
  const title = this.normalizeTitle(config.title);
  const content = this.normalizeContent(config.content);

  return new PopupTemplate({
    title,
    content,
    // ...
  });
}


static resolveTemplate(
  infoTemplate: string | PopupTemplateConfig | null | undefined,
  featureAttributes?: Record<string, any>
): PopupTemplate | null {
  if (infoTemplate === null || infoTemplate === undefined) {
    return null;
  }

  if (typeof infoTemplate === "string") {
    return this.createTemplateFromString(infoTemplate, featureAttributes);
  }

  if (typeof infoTemplate === "object") {
    // 👇 PASS attributes to createTemplateFromObject
    return this.createTemplateFromObject(infoTemplate, featureAttributes);
  }

  return null;
}
