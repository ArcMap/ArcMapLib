updateGeofenceCoordinates() {
  // Step 1: Close editor first to commit any active reshape/transform
  if (this.drawGeoJsonLayer) {
    const layer = this.drawGeoJsonLayer as any;
    if (layer.isEditorOpen && layer.isEditorOpen()) {
      layer.closeEditor();
    }
  }

  // Step 2: Wait for edit complete event to update geojson
  setTimeout(() => {
    // Step 3: Read latest features from the layer
    const layerGeoJson = this.drawGeoJsonLayer
      ? (this.drawGeoJsonLayer as any).geojson
      : null;

    const currentFeature = layerGeoJson?.features?.length > 0
      ? layerGeoJson.features
      : this.editGeofenceService.currentFeature;

    if (currentFeature && currentFeature.length > 0) {
      this.coordinates = this.saveFenceService.toLaLon(
        currentFeature[0].geometry.coordinates[0]
      );

      if (
        currentFeature[0].geometry.type === 'Circle' &&
        this.radius
      ) {
        this.getCircleDataWithRadius(
          this.saveFenceService.toLaLon(
            currentFeature[0].geometry.coordinates[0]
          ),
          this.geospatialConvService.toRadiusInMetersFromMiles(this.radius)
        );
        this.drawnFenceType = 'Circle';

      } else if (currentFeature[0].geometry.type === 'Circle') {
        this.getCircleDataWithoutRadius(this.coordinates);
        this.drawnFenceType = 'Circle';

      } else if (
        Object.prototype.hasOwnProperty.call(
          currentFeature[0].properties,
          'radius'
        )
      ) {
        this.getCircleDataWithoutRadius(this.coordinates);

      } else if (
        currentFeature[0].properties?.isCircle === true ||
        currentFeature[0].properties?.drawGeometryType === 'circle'
      ) {
        // FIX: Handle circles saved as Polygon geometry with isCircle flag
        this.getCircleDataWithoutRadius(this.coordinates);
        this.drawnFenceType = 'Circle';

      } else {
        this.circleData = undefined;
        this.drawnFenceType = 'Polygon';
      }
    }
  }, 100);
}
