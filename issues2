private syncMouseWheelZoom(): void {
  if (!this.view) return;

  this.eventHandles.remove('mouse-wheel');

  if (this.disableMapScrollWheelZoom) {
    const handle = this.view.on(
      'mouse-wheel',
      (event: ViewMouseWheelEvent) => {
        event.stopPropagation();
      },
    );
    this.eventHandles.add(handle, 'mouse-wheel');
  } else {
    // ✅ Fix shaky zoom — disable momentum and set smooth zoom factor
    try {
      (this.view as any).navigation = {
        ...(this.view as any).navigation,
        momentumEnabled: false,
        mouseWheelZoomEnabled: true,
      };
    } catch {}

    // ✅ Smooth out scroll by adding slight delay between wheel events
    let wheelTimer: any = null;
    const handle = this.view.on(
      'mouse-wheel',
      (event: ViewMouseWheelEvent) => {
        if (wheelTimer) {
          clearTimeout(wheelTimer);
        }
        wheelTimer = setTimeout(() => {
          wheelTimer = null;
        }, 50); // ✅ 50ms debounce smooths out rapid scroll events
      },
    );
    this.eventHandles.add(handle, 'mouse-wheel');
  }
}
