private async getHitGraphic(evt: any): Promise<Graphic | null> {
  if (!this.view || !this.featureLayer) {
    return null;
  }

  try {
    const hit = await this.view.hitTest(evt);
    const results = hit?.results ?? [];

    const graphicHits = results
      .map((r: any) => r?.graphic)
      .filter((g: Graphic | undefined) => !!g?.geometry) as Graphic[];

    if (!graphicHits.length) {
      return null;
    }

    // IMPORTANT:
    // Only the top-most graphic should handle the click.
    // If another layer is visually on top, this layer must ignore the click.
    const topGraphic = graphicHits[0];
    const topLayer =
      (topGraphic as any).origin?.layer ??
      (topGraphic as any).layer ??
      null;

    const topLayerId =
      topLayer?.id ??
      (topGraphic as any).origin?.layerId ??
      null;

    const currentLayerId = this.featureLayer.id;

    if (
      topLayer &&
      topLayer !== this.featureLayer &&
      topLayerId !== currentLayerId
    ) {
      return null;
    }

    const sourceGraphic = this.featureLayer.graphics.find((g: Graphic) => {
      const gId =
        g.attributes?.[this.uniqueIdPropertyName] ??
        g.attributes?.OBJECTID ??
        g.attributes?.objectId ??
        g.attributes?.id;

      const hitId =
        topGraphic.attributes?.[this.uniqueIdPropertyName] ??
        topGraphic.attributes?.OBJECTID ??
        topGraphic.attributes?.objectId ??
        topGraphic.attributes?.id;

      return String(gId) === String(hitId);
    });

    return (sourceGraphic as Graphic) ?? topGraphic;
  } catch (error) {
    console.warn("[arc-geojson-layer] hitTest failed", error);
    return null;
  }
}






private bindViewEvents(): void {
  if (!this.view || !this.featureLayer) {
    return;
  }

  this.cleanupViewEvents();

  // Disable ArcGIS auto-popup. We control popup manually.
  try {
    this.view.popupEnabled = false;
  } catch {}

  let clickTimer: any = null;

  const clickHandle = this.view.on("click", async (evt: any) => {
    if (clickTimer) {
      clearTimeout(clickTimer);
      clickTimer = null;
    }

    clickTimer = setTimeout(async () => {
      clickTimer = null;

      const graphic = await this.getHitGraphic(evt);
      if (!graphic) {
        return;
      }

      this.emitLayerEvent("layerClick", {
        graphic,
        feature: this.graphicToGeoJsonFeature(graphic),
        event: {
          coordinates: {
            latitude: evt.mapPoint?.latitude ?? 0,
            longitude: evt.mapPoint?.longitude ?? 0,
          },
          attributes: graphic.attributes ?? {},
        },
      });

      // Editor mode has priority.
      // Popup must NOT open when editor is enabled/open.
      if (this.enableUserEdit) {
        this.closePopup();
        await this.activateGraphicsEditor(graphic);
        return;
      }

      await this.showGraphicPopup(graphic, evt.mapPoint);
    }, 180);
  });

  const doubleClickHandle = this.view.on("double-click", async (evt: any) => {
    evt.stopPropagation();
    evt.preventDefault();

    if (clickTimer) {
      clearTimeout(clickTimer);
      clickTimer = null;
    }

    this.closePopup();

    const graphic = await this.getHitGraphic(evt);
    if (!graphic) {
      return;
    }

    this.emitLayerEvent("doubleClick", {
      graphic,
      feature: this.graphicToGeoJsonFeature(graphic),
      event: {
        coordinates: {
          latitude: evt.mapPoint?.latitude ?? 0,
          longitude: evt.mapPoint?.longitude ?? 0,
        },
        attributes: graphic.attributes ?? {},
      },
    });

    if (this.enableUserEdit) {
      await this.activateGraphicsEditor(graphic);
    }
  });

  this.eventHandles.push(clickHandle, doubleClickHandle);
}




private async showGraphicPopup(
  graphic: Graphic,
  mapPoint?: Point
): Promise<void> {
  if (
    !this.view ||
    !graphic?.geometry ||
    this.enableUserEdit ||
    this._editorOpen ||
    this._inDrawingMode ||
    this._isStartingDraw ||
    this.shouldSuppressPopup()
  ) {
    this.closePopup();
    return;
  }

  const popupTemplate = this.buildPopupTemplateForCurrent(graphic);
  if (!popupTemplate) {
    return;
  }

  const popupPoint =
    mapPoint ??
    UpGeojsonLayer.getPopupPoint(graphic.geometry) ??
    undefined;

  if (!popupPoint) {
    return;
  }

  // Do not permanently attach template to graphic.
  // This avoids stale popup content and reduces lag.
  const popupGraphic = graphic.clone();
  popupGraphic.popupTemplate = popupTemplate;

  await this.openPopup(popupGraphic, popupPoint);
}




private async openPopup(
  graphicMatch: Graphic,
  popupPoint?: Point | null
): Promise<void> {
  if (!this.view || !graphicMatch || this.shouldSuppressPopup()) {
    return;
  }

  try {
    const appEl = this.ancestorMapElement as any;
    const popupEl =
      typeof appEl?.getPopupComponent === "function"
        ? appEl.getPopupComponent()
        : null;

    const location =
      popupPoint ??
      UpGeojsonLayer.getPopupPoint(graphicMatch.geometry) ??
      undefined;

    if (!location) {
      return;
    }

    this.view.popupEnabled = true;

    if (popupEl && typeof popupEl.open === "boolean") {
      popupEl.location = location;
      popupEl.features = [graphicMatch];
      popupEl.open = true;
    } else if (this.view.openPopup) {
      this.view.openPopup({
        location,
        features: [graphicMatch],
      });
    } else if (this.view.popup) {
      this.view.popup.location = location;
      this.view.popup.features = [graphicMatch];
      (this.view.popup as any).open = true;
    }
  } catch (error) {
    console.warn("[arc-geojson-layer] openPopup failed", error);
  }
}


private buildPopupTemplateForCurrent(graphic: Graphic): PopupTemplate | null {
  if (!graphic || !this.infoTemplate) {
    return null;
  }

  const popupData = this.buildPopupContentFromInfoTemplate(graphic);
  if (!popupData) {
    return null;
  }

  return this.createHtmlPopupTemplate(
    popupData.title ?? this.name ?? "Details",
    popupData.content ?? ""
  );
}



private createHtmlPopupTemplate(
  title: string,
  htmlContent: string
): PopupTemplate {
  const safeTitle = title || this.name || "Details";
  const safeContent = htmlContent || "";

  const customContent = new CustomContent({
    outFields: ["*"],
    creator: () => {
      const wrapper = document.createElement("div");

      // Fix white-background-under-template issue.
      wrapper.className = "arc-geojson-popup-content";
      wrapper.style.background = "transparent";
      wrapper.style.margin = "0";
      wrapper.style.padding = "0";
      wrapper.style.boxShadow = "none";
      wrapper.style.border = "0";

      wrapper.innerHTML = safeContent;
      return wrapper;
    },
  });

  return new PopupTemplate({
    title: safeTitle,
    outFields: ["*"],
    content: [customContent],
  });
}


private enableInfoPopupWindow(enable: boolean): void {
  if (!this.view) {
    return;
  }

  if (enable && (this.enableUserEdit || this._editorOpen || this._inDrawingMode)) {
    return;
  }

  try {
    this.view.popupEnabled = enable;
  } catch {}

  if (!enable) {
    this.closePopup();

    if (this.featureLayer) {
      this.featureLayer.graphics.forEach((graphic: Graphic) => {
        graphic.popupTemplate = null as any;
      });
    }
  }
}


