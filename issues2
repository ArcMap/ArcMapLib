static normalizePlainSymbol(symbolJson: any): any {
  if (!symbolJson) {
    return symbolJson;
  }

  const parsed = JsonUtils.getJsonFor(symbolJson);

  if (parsed.error) {
    console.warn("[ArcGeoJSON][json-util] Could not parse symbol json", parsed.error);
    return symbolJson;
  }

  const symbol = { ...(parsed.parsedJson as any) };
  const rawType = String(symbol.type || "").toLowerCase();

  const typeMap: Record<string, string> = {
    esrisms: "simple-marker",
    sms: "simple-marker",
    simplemarkersymbol: "simple-marker",
    "simple-marker-symbol": "simple-marker",
    esrisimplemarkersymbol: "simple-marker",

    esripms: "picture-marker",
    pms: "picture-marker",
    picturemarkersymbol: "picture-marker",
    "picture-marker-symbol": "picture-marker",

    esrisls: "simple-line",
    sls: "simple-line",
    simplelinesymbol: "simple-line",
    "simple-line-symbol": "simple-line",
    esrisimplelinesymbol: "simple-line",

    esricls: "simple-line",
    cls: "simple-line",
    cartographiclinesymbol: "simple-line",

    esrisfs: "simple-fill",
    sfs: "simple-fill",
    simplefillsymbol: "simple-fill",
    "simple-fill-symbol": "simple-fill",
    esrisimplefillsymbol: "simple-fill",

    esripfs: "picture-fill",
    pfs: "picture-fill",
    picturefillsymbol: "picture-fill",
    "picture-fill-symbol": "picture-fill",

    esrits: "text",
    ts: "text",
    textsymbol: "text",
    "text-symbol": "text",
    esritextsymbol: "text"
  };

  if (typeMap[rawType]) {
    JsonUtils.warnArcGisMigration(
      "normalizePlainSymbol",
      "symbol type",
      symbol.type,
      typeMap[rawType]
    );

    symbol.type = typeMap[rawType];
  }

  if (Array.isArray(symbol.color)) {
    symbol.color = JsonUtils.normalizeColor(symbol.color);
  }

  if (symbol.outline) {
    symbol.outline = JsonUtils.normalizeOutline(symbol.outline);
  }

  return symbol;
}



