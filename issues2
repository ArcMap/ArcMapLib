private isUserEditEnabled(): boolean {
  const el = this as any;

  const propValue =
    el.enableUserEdit ??
    el["enable-user-edit"];

  const attrValue =
    this.getAttribute("enable-user-edit") ??
    this.getAttribute("enableUserEdit");

  return (
    propValue === true ||
    propValue === "true" ||
    attrValue === "" ||
    attrValue === "true" ||
    this.hasAttribute("enable-user-edit")
  );
}