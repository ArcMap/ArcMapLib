private static createTemplateFromObject(
  config: any,
  attributes?: Record<string, any>
): PopupTemplate {
  
  // 👇 NEW: Handle callback-based details
  if (typeof config.details === "function") {
    let title = config.listItem || "Details";
    
    // Resolve ${field} in title using attributes
    if (attributes && typeof title === "string") {
      title = title.replace(/\$\{([^}]+)\}/g, (_, key) => {
        const val = attributes[key.trim()];
        return val !== undefined && val !== null ? String(val) : "";
      });
    }
    
    // Call the details callback
    let htmlContent = "";
    try {
      htmlContent = config.details({ attributes }) ?? "";
    } catch (err) {
      console.warn("[PopupTemplateResolver] details() callback failed", err);
      return null;
    }
    
    return new PopupTemplate({
      title,
      content: [{ type: "text", text: htmlContent }]
    });
  }

  // 👇 EXISTING: Handle title/content object
  const title = this.normalizeTitle(config.title);
  const content = this.normalizeContent(config.content);

  return new PopupTemplate({
    title,
    content,
    fieldInfos: config.fieldInfos || [],
    overwriteActionFilter: config.overwriteActionFilter ?? true,
    actions: config.actions || []
  });
}
