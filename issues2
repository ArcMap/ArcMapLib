private _lastCursor: "default" | "pointer" = "default";

private setMapCursor(cursor: "default" | "pointer"): void {
  if (this._lastCursor === cursor) {
    return;
  }

  this._lastCursor = cursor;

  const container = this.view?.container as HTMLElement | undefined;

  if (!container) {
    return;
  }

  const value = cursor === "pointer" ? "pointer" : "default";

  container.style.setProperty("cursor", value, "important");

  const targets = container.querySelectorAll(
    [
      ".esri-view-root",
      ".esri-view-surface",
      ".esri-view-surface canvas",
      ".esri-view-surface--touch-none",
      "canvas",
      "div"
    ].join(",")
  );

  targets.forEach((el: Element) => {
    (el as HTMLElement).style.setProperty("cursor", value, "important");
  });

  /**
   * ArcGIS sometimes keeps cursor on the event target / canvas.
   * Force it one frame later also.
   */
  requestAnimationFrame(() => {
    container.style.setProperty("cursor", value, "important");

    container.querySelectorAll("canvas, .esri-view-surface").forEach((el: Element) => {
      (el as HTMLElement).style.setProperty("cursor", value, "important");
    });
  });
}