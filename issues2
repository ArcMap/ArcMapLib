private resizePopupToContent(popupEl: any): void {
  try {
    // Only target SPECIFIC outer containers, not all elements
    const walkAndResize = (el: Element | ShadowRoot | null) => {
      if (!el) return;
      
      const root = (el as any).shadowRoot || el;
      
      // ONLY resize the outermost container, NOT inner content
      const outerContainers = [
        'arcgis-feature-content',  // The main content wrapper
        'calcite-flow-item'         // The flow item wrapper
      ];
      
      outerContainers.forEach(selector => {
        root.querySelectorAll?.(selector).forEach((element: HTMLElement) => {
          element.style.setProperty('height', 'auto', 'important');
          element.style.setProperty('min-height', '0', 'important');
          // 👇 DO NOT set flex: 0 0 auto - keeps proper layout
        });
      });
      
      // Recurse into shadow DOM
      root.querySelectorAll?.('*').forEach((child: Element) => {
        if ((child as any).shadowRoot) {
          walkAndResize(child);
        }
      });
    };
    
    walkAndResize(popupEl);
  } catch (err) {
    console.warn("[up-geojson-layer] resizePopupToContent failed", err);
  }
}




