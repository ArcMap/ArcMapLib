private static normalizeContent(
  content?: string | PopupContent[],
  attributes?: Record<string, any>
): PopupContent[] {
  if (!content) {
    // Default: show ALL attributes as fields
    if (attributes) {
      const fieldInfos = Object.keys(attributes).map(key => ({
        fieldName: key,
        label: key
      }));
      return [{ type: "fields", fieldInfos }];
    }
    return [{ type: "text", text: "<p>No details available</p>" }];
  }

  if (typeof content === "string") {
    return [{ type: "text", text: content }];
  }

  if (Array.isArray(content)) {
    return content.map(block => this.validateContentBlock(block));
  }

  return [{ type: "text", text: "<p>No details available</p>" }];
}


