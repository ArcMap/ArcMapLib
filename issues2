const pointerMoveHandle = this.view.on("pointer-move", (evt: any) => {
  if (this._editorOpen || this.inDrawingMode) {
    this.setMapCursor("default");
    return;
  }

  // Use synchronous hitTest with a callback instead of async/await
  this.view.hitTest(evt, { include: [this.featureLayer] }).then((hit: any) => {
    const hasHit = (hit?.results ?? []).some((r: any) => {
      const g = r?.graphic;
      return (
        g &&
        g.geometry &&
        (g.layer === this.featureLayer ||
          (g.layer as any)?.id === this.featureLayer?.id)
      );
    });

    this.setMapCursor(hasHit ? "pointer" : "default");
  }).catch(() => {
    this.setMapCursor("default");
  });
});


private setMapCursor(cursor: "default" | "pointer"): void {
  // ArcGIS renders into a container div; we need to target it directly
  const container = this.view?.container as HTMLElement | undefined;
  if (!container) return;

  const value = cursor === "pointer" ? "pointer" : "default";

  // Set on all possible surfaces ArcGIS uses
  container.style.cursor = value;

  const surface = container.querySelector(
    ".esri-view-surface, .esri-display-object"
  ) as HTMLElement | null;
  if (surface) surface.style.cursor = value;

  const canvas = container.querySelector("canvas") as HTMLElement | null;
  if (canvas) canvas.style.cursor = value;
}
