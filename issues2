// ============================================================================
// REPLACEMENT: fixPopupHeight
// CHANGE: Scope walker STRICTLY to popupEl.shadowRoot subtree — never touches
//         the map view's DOM.
// CHANGE: Match ONLY specific Calcite/ArcGIS internal classes, not generic
//         "content" or "container" (those exist on the map view too and were
//         leaking pointer styles map-wide).
// CHANGE: Wrap traversal in try/catch INSIDE the loop so one bad node
//         doesn't kill the whole fix and silently break popup opening.
// ============================================================================

private fixPopupHeight(popupEl: any): void {
  if (!popupEl) return;

  if (this._popupHeightObserver) {
    this._popupHeightObserver.disconnect();
    this._popupHeightObserver = null;
  }

  // CHANGE: Strict allow-list of class/tag names. NO generic "content" or
  // "container" — those collide with the map view's own DOM classes.
  const TARGET_CLASSES = [
    "content-wrapper",
    "content-container",
    "main-container",
    "popup-content",
    "feature-content",
  ];
  const TARGET_TAGS = [
    "calcite-panel",
    "calcite-shell",
    "calcite-shell-panel",
    "calcite-flow",
    "calcite-flow-item",
  ];

  const applyFix = () => {
    const root = popupEl.shadowRoot;
    if (!root) return;

    // BFS through ONLY the popup's own shadow tree
    const queue: (Element | ShadowRoot)[] = [root];
    let safetyCounter = 0;

    while (queue.length > 0 && safetyCounter < 500) {
      safetyCounter++;
      const node = queue.shift()!;

      let children: NodeListOf<Element>;
      try {
        children = (node as ParentNode).querySelectorAll(":scope > *");
      } catch {
        continue;
      }

      children.forEach((el) => {
        try {
          const htmlEl = el as HTMLElement;
          const tag = el.tagName.toLowerCase();
          const cls = (el.getAttribute("class") || "").toLowerCase();

          const classMatch = TARGET_CLASSES.some((c) => cls.includes(c));
          const tagMatch = TARGET_TAGS.includes(tag);

          if (classMatch || tagMatch) {
            htmlEl.style.setProperty("block-size", "auto", "important");
            htmlEl.style.setProperty("height", "auto", "important");
            htmlEl.style.setProperty("min-height", "0", "important");
            htmlEl.style.setProperty("max-height", "none", "important");
            htmlEl.style.setProperty("flex", "0 0 auto", "important");
          }

          // Recurse into children (light DOM)
          if (el.children.length > 0) {
            queue.push(el);
          }
          // Recurse into shadow DOM (Calcite components nest shadow roots)
          const sr = (el as any).shadowRoot as ShadowRoot | null;
          if (sr) {
            queue.push(sr);
          }
        } catch {
          // skip this node, continue with siblings
        }
      });
    }
  };

  // Run multiple times to catch each render stage
  try { applyFix(); } catch {}
  requestAnimationFrame(() => {
    try { applyFix(); } catch {}
    setTimeout(() => { try { applyFix(); } catch {} }, 50);
    setTimeout(() => { try { applyFix(); } catch {} }, 200);
    setTimeout(() => { try { applyFix(); } catch {} }, 500);
  });

  // Observer — also scoped strictly to popup shadow root
  try {
    if (popupEl.shadowRoot) {
      this._popupHeightObserver = new MutationObserver(() => {
        try { applyFix(); } catch {}
      });
      this._popupHeightObserver.observe(popupEl.shadowRoot, {
        childList: true,
        subtree: true,
        attributes: true,
        attributeFilter: ["style", "class"],
      });
    }
  } catch {
    // observer setup failed — fix still applies via timeouts
  }
}



this.view.on("pointer-move", (evt) => {
  this.view.hitTest(evt).then((response) => {
    const hit = response.results.find(
      (r: any) => r.graphic?.layer === this.featureLayer
    );
    this.view.container.style.cursor = hit ? "pointer" : "default";
  });
});
