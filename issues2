// ✅ Carry over OBJECTID from existing graphic — same as Stencil
const existingGraphic = this.featureLayer?.graphics?.find(
  (g: Graphic) =>
    String(g.attributes?.[this.uniqueIdPropertyName]) === String(updateId) ||
    String(g.attributes?.OBJECTID) === String(updateId) ||
    String(g.attributes?.id) === String(updateId)
);

if (existingGraphic) {
  graphicToUpdate.attributes.OBJECTID = existingGraphic.attributes.OBJECTID;
}

// ✅ Build normalizedFeature AFTER setting OBJECTID
const normalizedProperties = {
  ...(convertedFeature.properties ?? {}),
  ...(isCircle
    ? {
        drawGeometryType: 'circle',
        shapeType: 'circle',
        shape: 'circle',
        isCircle: true,
      }
    : {
        drawGeometryType: 'polygon',
        shapeType: 'polygon',
        shape: 'polygon',
        isCircle: false,
      }),
  ...(existingGraphic
    ? { OBJECTID: existingGraphic.attributes.OBJECTID }
    : {}),
};
