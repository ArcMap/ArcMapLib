<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>GeoJSON Layer Edit Test</title>

  <link
    rel="stylesheet"
    href="https://js.arcgis.com/4.29/esri/themes/light/main.css"
  />

  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: sans-serif;
      display: flex;
      flex-direction: column;
      height: 100vh;
    }

    #toolbar {
      display: flex;
      gap: 8px;
      padding: 10px;
      background: #1a1a2e;
      flex-wrap: wrap;
      align-items: center;
    }

    #toolbar button {
      padding: 8px 14px;
      border: none;
      border-radius: 4px;
      cursor: pointer;
      font-size: 13px;
      font-weight: 600;
      color: white;
    }

    #btn-load       { background: #0078d4; }
    #btn-toggle-edit { background: #107c10; }
    #btn-save       { background: #d83b01; }
    #btn-cancel     { background: #605e5c; }
    #btn-clear      { background: #8e192e; }
    #btn-draw-polygon { background: #5c2d91; }
    #btn-draw-circle  { background: #004b50; }
    #btn-cancel-draw  { background: #605e5c; }

    #toolbar button:disabled {
      opacity: 0.4;
      cursor: not-allowed;
    }

    #status {
      padding: 6px 12px;
      background: #000;
      color: #0f0;
      font-size: 12px;
      font-family: monospace;
      min-height: 28px;
    }

    #map-container {
      flex: 1;
      position: relative;
    }

    p-map, arc-map {
      display: block;
      width: 100%;
      height: 100%;
    }

    arc-geojson-layer {
      display: none;
    }

    #geojson-output {
      position: absolute;
      bottom: 10px;
      left: 10px;
      right: 10px;
      max-height: 150px;
      overflow-y: auto;
      background: rgba(0,0,0,0.8);
      color: #0f0;
      font-family: monospace;
      font-size: 11px;
      padding: 8px;
      border-radius: 4px;
      display: none;
      z-index: 10;
    }
  </style>
</head>
<body>

<div id="toolbar">
  <button id="btn-load">Load Polygon</button>
  <button id="btn-draw-polygon">Draw Polygon</button>
  <button id="btn-draw-circle">Draw Circle</button>
  <button id="btn-cancel-draw" disabled>Cancel Draw</button>
  <button id="btn-toggle-edit" id="btn-toggle-edit">Toggle Edit</button>
  <button id="btn-save" disabled>Save Edit</button>
  <button id="btn-cancel" disabled>Cancel Edit</button>
  <button id="btn-clear">Clear Layer</button>
  <button id="btn-show-geojson">Show GeoJSON</button>
</div>

<div id="status">Ready — use controls above to test</div>

<div id="map-container">

  <!-- Your existing map element -->
  <-map
    id="main-map"
    zoom="5"
    center="-96, 39"
  >
    <!-- Polygon layer -->
    <arc-geojson-layer
      id="polygonLayer"
      name="Polygon Layer"
      unique-id-property-name="id"
    ></arc-geojson-layer>

    <!-- Circle layer -->
    <arc-geojson-layer
      id="circleLayer"
      name="Circle Layer"
      unique-id-property-name="id"
    ></arc-geojson-layer>

  </-map>

  <div id="geojson-output"></div>
</div>

<script type="module">
  // ── Test GeoJSON data ──────────────────────────────────────────────────

  const TEST_POLYGON_GEOJSON = {
    type: 'FeatureCollection',
    features: [
      {
        type: 'Feature',
        id: 1,
        geometry: {
          type: 'Polygon',
          coordinates: [[
            [-96.7, 40.8],
            [-90.2, 40.8],
            [-90.2, 36.5],
            [-96.7, 36.5],
            [-96.7, 40.8],
          ]],
        },
        properties: {
          id: 1,
          name: 'Test Polygon 1',
          type: 'Polygon',
          notes: 'This is a test polygon',
        },
      },
      {
        type: 'Feature',
        id: 2,
        geometry: {
          type: 'Polygon',
          coordinates: [[
            [-80.5, 42.5],
            [-75.0, 42.5],
            [-75.0, 38.0],
            [-80.5, 38.0],
            [-80.5, 42.5],
          ]],
        },
        properties: {
          id: 2,
          name: 'Test Polygon 2',
          type: 'Polygon',
          notes: 'Second test polygon',
        },
      },
    ],
  };

  const TEST_CIRCLE_GEOJSON = {
    type: 'FeatureCollection',
    features: [
      {
        type: 'Feature',
        id: 3,
        geometry: {
          type: 'Polygon',
          // Approximated circle coordinates
          coordinates: [[
            [-100.0, 38.5], [-99.8, 39.0], [-99.3, 39.3],
            [-98.7, 39.3], [-98.2, 39.0], [-98.0, 38.5],
            [-98.2, 38.0], [-98.7, 37.7], [-99.3, 37.7],
            [-99.8, 38.0], [-100.0, 38.5],
          ]],
        },
        properties: {
          id: 3,
          name: 'Test Circle 1',
          isCircle: true,
          drawGeometryType: 'circle',
          shapeType: 'circle',
          shape: 'circle',
        },
      },
    ],
  };

  // ── State ──────────────────────────────────────────────────────────────

  let polygonLayer = null;
  let circleLayer  = null;
  let activeLayer  = null;
  let editEnabled  = false;
  let isDrawing    = false;

  // ── Helpers ────────────────────────────────────────────────────────────

  function log(msg) {
    const el = document.getElementById('status');
    el.textContent = `[${new Date().toLocaleTimeString()}] ${msg}`;
    console.log('[Test]', msg);
  }

  function setButtonStates() {
    document.getElementById('btn-save').disabled       = !editEnabled;
    document.getElementById('btn-cancel').disabled     = !editEnabled;
    document.getElementById('btn-cancel-draw').disabled = !isDrawing;
    document.getElementById('btn-toggle-edit').textContent =
      editEnabled ? 'Disable Edit' : 'Toggle Edit';
    document.getElementById('btn-toggle-edit').style.background =
      editEnabled ? '#107c10' : '#5c2d91';
  }

  // ── Init ───────────────────────────────────────────────────────────────

  window.addEventListener('DOMContentLoaded', () => {
    // Wait for map to be ready
    const mapEl = document.getElementById('main-map');

    const waitForMap = setInterval(() => {
      polygonLayer = document.getElementById('polygonLayer');
      circleLayer  = document.getElementById('circleLayer');

      if (polygonLayer && circleLayer) {
        clearInterval(waitForMap);
        initLayers();
      }
    }, 500);
  });

  function initLayers() {
    log('All layers loaded on startup');

    // ── Layer event listeners ──────────────────────────────────────────

    // Polygon layer events
    polygonLayer.addEventListener('userDrawItemAdded', (e) => {
      log(`Draw complete — pointlayer — "${e.detail?.feature?.geometry?.type}"`);
      isDrawing = false;
      setButtonStates();
    });

    polygonLayer.addEventListener('userEditItemUpdated', (e) => {
      log(`Edit saved — polygonLayer — objectId: ${e.detail?.objectId}`);
      console.log('[userEditItemUpdated]', e.detail);
    });

    polygonLayer.addEventListener('layerClick', (e) => {
      log(`Clicked — polygonLayer — attrs: ${JSON.stringify(e.detail?.attributes)}`);
    });

    // Circle layer events
    circleLayer.addEventListener('userDrawItemAdded', (e) => {
      log(`Draw complete — circleLayer — "${e.detail?.feature?.geometry?.type}"`);
      isDrawing = false;
      setButtonStates();
    });

    circleLayer.addEventListener('userEditItemUpdated', (e) => {
      log(`Edit saved — circleLayer — objectId: ${e.detail?.objectId}`);
    });

    circleLayer.addEventListener('layerClick', (e) => {
      log(`Clicked — circleLayer — attrs: ${JSON.stringify(e.detail?.attributes)}`);
    });

    setButtonStates();
  }

  // ── Button handlers ────────────────────────────────────────────────────

  // Load Polygon
  document.getElementById('btn-load').addEventListener('click', () => {
    if (!polygonLayer) return;
    polygonLayer.geojson = TEST_POLYGON_GEOJSON;
    activeLayer = polygonLayer;
    log(`Loaded ${TEST_POLYGON_GEOJSON.features.length} polygons`);
  });

  // Draw Polygon
  document.getElementById('btn-draw-polygon').addEventListener('click', () => {
    if (!polygonLayer) return;
    activeLayer = polygonLayer;
    polygonLayer.enableUserEdit = true;
    polygonLayer.startDrawing('polygon');
    isDrawing = true;
    log('Drawing polygon on polygonLayer...');
    setButtonStates();
  });

  // Draw Circle
  document.getElementById('btn-draw-circle').addEventListener('click', () => {
    if (!circleLayer) return;

    // Load existing circle data first
    circleLayer.geojson = TEST_CIRCLE_GEOJSON;
    activeLayer = circleLayer;
    circleLayer.enableUserEdit = true;
    circleLayer.startDrawing('circle');
    isDrawing = true;
    log('Drawing circle on circleLayer...');
    setButtonStates();
  });

  // Cancel Draw
  document.getElementById('btn-cancel-draw').addEventListener('click', () => {
    if (!activeLayer) return;
    activeLayer.cancelDrawing();
    isDrawing = false;
    log('Drawing cancelled');
    setButtonStates();
  });

  // Toggle Edit
  document.getElementById('btn-toggle-edit').addEventListener('click', () => {
    if (!activeLayer) {
      activeLayer = polygonLayer;
    }
    editEnabled = !editEnabled;
    activeLayer.enableUserEdit = editEnabled;
    log(`Edit mode: ${editEnabled ? 'ON' : 'OFF'} on ${activeLayer.id}`);
    setButtonStates();
  });

  // Save Edit
  document.getElementById('btn-save').addEventListener('click', () => {
    if (!activeLayer) return;

    if (activeLayer.isEditorOpen && activeLayer.isEditorOpen()) {
      activeLayer.closeEditor();
      log('Editor closed — changes saved');
    } else {
      log('No active editor to save');
    }

    editEnabled = false;
    if (activeLayer) activeLayer.enableUserEdit = false;
    setButtonStates();
  });

  // Cancel Edit
  document.getElementById('btn-cancel').addEventListener('click', () => {
    if (!activeLayer) return;

    if (activeLayer.cancelEdit) {
      activeLayer.cancelEdit();
    } else if (activeLayer.cancelDrawing) {
      activeLayer.cancelDrawing();
    }

    editEnabled = false;
    if (activeLayer) activeLayer.enableUserEdit = false;
    log('Edit cancelled');
    setButtonStates();
  });

  // Clear Layer
  document.getElementById('btn-clear').addEventListener('click', () => {
    if (polygonLayer) polygonLayer.geojson = null;
    if (circleLayer)  circleLayer.geojson  = null;
    activeLayer  = null;
    editEnabled  = false;
    isDrawing    = false;
    log('All layers cleared');
    setButtonStates();
  });

  // Show GeoJSON
  document.getElementById('btn-show-geojson').addEventListener('click', () => {
    const output = document.getElementById('geojson-output');

    if (output.style.display === 'block') {
      output.style.display = 'none';
      return;
    }

    const polyJson  = polygonLayer?.geojson ?? null;
    const circJson  = circleLayer?.geojson  ?? null;

    output.style.display = 'block';
    output.textContent = JSON.stringify(
      { polygonLayer: polyJson, circleLayer: circJson },
      null,
      2
    );
  });
</script>

</body>
</html>
