private clearAllHighlights(): void {
  try {
    if (!this.view) return;
    
    // Clear all layer view highlights
    this.view.allLayerViews?.forEach((layerView: any) => {
      if (layerView.highlight && typeof layerView.highlight === 'function') {
        // Some layer views have highlight as a method
      }
      // Remove highlight property
      if (layerView._highlightIds) {
        layerView._highlightIds.clear?.();
      }
    });
    
    // Clear popup features (clears blue selection)
    if (this.view.popup) {
      (this.view.popup as any).features = [];
    }
  } catch (err) {
    console.warn("[up-geojson-layer] clearAllHighlights failed", err);
  }
}
