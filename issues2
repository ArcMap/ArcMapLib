private closePopup(): void {
  try {
    const popup: any = this.view?.popup;

    if (popup) {
      popup.features = [];
      popup.content = null;
      popup.title = "";
      popup.location = null;
      popup.open = false;
      popup.visible = false;
    }

    this.clearPopupHighlight();

    this._popupGraphic = null;
    this._popupOpen = false;
    this._suppressPopupUntil = Date.now() + 150;

    this.setViewCursor("default");
  } catch (error) {
    console.warn("[geojson-layer] closePopup failed", error);
    this.setViewCursor("default");
  }
}


private clearPopupHighlight(): void {
  try {
    this._popupHighlightHandle?.remove?.();
  } catch {}

  this._popupHighlightHandle = null;

  try {
    const popup: any = this.view?.popup;

    if (popup) {
      popup.features = [];
      popup.content = null;
      popup.title = "";
      popup.location = null;
      popup.open = false;
      popup.visible = false;
    }
  } catch {}
}


private setupPopupCloseWatcher(): void {
  try {
    this._popupVisibleWatchHandle?.remove?.();
  } catch {}

  this._popupVisibleWatchHandle = null;

  const popup: any = this.view?.popup;

  if (!popup || typeof popup.watch !== "function") {
    return;
  }

  this._popupVisibleWatchHandle = popup.watch("visible", (visible: boolean) => {
    if (!visible) {
      this._popupGraphic = null;
      this._popupOpen = false;
      this.clearPopupHighlight();
      this.setViewCursor("default");

      // Small delay prevents stuck pointer after ArcGIS popup close animation.
      window.setTimeout(() => {
        if (!this._editorOpen && !this.inDrawingMode) {
          this.setViewCursor("default");
        }
      }, 100);
    }
  });
}




