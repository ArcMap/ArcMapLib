static updateRenderer(
  newRenderer: any,
  featureLayer: FeatureLayer | GeoJSONLayer,
  rendererTypeToModule: any,
  symbolJson: any
) {
  if (newRenderer) {
    const rendererParseResult = JsonUtils.getJsonFor(newRenderer);

    if (rendererParseResult.error) {
      console.warn(
        "Could not parse new value for renderer, staying on the previous value",
        rendererParseResult.error
      );
      return;
    }

    const parsedRendererConfig = rendererParseResult.parsedJson;

    parsedRendererConfig.type = JsonUtils.toCanonicalArcGisRendererType(
      parsedRendererConfig.type
    );

    if (parsedRendererConfig.defaultSymbol) {
      parsedRendererConfig.defaultSymbol = JsonUtils.toCanonicalArcGisSymbol(
        parsedRendererConfig.defaultSymbol,
        featureLayer.geometryType
      );
    }

    if (Array.isArray(parsedRendererConfig.uniqueValueInfos)) {
      parsedRendererConfig.uniqueValueInfos =
        parsedRendererConfig.uniqueValueInfos.map((uniqueValueInfo: any) => {
          return {
            ...uniqueValueInfo,
            symbol: JsonUtils.toCanonicalArcGisSymbol(
              uniqueValueInfo.symbol,
              featureLayer.geometryType
            )
          };
        });
    }

    if (Array.isArray(parsedRendererConfig.classBreakInfos)) {
      parsedRendererConfig.classBreakInfos =
        parsedRendererConfig.classBreakInfos.map((classBreakInfo: any) => {
          return {
            ...classBreakInfo,
            symbol: JsonUtils.toCanonicalArcGisSymbol(
              classBreakInfo.symbol,
              featureLayer.geometryType
            )
          };
        });
    }

    const rendererModuleName = rendererTypeToModule[parsedRendererConfig.type];

    if (rendererModuleName === undefined) {
      console.error(
        "Unrecognized renderer type",
        parsedRendererConfig.type,
        "Must be one of",
        Object.keys(rendererTypeToModule)
      );
      return;
    }

    let rendererInstance;

    if (parsedRendererConfig.type === "simple") {
      rendererInstance = new SimpleRenderer(parsedRendererConfig);
    } else if (parsedRendererConfig.type === "unique-value") {
      rendererInstance = new UniqueValueRenderer(parsedRendererConfig);
    } else if (parsedRendererConfig.type === "class-breaks") {
      rendererInstance = new ClassBreaksRenderer(parsedRendererConfig);
    } else {
      console.error("Unrecognized renderer type", parsedRendererConfig.type);
      return;
    }

    featureLayer.renderer = rendererInstance;
  } else {
    const renderer = new SimpleRenderer(symbolJson);
    featureLayer.renderer = renderer;
  }
}



static toCanonicalArcGisRendererType(rendererType: string): string {
  if (!rendererType) {
    return "simple";
  }

  const normalizedType = String(rendererType).trim();

  switch (normalizedType) {
    case "simple":
    case "SimpleRenderer":
    case "esri.renderers.SimpleRenderer":
      return "simple";

    case "uniqueValue":
    case "unique-value":
    case "UniqueValueRenderer":
    case "esri.renderers.UniqueValueRenderer":
      return "unique-value";

    case "classBreaks":
    case "class-breaks":
    case "ClassBreaksRenderer":
    case "esri.renderers.ClassBreaksRenderer":
      return "class-breaks";

    default:
      console.warn(
        "Unrecognized renderer type",
        rendererType,
        "Must be one of simple, unique-value, class-breaks"
      );
      return normalizedType;
  }
}
