this.cleanupViewEvents();
let clickTimer: any = null;

const clickHandle = this.view.on('click', async (evt: any) => {
  if (clickTimer) {
    clearTimeout(clickTimer);
    clickTimer = null;
    return;
  }

  const graphic = await this.getHitGraphic(evt);
  if (!graphic) {
    return;
  }

  // ✅ Always emit layerClick immediately
  this.emitLayerEvent(
    'layerClick',
    this.graphicToGeoJsonFeature(graphic),
    graphic,
    {
      event: {
        coordinates: {
          latitude: evt.mapPoint?.latitude ?? 0,
          longitude: evt.mapPoint?.longitude ?? 0,
        },
        attributes: graphic.attributes ?? {},
      },
    }
  );

  clickTimer = setTimeout(async () => {
    clickTimer = null;

    // If editor is open or drawing — close popup and bail
    if (
      this._editorOpen ||
      this.inDrawingMode ||
      this._isStartingDraw ||
      this._shouldSuppressPopup()
    ) {
      try {
        this.view?.popup?.close();
      } catch {}
      return;
    }

    // ✅ Only show popup when edit is NOT enabled
    if (!this.enableUserEdit) {
      this.showGraphicPopup(graphic, evt.mapPoint);
    } else {
      // Edit is enabled — close any stale popup
      try {
        this.view?.popup?.close();
      } catch {}
    }

  }, 280);
});
