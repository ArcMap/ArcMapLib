private async getHitGraphic(evt: any): Promise<Graphic | null> {
  if (!this.view || !this.featureLayer) {
    return null;
  }

  try {
    const hit = await this.view.hitTest(evt);

    if (!hit?.results?.length) {
      return null;
    }

    console.log("[arc-geojson-layer] raw hit results", hit.results);

    const matchingResult = hit.results.find((result: any) => {
      const graphic = result?.graphic;

      if (!graphic) {
        return false;
      }

      const layer = graphic.layer as any;

      const isMatch =
        layer === this.featureLayer ||
        layer?.id === this.featureLayer?.id ||
        layer?.id === `${this.featureLayer.id}-graphics`;

      if (isMatch) {
        console.log("[arc-geojson-layer] matched graphic", {
          featureLayerId: this.featureLayer?.id,
          graphicLayerId: layer?.id,
          geometryType: graphic.geometry?.type,
          attributes: graphic.attributes,
        });
      }

      return isMatch;
    });

    return matchingResult?.graphic ?? null;
  } catch (error) {
    console.error("[arc-geojson-layer] getHitGraphic failed", error);
    return null;
  }
}


