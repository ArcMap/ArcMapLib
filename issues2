private hasOwnInfoTemplate(): boolean {
  return PopupUtils.hasValidInfoTemplate(this.infoTemplate);
}

const feature = new FeatureLayer({
  url: this.url,
  id: this.id || this.generatedElementId,
  title: this.name,
  popupEnabled: false,
  popupTemplate: undefined,
});

this.featureLayer = feature;

this.updateInfoTemplate(this.infoTemplate);



private updateInfoTemplate(newInfoTemplate: any): void {
  this.infoTemplate = newInfoTemplate;

  if (!this.featureLayer) return;

  if (!this.hasOwnInfoTemplate()) {
    this.featureLayer.popupEnabled = false;
    (this.featureLayer as any).popupTemplate = undefined;
    this.view?.popup?.close();
    return;
  }

  this.featureLayer.popupEnabled = true;

  PopupUtils.updatePopup(
    this.infoTemplate,
    this.ancestorMap,
    this.featureLayer,
  );
}


if (!this.hasOwnInfoTemplate()) {
  this.featureLayer.popupEnabled = false;
  (this.featureLayer as any).popupTemplate = undefined;
  this.view?.popup?.close();
  return;
}