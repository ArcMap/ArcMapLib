private createHtmlPopupTemplate(
  title: string,
  htmlContent: string
): PopupTemplate {

  return new PopupTemplate({
    title: title ?? "",
    outFields: ["*"],

    content: () => {
      const container = document.createElement("div");

      container.className = "arc-popup-wrapper";

      container.style.width = "100%";
      container.style.height = "auto";
      container.style.background = "white";
      container.style.padding = "0";
      container.style.margin = "0";
      container.style.overflow = "auto";

      // IMPORTANT
      // Angular sends raw HTML
      container.innerHTML = htmlContent || "";

      console.log(
        "[arc-geojson-layer] popup content attached"
      );

      return container;
    }
  });
}



private async showGraphicPopup(
    graphic: Graphic,
    mapPoint?: Point
): Promise<void> {

    if (
        !this.view ||
        !graphic ||
        !graphic.geometry ||
        this.enableUserEdit ||
        this._editorOpen ||
        this._inDrawingMode ||
        this.shouldSuppressPopup()
    ) {
        return;
    }

    try {

        const popupTemplate =
            this.buildPopupTemplateForCurrent(graphic);

        if (!popupTemplate) {
            return;
        }

        // IMPORTANT:
        // DON'T clone graphic
        // ArcGIS loses popup associations

        graphic.popupTemplate = popupTemplate;

        const popupLocation =
            mapPoint ??
            UpGeojsonLayer.getPopupPoint(
                graphic.geometry
            );

        if (!popupLocation) {
            return;
        }

        await this.view.openPopup({
            location: popupLocation,
            features: [graphic]
        });

        console.log(
            "[arc-geojson-layer] popup shown"
        );

    } catch (e) {

        console.error(
            "[arc-geojson-layer] popup failed",
            e
        );
    }
}


if (graphic) {
    this.setMapCursor("pointer");
} else {
    this.setMapCursor("default");
}