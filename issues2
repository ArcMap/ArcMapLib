private async getHitGraphic(evt: any): Promise<Graphic | null> {
  if (!this.view || !this.featureLayer) {
    return null;
  }

  try {
    const hit = await this.view.hitTest(evt);

    const graphicResults = (hit?.results ?? []).filter((r: any) => {
      const g = r?.graphic;
      return g?.geometry && g?.layer;
    });

    if (!graphicResults.length) {
      return null;
    }

    // Top-most graphic clicked on the map.
    const topGraphic = graphicResults[0].graphic as Graphic;

    // IMPORTANT:
    // If the top-most clicked graphic is from another GeoJSON layer,
    // this layer must not open popup.
    const topLayer: any = topGraphic.layer;
    const thisLayer: any = this.featureLayer;

    if (topLayer !== thisLayer && topLayer?.id !== thisLayer?.id) {
      return null;
    }

    return topGraphic;
  } catch (error) {
    console.warn("[geojson-layer] hitTest failed", error);
    return null;
  }
}