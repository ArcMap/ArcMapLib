if (popupEl) {
  popupEl.location = location;
  popupEl.features = [graphic];
  popupEl.open = true;
  
  // 👇 ADD THIS: Force popup container to fit content
  setTimeout(() => {
    this.resizePopupToContent(popupEl);
  }, 300);
}


private resizePopupToContent(popupEl: any): void {
  try {
    // Walk through Shadow DOM and resize containers
    const walkAndResize = (el: Element | ShadowRoot | null) => {
      if (!el) return;
      
      // Get shadow root if it's an element
      const root = (el as any).shadowRoot || el;
      
      // Find and fix all containers
      const selectors = [
        '.container',
        '.content-container', 
        '.content-element',
        '.content-feature',
        '.main',
        '.root',
        'calcite-flow-item',
        'arcgis-feature',
        'arcgis-feature-content'
      ];
      
      selectors.forEach(selector => {
        root.querySelectorAll?.(selector).forEach((element: HTMLElement) => {
          element.style.setProperty('flex', '0 0 auto', 'important');
          element.style.setProperty('height', 'auto', 'important');
          element.style.setProperty('min-height', '0', 'important');
          element.style.setProperty('max-height', 'none', 'important');
        });
      });
      
      // Recurse into all children's shadow roots
      root.querySelectorAll?.('*').forEach((child: Element) => {
        if ((child as any).shadowRoot) {
          walkAndResize(child);
        }
      });
    };
    
    walkAndResize(popupEl);
  } catch (err) {
    console.warn("[up-geojson-layer] resizePopupToContent failed", err);
  }
}
