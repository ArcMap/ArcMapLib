SECTION 16 — FULL BACKWARD COMPATIBLE EXAMPLE
--------------------------------------------------------------------------------

Consumer code:

element.renderer={

   type:"uniqueValue",

   field1:"SBDV_NAME",

   defaultSymbol:{

      type:"esriSLS",
      style:"esriSLSShortDot",
      color:[0,0,0,255]

   },

   uniqueValueInfos:[

      {

         value:"OREGON EASTERN (OCE)",

         symbol:{

            type:"esriSLS",
            style:"esriSLSSolid",
            color:[0,255,0,255]

         }

      },

      {

         value:"HUNTINGTON SUB",

         symbol:{

            type:"esriSLS",
            style:"esriSLSShortDash",
            color:[0,0,255,255]

         }

      }
   ]
}

Internally normalized to:

{

   type:"unique-value",

   field:"SBDV_NAME",

   defaultSymbol:{

      type:"simple-line",
      style:"short-dot"

   },

   uniqueValueInfos:[

      {

         symbol:{

            type:"simple-line",
            style:"solid"

         }

      },

      {

         symbol:{

            type:"simple-line",
            style:"short-dash"

         }

      }

   ]
}

