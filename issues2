const buildFieldsFromHtml = (htmlTemplate: string): any[] => {
  const resolvedHtml = replaceTokens(htmlTemplate);

  console.log(
    "[geojson-layer] parsing html",
    resolvedHtml
  );

  const wrapper = document.createElement("div");
  wrapper.innerHTML = resolvedHtml;

  const fieldInfos: any[] = [];
  const seen = new Set<string>();

  const rows = Array.from(
    wrapper.querySelectorAll("div,li,p,.info-template-data")
  );

  rows.forEach((row: Element) => {
    const text = (
      row.textContent ??
      ""
    )
      .replace(/\s+/g, " ")
      .trim();

    if (!text) {
      return;
    }

    let label = "";
    let value = "";

    // Support:
    // Name: Test Polygon
    if (text.includes(":")) {
      const parts = text.split(":");

      label = parts[0]?.trim();
      value = parts
        .slice(1)
        .join(":")
        .trim();
    }

    // Support:
    // label/value format
    if (!label) {
      const lbl = row.querySelector(
        ".info-template-label"
      );

      const val = row.querySelector(
        ".info-template-value"
      );

      label = lbl?.textContent?.trim() ?? "";
      value = val?.textContent?.trim() ?? "";
    }

    if (!label || !value) {
      return;
    }

    const duplicateKey = `${label}-${value}`;

    if (seen.has(duplicateKey)) {
      return;
    }

    seen.add(duplicateKey);

    const fieldName =
      `popup_field_${fieldInfos.length}`;

    attributes[fieldName] = value;

    fieldInfos.push({
      fieldName,
      label,
      visible: true,
    });
  });

  console.log(
    "[geojson-layer] generated fields",
    fieldInfos
  );

  return fieldInfos;
};