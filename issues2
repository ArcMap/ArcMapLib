private static getPopupPoint(geometry: Geometry | null | undefined): Point | null {
  if (!geometry) {
    return null;
  }

  if (geometry.type === 'point') {
    return geometry as Point;
  }

  if (geometry.type === 'polyline') {
    const polyline = geometry as Polyline;
    const paths = polyline.paths;
    if (paths && paths.length > 0 && paths[0].length > 0) {
      const midIndex = Math.floor(paths[0].length / 2);
      const midPoint = paths[0][midIndex];
      return new Point({
        x: midPoint[0],
        y: midPoint[1],
        spatialReference: polyline.spatialReference,
      });
    }
  }

  if (geometry.type === 'polygon') {
    return (geometry as Polygon).centroid;
  }

  return null;
}


async openPopup(id: string | number): Promise<void> {
  const graphicMatch: Graphic | undefined = await this.findFeatureByUniqueId(id);

  if (graphicMatch === undefined) {
    console.warn(
      'No feature found with a',
      this.uniqueIdPropertyName,
      'value of',
      id,
      '. Cannot open popup.'
    );
    return;
  }

  const popupPoint = graphicMatch.geometry
    ? UpGeojsonLayer.getPopupPoint(graphicMatch.geometry)
    : null;

  this.view?.popup?.open({
    features: [graphicMatch],
    location: popupPoint ?? undefined,
  });
}
