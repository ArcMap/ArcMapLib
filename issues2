private resizePopupToContent(popupEl: any): void {
  try {
    const MAX_POPUP_HEIGHT = 400; // Max height in pixels
    
    const walkAndFix = (el: Element | ShadowRoot | null) => {
      if (!el) return;
      
      const root = (el as any).shadowRoot || el;
      
      // Step 1: Make ALL outer containers fit content (no min-height)
      const containersToFit = [
        'arcgis-feature',
        'arcgis-feature-content',
        'calcite-flow-item',
        '.content-feature',
        '.content-element',
        '.content-container'
      ];
      
      containersToFit.forEach(selector => {
        root.querySelectorAll?.(selector).forEach((element: HTMLElement) => {
          element.style.setProperty('height', 'auto', 'important');
          element.style.setProperty('min-height', '0', 'important');
          element.style.setProperty('max-height', `${MAX_POPUP_HEIGHT}px`, 'important');
          element.style.setProperty('flex', '0 1 auto', 'important');
        });
      });
      
      // Step 2: Make INNER content containers scrollable when needed
      const scrollContainers = [
        '.container',
        '.main',
        '.root'
      ];
      
      scrollContainers.forEach(selector => {
        root.querySelectorAll?.(selector).forEach((element: HTMLElement) => {
          element.style.setProperty('height', 'auto', 'important');
          element.style.setProperty('min-height', '0', 'important');
          element.style.setProperty('max-height', `${MAX_POPUP_HEIGHT}px`, 'important');
          element.style.setProperty('overflow-y', 'auto', 'important');
          element.style.setProperty('flex', '0 1 auto', 'important');
        });
      });
      
      // Step 3: Recurse into shadow DOM children
      root.querySelectorAll?.('*').forEach((child: Element) => {
        if ((child as any).shadowRoot) {
          walkAndFix(child);
        }
      });
    };
    
    walkAndFix(popupEl);
  } catch (err) {
    console.warn("[up-geojson-layer] resizePopupToContent failed", err);
  }
}
