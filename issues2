private updateLabelJson(
  newLabelJsonArg: string | object | object[] | undefined
): void {
  if (!this.featureLayer) {
    return;
  }

  if (!newLabelJsonArg) {
    this.featureLayer.labelingInfo = [];
    return;
  }

  const labelClasses = JsonUtils.getLabelJson(newLabelJsonArg);

  if (!labelClasses || labelClasses.length === 0) {
    console.warn("-feature-layer] No valid label classes generated");
    this.featureLayer.labelingInfo = [];
    return;
  }

  this.featureLayer.labelingInfo = labelClasses;
}