private buildPopupTemplateFromCurrent(
  graphic: Graphic
): PopupTemplate | null {
  if (!graphic || !this.infoTemplate) {
    return null;
  }

  const attributes = graphic.attributes ?? {};

  // Only use fields provided by user in infoTemplate
  const configuredFields =
    this.infoTemplate?.fieldInfos ??
    this.infoTemplate?.fields ??
    this.infoTemplate?.content?.fieldInfos ??
    [];

  if (!Array.isArray(configuredFields) || configuredFields.length === 0) {
    return null;
  }

  const fieldInfos = configuredFields
    .map((field: any) => {
      const fieldName =
        field.fieldName ??
        field.name ??
        field.key;

      if (!fieldName || attributes[fieldName] === undefined || attributes[fieldName] === null) {
        return null;
      }

      return {
        fieldName,
        label: field.label ?? field.title ?? fieldName,
        visible: field.visible !== false,
      };
    })
    .filter(Boolean);

  if (fieldInfos.length === 0) {
    return null;
  }

  const title =
    this.infoTemplate?.title ??
    this.infoTemplate?.listTitle ??
    this.name ??
    "Details";

  return new PopupTemplate({
    title,
    content: [
      {
        type: "fields",
        fieldInfos,
      },
    ],
  });
}