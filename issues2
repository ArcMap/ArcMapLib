private buildPopupTemplateFromCurrent(
  graphic: Graphic
): PopupTemplate | null {
  console.log("[geojson-layer] buildPopupTemplateFromCurrent called", {
    graphic,
    infoTemplate: this.infoTemplate,
    attributes: graphic?.attributes,
  });

  if (!graphic || !this.infoTemplate) {
    console.warn("[geojson-layer] popup skipped: missing graphic or infoTemplate");
    return null;
  }

  const attributes = graphic.attributes ?? {};

  const replaceTokens = (value: string): string => {
    return value.replace(/\$\{([^}]+)\}/g, (_match: string, key: string) => {
      const attributeValue = attributes[key.trim()];
      return attributeValue === undefined || attributeValue === null
        ? ""
        : String(attributeValue);
    });
  };

  const resolveTitle = (): string => {
    const rawTitle =
      this.infoTemplate?.title ??
      this.infoTemplate?.listTitle ??
      this.infoTemplate?.listItem ??
      this.name ??
      "Details";

    return typeof rawTitle === "string"
      ? replaceTokens(rawTitle)
      : String(rawTitle);
  };

  try {
    let content: any = null;

    // Angular current format:
    // { listItem: 'Details', details: '<ul>...</ul>' }
    if (typeof this.infoTemplate?.details === "string") {
      console.log("[geojson-layer] popup using infoTemplate.details string");
      content = replaceTokens(this.infoTemplate.details);
    }

    // Function format:
    // { details: (graphic) => '<ul>...</ul>' }
    else if (typeof this.infoTemplate?.details === "function") {
      console.log("[geojson-layer] popup using infoTemplate.details function");
      content = this.infoTemplate.details(graphic);
    }

    // Content format:
    // { content: '<div>...</div>' }
    else if (typeof this.infoTemplate?.content === "string") {
      console.log("[geojson-layer] popup using infoTemplate.content string");
      content = replaceTokens(this.infoTemplate.content);
    }

    // Plain string format:
    // infoTemplate = '<div>${name}</div>'
    else if (typeof this.infoTemplate === "string") {
      console.log("[geojson-layer] popup using plain string infoTemplate");
      content = replaceTokens(this.infoTemplate);
    }

    // Field/table format:
    // { fieldInfos: [{ fieldName: 'id', label: 'id' }] }
    else if (Array.isArray(this.infoTemplate?.fieldInfos)) {
      console.log("[geojson-layer] popup using fieldInfos");

      const fieldInfos = this.infoTemplate.fieldInfos
        .map((field: any) => {
          const fieldName = field.fieldName ?? field.name ?? field.key;

          if (!fieldName) {
            return null;
          }

          return {
            fieldName,
            label: field.label ?? field.title ?? fieldName,
            visible: field.visible !== false,
          };
        })
        .filter(Boolean);

      if (!fieldInfos.length) {
        return null;
      }

      return new PopupTemplate({
        title: resolveTitle(),
        content: [
          {
            type: "fields",
            fieldInfos,
          },
        ],
      });
    }

    if (!content) {
      console.warn("[geojson-layer] popup skipped: unsupported infoTemplate format", this.infoTemplate);
      return null;
    }

    return new PopupTemplate({
      title: resolveTitle(),
      content,
    });
  } catch (error) {
    console.error("[geojson-layer] buildPopupTemplateFromCurrent failed", error);
    return null;
  }
}