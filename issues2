SECTION 8 — LABEL JSON MIGRATION
--------------------------------------------------------------------------------

OLD

element.labelJson={

   labelExpressionInfo:{
      expression:"$feature.SBDV_NAME"
   },

   symbol:{
      font:{},
      color:[0,0,0]
   }
}

NEW

element.labelJson={

   labelExpressionInfo:{
      expression:"$feature['SBDV_NAME']"
   },

   symbol:{

      type:"text",

      font:{
         size:10,
         family:"Arial",
         weight:"bold"
      },

      color:[0,0,0,255],

      haloColor:[255,255,255,255],

      haloSize:1
   }
}

