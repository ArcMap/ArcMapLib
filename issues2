private async activateGraphicsEditor(graphic: Graphic): Promise<void> {
  if (!this.isUserEditEnabled() || !graphic?.geometry) {
    console.warn("[arc-geojson-layer] editor blocked or invalid graphic", {
      enableUserEdit: this.enableUserEdit,
      hasGraphic: !!graphic,
      hasGeometry: !!graphic?.geometry,
    });
    return;
  }

  await this.createEditor();

  if (!this.graphicsEditor) {
    console.warn("[arc-geojson-layer] graphicsEditor missing");
    return;
  }

  this._editorOpen = true;
  this.inDrawingMode = false;
  this._isStartingDraw = false;
  this._suppressPopupUntil = Date.now() + 2000;

  this.enableInfoPopupWindow(false);

  try {
    this.view!.popupEnabled = false;
    this.view?.popup?.close();
  } catch {}

  try {
    this.graphicsEditor.cancel();
  } catch {}

  if (!graphic.attributes) {
    graphic.attributes = {};
  }

  const isCircle = this.isCircleGraphic(graphic);

  if (isCircle) {
    graphic.attributes = {
      ...(graphic.attributes ?? {}),
      isCircle: true,
      shape: "circle",
      shapeType: "circle",
      drawGeometryType: "circle",
      geometryType: "circle",
    };
  } else {
    graphic.attributes = {
      ...(graphic.attributes ?? {}),
      isCircle: false,
      shape: "polygon",
      shapeType: "polygon",
      drawGeometryType: "polygon",
      geometryType: "polygon",
    };
  }

  graphic.popupTemplate = null as any;

  console.log("[arc-geojson-layer] activateGraphicsEditor target", {
    geometryType: graphic.geometry?.type,
    isCircle,
    tool: "transform",
    attributes: graphic.attributes,
  });

  /**
   * IMPORTANT:
   * Use transform for both circle and polygon for now.
   * reshape was causing polygon/circle distortion and diagonal redraw behavior.
   *
   * Circle:
   * - can resize bigger/smaller
   * - uniform scaling forced
   *
   * Polygon:
   * - can move/resize safely
   * - does not corrupt vertices
   */
  await this.graphicsEditor.update([graphic], {
    tool: "transform",

    enableRotation: false,
    enableScaling: true,

    enableUniformScaling: isCircle ? true : this.enableUserEditUniformScaling,
    preserveAspectRatio: isCircle ? true : this.enableUserEditUniformScaling,

    multipleSelectionEnabled: false,
    toggleToolOnClick: false,
  } as any);

  console.log("[arc-geojson-layer] editor opened", {
    geometryType: graphic.geometry?.type,
    isCircle,
    tool: "transform",
  });
}