private updateZoom(newValue: number, oldValue?: number): void {
  if (!this.view) return;

  const normalizedZoom = this.normalizeZoom(newValue);

  if (oldValue === normalizedZoom && this.view.zoom === normalizedZoom) {
    return;
  }

  if (Math.abs((this.view.zoom ?? 0) - normalizedZoom) < 0.000001) {
    return;
  }

  this.view.zoom = normalizedZoom;
}