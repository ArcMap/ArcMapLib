private async handleEditorDoubleClick(
  evtOrMapPoint: any,
  source: string
): Promise<void> {
  if (!this.enableUserEdit) {
    console.warn("[arc-geojson-layer] editor blocked: enableUserEdit is false", {
      source,
    });
    return;
  }

  this._suppressPopupUntil = Date.now() + 1500;
  this.enableInfoPopupWindow(false);

  try {
    this.view!.popupEnabled = false;
    this.view?.popup?.close();
  } catch {}

  // If editor already open — close it, do NOT reopen
  if (this._editorOpen) {
    this.finishActiveEditor();
    return;
  }

  // Only use hitTest — never fallback to findNearest on double-click
  // findNearest opens editor even when clicking empty space far away
  const graphic = await this.getHitGraphic(evtOrMapPoint);

  if (!graphic) {
    console.log("[arc-geojson-layer] double-click on empty space — editor stays closed", {
      source,
    });
    // Double-click on empty space: just close popup, don't open editor
    this.enableInfoPopupWindow(true);
    return;
  }

  await this.activateGraphicsEditor(graphic);
}
