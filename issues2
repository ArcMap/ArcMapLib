private addToGeoJson(graphicToAdd: Graphic): void {
  if (!graphicToAdd?.geometry) {
    return;
  }

  // ✅ Same fix as updateGeoJsonWithChanges
  if (graphicToAdd.geometry?.spatialReference?.isWebMercator) {
    graphicToAdd = graphicToAdd.clone();
    graphicToAdd.geometry = webMercatorUtils.webMercatorToGeographic(
      graphicToAdd.geometry!
    ) as Geometry;
  }

  // ... rest of your existing addToGeoJson logic
}
