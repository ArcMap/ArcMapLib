static toCanonicalArcGisRendererType(rendererType: string): string {
  if (!rendererType) {
    return "simple";
  }

  const normalizedType = String(rendererType).trim();
  const lookupType = normalizedType.toLowerCase();

  let newRendererType = normalizedType;

  switch (lookupType) {
    case "simple":
    case "simplerenderer":
    case "esri.renderers.simplerenderer":
    case "esrisimplerenderer":
      newRendererType = "simple";
      break;

    case "uniquevalue":
    case "unique-value":
    case "uniquevaluerenderer":
    case "unique-renderer":
    case "uniquerenderer":
    case "esri.renderers.uniquevaluerenderer":
    case "esriuniquevaluerenderer":
      newRendererType = "unique-value";
      break;

    case "classbreaks":
    case "class-breaks":
    case "classbreaksrenderer":
    case "class-renderer":
    case "classrenderer":
    case "esri.renderers.classbreaksrenderer":
    case "esriclassbreaksrenderer":
      newRendererType = "class-breaks";
      break;

    default:
      console.warn(
        `[ArcGIS Migration Warning] toCanonicalArcGisRendererType: Unrecognized renderer type "${rendererType}". ` +
          `Expected one of: simple, unique-value, class-breaks.`
      );
      return normalizedType;
  }

  JsonUtils.warnArcGisMigration(
    "toCanonicalArcGisRendererType",
    "renderer type",
    rendererType,
    newRendererType
  );

  return newRendererType;
}


static normalizeMarkerStyle(style: any): any {
  const value = String(style ?? "circle").toLowerCase();

  const map: Record<string, string> = {
    esrismscircle: "circle",
    esrismssquare: "square",
    esrismsdiamond: "diamond",
    esrismscross: "cross",
    esrismsx: "x",
    esrismsstylecircle: "circle",
    esrismsstylesquare: "square",
    esrismsstylediamond: "diamond",
    esrismsstylecross: "cross",
    esrismsstylex: "x",

    circle: "circle",
    square: "square",
    diamond: "diamond",
    cross: "cross",
    x: "x",
    triangle: "triangle",
    path: "path"
  };

  const newStyle = map[value] ?? "circle";

  if (JsonUtils.ARCGIS_3X_MARKER_STYLES.has(value)) {
    JsonUtils.warnArcGisMigration("normalizeMarkerStyle", "marker style", style, newStyle);
  }

  return newStyle;
}



