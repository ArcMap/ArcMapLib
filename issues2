const pointerMoveHandle = this.view.on(
  "pointer-move",
  async (evt: any) => {

    if (!this.view || !this.featureLayer) {
      this.setMapCursor("default");
      return;
    }

    try {
      const hit = await this.view.hitTest(evt);

      const graphic = hit?.results?.find((r: any) => {
        const g = r?.graphic;

        return (
          g &&
          g.geometry &&
          (
            g.layer === this.featureLayer ||
            g.sourceLayer === this.featureLayer
          )
        );
      })?.graphic;

      if (graphic) {
        this.setMapCursor("pointer");
      } else {
        this.setMapCursor("default");
      }

    } catch (error) {
      this.setMapCursor("default");
    }
  }
);



graphic.symbol = {
  ...graphic.symbol,
  style: "solid",
};



private setMapCursor(cursor: string): void {

  const container = this.view?.container as HTMLElement;

  if (!container) {
    return;
  }

  container.style.cursor = cursor;

  const canvas = container.querySelector("canvas") as HTMLElement;

  if (canvas) {
    canvas.style.cursor = cursor;
  }

  const surface = container.querySelector(".esri-view-surface") as HTMLElement;

  if (surface) {
    surface.style.cursor = cursor;
  }
}


