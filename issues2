private _editingEnabled = false;


private async updateEditing(enabled: boolean): Promise<void> {
  if (this._lastEditingState === enabled) {
    return;
  }
  this._lastEditingState = enabled;

  // FIX: Set this synchronously so double-click handler sees it immediately
  this._editingEnabled = enabled;
  this.enableUserEdit = enabled;

  console.log("[arc-geojson-layer] updateEditing", {
    enabled,
    editorOpen: this._editorOpen,
    inDrawingMode: this.inDrawingMode,
  });

  if (!enabled) {
    this.enableInfoPopupWindow(true);
    return;
  }

  await this.createEditor();
  this.enableInfoPopupWindow(false);
}


private isUserEditEnabled(): boolean {
  // Check private flag first — set synchronously by updateEditing
  if (this._editingEnabled === true) {
    return true;
  }

  // Fallback: check property
  if (this.enableUserEdit === true) {
    return true;
  }

  // Fallback: check attribute
  const attrValue =
    this.getAttribute("enable-user-edit") ??
    this.getAttribute("enableUserEdit");

  return attrValue === "true" || attrValue === "";
}



private async handleEditorDoubleClick(
  evtOrMapPoint: any,
  source: string
): Promise<void> {
  // FIX: Use isUserEditEnabled() which checks _editingEnabled flag
  if (!this.isUserEditEnabled()) {
    console.warn("[arc-geojson-layer] editor blocked: enableUserEdit is false", {
      source,
    });
    return;
  }

  this._suppressPopupUntil = Date.now() + 1500;
  this.enableInfoPopupWindow(false);

  try {
    this.view!.popupEnabled = false;
    this.view?.popup?.close();
  } catch {}

  if (this._editorOpen) {
    this.finishActiveEditor();
    return;
  }

  // Only hitTest — no findNearest fallback
  const graphic = await this.getHitGraphic(evtOrMapPoint);

  if (!graphic) {
    console.log("[arc-geojson-layer] double-click on empty space", { source });
    this.enableInfoPopupWindow(true);
    return;
  }

  await this.activateGraphicsEditor(graphic);
}


disconnectedCallback(): void {
  super.disconnectedCallback();
  this._editingEnabled = false;
  this._lastEditingState = undefined;
  // ... rest of existing cleanup
}
