async zoomTo(id: string | number, zoomLevel = 9): Promise<void> {
  const graphicMatch: Graphic | undefined = await this.findFeatureByUniqueId(id);

  if (graphicMatch === undefined) {
    console.warn(
      'No feature found with a',
      this.uniqueIdPropertyName,
      'value of',
      id,
      '. Cannot zoom to.'
    );
    return;
  }

  if (!this.view) return;

  const geometry = graphicMatch.geometry;
  if (!geometry) return;

  if (geometry.type === 'point') {
    // ✅ Replaces Stencil's map.centerAndZoom()
    await this.view.goTo({
      center: geometry as Point,
      zoom: zoomLevel,
    });
  } else if (
    geometry.type === 'polyline' ||
    geometry.type === 'polygon'
  ) {
    // ✅ Replaces Stencil's map.setExtent()
    const extent = (geometry as Polygon | Polyline).extent;
    if (extent) {
      await this.view.goTo(extent);
    }
  } else {
    console.error(
      'Unrecognized geometry type',
      geometry.type,
      'this isn\'t supposed to be possible. Please contact the GIS team for assistance.'
    );
  }
}
