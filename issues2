private async showGraphicPopup(
  graphic: Graphic,
  location?: Point,
  graphics: Graphic[] = []
): Promise<void> {
  if (!this.view || !graphic) {
    return;
  }

  if (
    this._editorOpen ||
    this.inDrawingMode ||
    this._isStartingDraw ||
    this.shouldSuppressPopup()
  ) {
    this.closePopup();
    return;
  }

  const popupLocation =
    location ??
    UpGeojsonLayer.getPopupPoint(graphic.geometry) ??
    undefined;

  if (!popupLocation) {
    return;
  }

  const popupGraphics = graphics.length > 0 ? graphics : [graphic];

  popupGraphics.forEach((item) => {
    const template = this.buildPopupTemplateFromCurrent(item);
    if (template) {
      item.popupTemplate = template;
    }
  });

  try {
    const popup: any = this.view.popup;

    this._popupGraphic = graphic;
    this._popupOpen = true;
    this._showPopup = true;

    this.view.popupEnabled = true;

    popup.features = [];
    popup.content = null;
    popup.title = "";
    popup.location = popupLocation;

    await Promise.resolve();

    popup.features = popupGraphics;
    popup.location = popupLocation;
    popup.open = true;
    popup.visible = true;
  } catch (error) {
    console.warn("[geojson-layer] popup open failed", error);
  }
}