public openPopup(featureId: string): void {
  const graphic = (this._sourceCache ?? []).find((g: Graphic) =>
    String(g.attributes?.[this.uniqueIdPropertyName]) === String(featureId) ||
    String(g.attributes?.OBJECTID) === String(featureId) ||
    String(g.attributes?.id) === String(featureId)
  );

  if (!graphic) {
    console.warn('[arc-geojson-layer] openPopup: not found', featureId);
    return;
  }

  const location =
    graphic.geometry?.type === 'point'
      ? (graphic.geometry as Point)
      : (graphic.geometry as Polygon).centroid;

  this.view?.popup?.open({
    features: [graphic],
    location,
  });
}
