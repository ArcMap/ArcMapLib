/* Legacy ArcGIS Popup — force auto-height instead of fixed/min height */
.esri-popup__main-container {
  min-height: 0 !important;
  height: auto !important;
  max-height: 80vh !important;
}

.esri-popup__content {
  min-height: 0 !important;
  height: auto !important;
  flex: 0 0 auto !important;
  overflow: visible !important;
}

.esri-popup__feature-menu-viewport {
  min-height: 0 !important;
  height: auto !important;
}

.esri-features__content-feature,
.esri-feature,
.esri-feature__main-container,
.esri-feature__content,
.esri-feature-content {
  min-height: 0 !important;
  height: auto !important;
  flex: 0 0 auto !important;
  overflow: visible !important;
}

.esri-popup.esri-widget {
  min-height: 0 !important;
  height: auto !important;
}


private async showGraphicPopup(
  graphic: Graphic,
  mapPoint?: Point,
): Promise<void> {
  if (this._popupOpening) return;

  if (
    this._editorOpen ||
    this.inDrawingMode ||
    this._isStartingDraw ||
    this.shouldSuppressPopup()
  ) {
    this.closePopup();
    return;
  }

  if (!graphic?.geometry || !this.view?.popup) return;

  const location =
    mapPoint ?? UpGeojsonLayer.getPopupPoint(graphic.geometry) ?? undefined;
  if (!location) return;

  const popupTemplate = this.buildPopupTemplateFromCurrent(graphic);
  if (!popupTemplate) { this.closePopup(); return; }

  this._popupOpening = true;
  try {
    graphic.popupTemplate = popupTemplate;

    const popup = this.view.popup as any;

    if (popup.visible) {
      popup.visible = false;
      await new Promise((r) => requestAnimationFrame(() => r(null)));
    }

    popup.location = location;
    popup.features = [graphic];
    popup.visible = true;
    popup.open = true;
  } catch (err) {
    console.warn("[arc-geojson-layer] showGraphicPopup failed", err);
  } finally {
    this._popupOpening = false;
  }
}


private closePopup(): void {
  try {
    const popup = this.view?.popup as any;
    if (popup) {
      popup.visible = false;
      popup.open = false;
      popup.features = [];
      popup.selectedFeature = null;
    }
  } catch {}
  this.clearPopupHighlight();
}
