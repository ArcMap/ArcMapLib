private updateGeoJsonWithChanges(graphicToUpdate: Graphic): void {
  if (!graphicToUpdate?.geometry) {
    return;
  }

  this.applyGraphicDefaults(graphicToUpdate);

  // Convert Web Mercator → Geographic before processing
  if (webMercatorUtils.canProject(graphicToUpdate.geometry)) {
    graphicToUpdate = graphicToUpdate.clone();
    graphicToUpdate.geometry = webMercatorUtils.webMercatorToGeographic(
      graphicToUpdate.geometry
    ) as __esri.Geometry;
  }

  const convertedFeature = this.graphicToGeoJsonFeature(graphicToUpdate);
  if (!convertedFeature?.geometry) {
    return;
  }

  const isCircle = this.isCircleGraphic(graphicToUpdate);

  const normalizedFeature = {
    ...convertedFeature,
    geometry: {
      ...convertedFeature.geometry,
      type: "Polygon",
      coordinates: this.normalizePolygonCoordinates(
        (convertedFeature.geometry as any).coordinates,
      ),
    },
    properties: {
      ...(convertedFeature.properties ?? {}),
      ...(isCircle
        ? {
            drawGeometryType: "circle",
            shapeType: "circle",
            shape: "circle",
            isCircle: true,
          }
        : {
            drawGeometryType: "polygon",
            shapeType: "polygon",
            shape: "polygon",
            isCircle: false,
          }),
    },
  };

  const parsedResult = this.getJsonForAny(this.geojson);
  const currentGeoJson =
    !parsedResult.error &&
    parsedResult.parsedJson &&
    Array.isArray(parsedResult.parsedJson.features)
      ? parsedResult.parsedJson
      : { type: "FeatureCollection", features: [] };

  const normalizedProperties = (normalizedFeature.properties ??
    {}) as Record<string, any>;

  const updateId =
    graphicToUpdate.attributes?.[this.uniqueIdPropertyName] ??
    graphicToUpdate.attributes?.OBJECTID ??
    normalizedProperties[this.uniqueIdPropertyName] ??
    normalizedProperties.OBJECTID ??
    normalizedProperties.id;

  let updated = false;

  const updatedFeatures = currentGeoJson.features.map((feature: any) => {
    const featureId =
      feature?.properties?.[this.uniqueIdPropertyName] ??
      feature?.properties?.OBJECTID ??
      feature?.properties?.id;

    if (String(featureId) === String(updateId)) {
      updated = true;
      return {
        ...feature,
        geometry: normalizedFeature.geometry,
        properties: {
          ...(feature.properties ?? {}),
          ...(normalizedFeature.properties ?? {}),
        },
      };
    }

    return feature;
  });

  if (!updated) {
    updatedFeatures.push(normalizedFeature as any);
  }

  const updatedGeoJson: FeatureCollection<
    GeoJsonGeometry,
    GeoJsonProperties
  > = {
    type: "FeatureCollection",
    features: updatedFeatures as any,
  };

  // FIX: Update signature BEFORE setting geojson so updateGeoJson()
  // skips the reload entirely when it sees the same signature
  this._lastGeoJsonSignature = JSON.stringify(updatedGeoJson);

  this.blockGeoJsonUpdate = true;
  this.geojson = updatedGeoJson;
  this.blockGeoJsonUpdate = false;

  // FIX: Manually update the graphic's symbol and popup in featureLayer
  // instead of relying on clearGeoJSONLayer + re-add cycle
  this.featureLayer?.graphics?.forEach((g: Graphic) => {
    const gId =
      g.attributes?.[this.uniqueIdPropertyName] ??
      g.attributes?.OBJECTID ??
      g.attributes?.id;

    if (String(gId) === String(updateId)) {
      g.geometry = graphicToUpdate.geometry;
      g.attributes = { ...graphicToUpdate.attributes };
      this.applyGraphicDefaults(g);
    }
  });

  this.refreshLabels();

  this.emitLayerEvent(
    "userEditItemUpdated",
    normalizedFeature as any,
    graphicToUpdate,
    {
      geojson: updatedGeoJson,
    }
  );
}
