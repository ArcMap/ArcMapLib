private async showGraphicPopup(graphic: Graphic, mapPoint?: Point): Promise<void> {
  if (!this.view || !graphic?.geometry) {
    this.setViewCursor("default");
    return;
  }

  if (
    this._editorOpen ||
    this.inDrawingMode ||
    this._isStartingDraw ||
    this.shouldSuppressPopup()
  ) {
    this.setViewCursor("default");
    return;
  }

  try {
    const popupTemplate = this.buildPopupTemplateFromCurrent(graphic);

    if (!popupTemplate) {
      console.warn("[geojson-layer] popup skipped: no popupTemplate", {
        graphic,
        attributes: graphic.attributes,
        infoTemplate: this.infoTemplate,
      });
      this.setViewCursor("default");
      return;
    }

    graphic.popupTemplate = popupTemplate;

    const location =
      mapPoint ??
      UpGeosonLayer.getPopupPoint(graphic.geometry) ??
      undefined;

    if (!location) {
      console.warn("[geojson-layer] popup skipped: no location", graphic);
      this.setViewCursor("default");
      return;
    }

    this.closePopup();

    const popup: any = this.view.popup;

    this.view.popupEnabled = true;

    // Do NOT assign selectedFeature. It is read-only in ArcGIS 5.
    popup.features = [];
    popup.content = null;
    popup.title = "";
    popup.location = location;

    await Promise.resolve();

    popup.features = [graphic];
    popup.location = location;
    popup.open = true;
    popup.visible = true;

    // Force render again after ArcGIS finishes internal async popup lifecycle.
    requestAnimationFrame(() => {
      try {
        popup.features = [graphic];
        popup.location = location;
        popup.open = true;
        popup.visible = true;

        console.log("[geojson-layer] popup forced open", {
          open: popup.open,
          visible: popup.visible,
          location: popup.location,
          features: popup.features,
          popupTemplate: graphic.popupTemplate,
        });
      } catch (error) {
        console.error("[geojson-layer] popup force render failed", error);
      }
    });
  } catch (error) {
    console.error("[geojson-layer] popup open failed", error);
    this.closePopup();
  } finally {
    window.setTimeout(() => {
      if (!this._editorOpen && !this.inDrawingMode) {
        this.setViewCursor("default");
      }
    }, 100);
  }
}