private clearFeatureHighlight(): void {
  try {
    // Clear the highlighted feature from the view
    if (this.view) {
      // Remove all highlights
      const layerViews = this.view.allLayerViews;
      layerViews?.forEach((layerView: any) => {
        if (layerView.highlight) {
          layerView.highlight = null;
        }
      });
      
      // Alternative: clear popup features
      if (this.view.popup) {
        (this.view.popup as any).features = [];
      }
    }
  } catch (err) {
    console.warn("[up-geojson-layer] clearFeatureHighlight failed", err);
  }
}



