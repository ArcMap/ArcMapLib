const clickHandle = this.view.on("click", async (evt: any) => {
  if (clickTimer) {
    clearTimeout(clickTimer);
    clickTimer = null;
    return;
  }

  clickTimer = setTimeout(async () => {
    clickTimer = null;

    const graphic = await this.getHitGraphic(evt);
    if (!graphic) {
      return;
    }

    // ✅ IMPORTANT FIX:
    // Check actual top-most clicked graphic across ALL layers.
    // If top-most graphic is not from this layer, do not open this layer popup.
    const allHit = await this.view.hitTest(evt);
    const topGraphic = (allHit.results ?? [])
      .map((r: any) => r?.graphic as Graphic)
      .find((g: Graphic | null | undefined) => !!g?.geometry);

    if (
      topGraphic &&
      topGraphic.layer !== this.featureLayer &&
      (topGraphic.layer as any)?.id !== this.featureLayer?.id
    ) {
      return;
    }

    this.emitLayerEvent(
      "layerClick",
      this.graphicToGeoJsonFeature(graphic),
      graphic,
      {
        event: {
          coordinates: {
            latitude: evt.mapPoint?.latitude ?? 0,
            longitude: evt.mapPoint?.longitude ?? 0,
          },
          attributes: graphic.attributes ?? {},
        },
      }
    );

    if (
      !this._editorOpen &&
      !this.inDrawingMode &&
      !this._isStartingDraw &&
      !this.shouldSuppressPopup()
    ) {
      this.showGraphicPopup(graphic, evt.mapPoint);
    }

    if (
      this.enableUserEdit &&
      !this._editorOpen &&
      !this.inDrawingMode &&
      !this.infoTemplate
    ) {
      if (evt.native?.ctrlKey && this.enableUserEditRemove) {
        this.removeFromGeoJSON(graphic);
        this.graphicsEditor?.cancel();
        return;
      }

      this.activateGraphicsEditor(graphic);
    }
  }, 250);
});