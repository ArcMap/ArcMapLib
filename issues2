console.log("[arc-geojson-layer] editor target", {
  geometryType: graphic.geometry?.type,
  isCircle,
  attributes: graphic.attributes,
});



if (isCircle) {

  await this.graphicsEditor.update([graphic], {
    tool: "transform",

    enableRotation: false,

    enableScaling: true,

    enableUniformScaling: true,

    preserveAspectRatio: true,

    multipleSelectionEnabled: false,

    toggleToolOnClick: false,
  } as any);

} else {

  await this.graphicsEditor.update([graphic], {
    tool: "reshape",

    enableRotation: false,

    enableScaling: false,

    multipleSelectionEnabled: false,

    toggleToolOnClick: false,
  } as any);
}