private buildPopupTemplateFromCurrent(graphic: Graphic): PopupTemplate | null {
  console.log("[DEBUG] buildPopupTemplateFromCurrent CALLED");  // 👈 ADD THIS
  console.log("[DEBUG] infoTemplate:", this.infoTemplate);
  console.log("[DEBUG] graphic.attributes:", graphic?.attributes);
  
  if (!graphic) return null;
  if (!this.infoTemplate) return null;

  return PopupTemplateResolver.resolveTemplate(
    this.infoTemplate,
    graphic.attributes
  );
}



if (typeof config.details === "string" && config.listItem !== undefined) {
  let title = config.listItem;
  if (attributes && typeof title === "string") {
    title = title.replace(/\$\{([^}]+)\}/g, (_: string, key: string) => {
      const val = attributes[key.trim()];
      return val !== undefined && val !== null ? String(val) : "";
    });
  }
  
  let htmlContent = config.details.trim();
  
  // 👇 ADD: Deduplicate repeated content blocks
  // Remove duplicate <div>Name: ...</div><div>ID: ...</div> patterns
  const lines = htmlContent.split('\n').map(l => l.trim()).filter(l => l.length > 0);
  const uniqueLines = [...new Set(lines)];
  htmlContent = uniqueLines.join('\n');
  
  if (attributes) {
    htmlContent = htmlContent.replace(/\$\{([^}]+)\}/g, (_: string, key: string) => {
      const val = attributes[key.trim()];
      return val !== undefined && val !== null ? String(val) : "";
    });
  }
  
  return new PopupTemplate({
    title,
    content: [{ type: "text", text: htmlContent }]
  });
}
