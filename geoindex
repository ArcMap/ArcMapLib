<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Arc GeoJSON Layer Test Page</title>

    <style>
      html,
      body {
        margin: 0;
        padding: 0;
        width: 100%;
        height: 100%;
        font-family: Arial, sans-serif;
      }

      .page {
        display: grid;
        grid-template-columns: 1fr 360px;
        grid-template-rows: auto 1fr;
        width: 100%;
        height: 100%;
      }

      .toolbar {
        grid-column: 1 / 3;
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        padding: 10px;
        border-bottom: 1px solid #d8d8d8;
        background: #f7f7f7;
      }

      .map-panel {
        position: relative;
        min-width: 0;
        min-height: 0;
      }

      .side-panel {
        border-left: 1px solid #d8d8d8;
        padding: 10px;
        overflow: auto;
        background: #fff;
      }

      arc-map,
      
      arcgis-map {
        display: block;
        width: 100%;
        height: 100%;
      }

      button {
        padding: 8px 10px;
        cursor: pointer;
      }

      .section-title {
        font-weight: 700;
        margin: 12px 0 6px;
      }

      .box {
        border: 1px solid #d8d8d8;
        min-height: 88px;
        padding: 8px;
        background: #fafafa;
        white-space: pre-wrap;
        overflow: auto;
        margin-bottom: 10px;
      }

      .hint {
        font-size: 12px;
        color: #555;
        margin-bottom: 10px;
      }
    </style>
  </head>

  <body>
    <div class="page">
      <div class="toolbar">
        <button id="drawPointBtn">Start Point Drawing</button>
        <button id="drawPolylineBtn">Start Polyline Drawing</button>
        <button id="drawPolygonBtn">Start Polygon Drawing</button>
        <button id="cancelDrawingBtn">Cancel Drawing</button>

        <button id="editOffBtn">Edit OFF</button>
        <button id="editOnBtn">Edit ON</button>
        <button id="allEditOnBtn">All Edit Features ON</button>
        <button id="allEditOffBtn">All Edit Features OFF</button>

        <button id="zoomToFirstBtn">Zoom To point-1</button>
        <button id="popupFirstBtn">Open Popup point-1</button>
        <button id="printGeoJsonBtn">Print Current GeoJSON</button>
        <button id="resetGeoJsonBtn">Reset GeoJSON</button>
      </div>

      <div class="map-panel">
        <!--
          IMPORTANT:
          Replace the tag names below if your project uses different names.
          Example:
            
            <arc-map> + <arc-geojson-layer>
        -->
        <arc-map
          id="arcMap"
          basemap="streets-vector"
          center='[-96.5, 38.5]'
          zoom="4"
        >
          <arc-geojson-layer id="geoLayer"></arc-geojson-layer>
        </arc-map>
      </div>

      <div class="side-panel">
        <div class="section-title">Test Scenarios</div>
        <div class="hint">
          1. Edit OFF → click feature → popup should appear.<br />
          2. Edit ON → single click should not open popup.<br />
          3. Edit ON → double click feature → editor should appear.<br />
          4. Ctrl+Click with remove ON → feature should be deleted.<br />
          5. Draw new point/polyline/polygon → shape should remain visible after completion.<br />
          6. Double click newly drawn shape in edit mode → editor should appear again.<br />
        </div>

        <div class="section-title">Layer Click</div>
        <div id="layerClickBox" class="box">Waiting...</div>

        <div class="section-title">Double Click</div>
        <div id="doubleClickBox" class="box">Waiting...</div>

        <div class="section-title">Draw / Edit / Remove Events</div>
        <div id="editEventBox" class="box">Waiting...</div>

        <div class="section-title">Current GeoJSON</div>
        <div id="geojsonBox" class="box">Waiting...</div>
      </div>
    </div>

    <script type="module">
      // IMPORTANT:
      // Update this import path to your project entry file.
      // Examples:
      // import './dist/index.js';
      // import './src/index.ts';
      import './src/index.ts';

      const map = document.getElementById('arcMap');
      const geo = document.getElementById('geoLayer');

      const layerClickBox = document.getElementById('layerClickBox');
      const doubleClickBox = document.getElementById('doubleClickBox');
      const editEventBox = document.getElementById('editEventBox');
      const geojsonBox = document.getElementById('geojsonBox');

      function show(el, value) {
        el.textContent =
          typeof value === 'string' ? value : JSON.stringify(value, null, 2);
      }

      const initialGeoJson = {
        type: 'FeatureCollection',
        features: [
          {
            type: 'Feature',
            geometry: {
              type: 'Point',
              coordinates: [-104.9903, 39.7392]
            },
            properties: {
              id: 'point-1',
              firstField: 'Denver',
              secondField: 'Initial point',
              listDescription: 'Initial point feature'
            }
          },
          {
            type: 'Feature',
            geometry: {
              type: 'LineString',
              coordinates: [
                [-122.4194, 37.7749],
                [-115.1398, 36.1699],
                [-104.9903, 39.7392],
                [-87.6298, 41.8781]
              ]
            },
            properties: {
              id: 'line-1',
              firstField: 'West to Midwest',
              secondField: 'Initial polyline',
              listDescription: 'Initial polyline feature'
            }
          },
          {
            type: 'Feature',
            geometry: {
              type: 'Polygon',
              coordinates: [[
                [-99.5, 35.8],
                [-94.2, 37.8],
                [-92.3, 34.1],
                [-97.8, 33.2],
                [-99.5, 35.8]
              ]]
            },
            properties: {
              id: 'polygon-1',
              firstField: 'Test Polygon',
              secondField: 'Initial polygon',
              listDescription: 'Initial polygon feature'
            }
          }
        ]
      };

      function cloneJson(obj) {
        return JSON.parse(JSON.stringify(obj));
      }

      function loadInitialData() {
        geo.uniqueIdPropertyName = 'id';

        geo.geojson = cloneJson(initialGeoJson);

        // Popup template
        geo.infoTemplate = {
          title: 'Details',
          content: `
            <div>First Field: \${firstField}</div>
            <div>Second Field: \${secondField}</div>
          `
        };

        // Safe simple renderer
        geo.renderer = {
          type: 'simple',
          symbol: {
            type: 'simple-fill',
            color: [173, 216, 230, 0.35],
            outline: {
              color: [0, 0, 0, 1],
              width: 2
            }
          }
        };

        geo.name = 'Arc GeoJSON Test Layer';

        // Start with popup mode
        geo.enableUserEdit = false;
        geo.enableUserEditMove = false;
        geo.enableUserEditVertices = false;
        geo.enableUserEditAddVertices = false;
        geo.enableUserEditDeleteVertices = false;
        geo.enableUserEditScaling = false;
        geo.enableUserEditUniformScaling = false;
        geo.enableUserEditRotating = false;
        geo.enableUserEditRemove = false;

        refreshGeoJsonPanel();
      }

      function refreshGeoJsonPanel() {
        show(geojsonBox, geo.geojson ?? 'No geojson set');
      }

      function setAllEditFlags(enabled) {
        geo.enableUserEdit = enabled;
        geo.enableUserEditMove = enabled;
        geo.enableUserEditVertices = enabled;
        geo.enableUserEditAddVertices = enabled;
        geo.enableUserEditDeleteVertices = enabled;
        geo.enableUserEditScaling = enabled;
        geo.enableUserEditUniformScaling = enabled;
        geo.enableUserEditRotating = enabled;
        geo.enableUserEditRemove = enabled;
      }

      loadInitialData();

      // ------------------------------------------------------------
      // Buttons
      // ------------------------------------------------------------
      document.getElementById('drawPointBtn').addEventListener('click', () => {
        geo.startDrawing('point');
      });

      document.getElementById('drawPolylineBtn').addEventListener('click', () => {
        geo.startDrawing('polyline');
      });

      document.getElementById('drawPolygonBtn').addEventListener('click', () => {
        geo.startDrawing('polygon');
      });

      document.getElementById('cancelDrawingBtn').addEventListener('click', () => {
        geo.cancelDrawing();
      });

      document.getElementById('editOffBtn').addEventListener('click', () => {
        geo.enableUserEdit = false;
        show(editEventBox, 'Edit OFF\nSingle click should show popup.');
      });

      document.getElementById('editOnBtn').addEventListener('click', () => {
        geo.enableUserEdit = true;
        show(editEventBox, 'Edit ON\nDouble click should open editor.\nSingle click should not show popup.');
      });

      document.getElementById('allEditOnBtn').addEventListener('click', () => {
        setAllEditFlags(true);
        show(
          editEventBox,
          'All edit features ON\n- move\n- vertices\n- add vertices\n- delete vertices\n- scale\n- rotate\n- remove (Ctrl+Click)'
        );
      });

      document.getElementById('allEditOffBtn').addEventListener('click', () => {
        setAllEditFlags(false);
        show(editEventBox, 'All edit features OFF\nPopup mode only.');
      });

      document.getElementById('zoomToFirstBtn').addEventListener('click', async () => {
        try {
          await geo.zoomTo('point-1', 7);
        } catch (e) {
          console.error('zoomTo failed', e);
        }
      });

      document.getElementById('popupFirstBtn').addEventListener('click', async () => {
        try {
          await geo.openPopup('point-1');
        } catch (e) {
          console.error('openPopup failed', e);
        }
      });

      document.getElementById('printGeoJsonBtn').addEventListener('click', () => {
        refreshGeoJsonPanel();
      });

      document.getElementById('resetGeoJsonBtn').addEventListener('click', () => {
        loadInitialData();
        show(editEventBox, 'GeoJSON reset to initial data.');
      });

      // ------------------------------------------------------------
      // Layer events
      // ------------------------------------------------------------
      geo.addEventListener('layerClick', (event) => {
        show(layerClickBox, event.detail);
      });

      geo.addEventListener('doubleClick', (event) => {
        show(doubleClickBox, event.detail);
      });

      geo.addEventListener('userDrawItemAdded', (event) => {
        show(editEventBox, {
          event: 'userDrawItemAdded',
          detail: event.detail
        });
        refreshGeoJsonPanel();
      });

      geo.addEventListener('userEditItemUpdated', (event) => {
        show(editEventBox, {
          event: 'userEditItemUpdated',
          detail: event.detail
        });
        refreshGeoJsonPanel();
      });

      geo.addEventListener('userEditItemRemoved', (event) => {
        show(editEventBox, {
          event: 'userEditItemRemoved',
          detail: event.detail
        });
        refreshGeoJsonPanel();
      });

      // ------------------------------------------------------------
      // Helpful console test notes
      // ------------------------------------------------------------
      console.log(`
SCENARIO 1 - POPUP TEST
1. Click "All Edit Features OFF"
2. Click point / line / polygon
3. Popup should appear

SCENARIO 2 - EDIT TEST
1. Click "All Edit Features ON"
2. Double click point / line / polygon
3. Editor should appear
4. Single click should NOT show popup

SCENARIO 3 - DRAW TEST
1. Click "Start Polygon Drawing"
2. Draw polygon and complete it
3. Polygon should remain visible
4. Double click new polygon
5. Editor should appear

SCENARIO 4 - REMOVE TEST
1. Keep "All Edit Features ON"
2. Hold Ctrl and click a feature
3. Feature should be removed

SCENARIO 5 - GEOJSON VERIFICATION
1. Click "Print Current GeoJSON"
2. Confirm added / updated / removed shapes are reflected
      `);
    </script>
  </body>
</html>