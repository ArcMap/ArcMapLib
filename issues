private graphicToGeoJsonFeature(graphic: Graphic): Feature | null {
  if (!graphic || !graphic.geometry) {
    return null;
  }

  const geometry = this.arcGeometryToGeoJson(graphic.geometry);

  if (!geometry) {
    return null;
  }

  return {
    type: "Feature",
    geometry,
    properties: {
      ...(graphic.attributes ?? {})
    }
  };
}

private toFeatureCollectionFromLayer(): FeatureCollection {
  const graphics = this.featureLayer?.graphics?.toArray?.() ?? [];

  return {
    type: "FeatureCollection",
    features: graphics
      .map((graphic: Graphic) => this.graphicToGeoJsonFeature(graphic))
      .filter((feature: Feature | null): feature is Feature => feature !== null)
  };
}