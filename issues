private async finishActiveEditor(): Promise<void> {
  if (!this._editorOpen) {
    return;
  }

  const graphics = this.featureLayer?.graphics?.toArray?.() ?? [];

  graphics.forEach((graphic: Graphic) => {
    if (!graphic.geometry) {
      return;
    }

    // Save edited geometry back into geojson
    this.updateGeoJSONWithChanges(graphic);

    // Restore symbol after edit is completed
    graphic.symbol =
      this.getSymbolFromRendererConfig(this.renderer, graphic) ??
      this.getDefaultSymbolForGeometry(graphic.geometry, graphic.attributes);
  });

  try {
    this.graphicsEditor?.cancel();
  } catch {
    // ignore ArcGIS cancel error
  }

  this._editorOpen = false;

  // Re-enable popup after editor closes
  this.enableInfoPopupWindow(this.enableUserEdit);

  console.log("[arc-geojson-layer] editor closed");
}