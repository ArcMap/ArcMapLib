static updateLabelJson(
    newLabelJsonArg: string | object | object[] | undefined,
    featureLayer: FeatureLayer | GeoJSONLayer
) {

    if (!newLabelJsonArg) {
        featureLayer.labelingInfo = [];
        return;
    }

    const jsonParseResult =
        JsonUtils.getJsonFor(newLabelJsonArg);

    if (jsonParseResult.error) {
        console.warn(
            "Could not parse new value for label json",
            jsonParseResult.error
        );
        return;
    }

    const parsedJson = jsonParseResult.parsedJson;

    const parsedArray =
        parsedJson instanceof Array
            ? parsedJson
            : [parsedJson];

    const labelClasses: LabelClass[] =
        parsedArray.map((individualLabelJson: any) => {

            const symbol =
                new TextSymbol({
                    color:
                        individualLabelJson.symbol?.color ??
                        [0,0,0,255],

                    haloColor:
                        individualLabelJson.symbol?.haloColor ??
                        [255,255,255,255],

                    haloSize:
                        individualLabelJson.symbol?.haloSize ?? 1,

                    font: {
                        size:
                            individualLabelJson.symbol?.font?.size ?? 12,

                        family:
                            individualLabelJson.symbol?.font?.family ??
                            "sans-serif",

                        weight:
                            individualLabelJson.symbol?.font?.weight ??
                            "normal"
                    }
                });

            return new LabelClass({
                labelPlacement:
                    individualLabelJson.labelPlacement ??
                    "above-right",

                labelExpressionInfo:
                    individualLabelJson.labelExpressionInfo,

                symbol
            });
        });

    featureLayer.labelingInfo = labelClasses;
}