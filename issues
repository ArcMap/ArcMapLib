private bindEditorEvents(): void {
  this.cleanupEditorEvents();

  if (!this.graphicsEditor) {
    console.warn("[arc-geojson-layer] bindEditorEvents skipped: graphicsEditor missing");
    return;
  }

  const createHandle = this.graphicsEditor.on("create", (event: any) => {
    console.log("[arc-geojson-layer] Sketch create event", {
      state: event.state,
      tool: event.tool,
      graphic: event.graphic
    });

    if (event.state !== "complete") {
      return;
    }

    const graphic = event.graphic as Graphic;

    if (!graphic) {
      console.warn("[arc-geojson-layer] create complete but graphic missing");
      this.inDrawingMode = false;
      this.isStartingDraw = false;
      this.editorOpen = false;
      this.enableInfoPopupWindow(!this.enableUserEdit);
      return;
    }

    if (!graphic.attributes) {
      graphic.attributes = {};
    }

    /**
     * 2026-05-08
     * Purpose:
     * Preserve original drawing tool type.
     * ArcGIS stores circle/rectangle as polygon geometry internally.
     * Without this metadata, circle edit is treated as polygon reshape.
     */
    if (this._currentDrawGeometryType) {
      graphic.attributes.drawGeometryType = this._currentDrawGeometryType;
      graphic.attributes.shapeType = this._currentDrawGeometryType;
      graphic.attributes.geometryType = this._currentDrawGeometryType;
    }

    this.addToGeoJSON(graphic);

    this.inDrawingMode = false;
    this.isStartingDraw = false;
    this.editorOpen = false;
    this._currentDrawGeometryType = undefined;
    this.suppressPopupUntil = Date.now() + 700;

    this.enableInfoPopupWindow(!this.enableUserEdit);

    console.log("[arc-geojson-layer] Sketch create complete handled", {
      geometryType: graphic.geometry?.type,
      drawGeometryType: graphic.attributes.drawGeometryType,
      attributes: graphic.attributes
    });
  });

  const updateHandle = this.graphicsEditor.on("update", (event: any) => {
    console.log("[arc-geojson-layer] Sketch update event", {
      state: event.state,
      tool: event.tool,
      graphicsCount: event.graphics?.length
    });

    if (event.state === "complete") {
      event.graphics?.forEach((graphic: Graphic) => {
        if (!graphic.attributes) {
          graphic.attributes = {};
        }

        graphic.symbol =
          this.getSymbolFromRendererConfig(this.renderer, graphic) ??
          this.getDefaultSymbolForGeometry(graphic.geometry);

        this.updateGeojsonWithChanges(graphic);
      });

      this.editorOpen = false;
      this.suppressPopupUntil = Date.now() + 700;
      this.enableInfoPopupWindow(!this.enableUserEdit);

      console.log("[arc-geojson-layer] Sketch update complete handled");
      return;
    }

    if (event.state === "cancel" || event.aborted) {
      this.editorOpen = false;
      this.enableInfoPopupWindow(!this.enableUserEdit);

      console.log("[arc-geojson-layer] Sketch update cancelled");
    }
  });

  const deleteHandle = this.graphicsEditor.on("delete", (event: any) => {
    console.log("[arc-geojson-layer] Sketch delete event", {
      graphicsCount: event.graphics?.length
    });

    event.graphics?.forEach((graphic: Graphic) => {
      this.removeFromGeojson(graphic);
    });

    this.editorOpen = false;
    this.suppressPopupUntil = Date.now() + 700;
    this.enableInfoPopupWindow(!this.enableUserEdit);
  });

  this.editorHandles.push(createHandle, updateHandle, deleteHandle);
}