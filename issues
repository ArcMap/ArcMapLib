private getDefaultSymbolForGeometry(geometry: Geometry | undefined | null): any {
  if (!geometry) {
    return null;
  }

  const geometryType = String((geometry as any).type ?? "").toLowerCase();

  if (geometryType === "point" || geometryType === "multipoint") {
    return {
      type: "simple-marker",
      style: "circle",
      size: 18,
      color: [0, 120, 255, 1],
      outline: {
        type: "simple-line",
        color: [255, 255, 255, 1],
        width: 2,
        style: "solid",
      },
    };
  }

  if (geometryType === "polyline") {
    return {
      type: "simple-line",
      style: "solid",
      color: [0, 120, 255, 1],
      width: 3,
    };
  }

  return {
    type: "simple-fill",
    style: "solid",
    color: [0, 120, 255, 0.18],
    outline: {
      type: "simple-line",
      color: [0, 120, 255, 1],
      width: 2,
      style: "solid",
    },
  };
}


private applyGraphicDefaults(graphic: Graphic): void {
  if (!graphic.attributes) {
    graphic.attributes = {};
  }

  const id =
    graphic.attributes[this.uniqueIdPropertyName] ??
    graphic.attributes.OBJECTID ??
    Date.now() + Math.floor(Math.random() * 100000);

  if (graphic.attributes[this.uniqueIdPropertyName] === undefined) {
    graphic.attributes[this.uniqueIdPropertyName] = id;
  }

  if (graphic.attributes.OBJECTID === undefined) {
    graphic.attributes.OBJECTID = id;
  }

  const rendererSymbol = this.getSymbolFromRendererConfig(this.renderer, graphic);

  graphic.symbol =
    rendererSymbol ??
    graphic.symbol ??
    this.getDefaultSymbolForGeometry(graphic.geometry);

  graphic.popupTemplate =
    this._editorOpen || this.inDrawingMode || this._isStartingDraw
      ? null as any
      : this.buildPopupTemplateFromCurrent(graphic);

  console.log("[arc-geojson-layer] applyGraphicDefaults", {
    geometryType: graphic.geometry?.type,
    attributes: graphic.attributes,
    symbol: graphic.symbol,
  });
}


static toCanonicalArcGisSymbol(symbolInput: any, geometryType?: string): any {
  if (!symbolInput) {
    return JsonUtils.getDefaultSymbolJson(geometryType);
  }

  const symbol =
    typeof symbolInput?.toJSON === "function"
      ? symbolInput.toJSON()
      : JSON.parse(JSON.stringify(symbolInput));

  const rawType = String(
    symbol.type ??
    symbol.symbolType ??
    symbol.esriType ??
    ""
  ).toLowerCase();

  switch (rawType) {
    case "esrisms":
    case "esrims":
    case "sms":
    case "simplemarkersymbol":
    case "simple-marker":
      return {
        type: "simple-marker",
        style: JsonUtils.normalizeMarkerStyle(symbol.style),
        color: JsonUtils.normalizeColor(symbol.color, [0, 120, 255, 1]),
        size: symbol.size ?? symbol.width ?? 18,
        angle: symbol.angle ?? 0,
        xoffset: symbol.xoffset ?? symbol.xOffset ?? 0,
        yoffset: symbol.yoffset ?? symbol.yOffset ?? 0,
        outline: JsonUtils.normalizeOutline(symbol.outline),
      };

    case "esripms":
    case "pms":
    case "picturemarkersymbol":
    case "picture-marker":
      return {
        type: "picture-marker",
        url: symbol.url ?? symbol.imageData ?? "",
        width: symbol.width ?? symbol.size ?? 24,
        height: symbol.height ?? symbol.size ?? 24,
        angle: symbol.angle ?? 0,
        xoffset: symbol.xoffset ?? symbol.xOffset ?? 0,
        yoffset: symbol.yoffset ?? symbol.yOffset ?? 0,
      };

    case "esrisls":
    case "sls":
    case "simplelinesymbol":
    case "simple-line":
      return {
        type: "simple-line",
        color: JsonUtils.normalizeColor(symbol.color, [0, 120, 255, 1]),
        width: symbol.width ?? 2,
        style: JsonUtils.normalizeLineStyle(symbol.style),
      };

    case "esrisfs":
    case "sfs":
    case "simplefillsymbol":
    case "simple-fill":
      return {
        type: "simple-fill",
        style: JsonUtils.normalizeFillStyle(symbol.style),
        color: JsonUtils.normalizeColor(symbol.color, [0, 120, 255, 0.18]),
        outline: JsonUtils.normalizeOutline(symbol.outline),
      };

    default:
      console.warn("[ArcGeoJSON][json-util] Unknown symbol type. Falling back.", {
        rawType,
        symbol,
        geometryType,
      });

      return JsonUtils.getDefaultSymbolJson(geometryType);
  }
}