private addToGeoJSON(newGraphic: Graphic): void {
  if (!newGraphic) return;

  if (!newGraphic.attributes) {
    newGraphic.attributes = {};
  }

  const now = Date.now();

  // Fix: Graphic does not have uid in ArcGIS typing.
  // Use attributes as stable id storage.
  if (newGraphic.attributes[this.uniqueIdPropertyName] === undefined) {
    newGraphic.attributes[this.uniqueIdPropertyName] = now;
  }

  if (newGraphic.attributes.OBJECTID === undefined) {
    newGraphic.attributes.OBJECTID = now;
  }

  // Important for circle editing:
  // Circle drawn by Sketch becomes polygon geometry,
  // so we must store original draw shape metadata.
  if (!newGraphic.attributes.drawGeometryType) {
    newGraphic.attributes.drawGeometryType =
      newGraphic.attributes.shapeType ??
      newGraphic.attributes.geometryType ??
      newGraphic.geometry?.type;
  }

  if (
    String(newGraphic.attributes.drawGeometryType).toUpperCase() === DrawGeometryTypes.CIRCLE
  ) {
    newGraphic.attributes.shapeType = DrawGeometryTypes.CIRCLE;
    newGraphic.attributes.geometryType = DrawGeometryTypes.CIRCLE;
  }

  this.applyGraphicDefaults(newGraphic);

  if (this.enableUserEdit) {
    newGraphic.popupTemplate = null as any;
  }

  if (!this.featureLayer.graphics.includes(newGraphic)) {
    this.featureLayer.add(newGraphic);
  }

  this.blockGeoJsonUpdate = true;
  this.geojson = this.toFeatureCollectionFromLayer();
  this.blockGeoJsonUpdate = false;

  this.refreshLabels();

  this.emitLayerEvent("userDrawnItemAdded", this.graphicToGeoJsonFeature(newGraphic));
}



if (event.state === "complete") {
  const graphic = event.graphic as Graphic;

  if (!graphic.attributes) {
    graphic.attributes = {};
  }

  /**
   * Preserve original draw type.
   * ArcGIS converts circle/rectangle to polygon internally.
   */
  graphic.attributes.drawGeometryType =
    this.currentDrawType;

  graphic.attributes.shapeType =
    this.currentDrawType;

  graphic.attributes.geometryType =
    this.currentDrawType;

  this.addToGeoJSON(graphic);

  this.resetEditorStateOnly();
}