const isCircle = this.isCircleGraphic(graphic);
const isPolygon = graphic.geometry?.type === "polygon" && !isCircle;
const tool = this.resolveUpdateTool(graphic);

await this.graphicsEditor.update([graphic], {
  tool,

  /**
   * Circle:
   * - transform
   * - scale uniformly
   *
   * Polygon:
   * - reshape
   * - edit vertices
   * - add/delete vertices
   * - no transform box
   */
  enableRotation: isCircle ? false : false,
  enableScaling: isCircle ? true : false,
  preserveAspectRatio: isCircle ? true : false,

  multipleSelectionEnabled: false,
  toggleToolOnClick: false,
} as any);