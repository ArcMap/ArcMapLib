onUpdateGeojsonLayer(data: any): void {
  console.log("onUpdateGeojsonLayer", data);

  const updatedFeature = data?.feature ?? data;
  const updatedGeometry = data?.geometry ?? updatedFeature?.geometry;
  const updatedProperties =
    data?.properties ??
    data?.attributes ??
    updatedFeature?.properties ??
    {};

  if (!updatedGeometry) {
    console.warn("onUpdateGeojsonLayer skipped: geometry missing", data);
    return;
  }

  const editedObjectId =
    updatedProperties.OBJECTID ??
    updatedProperties.id ??
    updatedFeature?.id;

  const selectedFenceIndex = this.currentFeature.findIndex((feature: any) => {
    const featureId =
      feature?.id ??
      feature?.properties?.OBJECTID ??
      feature?.properties?.id;

    return String(featureId) === String(editedObjectId);
  });

  if (selectedFenceIndex === -1) {
    console.warn("Edited feature not found. Skipping update.", {
      editedObjectId,
      currentFeature: this.currentFeature,
      data,
    });
    return;
  }

  if (!CreateFenceUtil.validateFenceBoundaries(updatedFeature)) {
    this.resetCurrentFeature();
    this.store.dispatch(
      new ShowErrorBanner(CreateFenceUtil.ERROR_OUTSIDE_BOUNDARY)
    );
    this.editGeofenceService.invalidateFenceDrawn();
    return;
  }

  const existingFeature = this.currentFeature[selectedFenceIndex];

  const finalFeature = {
    ...existingFeature,
    id: existingFeature?.id ?? editedObjectId,
    geometry: {
      ...(existingFeature?.geometry ?? {}),
      type: this.isCircle ? "Circle" : updatedGeometry.type,
      coordinates: updatedGeometry.coordinates,
    },
    properties: {
      ...(existingFeature?.properties ?? {}),
      ...updatedProperties,
      id: existingFeature?.properties?.id ?? editedObjectId,
      OBJECTID: existingFeature?.properties?.OBJECTID ?? editedObjectId,
    },
  };

  this.currentFeature = [
    ...this.currentFeature.slice(0, selectedFenceIndex),
    finalFeature,
    ...this.currentFeature.slice(selectedFenceIndex + 1),
  ];

  if (this.geometryData?.[selectedFenceIndex]?.geometry) {
    this.geometryData[selectedFenceIndex].geometry.coordinates =
      updatedGeometry.coordinates;
  }

  this.editGeofenceService.currentFeature = this.currentFeature;
  this.cdr.detectChanges();
}