private resolveUpdateTool(
  graphic: Graphic,
): 'move' | 'reshape' | 'transform' {

  const drawGeometryType =
    graphic.attributes?.drawGeometryType ??
    graphic.attributes?.shapeType ??
    graphic.attributes?.geometryType;

  const geometryType =
    String(drawGeometryType || '').toUpperCase();

  const isCircle =
    geometryType === DrawGeometryTypes.CIRCLE ||
    geometryType === 'CIRCLE';

  /**
   * IMPORTANT:
   * ArcGIS converts circles into polygons internally.
   * If reshape is enabled, the polygon vertices distort the circle.
   * So circles MUST use transform only.
   */
  if (isCircle) {
    return 'transform';
  }

  /**
   * Polygon editing with vertices
   */
  if (
    graphic.geometry?.type === 'polygon' &&
    (
      this.enableUserEditVertices ||
      this.enableUserEditAddVertices ||
      this.enableUserEditDeleteVertices
    )
  ) {
    return 'reshape';
  }

  /**
   * Scale / rotate
   */
  if (
    this.enableUserEditScaling ||
    this.enableUserEditRotating
  ) {
    return 'transform';
  }

  return 'move';
}



const tool = this.resolveUpdateTool(graphic);

this.graphicsEditor.update([graphic], {
  tool,

  enableRotation:
    tool === 'transform' &&
    this.enableUserEditRotating,

  enableScaling:
    tool === 'transform' &&
    this.enableUserEditScaling,

  multipleSelectionEnabled: false,

  preserveAspectRatio: true,

  toggleToolOnClick: false,
});