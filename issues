async updateGeojson(
  newGeojson: string | FeatureCollection | null | undefined
): Promise<void> {
  if (this._isClearingGeoJSONLayer) {
    return;
  }

  if (this.inDrawingMode || this._isStartingDraw || this.removingItem) {
    console.log("[arc-geojson-layer] updateGeojson skipped during active draw/edit");
    return;
  }

  const isBlank =
    newGeojson === undefined ||
    newGeojson === null ||
    newGeojson === "" ||
    (
      typeof newGeojson === "object" &&
      Array.isArray((newGeojson as FeatureCollection).features) &&
      (newGeojson as FeatureCollection).features.length === 0
    );

  if (isBlank) {
    this.clearGeoJSONLayer(false);
    return;
  }

  if (!this.featureLayer) {
    await this.createLayer(newGeojson as any);
    return;
  }

  this.featureLayer.graphics.removeAll();
  this.labelLayer?.graphics?.removeAll();
  this.sketchLayer?.graphics?.removeAll();

  const fsInfo = this.getUPGISJson(newGeojson as any);

  fsInfo?.graphics?.forEach((graphic: Graphic) => {
    this.applyGraphicDefaults(graphic);

    graphic.symbol =
      this.getSymbolFromRendererConfig(this.renderer, graphic) ??
      this.getDefaultSymbolForGeometry(graphic.geometry, graphic.attributes);

    this.featureLayer?.add(graphic);
  });

  this.refreshLabels();
  this.updateInfoTemplate(this.infoTemplate);

  console.log("[arc-geojson-layer] updateGeojson DONE", {
    graphicsCount: this.featureLayer.graphics.length,
  });
}


public clearGeoJSONLayer(updateGeojsonProperty = true): void {
  if (this._isClearingGeoJSONLayer) {
    return;
  }

  this._isClearingGeoJSONLayer = true;

  try {
    this.graphicsEditor?.cancel();
  } catch {}

  this._editorOpen = false;
  this.inDrawingMode = false;
  this._isStartingDraw = false;
  this._currentDrawGeometryType = undefined;

  this.featureLayer?.graphics?.removeAll();
  this.labelLayer?.graphics?.removeAll();
  this.sketchLayer?.graphics?.removeAll();

  try {
    this.view?.popup?.close();
  } catch {}

  if (updateGeojsonProperty) {
    this.blockGeoJsonUpdate = true;
    this.geojson = {
      type: "FeatureCollection",
      features: [],
    };
    this.blockGeoJsonUpdate = false;
  }

  this.enableInfoPopupWindow(true);
  this.setMapCursor("default");

  this._isClearingGeoJSONLayer = false;

  console.log("[arc-geojson-layer] clearGeoJSONLayer completed");
}