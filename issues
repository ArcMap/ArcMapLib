private handleCreateComplete(graphic: Graphic): void {

  this.inDrawingMode = false;
  this._isStartingDraw = false;
  this._editorOpen = false;

  this._suppressPopupUntil = Date.now() + 700;

  if (!graphic) {
    return;
  }

  if (!graphic.attributes) {
    graphic.attributes = {};
  }

  const drawGeometryType =
    graphic.attributes.drawGeometryType ??
    graphic.attributes.shapeType ??
    graphic.attributes.geometryType ??
    this._currentDrawGeometryType ??
    graphic.geometry?.type;

  /**
   * IMPORTANT:
   * Never mutate geometry.type.
   * Store custom circle metadata ONLY in attributes.
   */
  if (String(drawGeometryType ?? "").toLowerCase() === "circle") {

    graphic.attributes.drawGeometryType = "circle";
    graphic.attributes.shapeType = "circle";
    graphic.attributes.geometryType = "circle";
    graphic.attributes.shape = "circle";
    graphic.attributes.isCircle = true;
  }

  this.applyGraphicDefaults(graphic);

  graphic.symbol =
    this.getSymbolFromRendererConfig(this.renderer, graphic)
    ??
    this.getDefaultSymbolForGeometry(
      graphic.geometry,
      graphic.attributes
    );

  /**
   * Add into feature layer FIRST
   */
  if (
    this.featureLayer &&
    !this.featureLayer.graphics.includes(graphic)
  ) {
    this.featureLayer.add(graphic);
  }

  /**
   * Sync GeoJSON
   */
  this.updateGeoJsonWithChanges(graphic);

  /**
   * Re-enable popup
   */
  this.enableInfoPopupWindow(!this.enableUserEdit);

  console.log("[arc-geojson-layer] create complete", {
    geometryType: graphic.geometry?.type,
    drawGeometryType: graphic.attributes.drawGeometryType,
    shapeType: graphic.attributes.shapeType,
    attributes: graphic.attributes,
  });
}




private updateGeoJsonWithChanges(
  graphicToUpdate: Graphic
): void {

  if (!graphicToUpdate?.geometry) {
    return;
  }

  this.applyGraphicDefaults(graphicToUpdate);

  this.blockGeoJsonUpdate = true;

  this.geojson =
    this.toFeatureCollectionFromLayer();

  this.blockGeoJsonUpdate = false;

  this.refreshLabels();

  const feature =
    this.graphicToGeoJsonFeature(graphicToUpdate);

  /**
   * Prevent undefined feature emission
   */
  if (!feature) {
    return;
  }

  this.emitLayerEvent(
    "userEditItemUpdated",
    feature
  );
}