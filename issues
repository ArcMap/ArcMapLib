private resetEditorStateOnly(): void {
  try {
    this.sketchLayer?.graphics?.removeAll();
  } catch (error) {
    console.warn(
      "[arc-geojson-layer] resetEditorStateOnly removeAll failed",
      error
    );
  }

  try {
    if (this.graphicsEditor) {
      this.graphicsEditor.cancel();
    }
  } catch (error) {
    console.warn(
      "[arc-geojson-layer] resetEditorStateOnly cancel failed",
      error
    );
  }

  try {
    if (this.graphicsEditor) {
      this.graphicsEditor.destroy();
    }
  } catch (error) {
    console.warn(
      "[arc-geojson-layer] resetEditorStateOnly destroy failed",
      error
    );
  }

  this.graphicsEditor = undefined;
  this.editorOpen = false;

  try {
    this.editorHandles.forEach((handle: any) => {
      try {
        handle?.remove?.();
      } catch (_) {}
    });
  } catch (_) {}

  this.editorHandles = [];
}