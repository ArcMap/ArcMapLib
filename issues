private async updateGeojson(): Promise<void> {
  if (this.blockGeoJsonUpdate) {
    return;
  }

  if (this._isClearingGeoJSONLayer) {
    return;
  }

  /**
   * VERY IMPORTANT:
   * Avoid Angular/Lit re-render loop.
   */
  if (this._lastGeoJsonReference === this.geojson) {
    return;
  }

  this._lastGeoJsonReference = this.geojson;

  console.log("[up-geojson-layer] updateGeojson START");

  const geojson = JsonUtils.getJsonFor<any>(this.geojson);

  if (
    geojson.error ||
    !geojson.parsedJson ||
    !geojson.parsedJson.features
  ) {
    console.warn("[up-geojson-layer] invalid geojson");

    this.clearGeoJSONLayer(false);
    return;
  }

  /**
   * ONLY clear existing graphics.
   * DO NOT reset geojson property again.
   */
  this.featureLayer?.graphics?.removeAll();
  this.labelLayer?.graphics?.removeAll();

  /**
   * DO NOT CLEAR sketch layer while editing.
   */
  if (!this._editorOpen && !this.inDrawingMode) {
    this.sketchLayer?.graphics?.removeAll();
  }

  const features = geojson.parsedJson.features ?? [];

  console.log("[up-geojson-layer] rendering features", {
    count: features.length,
  });

  for (const feature of features) {
    try {
      const graphic = this.createGraphicFromGeoJson(feature);

      if (!graphic) {
        continue;
      }

      this.applyGraphicDefaults(graphic);

      this.featureLayer?.graphics?.add(graphic);
    } catch (error) {
      console.warn(
        "[up-geojson-layer] feature render failed",
        error,
        feature
      );
    }
  }

  this.refreshLabels();

  console.log("[up-geojson-layer] updateGeojson DONE", {
    graphics: this.featureLayer?.graphics?.length ?? 0,
  });
}