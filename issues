private emitLayerEvent(
  eventName: string,
  feature?: Feature | null,
  graphic?: Graphic | null,
  extraData?: any
): void {

  /**
   * Prevent invalid event emission
   */
  if (!feature && !graphic) {
    console.warn(
      "[arc-geojson-layer] emitLayerEvent skipped",
      eventName
    );
    return;
  }

  const objectId =
    feature?.properties?.OBJECTID ??
    graphic?.attributes?.OBJECTID ??
    graphic?.attributes?.objectid ??
    null;

  const payload = {
    type: eventName,

    objectId,

    feature: feature ?? null,

    graphic: graphic ?? null,

    attributes:
      feature?.properties ??
      graphic?.attributes ??
      {},

    geometry:
      feature?.geometry ??
      graphic?.geometry ??
      null,

    geojson: this.geojson,

    layerId: this.layerId,

    ...extraData
  };

  this.dispatchEvent(
    new CustomEvent(eventName, {
      detail: payload,
      bubbles: true,
      composed: true
    })
  );
}


private buildPopupTemplateFromCurrent(
  graphic: Graphic
): PopupTemplate | null {

  if (!graphic) {
    return null;
  }

  const attributes =
    graphic.attributes ?? {};

  const fieldInfos = Object.keys(attributes)
    .filter((key) => {
      const value = attributes[key];

      return (
        value !== undefined &&
        value !== null &&
        typeof value !== "object"
      );
    })
    .map((key) => ({
      fieldName: key,
      label: key,
      visible: true
    }));

  return new PopupTemplate({
    title:
      this.name ??
      "Details",

    content: [
      {
        type: "fields",
        fieldInfos
      }
    ]
  });
}