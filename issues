private applyGraphicDefaults(graphic: Graphic): void {
  if (!graphic.attributes) {
    graphic.attributes = {};
  }

  const id =
    graphic.attributes[this.uniqueIdPropertyName] ??
    graphic.attributes.OBJECTID ??
    Date.now() + Math.floor(Math.random() * 100000);

  if (graphic.attributes[this.uniqueIdPropertyName] === undefined) {
    graphic.attributes[this.uniqueIdPropertyName] = id;
  }

  if (graphic.attributes.OBJECTID === undefined) {
    graphic.attributes.OBJECTID = id;
  }

  /**
   * Do NOT always assign default symbol here.
   * First respect renderer/symbol passed from Angular.
   */
  if (!graphic.symbol) {
    graphic.symbol =
      this.getSymbolFromRendererConfig(this.renderer, graphic) ??
      this.getDefaultSymbolForGeometry(graphic.geometry);
  }

  graphic.popupTemplate =
    this._editorOpen || this.inDrawingMode || this._isStartingDraw
      ? null as any
      : this.buildPopupTemplateFromCurrent(graphic);
}




private getSymbolFromRendererConfig(
  rendererRaw: any,
  graphic: Graphic
): any {
  const parsed = JsonUtils.getJsonFor<any>(rendererRaw);

  if (parsed.error || !parsed.parsedJson || !graphic?.attributes) {
    return null;
  }

  const renderer = parsed.parsedJson;
  const rendererType = String(renderer.type ?? "").toLowerCase();

  if (rendererType === "simple") {
    return JsonUtils.createSymbolFromJson(
      renderer.symbol ?? renderer.defaultSymbol,
      graphic.geometry?.type
    );
  }

  if (rendererType !== "unique-value" && rendererType !== "uniquevalue") {
    return renderer.defaultSymbol
      ? JsonUtils.createSymbolFromJson(renderer.defaultSymbol, graphic.geometry?.type)
      : null;
  }

  const attrs = graphic.attributes ?? {};

  const field1 = renderer.field1 ?? renderer.field;
  const field2 = renderer.field2;
  const field3 = renderer.field3;

  const fields = [field1, field2, field3].filter(Boolean);

  const values = fields.map((fieldName: string) =>
    String(attrs[fieldName] ?? "").trim()
  );

  const hasDelimiter =
    renderer.fieldDelimiter !== undefined &&
    renderer.fieldDelimiter !== null;

  const delimiter = hasDelimiter ? String(renderer.fieldDelimiter) : undefined;

  const candidateKeys = new Set<string>();

  if (hasDelimiter) {
    candidateKeys.add(values.join(delimiter));
  }

  candidateKeys.add(values.join(""));
  candidateKeys.add(values.join("|"));
  candidateKeys.add(values.join(","));
  candidateKeys.add(values.join(", "));

  values.forEach((value) => {
    if (value) {
      candidateKeys.add(value);
    }
  });

  const keys = Array.from(candidateKeys).map((x) => String(x).trim());

  const matchedInfo = renderer.uniqueValueInfos?.find((info: any) => {
    return keys.includes(String(info.value ?? "").trim());
  });

  if (matchedInfo?.symbol) {
    return JsonUtils.createSymbolFromJson(
      matchedInfo.symbol,
      graphic.geometry?.type
    );
  }

  if (renderer.defaultSymbol) {
    return JsonUtils.createSymbolFromJson(
      renderer.defaultSymbol,
      graphic.geometry?.type
    );
  }

  return null;
}


