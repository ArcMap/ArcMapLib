public clearGeoJSONLayer(updateGeojsonProperty = true): void {
  if (this._isClearingGeoJSONLayer) {
    return;
  }

  this._isClearingGeoJSONLayer = true;

  try {
    this.graphicsEditor?.cancel();
  } catch {}

  this._editorOpen = false;
  this.inDrawingMode = false;
  this._isStartingDraw = false;
  this._currentDrawGeometryType = undefined;

  try {
    this.view?.popup?.close();
  } catch {}

  this.featureLayer?.graphics?.removeAll();
  this.labelLayer?.graphics?.removeAll();
  this.sketchLayer?.graphics?.removeAll();

  /**
   * Angular side sheet fix:
   * Sometimes old GraphicsLayer references remain on the map.
   * Clear every layer created by this ArcGeoJSON instance.
   */
  const mapLayers = this.view?.map?.layers?.toArray?.() ?? [];

  mapLayers.forEach((layer: any) => {
    const id = String(layer?.id ?? "");

    if (
      id === this.featureLayer?.id ||
      id === this.labelLayer?.id ||
      id === this.sketchLayer?.id ||
      id.includes("arc-geojson") ||
      id.includes(this.name ?? "")
    ) {
      try {
        layer.graphics?.removeAll?.();
      } catch {}
    }
  });

  if (updateGeojsonProperty) {
    this.blockGeoJsonUpdate = true;
    this.geojson = {
      type: "FeatureCollection",
      features: [],
    };
    this.blockGeoJsonUpdate = false;
  }

  this.refreshLabels();
  this.setMapCursor("default");

  this._isClearingGeoJSONLayer = false;

  console.log("[arc-geojson-layer] clearGeoJSONLayer completed", {
    featureLayerGraphics: this.featureLayer?.graphics?.length ?? 0,
    labelLayerGraphics: this.labelLayer?.graphics?.length ?? 0,
    sketchLayerGraphics: this.sketchLayer?.graphics?.length ?? 0,
  });
}


disconnectedCallback(): void {
  super.disconnectedCallback();

  this.clearGeoJSONLayer(false);

  this.editorHandles?.forEach((handle: any) => {
    try {
      handle?.remove?.();
    } catch {}
  });
  this.editorHandles = [];

  this.eventHandles?.forEach((handle: any) => {
    try {
      handle?.remove?.();
    } catch {}
  });
  this.eventHandles = [];

  try {
    this.cursorMoveHandle?.remove?.();
  } catch {}
  this.cursorMoveHandle = undefined;

  try {
    this.graphicsEditor?.destroy();
  } catch {}
  this.graphicsEditor = undefined as any;

  if (this.view?.map) {
    try {
      if (this.featureLayer) {
        this.view.map.remove(this.featureLayer);
      }

      if (this.labelLayer) {
        this.view.map.remove(this.labelLayer);
      }

      if (this.sketchLayer) {
        this.view.map.remove(this.sketchLayer);
      }
    } catch {}
  }

  this.featureLayer = undefined as any;
  this.labelLayer = undefined as any;
  this.sketchLayer = undefined as any;

  console.log("[arc-geojson-layer] disconnectedCallback cleanup completed");
}