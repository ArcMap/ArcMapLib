private emitLayerEvent(
  eventName: string,
  feature?: Feature | null,
  graphic?: Graphic | null,
  extraData?: any
): void {
  const safeFeature =
    feature ??
    (graphic?.geometry
      ? this.graphicToGeoJsonFeature(graphic)
      : null);

  const attributes =
    safeFeature?.properties ??
    graphic?.attributes ??
    {};

  const geometry =
    safeFeature?.geometry ??
    (graphic?.geometry ? this.arcGeometryToGeoJson(graphic.geometry) : null);

  const objectId =
    attributes?.OBJECTID ??
    attributes?.objectId ??
    attributes?.id ??
    null;

  this.dispatchEvent(
    new CustomEvent(eventName, {
      detail: {
        type: eventName,
        OBJECTID: objectId,
        objectId,
        id: objectId,
        feature: safeFeature,
        graphic: graphic ?? null,
        attributes,
        properties: attributes,
        geometry,
        geojson: this.geojson,
        layerId:
          this.featureLayer?.id ??
          this.name ??
          "arc-geojson-layer",
        ...extraData,
      },
      bubbles: true,
      composed: true,
    })
  );
}