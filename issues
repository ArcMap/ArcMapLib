private showGraphicPopup(
  graphic: Graphic,
  mapPoint?: Point
): void {

  if (
    this.enableUserEdit ||
    this.editorOpen ||
    this.inDrawingMode ||
    this.shouldSuppressPopup()
  ) {
    return;
  }

  if (!graphic?.geometry || !this.view?.popup) {
    return;
  }

  const location =
    mapPoint ??
    this.getPopupPoint(graphic.geometry) ??
    undefined;

  if (!location) {
    return;
  }

  const popupTemplate =
    graphic.popupTemplate ??
    this.buildPopupTemplateFromCurrent(graphic);

  if (!popupTemplate) {
    return;
  }

  graphic.popupTemplate = popupTemplate;

  try {

    this.view.popupEnabled = true;

    this.view.popup.open({
      location,
      features: [graphic]
    });

  } catch (error) {
    console.warn(
      "[arc-geojson-layer] popup open failed",
      error
    );
  }
}