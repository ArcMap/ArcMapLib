private setupMapCursorHover(): void {
  if (!this.view) return;

  this.cursorMoveHandle?.remove();

  this.cursorMoveHandle = this.view.on(
    "pointer-move",
    async (evt: any) => {
      if (!this.view || !this.featureLayer) {
        this.setMapCursor("default");
        return;
      }

      try {
        const hit = await this.view.hitTest(evt, {
          include: [this.featureLayer]
        });

        const result = hit.results.find((r: any) => {
          const g = r.graphic;
          return (
            g &&
            g.geometry &&
            (
              g.layer === this.featureLayer ||
              g.layer?.id === this.featureLayer.id
            )
          );
        }) as any;

        const graphic = result?.graphic as Graphic | undefined;

        if (!graphic) {
          this.hoveredGraphicUid = undefined;
          this.setMapCursor("default", evt);
          return;
        }

        this.hoveredGraphicUid =
          graphic.attributes?.[this.uniqueIdPropertyName] ??
          graphic.attributes?.OBJECTID;

        this.setMapCursor("pointer", evt);
      } catch {
        this.setMapCursor("default", evt);
      }
    }
  );
}