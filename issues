const objectId =
  graphic.attributes?.[this.uniqueIdPropertyName] ??
  graphic.attributes?.OBJECTID ??
  graphic.attributes?.id ??
  Date.now();

return {
  type: "Feature",
  id: objectId,
  geometry: this.arcGeometryToGeoJson(graphic.geometry),
  properties: {
    ...(graphic.attributes ?? {}),
    id: objectId,
    OBJECTID: objectId,
    [this.uniqueIdPropertyName]: objectId,
  },
};