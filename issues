if (event.state === "start" || event.state === "active") {
  this.inDrawingMode = true;
  this._isStartingDraw = true;
  this._editorOpen = false;
  this.enableInfoPopupWindow(false);

  const activeGraphic = event.graphic as Graphic;

  /**
   * Drawing mode rule:
   * Show only the current drawing item.
   * Do not allow multiple preview graphics.
   */
  this.featureLayer?.graphics?.toArray().forEach((g: Graphic) => {
    if (g !== activeGraphic && g.attributes?.__isTemporaryDrawing === true) {
      this.featureLayer?.remove(g);
    }
  });

  if (activeGraphic) {
    activeGraphic.attributes = {
      ...(activeGraphic.attributes ?? {}),
      __isTemporaryDrawing: true,
    };
  }
}