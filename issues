private refreshLabels(): void {
  if (!this.labelLayer || !this.featureLayer) {
    return;
  }

  this.labelLayer.removeAll();

  const hasLabelJson =
    this.labelJson !== undefined &&
    this.labelJson !== null &&
    String(this.labelJson).trim() !== "";

  if (!hasLabelJson) {
    return;
  }

  const labelRulesRaw = JsonUtils.getLabelJson(
    this.labelJson,
    this.labelColor,
    this.labelSize
  );

  const labelRules = Array.isArray(labelRulesRaw)
    ? labelRulesRaw
    : [labelRulesRaw];

  const resolvedColor = JsonUtils.resolveLabelColor(this.labelColor as any);
  const resolvedSize = JsonUtils.resolveLabelSize(this.labelSize);

  this.featureLayer.graphics.forEach((graphic: Graphic) => {
    if (!graphic.geometry || !graphic.attributes) {
      return;
    }

    const labelText = this.resolveLabelTextFromRules(graphic, labelRules);
    if (!labelText) {
      return;
    }

    const pt = jj.getPopupPoint(graphic.geometry);
    if (!pt) {
      return;
    }

    this.labelLayer?.add(
      new Graphic({
        geometry: pt,
        attributes: {
          __labelFor:
            graphic.attributes?.[this.uniqueIdPropertyName] ??
            graphic.attributes?.OBJECTID,
        },
        symbol: new TextSymbol({
          text: labelText,
          color: resolvedColor as any,
          haloColor: "black",
          haloSize: 1,
          xoffset: 3,
          yoffset: 3,
          font: {
            size: resolvedSize,
            family: "sans-serif",
            weight: "bold",
          },
        }),
      })
    );
  });
}


private resolveLabelTextFromRules(
  graphic: Graphic,
  labelRules: any[]
): string {
  if (!graphic?.attributes || !Array.isArray(labelRules)) {
    return "";
  }

  for (const rule of labelRules) {
    if (!rule) {
      continue;
    }

    const where = rule.where;
    if (where && !this.matchesSimpleWhere(graphic.attributes, where)) {
      continue;
    }

    const expression =
      rule?.labelExpressionInfo?.expression ??
      rule?.labelExpression ??
      rule?.expression;

    if (!expression || typeof expression !== "string") {
      continue;
    }

    const match = expression.match(/\$feature\.([a-zA-Z0-9_]+)/);
    if (!match?.[1]) {
      continue;
    }

    const value = graphic.attributes[match[1]];
    if (value !== undefined && value !== null && String(value).trim() !== "") {
      return String(value);
    }
  }

  return "";
}


private matchesSimpleWhere(attributes: any, where: string): boolean {
  if (!where || !attributes) {
    return true;
  }

  const match = where.match(/^([a-zA-Z0-9_]+)\s*(=|==|!=|>|>=|<|<=)\s*['"]?([^'"]+)['"]?$/);

  if (!match) {
    return true;
  }

  const field = match[1];
  const operator = match[2];
  const expectedRaw = match[3];

  const actual = attributes[field];

  if (actual === undefined || actual === null) {
    return false;
  }

  const actualNumber = Number(actual);
  const expectedNumber = Number(expectedRaw);

  const useNumber =
    !Number.isNaN(actualNumber) && !Number.isNaN(expectedNumber);

  const left = useNumber ? actualNumber : String(actual);
  const right = useNumber ? expectedNumber : String(expectedRaw);

  switch (operator) {
    case "=":
    case "==":
      return left === right;
    case "!=":
      return left !== right;
    case ">":
      return left > right;
    case ">=":
      return left >= right;
    case "<":
      return left < right;
    case "<=":
      return left <= right;
    default:
      return true;
  }
}