const isPolygon = graphic.geometry?.type === "polygon" && !isCircle;

await this.graphicsEditor.update([graphic], {
  tool,

  enableRotation:
    isCircle ? false : this.enableUserEditRotating,

  enableScaling:
    isCircle || isPolygon || this.enableUserEditScaling,

  preserveAspectRatio:
    isCircle || this.enableUserEditUniformScaling,

  multipleSelectionEnabled: false,
  toggleToolOnClick: true,
} as any);