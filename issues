if (!fieldInfos.length) {
  fieldInfos = Object.keys(attributes)
    .filter((key) => attributes[key] !== undefined && attributes[key] !== null)
    .map((key) => ({
      fieldName: key,
      label: key,
      visible: true,
    }));

  if (!fieldInfos.length) {
    console.warn("[geojson-layer] popup skipped: no popup fields resolved", {
      infoTemplate: this.infoTemplate,
      attributes,
    });
    return null;
  }
}