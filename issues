private resolveLabelTextFromRules(
  graphic: Graphic,
  labelRules: any[]
): string {
  if (!graphic?.attributes || !Array.isArray(labelRules)) {
    return "";
  }

  for (const rule of labelRules) {
    if (!rule) {
      continue;
    }

    /**
     * ArcGIS style:
     * labelExpressionInfo.expression
     */
    const expression =
      rule?.labelExpressionInfo?.expression ??
      rule?.labelExpression ??
      rule?.expression;

    if (!expression || typeof expression !== "string") {
      continue;
    }

    /**
     * Example:
     * "$feature.name"
     * "$feature.route"
     */
    const matches = expression.match(/\$feature\.([a-zA-Z0-9_]+)/);

    if (!matches?.[1]) {
      continue;
    }

    const fieldName = matches[1];

    const value = graphic.attributes[fieldName];

    if (value !== undefined && value !== null) {
      return String(value);
    }
  }

  return "";
}