private async updateEditing(enabled: boolean): Promise<void> {
  this.enableUserEdit = enabled;

  console.log("[arc-geojson-layer] updateEditing", {
    enabled,
    editorOpen: this._editorOpen,
    inDrawingMode: this.inDrawingMode,
  });

  if (!enabled) {
    /**
     * IMPORTANT:
     * Do NOT call finishActiveEditor() here.
     * This method is triggered by property changes, sometimes before user edits.
     * Closing editor here causes polygon/circle to disappear or not save.
     */
    this._editorOpen = false;
    this.inDrawingMode = false;
    this._isStartingDraw = false;
    this.enableInfoPopupWindow(true);
    return;
  }

  await this.createEditor();

  this.enableInfoPopupWindow(false);
}