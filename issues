private resolveUpdateTool(
  graphic: Graphic,
): "move" | "reshape" | "transform" {

  /**
   * IMPORTANT:
   * ArcGIS converts circles into polygons internally.
   * So we MUST detect original circle metadata.
   */
  const isCircle = this.isCircleGraphic(graphic);

  if (isCircle) {
    /**
     * Circles should use transform.
     * Reshape breaks circle geometry.
     */
    return "transform";
  }

  /**
   * Polygon / polyline vertex editing
   */
  if (
    this.enableUserEditAddVertices ||
    this.enableUserEditDeleteVertices
  ) {
    return "reshape";
  }

  /**
   * Scale / rotate
   */
  if (
    this.enableUserEditScaling ||
    this.enableUserEditRotating
  ) {
    return "transform";
  }

  return "move";
}