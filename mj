import { execSync } from 'child_process';
import { resolve, dirname, join } from 'path';
import { fileURLToPath } from 'url';

const __filename = fileURLToPath(import.meta.url);
const __dirname = dirname(__filename);

// Go up one level to library root (since this file is in scripts/)
const LIBRARY_ROOT = resolve(__dirname, '..');

const ANGULAR_PATH = 'C:/path/to/your/angular-project';
const TGZ_NAME = 'your-library-name-1.0.0.tgz';

const run = (cmd, cwd = LIBRARY_ROOT) => {
  console.log(`\n▶ ${cmd}`);
  execSync(cmd, { cwd, stdio: 'inherit' });
};

try {
  console.log('\n🔨 Step 1: Building library...');
  run('npm run build');

  console.log('\n📦 Step 2: Packing library...');
  run('npm pack');

  console.log('\n📥 Step 3: Installing in Angular project...');
  run(
    `npm install ${resolve(LIBRARY_ROOT, TGZ_NAME)} --no-save`,
    ANGULAR_PATH
  );

  console.log('\n✅ Done! Refresh your browser.\n');
} catch (error) {
  console.error('\n❌ Error:', error.message);
  process.exit(1);
}
