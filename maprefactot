private updateRenderer(newRenderer: any = this.renderer): void {
  if (!this.featureLayer) {
    console.warn('[up-geojson-layer] updateRenderer skipped - featureLayer missing');
    return;
  }

  const graphicsLayer = this.featureLayer as any;

  const graphics = graphicsLayer.graphics?.toArray?.() || [];

  if (!graphics.length) {
    console.warn('[up-geojson-layer] updateRenderer skipped - no graphics yet');

    requestAnimationFrame(() => {
      this.updateRenderer(newRenderer);
    });

    return;
  }

  console.log('[up-geojson-layer] applying renderer to graphics', graphics.length);

  graphics.forEach((graphic: any) => {
    const geometryType = graphic.geometry?.type;

    let symbol: any = null;

    if (geometryType === 'point') {
      symbol = this.getDefaultSymbolForGeometry(
        graphic.geometry,
        graphic.attributes
      );
    } else if (geometryType === 'polygon') {
      symbol = this.getDefaultSymbolForGeometry(
        graphic.geometry,
        graphic.attributes
      );
    } else if (geometryType === 'polyline') {
      symbol = this.getDefaultSymbolForGeometry(
        graphic.geometry,
        graphic.attributes
      );
    }

    console.log('[up-geojson-layer] final graphic symbol applied', {
      geometryType,
      attributes: graphic.attributes,
      matchedSymbol: symbol,
      finalSymbol: symbol
    });

    if (symbol) {
      graphic.symbol = symbol;
    }
  });

  graphicsLayer.refresh?.();

  this.requestUpdate();
}