private emitTransientShapeCoordinates(
  geometry: Geometry | null | undefined,
): void {
  if (!geometry) return;

  let selectionCoordinates: number[][] | number[][][] | null = null;

  if (geometry.type === "point") {
    const point = geometry as Point;
    const geographicPoint = webMercatorUtils.webMercatorToGeographic(
      point,
    ) as Point | null;

    const longitude = geographicPoint?.longitude;
    const latitude = geographicPoint?.latitude;

    if (typeof longitude !== "number" || typeof latitude !== "number") {
      return;
    }

    selectionCoordinates = [[longitude, latitude]];
  }

  if (geometry.type === "polyline") {
    const polyline = geometry as Polyline;
    const geographicPolyline = webMercatorUtils.webMercatorToGeographic(
      polyline,
    ) as Polyline | null;

    selectionCoordinates = geographicPolyline?.paths?.[0] ?? null;
  }

  if (geometry.type === "polygon") {
    const polygon = geometry as Polygon;
    const geographicPolygon = webMercatorUtils.webMercatorToGeographic(
      polygon,
    ) as Polygon | null;

    selectionCoordinates = geographicPolygon?.rings ?? null;
  }

  if (!selectionCoordinates) return;

  const detail: MapTransientShapeCoordinates = {
    selectionCoordinates,
  };

  this.dispatchEvent(
    new CustomEvent<MapTransientShapeCoordinates>(
      "map-draw-transient-shape-coordinates",
      {
        detail,
        bubbles: true,
        composed: true,
      },
    ),
  );

  this.dispatchEvent(
    new CustomEvent<MapTransientShapeCoordinates>(
      "mapDrawTransientShapeCoordinates",
      {
        detail,
        bubbles: true,
        composed: true,
      },
    ),
  );
}