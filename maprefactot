private updateRenderer(newRenderer: any = this.renderer): void {
  this.renderer = newRenderer;

  if (!this.featureLayer) {
    console.warn('[up-geojson-layer] updateRenderer skipped: featureLayer missing');
    return;
  }

  const graphicsLayer = this.featureLayer as any;

  if (!graphicsLayer.graphics) {
    console.warn('[up-geojson-layer] graphics missing on layer');
    return;
  }

  console.log('[up-geojson-layer] manually applying renderer to graphics');

  graphicsLayer.graphics.forEach((graphic: any) => {
    const geometryType = graphic.geometry?.type;

    console.log('[up-geojson-layer] processing graphic', {
      geometryType,
      attributes: graphic.attributes
    });

    if (geometryType === 'point') {
      graphic.symbol = this.getDefaultSymbolForGeometry('point');
    } else if (geometryType === 'polygon') {
      graphic.symbol = this.getDefaultSymbolForGeometry('polygon');
    } else if (geometryType === 'polyline') {
      graphic.symbol = this.getDefaultSymbolForGeometry('polyline');
    }

    console.log('[up-geojson-layer] symbol applied', graphic.symbol);
  });

  graphicsLayer.refresh?.();
}