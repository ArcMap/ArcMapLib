private updateRenderer(newRenderer: any = this.renderer): void {
  if (!this.featureLayer) {
    console.warn('[up-geojson-layer] updateRenderer skipped - featureLayer missing');
    return;
  }

  const graphicsLayer = this.featureLayer as any;
  const graphics: Graphic[] = graphicsLayer.graphics?.toArray?.() ?? [];

  if (!graphics.length) {
    console.warn('[up-geojson-layer] updateRenderer skipped - no graphics yet');
    return;
  }

  console.log('[up-geojson-layer] applying renderer to graphics', {
    graphicsCount: graphics.length,
    renderer: newRenderer
  });

  graphics.forEach((graphic: any) => {
    const matchedSymbol = this.getSymbolFromRendererConfig(
      newRenderer,
      graphic
    );

    const fallbackSymbol = this.getDefaultSymbolForGeometry(
      graphic.geometry,
      graphic.attributes
    );

    graphic.symbol = matchedSymbol ?? fallbackSymbol;

    console.log('[up-geojson-layer] final graphic symbol applied', {
      geometryType: graphic.geometry?.type,
      attributes: graphic.attributes,
      matchedSymbol,
      fallbackSymbol,
      finalSymbol: graphic.symbol
    });
  });
}