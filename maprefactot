private updateBasemap(nextBasemap: string): void {
  if (!this.map) return;

  const safeBasemap =
    typeof nextBasemap === "string" && nextBasemap.trim().length > 0
      ? nextBasemap
      : ArcMap.DEFAULT_BASEMAP;

  const currentBasemap = this.map.basemap as any;

  const currentBasemapId =
    typeof currentBasemap === "string"
      ? currentBasemap
      : currentBasemap?.id ?? currentBasemap?.title ?? "";

  if (currentBasemapId === safeBasemap) return;

  try {
    (this.map as any).basemap = safeBasemap;
  } catch (error) {
    console.warn("Invalid basemap. Falling back to default.", error);
    (this.map as any).basemap = ArcMap.DEFAULT_BASEMAP;
  }
}