async updateGeojson(newGeojson: string | FeatureCollection): Promise<void> {
  if (
    this.inDrawingMode ||
    this.removingItem ||
    this.blockGeoJsonUpdate ||
    this._isStartingDraw
  ) {
    return;
  }

  const parsed = UpGeojsonLayer.parseJson<FeatureCollection>(newGeojson);
  const incomingCount = parsed.parsedJson?.features?.length ?? 0;

  console.log('[up-geojson-layer] updateGeojson START', {
    name: this.name,
    incomingCount,
    renderer: this.renderer,
    editMode: this.enableUserEdit
  });

  if (this.enableUserEdit && incomingCount > 0) {
    return;
  }

  if (!this.featureLayer) {
    await this.createLayer(newGeojson);
    return;
  }

  try {
    this.graphicsEditor?.cancel();
  } catch {}

  this.featureLayer.graphics.removeAll();
  this.labelLayer?.graphics?.removeAll();
  this.sketchLayer?.graphics?.removeAll();

  const fsInfo = this.getUpGISJson(newGeojson);

  fsInfo?.graphics?.forEach((g: Graphic) => {
    const matchedSymbol = this.getSymbolFromRendererConfig(this.renderer, g);

    const fallbackSymbol = this.getDefaultSymbolForGeometry(
      g.geometry,
      g.attributes
    );

    this.applyGraphicDefaults(g);

    g.symbol = matchedSymbol ?? fallbackSymbol;

    console.log('[up-geojson-layer] updateGeojson graphic BEFORE add', {
      layerName: this.name,
      geometryType: g.geometry?.type,
      attributes: g.attributes,
      matchedSymbol,
      fallbackSymbol,
      finalSymbol: g.symbol
    });

    this.featureLayer.add(g);

    console.log('[up-geojson-layer] updateGeojson graphic AFTER add', {
      layerName: this.name,
      graphicsCount: this.featureLayer.graphics.length,
      layerVisible: this.featureLayer.visible,
      layerInMap: this.view?.map?.layers?.includes(this.featureLayer as any),
      graphicGeometry: g.geometry,
      graphicSymbol: g.symbol
    });
  });

  if (this.view?.map?.layers?.includes(this.featureLayer as any)) {
    this.view.map.reorder(
      this.featureLayer,
      this.view.map.layers.length - 1
    );
  }

  this.refreshLabels();
  this.updateInfoTemplate(this.infoTemplate);

  console.log('[up-geojson-layer] updateGeojson DONE', {
    name: this.name,
    graphicsCount: this.featureLayer.graphics.length,
    layerVisible: this.featureLayer.visible
  });
}