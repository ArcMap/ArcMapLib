fsInfo?.graphics?.forEach((g: Graphic) => {
  const matchedSymbol = this.getSymbolFromRendererConfig(this.renderer, g);

  const fallbackSymbol = this.getDefaultSymbolForGeometry(
    g.geometry,
    g.attributes
  );

  console.log('[up-geojson-layer] BEFORE defaults/add', {
    geometryType: (g.geometry as any)?.type,
    attributes: g.attributes,
    matchedSymbol,
    fallbackSymbol,
    symbolBefore: g.symbol
  });

  this.applyGraphicDefaults(g);

  console.log('[up-geojson-layer] AFTER defaults BEFORE symbol set', {
    symbolAfterDefaults: g.symbol
  });

  g.symbol = matchedSymbol ?? fallbackSymbol;

  console.log('[up-geojson-layer] FINAL symbol BEFORE add', {
    finalSymbol: g.symbol
  });

  this.featureLayer.add(g);

  console.log('[up-geojson-layer] AFTER add', {
    graphicsCount: (this.featureLayer as any).graphics?.length,
    layerVisible: (this.featureLayer as any).visible,
    layerListMode: (this.featureLayer as any).listMode
  });
});