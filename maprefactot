private handleArcgisMapReady = async (event: Event): Promise<void> => {
  if (this.isMapInitialized) return;

  const mapEl = event.target as any;

  if (!mapEl?.view || !mapEl?.map) {
    console.warn("arcgis-map ready fired, but map/view is missing");
    return;
  }

  this.view = mapEl.view;
  this.map = mapEl.map;

  await this.view.when();

  this.isMapInitialized = true;

  this.applyZoomConstraints();
  this.ensureDrawLayer();
  this.setupDrawTool();
  this.setupMapClickHandler();
  this.setupViewStateWatchers();
  this.setupPopupBridge();
  this.syncPopupOptions();
  this.syncMouseWheelZoom();
  this.syncDoubleClickZoom();
  this.syncKeyboardNavigation();

  this.resolveMapReady();
  this.reflectCurrentMapState();
};