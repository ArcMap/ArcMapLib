private async initializeMap(
  parsedCenter?: number[],
  parsedExtent?: any
): Promise<void> {

  if (this.view) {
    return;
  }

  const mapEl = this.renderRoot?.querySelector('#upMap') as any;

  if (!mapEl) {
    console.error('[up-map] arcgis-map element not found');
    return;
  }

  mapEl.basemap = this.basemap || 'gray-vector';

  if (parsedCenter) {
    mapEl.center = parsedCenter;
  }

  if (typeof this.zoom === 'number') {
    mapEl.zoom = this.zoom;
  }

  if (parsedExtent) {
    mapEl.extent = parsedExtent;
  }

  await mapEl.componentOnReady?.();

  this.mapElement = mapEl;
  this.view = mapEl.view;

  if (!this.view) {
    console.error('[up-map] MapView not available');
    return;
  }

  await this.view.when();

  if (parsedExtent) {
    await this.view.goTo(parsedExtent);
  } else if (parsedCenter) {
    await this.view.goTo({
      center: parsedCenter,
      zoom: this.zoom
    });
  }

  console.log('[up-map] initialized');
}