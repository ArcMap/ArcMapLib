private setupMapCursorHover(): void {
  if (!this.view) return;

  this.cursorMoveHandle?.remove();

  this.cursorMoveHandle = this.view.on('pointer-move', async (evt: any) => {
    if (!this.view || !this.featureLayer) return;

    const hit = await this.view.hitTest(evt);

    const isOverThisLayer = hit.results?.some((result: any) => {
      return result.graphic?.layer === this.featureLayer;
    });

    this.setMapCursor(isOverThisLayer ? 'pointer' : 'default', evt);
  });
}

disconnectedCallback(): void {
  super.disconnectedCallback();
  this.cursorMoveHandle?.remove();
}