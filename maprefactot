async startDrawing(drawGeometryType: string): Promise<void> {
  if (!this.view) {
    console.warn('[up-geojson-layer] startDrawing skipped: view missing');
    return;
  }

  if (!this.featureLayer) {
    await this.createLayer(this.geojson);
  }

  if (!this.featureLayer) {
    console.warn('[up-geojson-layer] startDrawing skipped: featureLayer still missing');
    return;
  }

  await this.createEditor();

  if (!this.graphicsEditor?.layer) {
    console.error('[up-geojson-layer] startDrawing failed: SketchViewModel layer missing', {
      graphicsEditor: this.graphicsEditor,
      featureLayer: this.featureLayer
    });
    return;
  }

  this.inDrawingMode = true;
  this._isStartingDraw = true;

  this.enableInfoPopupWindow(false);

  try {
    this.graphicsEditor.cancel();
  } catch {}

  console.log('[up-geojson-layer] startDrawing', {
    drawGeometryType,
    sketchLayer: this.graphicsEditor.layer,
    featureLayer: this.featureLayer
  });

  this.graphicsEditor.create(drawGeometryType as any);
}


private setupMapCursorHover(): void {
  if (!this.view) {
    return;
  }

  if (this.cursorMoveHandle) {
    this.cursorMoveHandle.remove();
    this.cursorMoveHandle = undefined;
  }

  this.cursorMoveHandle = this.view.on('pointer-move', async (evt: any) => {
    if (!this.view || !this.featureLayer) {
      this.setMapCursor('default', evt);
      return;
    }

    try {
      const hit = await this.view.hitTest(evt);

      const isOverThisLayer = hit.results?.some((result: any) => {
        const graphic = result?.graphic;
        return !!graphic && graphic.layer === this.featureLayer;
      });

      this.setMapCursor(isOverThisLayer ? 'pointer' : 'default', evt);
    } catch {
      this.setMapCursor('default', evt);
    }
  });
}

