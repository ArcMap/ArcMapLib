  private async getAllLayerIdsFromDescendants(
    element: Element,
    layerCheckFunction: (elm: Element) => elm is LayerElement,
  ): Promise<string[]> {
    const ids: string[] = [];

    for (const childElement of Array.from(element.children)) {
      if (layerCheckFunction(childElement)) {
        const layerId = await Promise.resolve(childElement.getLayerId?.() ?? "");
        if (layerId) ids.push(layerId);
      } else {
        ids.push(
          ...(await this.getAllLayerIdsFromDescendants(
            childElement,
            layerCheckFunction,
          )),
        );
      }
    }

    return ids;
  }

  private getAllLayerIdsFromSubsequentSiblings(
    element: Element,
    layerCheckFunction: (elm: Element) => elm is LayerElement,
  ): Promise<string>[] {
    const layerIdPromises: Promise<string>[] = [];
    let nextSibling = element.nextElementSibling;

    while (nextSibling) {
      if (layerCheckFunction(nextSibling)) {
        layerIdPromises.push(
          Promise.resolve(nextSibling.getLayerId?.() ?? ""),
        );
      } else if (nextSibling.matches("[data-basemap]")) {
        layerIdPromises.push(
          this.getAllLayerIdsFromDescendants(
            nextSibling,
            layerCheckFunction,
          ).then((ids) => ids[0] ?? ""),
        );
      }

      nextSibling = nextSibling.nextElementSibling;
    }

    return layerIdPromises;
  }

  private static isGraphicsLayerElement(
    element: Element,
  ): element is GraphicsLayerElement {
    return [
      "ARC-FEATURE-LAYER",
      "ARC-GEOJSON-LAYER",
      "ARC-POINT",
      "ARC-POLYLINE",
      "ARC-ROUTE",
    ].includes(element.tagName.toUpperCase());
  }

  private static isNonGraphicsLayerElement(
    element: Element,
  ): element is NonGraphicsLayerElement {
    return [
      "ARC-WMS-LAYER",
      "ARC-TILED-MAP-SERVICE-LAYER",
      "ARC-IMAGE-SERVICE-LAYER",
    ].includes(element.tagName.toUpperCase());
  }

  private static parseValidateAndConvertLatLongPoint(
    latLong: LatLongPoint | string,
  ): LatLongPoint | undefined {
    let parsedLatLong: LatLongPoint;

    if (typeof latLong === "string") {
      try {
        parsedLatLong = JSON.parse(latLong) as LatLongPoint;
      } catch {
        console.warn("Invalid center JSON");
        return;
      }
    } else {
      parsedLatLong = latLong;
    }

    if (
      !parsedLatLong ||
      typeof parsedLatLong.latitude !== "number" ||
      typeof parsedLatLong.longitude !== "number"
    ) {
      return;
    }

    return {
      latitude: Math.max(-85, Math.min(85, parsedLatLong.latitude)),
      longitude: Math.max(-180, Math.min(180, parsedLatLong.longitude)),
    };
  }

  private static async parseValidateAndConvertExtent(
    extent: ArcMapExtent | string,
  ): Promise<Extent> {
    let parsed: ArcMapExtent;

    if (typeof extent === "string") {
      try {
        parsed = JSON.parse(extent) as ArcMapExtent;
      } catch {
        return Promise.reject("Invalid extent JSON");
      }
    } else {
      parsed = extent;
    }

    if (
      !parsed ||
      parsed.leftLongitude >= parsed.rightLongitude ||
      parsed.bottomLatitude >= parsed.topLatitude
    ) {
      return Promise.reject("Invalid extent values");
    }

    return new Extent({
      xmin: parsed.leftLongitude,
      ymin: parsed.bottomLatitude,
      xmax: parsed.rightLongitude,
      ymax: parsed.topLatitude,
      spatialReference: { wkid: 4326 },
    });
  }

  private static areLatLongEqual(
    a: LatLongPoint | Point | undefined,
    b: LatLongPoint | undefined,
  ): boolean {
    if (!a || !b) return false;

    const aLatitude = "latitude" in a ? a.latitude : undefined;
    const aLongitude = "longitude" in a ? a.longitude : undefined;

    return (
      Math.abs((aLatitude ?? 0) - b.latitude) < 0.000001 &&
      Math.abs((aLongitude ?? 0) - b.longitude) < 0.000001
    );
  }

  private destroyMap(): void {
    this.eventHandles.removeAll();

    if (this.drawTransientShapeTool) {
      this.drawTransientShapeTool.destroy();
      this.drawTransientShapeTool = undefined;
    }

    if (this.view) {
      this.view.destroy();
      this.view = undefined;
    }

    this.map = undefined;
    this.isMapInitialized = false;
  }

  render() {
    const parsedCenter =
      this.center &&
      typeof this.center === "object" &&
      "longitude" in this.center &&
      "latitude" in this.center
        ? [this.center.longitude, this.center.latitude]
        : undefined;

    const parsedExtent =
      this.extent &&
      typeof this.extent === "object" &&
      typeof this.extent.leftLongitude === "number" &&
      typeof this.extent.rightLongitude === "number" &&
      typeof this.extent.topLatitude === "number" &&
      typeof this.extent.bottomLatitude === "number"
        ? {
            xmin: this.extent.leftLongitude,
            ymin: this.extent.bottomLatitude,
            xmax: this.extent.rightLongitude,
            ymax: this.extent.topLatitude,
            spatialReference: { wkid: 4326 },
          }
        : undefined;

    return html`
      <div class="map-wrapper">
        <arcgis-map
          id="arcMap"
          class="map"
          .basemap=${this.basemap || ArcMap.DEFAULT_BASEMAP}
          .extent=${parsedExtent}
          .center=${parsedExtent ? undefined : parsedCenter}
          .zoom=${parsedExtent ? undefined : this.zoom}
          .maxZoom=${this.maxZoom}
          .minZoom=${this.minZoom}
        >
          <arcgis-popup slot="popup"></arcgis-popup>

          <div class="widget-stack" slot="top-left">
            ${this.showHome
              ? html`<arcgis-home position="manual"></arcgis-home>`
              : ""}
            ${this.showLocate
              ? html`<arcgis-locate position="manual"></arcgis-locate>`
              : ""}
            ${this.showZoom
              ? html`<arcgis-zoom position="manual"></arcgis-zoom>`
              : ""}
            ${this.showScaleBar
              ? html`<arcgis-scale-bar
                  position="manual"
                  unit="dual"
                ></arcgis-scale-bar>`
              : ""}
          </div>
        </arcgis-map>
      </div>
    `;
  }
