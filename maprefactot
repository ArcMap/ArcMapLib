private evaluateLabelExpression(
  expression: string | undefined,
  attributes: any
): any {

  if (!expression || String(expression).trim() === '') {
    return undefined;
  }

  const expressionText = String(expression).trim();

  /*
   * Handles:
   * $feature.sampleProp
   * $feature.otherProp
   */

  const featureMatch = expressionText.match(
    /\$feature\.([A-Za-z0-9_]+)/i
  );

  if (featureMatch) {
    const fieldName = featureMatch[1];

    return attributes?.[fieldName];
  }

  /*
   * Static string fallback
   */

  return expressionText;
}