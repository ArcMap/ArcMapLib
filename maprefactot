if (changedProperties.has('basemap')) {
  const oldBasemap = this.normalizeBasemapName(
    changedProperties.get('basemap') as string
  );

  const newBasemap = this.normalizeBasemapName(this.basemap);

  if (oldBasemap !== newBasemap) {
    await this.updateBasemap(newBasemap, oldBasemap);
  }
}



private normalizeBasemapName(basemap: string | undefined | null): string {
  const value = String(basemap || '').trim().toLowerCase();

  const basemapMap: Record<string, string> = {
    gray: 'gray-vector',
    grey: 'gray-vector',
    streets: 'streets-vector',
    street: 'streets-vector',
    topo: 'topo-vector',
    topographic: 'topo-vector',
    satellite: 'satellite',
    hybrid: 'hybrid',
    'hybrid-streets': 'hybrid',
    'streets-hybrid': 'hybrid',
    'satellite-streets': 'hybrid',
    dark: 'dark-gray-vector',
    'dark-gray': 'dark-gray-vector',
    osm: 'osm'
  };

  return basemapMap[value] || value || UpMap.DEFAULT_BASEMAP;
}