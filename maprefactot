private async updateBasemap(
  newBasemapInput: string,
  oldBasemapInput?: string
): Promise<void> {
  if (!this.view?.map) return;

  const newBasemap = this.normalizeBasemapName(newBasemapInput);
  const oldBasemap = this.normalizeBasemapName(oldBasemapInput);

  if (newBasemap === oldBasemap) {
    return;
  }

  try {
    this.view.map.basemap = newBasemap as any;
  } catch (error) {
    console.warn(
      '[up-map] Failed to update basemap. Falling back to default.',
      { newBasemapInput, newBasemap, error }
    );

    this.view.map.basemap = UpMap.DEFAULT_BASEMAP as any;
  }
}


if (changedProperties.has('basemap')) {
  const oldBasemap = this.normalizeBasemapName(
    changedProperties.get('basemap') as string
  );

  const newBasemap = this.normalizeBasemapName(this.basemap);

  if (oldBasemap !== newBasemap) {
    await this.updateBasemap(newBasemap, oldBasemap);
  }
}


