private getParsedCenter(): number[] | undefined {
  const centerValue = this.center;

  if (
    centerValue &&
    typeof centerValue === 'object' &&
    'longitude' in centerValue &&
    'latitude' in centerValue &&
    typeof centerValue.longitude === 'number' &&
    typeof centerValue.latitude === 'number'
  ) {
    return [centerValue.longitude, centerValue.latitude];
  }

  return undefined;
}


private getParsedExtent(): any | undefined {
  const extentValue = this.extent;

  if (
    extentValue &&
    typeof extentValue === 'object' &&
    typeof extentValue.leftLongitude === 'number' &&
    typeof extentValue.rightLongitude === 'number' &&
    typeof extentValue.topLatitude === 'number' &&
    typeof extentValue.bottomLatitude === 'number'
  ) {
    return {
      xmin: extentValue.leftLongitude,
      ymin: extentValue.bottomLatitude,
      xmax: extentValue.rightLongitude,
      ymax: extentValue.topLatitude,
      spatialReference: { wkid: 4326 }
    };
  }

  return undefined;
}


protected async firstUpdated(): Promise<void> {
  await this.updateComplete;

  const parsedCenter = this.getParsedCenter();
  const parsedExtent = this.getParsedExtent();

  console.log('[up-map] firstUpdated parsedCenter:', parsedCenter);
  console.log('[up-map] firstUpdated parsedExtent:', parsedExtent);
  console.log('[up-map] firstUpdated zoom:', this.zoom);

  await this.initializeMap(parsedCenter, parsedExtent);
}


protected updated(changedProps: Map<string, unknown>): void {
  if (!this.view) return;

  if (
    changedProps.has('center') ||
    changedProps.has('extent') ||
    changedProps.has('zoom')
  ) {
    this.applyViewProperties();
  }
}


private async applyViewProperties(): Promise<void> {
  if (!this.view) return;

  const parsedExtent = this.getParsedExtent();
  const parsedCenter = this.getParsedCenter();

  try {
    if (parsedExtent) {
      await this.view.goTo(parsedExtent);
      return;
    }

    if (parsedCenter) {
      await this.view.goTo({
        center: parsedCenter,
        zoom: this.zoom
      });
      return;
    }

    if (typeof this.zoom === 'number') {
      this.view.zoom = this.zoom;
    }
  } catch (error) {
    console.warn('[up-map] failed to apply view properties:', error);
  }
}