private async createLayer(
  geojson?: string | object
): Promise<void> {

  console.log('[up-geojson-layer] createLayer START', {
    existingFeatureLayer: this.featureLayer,
    existingLayerId: this.featureLayer?.id,
    mapLayersBefore: this.view?.map?.layers?.length
  });

  if (this.featureLayer) {
    console.log('[up-geojson-layer] removing old featureLayer', {
      id: this.featureLayer.id
    });

    this.view?.map?.remove(this.featureLayer);
  }

  this.featureLayer = new GraphicsLayer({
    id: this.internalLayerUid
  });

  console.log('[up-geojson-layer] new featureLayer created', {
    id: this.featureLayer.id
  });

  this.view?.map?.add(this.featureLayer);

  console.log('[up-geojson-layer] featureLayer added to map', {
    mapLayersAfter: this.view?.map?.layers?.length,
    layerExistsInMap: this.view?.map?.layers?.includes(this.featureLayer)
  });

  const fsInfo = this.getUpGISJson(
    geojson ?? { type: 'FeatureCollection', features: [] }
  );

  fsInfo?.graphics?.forEach((g: Graphic) => {

    console.log('[up-geojson-layer] adding graphic to layer', {
      layerId: this.featureLayer?.id,
      geometryType: g.geometry?.type
    });

    this.applyGraphicDefaults(g);

    this.featureLayer.add(g);
  });

  console.log('[up-geojson-layer] createLayer END', {
    finalGraphicsCount: this.featureLayer.graphics.length,
    layerExistsInMap: this.view?.map?.layers?.includes(this.featureLayer)
  });
}