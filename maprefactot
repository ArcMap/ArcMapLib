private currentZoomValue?: number;

private setupZoomEmitter(): void {
  if (!this.view) return;

  this.eventHandles.remove("map-zoom");

  this.eventHandles.add(
    reactiveUtils.watch(
      () => this.view?.zoom,
      (zoom) => {
        if (typeof zoom !== "number") return;

        if (this.currentZoomValue === zoom) {
          return;
        }

        this.currentZoomValue = zoom;

        this.zoom = zoom;

        this.dispatchEvent(
          new CustomEvent<number>("zoom", {
            detail: zoom,
            bubbles: true,
            composed: true,
          }),
        );
      },
      {
        initial: false,
      },
    ),
    "map-zoom",
  );
}


