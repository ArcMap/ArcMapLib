private async updateRenderer(): Promise<void> {
  if (!this.layer) {
    console.warn('[GeoJSONLayer.updateRenderer] layer missing');
    return;
  }

  console.log(
    '[GeoJSONLayer.updateRenderer] incoming renderer config',
    this.renderer
  );

  console.log(
    '[GeoJSONLayer.updateRenderer] layer geometry type BEFORE',
    (this.layer as any).geometryType
  );

  JsonUtils.updateRenderer(
    this.renderer,
    this.layer,
    rendererTypeToModule,
    this.symbolJSON
  );

  console.log(
    '[GeoJSONLayer.updateRenderer] layer renderer AFTER',
    this.layer.renderer
  );

  console.log(
    '[GeoJSONLayer.updateRenderer] renderer unique infos',
    (this.layer.renderer as any)?.uniqueValueInfos
  );

  console.log(
    '[GeoJSONLayer.updateRenderer] renderer field',
    (this.layer.renderer as any)?.field
  );

  console.log(
    '[GeoJSONLayer.updateRenderer] renderer field1',
    (this.layer.renderer as any)?.field1
  );

  console.log(
    '[GeoJSONLayer.updateRenderer] renderer field2',
    (this.layer.renderer as any)?.field2
  );

  console.log(
    '[GeoJSONLayer.updateRenderer] renderer fieldDelimiter',
    (this.layer.renderer as any)?.fieldDelimiter
  );
}