private updateRenderer(newRenderer: any = this.renderer): void {
  if (!this.featureLayer) {
    console.warn('[up-geojson-layer] featureLayer missing');
    return;
  }

  const graphicsLayer = this.featureLayer as any;

  const graphics = graphicsLayer?.graphics?.toArray?.() ?? [];

  if (!graphics.length) {
    console.warn(
      '[up-geojson-layer] updateRenderer skipped - no graphics yet'
    );
    return;
  }

  console.log(
    '[up-geojson-layer] applying renderer to graphics',
    graphics.length
  );

  graphics.forEach((graphic: any) => {
    const matchedSymbol = this.getSymbolFromRendererConfig(
      newRenderer,
      graphic
    );

    graphic.symbol =
      matchedSymbol ??
      this.getDefaultSymbolForGeometry(
        graphic.geometry,
        graphic.attributes
      );
  });

  graphicsLayer.refresh?.();
}